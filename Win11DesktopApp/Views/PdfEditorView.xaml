<UserControl x:Class="Win11DesktopApp.Views.PdfEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1100">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER BAR ===== -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" 
                Padding="12,8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding GoBackCommand}" 
                        Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" 
                        FontSize="16" Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,10,0"
                        VerticalAlignment="Center" Cursor="Hand" ToolTip="{DynamicResource XlsxBack}"/>

                <TextBlock Grid.Column="1" Text="{Binding Title}" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="{DynamicResource ForegroundBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="2" Content="{DynamicResource XlsxCancel}" 
                        Command="{Binding GoBackCommand}"
                        Padding="14,5" Margin="0,0,6,0" FontSize="12"
                        Background="{DynamicResource CardBackgroundBrush}"
                        Foreground="{DynamicResource ForegroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        VerticalAlignment="Center" Cursor="Hand"/>

                <Button Grid.Column="3"
                        Command="{Binding SaveCommand}"
                        Padding="14,5"
                        Background="{DynamicResource AccentBrush}" Foreground="White" 
                        BorderThickness="0" FontWeight="SemiBold"
                        VerticalAlignment="Center" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource XlsxSave}" FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===== PAGE NAVIGATION BAR ===== -->
        <Border Grid.Row="1" Background="#F8F9FA" 
                Padding="8,6" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding PrevPageCommand}" 
                        Content="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                        Width="30" Height="28" Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand"/>
                <TextBlock VerticalAlignment="Center" FontSize="13" Margin="10,0"
                           Foreground="{DynamicResource ForegroundBrush}">
                    <Run Text="{Binding CurrentPageDisplay, Mode=OneWay}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding PageCount, Mode=OneWay}"/>
                </TextBlock>
                <Button Command="{Binding NextPageCommand}" 
                        Content="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                        Width="30" Height="28" Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand"/>

                <Border Width="1" Background="#DDD" Margin="16,4"/>

                <!-- Font size selector for new tags -->
                <TextBlock Text="{DynamicResource EditorFontSize}" FontSize="11" Foreground="#888"
                           VerticalAlignment="Center" Margin="10,0,6,0"/>
                <ComboBox Width="55" Height="24" VerticalContentAlignment="Center" FontSize="11"
                          SelectedItem="{Binding NewTagFontSize}"
                          IsEditable="True">
                    <ComboBox.Items>
                        <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">7</system:Double>
                        <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">8</system:Double>
                        <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">9</system:Double>
                        <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">10</system:Double>
                        <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">11</system:Double>
                        <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">12</system:Double>
                        <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">14</system:Double>
                        <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">16</system:Double>
                        <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">18</system:Double>
                        <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">20</system:Double>
                        <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">24</system:Double>
                    </ComboBox.Items>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- ===== MAIN: PDF Canvas + Tag Catalog ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" MinWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="3*" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <!-- ===== PDF CANVAS ===== -->
            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Auto" Background="#E0E0E0">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">
                    <Border Background="White" BorderBrush="#B0B0B0" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.2"/>
                        </Border.Effect>
                        <Canvas x:Name="PdfCanvas" 
                                ClipToBounds="True"
                                MouseLeftButtonDown="PdfCanvas_MouseLeftButtonDown"
                                Background="Transparent">
                            <Image x:Name="PdfImage" Source="{Binding CurrentPageImage}" 
                                   Stretch="None"/>
                        </Canvas>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" 
                          VerticalAlignment="Stretch" Background="#DDD" 
                          Cursor="SizeWE" ShowsPreview="True"/>

            <!-- ===== TAG CATALOG + PLACED TAGS ===== -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource ContentBackgroundBrush}" Padding="0"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tags header -->
                    <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource EditorTagCatalog}" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource PdfClickToPlace}"
                                       FontSize="10" Foreground="#888" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Search -->
                    <Border Grid.Row="1" Padding="10,6" Background="#F0F4F8"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBox Text="{Binding TagSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="6,4" FontSize="11"
                                     Background="White" BorderBrush="#CCC" BorderThickness="1"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock Text="{DynamicResource EditorSearchTags}" FontSize="11" Foreground="#AAA"
                                       IsHitTestVisible="False" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TagSearchQuery}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding TagSearchQuery}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Tags list -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="6,4">
                        <ItemsControl ItemsSource="{Binding FilteredTagGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander IsExpanded="True" Margin="0,0,0,6">
                                        <Expander.Header>
                                            <TextBlock Text="{Binding GroupName}" FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                        </Expander.Header>
                                        <ItemsControl ItemsSource="{Binding Tags}" Margin="0,4,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource CardBackgroundBrush}" 
                                                            CornerRadius="4" Padding="8,5" Margin="0,0,0,3"
                                                            BorderBrush="#E0E0E0" BorderThickness="1">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                                                       FontSize="11" FontWeight="SemiBold"
                                                                       FontFamily="Consolas" Foreground="#1565C0"
                                                                       TextTrimming="CharacterEllipsis">
                                                                <Run Text="${"/><Run Text="{Binding Tag}"/><Run Text="}"/>
                                                            </TextBlock>

                                                            <!-- Place button -->
                                                            <Button Grid.Row="0" Grid.Column="1"
                                                                    Command="{Binding DataContext.PlaceTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Padding="8,2" Margin="4,0,2,0"
                                                                    Background="{DynamicResource AccentBrush}" 
                                                                    Foreground="White" BorderThickness="0"
                                                                    VerticalAlignment="Center" Cursor="Hand"
                                                                    ToolTip="{DynamicResource PdfPlaceTag}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="&#xE819;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{DynamicResource EditorInsert}" FontSize="10"/>
                                                                </StackPanel>
                                                            </Button>

                                                            <!-- Copy button -->
                                                            <Button Grid.Row="0" Grid.Column="2" Content="&#xE8C8;"
                                                                    FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                                    Command="{Binding DataContext.CopyTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Width="26" Height="24"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    Foreground="{DynamicResource ForegroundBrush}"
                                                                    VerticalAlignment="Center" Cursor="Hand"
                                                                    ToolTip="{DynamicResource EditorCopyTag}"/>

                                                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                                       Text="{Binding Description}" 
                                                                       FontSize="10" Foreground="#888"
                                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Placed tags header -->
                    <Border Grid.Row="3" Background="{DynamicResource CardBackgroundBrush}" 
                            Padding="12,6" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
                        <TextBlock Text="{DynamicResource PdfPlacedTags}" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                    </Border>

                    <!-- Placed tags list -->
                    <ScrollViewer Grid.Row="4" MaxHeight="150" VerticalScrollBarVisibility="Auto" Padding="6,4">
                        <ItemsControl ItemsSource="{Binding AllPlacements}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundBrush}" 
                                            CornerRadius="4" Padding="6,4" Margin="0,0,0,3"
                                            BorderBrush="#E0E0E0" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#1565C0">
                                                    <Run Text="${"/><Run Text="{Binding Tag, Mode=OneWay}"/><Run Text="}"/>
                                                </TextBlock>
                                                <TextBlock FontSize="9" Foreground="#888">
                                                    <Run Text="P"/><Run Text="{Binding Page, Mode=OneWay}"/>
                                                    <Run Text=" | "/>
                                                    <Run Text="{Binding FontSize, StringFormat={}{0}pt, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <Button Grid.Column="1" Content="&#xE74D;" 
                                                    FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                    Command="{Binding DataContext.RemovePlacementCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Width="24" Height="22"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#CC4444" Cursor="Hand"
                                                    VerticalAlignment="Center"
                                                    ToolTip="{DynamicResource BtnDelete}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== FOOTER ===== -->
        <Border Grid.Row="3" Background="{DynamicResource CardBackgroundBrush}" 
                Padding="10,4" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                    <Border Width="14" Height="14" CornerRadius="2" Margin="0,0,4,0"
                            Background="#E3F2FD" BorderBrush="#93C5FD" BorderThickness="1"/>
                    <TextBlock Text="{DynamicResource PdfTagMarker}" FontSize="10" Foreground="#666" 
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" 
                           FontSize="11" Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
