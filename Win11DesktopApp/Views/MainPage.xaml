<UserControl x:Class="Win11DesktopApp.Views.MainPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:Win11DesktopApp.Views"
             xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <CubicEase x:Key="DrawerEase" EasingMode="EaseOut"/>
    </UserControl.Resources>
    
    <Grid>
        <!-- Main Content -->
        <Grid>
            <!-- Top Bar -->
            <Grid VerticalAlignment="Top" Height="60" Margin="20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Hamburger (Now on Left) -->
                <Button Grid.Column="0" Command="{Binding ToggleDrawerCommand}" 
                        Width="40" Height="40" Background="Transparent" BorderThickness="0" Margin="0,0,10,0">
                    <Path Data="{StaticResource IconHamburger}" 
                          Fill="{DynamicResource ForegroundBrush}"
                          Stretch="Uniform" Width="20" Height="20"/>
                </Button>

                <!-- Center: Company Name + Edit Icon -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" 
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedCompany.Name, FallbackValue=''}" 
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                    <!-- Edit icon (pencil) -->
                    <Button Command="{Binding EditCompanyCommand}"
                            Width="32" Height="32" Background="Transparent" 
                            BorderThickness="0" Margin="8,0,0,0"
                            Cursor="Hand" ToolTip="{DynamicResource MainTooltipEdit}"
                            Visibility="{Binding HasSelectedCompany, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" 
                                   FontSize="14" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"/>
                    </Button>
                </StackPanel>
                
                <!-- Right: Settings -->
                <Button Grid.Column="2" Command="{Binding GoToSettingsCommand}" 
                        Width="40" Height="40" Background="Transparent" BorderThickness="0">
                    <Path Data="{StaticResource IconSettings}" 
                          Fill="{DynamicResource ForegroundBrush}"
                          Stretch="Uniform" Width="20" Height="20"/>
                </Button>
            </Grid>
            
            <!-- Cards -->
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal" ItemWidth="170" ItemHeight="170">
                <views:CardControl Title="{DynamicResource BtnEmployees}" Icon="{StaticResource IconPeople}" Margin="10"
                                   Command="{Binding OpenEmployeesCommand}"/>
                <views:CardControl Title="{DynamicResource BtnTemplates}" 
                                   Icon="{StaticResource IconTemplates}" 
                                   Margin="10"
                                   Command="{Binding OpenTemplatesCommand}"/>
                <views:CardControl Title="{DynamicResource BtnProblems}" Icon="{StaticResource IconProblems}" Margin="10"
                                   Command="{Binding OpenProblemsCommand}"
                                   BadgeCount="{Binding ProblemsCount}"/>
                <views:CardControl Title="{DynamicResource BtnFinances}" Icon="{StaticResource IconFinances}" Margin="10"/>
                <views:CardControl Title="{DynamicResource BtnArchive}" Icon="{StaticResource IconArchive}" Margin="10"
                                   Command="{Binding OpenArchiveCommand}"/>
            </WrapPanel>
        </Grid>
        
        <!-- Drawer Overlay (Click to close) -->
        <Border x:Name="DrawerOverlay" Background="#44000000" Opacity="0"
                IsHitTestVisible="{Binding IsDrawerOpen}">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleDrawerCommand}"/>
            </Border.InputBindings>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDrawerOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.25"
                                                         EasingFunction="{StaticResource DrawerEase}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
        
        <!-- Drawer Panel -->
        <Border x:Name="DrawerPanel" Width="320" HorizontalAlignment="Left" 
                Background="{DynamicResource ContentBackgroundBrush}" 
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,1,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="8" Direction="0" Color="#000000" Opacity="0.25"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform X="-320"/>
            </Border.RenderTransform>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDrawerOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         From="-320" To="0" Duration="0:0:0.3"
                                                         EasingFunction="{StaticResource DrawerEase}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         From="0" To="-320" Duration="0:0:0.25"
                                                         EasingFunction="{StaticResource DrawerEase}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ===== HEADER ===== -->
                <Border Grid.Row="0" Padding="20,20,20,16"
                        Background="{DynamicResource AccentBrush}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="42" Height="42" CornerRadius="10" Background="#20FFFFFF" Margin="0,0,14,0">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource DrawerTitle}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{DynamicResource MainSelectCompany}" FontSize="11" Foreground="#CCFFFFFF" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Close button -->
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                                Command="{Binding ToggleDrawerCommand}"
                                Width="30" Height="30" Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#AAFFFFFF"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ===== SELECTED INDICATOR ===== -->
                <Border Grid.Row="1" Padding="16,10" 
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                   Foreground="#4CAF50" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock FontSize="12" Foreground="#888" VerticalAlignment="Center">
                            <Run Text="Обрано: "/>
                            <Run Text="{Binding SelectedCompany.Name, FallbackValue='не обрано', Mode=OneWay}" 
                                 FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ===== COMPANY LIST ===== -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="12,10,12,0">
                    <ListBox ItemsSource="{Binding Companies}" 
                             SelectedItem="{Binding SelectedCompany}"
                             Background="Transparent" BorderThickness="0"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <EventSetter Event="MouseDoubleClick" Handler="CompanyItem_DoubleClick"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                                <Setter Property="ToolTip" Value="{DynamicResource MainTooltipDblClick}"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="CardBorder" 
                                                    Background="{DynamicResource ContentBackgroundBrush}" 
                                                    CornerRadius="10" 
                                                    Padding="12"
                                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                                    BorderThickness="1">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06"/>
                                                </Border.Effect>
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="CardBorder" Property="Background" Value="#E8F5E9"/>
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="#66BB6A"/>
                                                    <Setter TargetName="CardBorder" Property="BorderThickness" Value="1.5"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                        <Condition Property="IsSelected" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar circle with first letter -->
                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" 
                                            Background="{DynamicResource AccentBrush}" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding Name[0]}" FontSize="18" FontWeight="Bold" 
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Company info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="ICO:" FontSize="11" Foreground="#999" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding ICO}" FontSize="11" Foreground="#777"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Chevron -->
                                    <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" 
                                               FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- ===== ADD BUTTON ===== -->
                <Border Grid.Row="3" Padding="14,12,14,16"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
                    <Button Command="{Binding OpenAddCompanyDialogCommand}" 
                            Height="44" Cursor="Hand"
                            Background="{DynamicResource AccentBrush}" Foreground="White" 
                            BorderThickness="0" HorizontalContentAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" 
                                        CornerRadius="10" Padding="16,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource BtnAddNewCompany}" FontSize="14" 
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- Modal Dialog Overlay -->
        <Grid Visibility="{Binding IsAddCompanyDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#66000000">
                 <!-- Clicking background closes dialog -->
                 <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAddCompanyDialogCommand}"/>
                </Border.InputBindings>
            </Border>
            <!-- Removed HorizontalAlignment/VerticalAlignment to allow resizing via Grid in View -->
            <ContentControl Content="{Binding AddCompanyVm}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:AddCompanyViewModel}" xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels">
                        <views:AddCompanyView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>
    </Grid>
</UserControl>
