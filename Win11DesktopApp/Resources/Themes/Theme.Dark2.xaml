    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandAiGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#8B5CF6" Offset="0"/>
        <GradientStop Color="#60A5FA" Offset="1"/>
    </LinearGradientBrush>

    <DropShadowEffect x:Key="CardShadow" BlurRadius="16" ShadowDepth="3" Direction="270" Color="#000000" Opacity="0.6"/>
    <DropShadowEffect x:Key="CardShadowHover" BlurRadius="24" ShadowDepth="10" Direction="270" Color="#000000" Opacity="0.75"/>
    <DropShadowEffect x:Key="DialogShadow" BlurRadius="40" ShadowDepth="16" Direction="270" Color="#000000" Opacity="0.85"/>
</ResourceDictionary>
