<UserControl x:Class="Win11DesktopApp.Views.AddCompanyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="600">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>
    
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border x:Name="MainBorder" 
                Background="{DynamicResource CardBackgroundBrush}" 
                CornerRadius="12" 
                MinWidth="500" MinHeight="400"
                MaxWidth="1200" MaxHeight="900"
                Width="600" Height="700">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.3"/>
            </Border.Effect>
            
            <Grid>
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header: dynamic title -->
                    <TextBlock Text="{Binding DialogTitle}" FontSize="{DynamicResource FS24}" FontWeight="Bold" Margin="0,0,0,20" Foreground="{DynamicResource ForegroundBrush}"/>
                    
                    <!-- Tabs -->
                    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border Name="Border" BorderThickness="0,0,0,2" BorderBrush="Transparent" Margin="0,0,10,0" Padding="10,5">
                                                <ContentPresenter x:Name="ContentSite"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    ContentSource="Header"
                                                    Margin="10,2"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- Employer Tab -->
                        <TabItem Header="{DynamicResource TabEmployer}">
                            <ScrollViewer Margin="0,20,0,0" Style="{StaticResource ThinScroll}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource LabelCompanyName}"/>
                                    <TextBox Text="{Binding Employer.Name, UpdateSourceTrigger=PropertyChanged}"/>
                                    
                                    <TextBlock Text="{DynamicResource LabelICO}"/>
                                    <TextBox Text="{Binding Employer.ICO, UpdateSourceTrigger=PropertyChanged}"/>
                                    
                                    <!-- Addresses -->
                                    <TextBlock Text="{DynamicResource LabelAddress}" FontSize="{DynamicResource FS18}" Margin="0,10,0,10"/>
                                    <ItemsControl ItemsSource="{Binding Employer.Addresses}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}" Padding="10" Margin="0,0,0,10" CornerRadius="6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="3*"/>
                                                                    <ColumnDefinition Width="1*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                    <TextBlock Text="{DynamicResource LabelStreet}"/>
                                                                    <TextBox Text="{Binding Street}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{DynamicResource LabelNumber}"/>
                                                                    <TextBox Text="{Binding Number}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="2*"/>
                                                                    <ColumnDefinition Width="1*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                    <TextBlock Text="{DynamicResource LabelCity}"/>
                                                                    <TextBox Text="{Binding City}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{DynamicResource LabelZip}"/>
                                                                    <TextBox Text="{Binding ZipCode}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                        <!-- Delete address button -->
                                                        <Button Grid.Column="1" 
                                                                Command="{Binding DataContext.RemoveAddressCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                VerticalAlignment="Top" Margin="6,0,0,0"
                                                                Width="28" Height="28" Background="Transparent" BorderThickness="0" 
                                                                Cursor="Hand" ToolTip="{DynamicResource CompanyTooltipDeleteAddr}">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" Foreground="{DynamicResource ErrorBrush}"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Command="{Binding AddAddressCommand}" Content="{DynamicResource BtnAddAddress}" HorizontalAlignment="Left" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentBrush}"/>
                                    
                                    <!-- Positions -->
                                    <TextBlock Text="{DynamicResource LabelPositions}" FontSize="{DynamicResource FS18}" Margin="0,20,0,10"/>
                                    <ItemsControl ItemsSource="{Binding Employer.Positions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}" Padding="10" Margin="0,0,0,10" CornerRadius="6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="2*"/>
                                                                    <ColumnDefinition Width="1*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                    <TextBlock Text="{DynamicResource LabelPosTitle}"/>
                                                                    <TextBox Text="{Binding Title}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{DynamicResource LabelPosNumber}"/>
                                                                    <TextBox Text="{Binding PositionNumber}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="1*"/>
                                                                    <ColumnDefinition Width="1*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                    <TextBlock Text="{DynamicResource LabelSalary}"/>
                                                                    <TextBox Text="{Binding MonthlySalaryBrutto}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{DynamicResource LabelHourly}"/>
                                                                    <TextBox Text="{Binding HourlySalary}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                        <!-- Delete position button -->
                                                        <Button Grid.Column="1" 
                                                                Command="{Binding DataContext.RemovePositionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                VerticalAlignment="Top" Margin="6,0,0,0"
                                                                Width="28" Height="28" Background="Transparent" BorderThickness="0" 
                                                                Cursor="Hand" ToolTip="{DynamicResource CompanyTooltipDeletePos}">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" Foreground="{DynamicResource ErrorBrush}"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Command="{Binding AddPositionCommand}" Content="{DynamicResource BtnAddPosition}" HorizontalAlignment="Left" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentBrush}"/>

                                    <!-- Work Hours & Shifts -->
                                    <TextBlock Text="{DynamicResource LabelWorkHoursAndShifts}" FontSize="{DynamicResource FS18}" Margin="0,20,0,10"/>
                                    <Border BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}" Padding="10" CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <TextBlock Text="{DynamicResource LabelWeeklyHours}"/>
                                                <TextBox Text="{Binding Employer.WeeklyWorkHours}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                                <TextBlock Text="{DynamicResource LabelDailyHours}"/>
                                                <TextBox Text="{Binding Employer.DailyWorkHours}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{DynamicResource LabelShiftCount}"/>
                                                <ComboBox SelectedItem="{Binding Employer.ShiftCount, UpdateSourceTrigger=PropertyChanged}">
                                                    <sys:Int32>1</sys:Int32>
                                                    <sys:Int32>2</sys:Int32>
                                                    <sys:Int32>3</sys:Int32>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        
                        <!-- Agency Tab -->
                        <TabItem Header="{DynamicResource TabAgency}">
                            <StackPanel Margin="0,20,0,0">
                                <TextBlock Text="{DynamicResource LabelCompanyName}"/>
                                <TextBox Text="{Binding Agency.Name, UpdateSourceTrigger=PropertyChanged}"/>
                                
                                <TextBlock Text="{DynamicResource LabelICO}"/>
                                <TextBox Text="{Binding Agency.ICO, UpdateSourceTrigger=PropertyChanged}"/>
                                
                                <TextBlock Text="{DynamicResource LabelFullAddress}"/>
                                <TextBox Text="{Binding Agency.FullAddress, UpdateSourceTrigger=PropertyChanged}" Height="80" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                    
                    <!-- Buttons -->
                    <Grid Grid.Row="2" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Delete button (only in edit mode) -->
                        <Button Grid.Column="0" Command="{Binding DeleteCompanyCommand}" 
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                Width="40" Height="35" Background="Transparent" BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1"
                                ToolTip="{DynamicResource CompanyTooltipDeleteCompany}" Cursor="Hand">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}" Foreground="{DynamicResource ErrorBrush}"/>
                        </Button>

                        <!-- Cancel -->
                        <Button Grid.Column="2" Command="{Binding CancelCommand}" Content="{DynamicResource BtnCancel}" 
                                Width="100" Height="35" Margin="0,0,10,0" Background="Transparent" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"/>
                        
                        <!-- Save -->
                        <Button Grid.Column="3" Command="{Binding SaveCommand}" Content="{DynamicResource BtnSave}" 
                                Width="150" Height="35" Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0"/>
                    </Grid>
                </Grid>
                
                <!-- Resize Grip -->
                <Thumb HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" Width="20" Height="20" Margin="0,0,0,0" DragDelta="Thumb_DragDelta">
                    <Thumb.Template>
                        <ControlTemplate>
                            <Grid Background="Transparent">
                                <Path Data="M16,16 L16,4 L4,16 Z" Fill="{DynamicResource ForegroundBrush}" Opacity="0.5" Stretch="Uniform" Width="10" Height="10" Margin="5"/>
                            </Grid>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
            </Grid>
        </Border>
    </Grid>
</UserControl>
