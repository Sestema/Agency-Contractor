<UserControl x:Class="Win11DesktopApp.Views.AddCandidateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="860">
    <UserControl.Resources>
        <conv:StepEqualsToVisibilityConverter x:Key="StepVis"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

        <Style x:Key="WizInput" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="WizLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="UploadBtn" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WizCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource ContentBackgroundBrush}" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS18}"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource CandAddTitle}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Step indicator -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#CCC"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StepIndex}" Value="0">
                                        <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Ellipse Width="10" Height="10" Margin="4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#CCC"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StepIndex}" Value="1">
                                        <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <Ellipse Width="10" Height="10" Margin="4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#CCC"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StepIndex}" Value="2">
                                        <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Row="1">

            <!-- ===== STEP 0: Upload passport ===== -->
            <Border Visibility="{Binding StepIndex, Converter={StaticResource StepVis}, ConverterParameter=0}"
                    Padding="24">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Width="40" Height="40"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource CandStepPassport}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <TextBlock Text="{DynamicResource CandStepPassportHint}" FontSize="{DynamicResource FS13}"
                               Foreground="#888" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <!-- Upload button -->
                    <Button Command="{Binding UploadPassportCommand}" Style="{StaticResource UploadBtn}"
                            HorizontalAlignment="Center" Padding="24,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource CandSelectPassport}" FontSize="{DynamicResource FS13}"/>
                        </StackPanel>
                    </Button>

                    <!-- File name -->
                    <TextBlock Text="{Binding PassportFileName}" FontSize="{DynamicResource FS12}" Foreground="#4CAF50"
                               HorizontalAlignment="Center" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>

                    <!-- Preview -->
                    <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="8" Margin="0,16,0,0"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            MaxHeight="320" ClipToBounds="True"
                            Visibility="{Binding HasPassportImage, Converter={StaticResource BoolToVis}}">
                        <Image Source="{Binding PassportPreviewPath}" Stretch="Uniform" MaxHeight="310" Margin="8"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== STEP 1: Crop photo from passport ===== -->
            <Border Visibility="{Binding StepIndex, Converter={StaticResource StepVis}, ConverterParameter=1}"
                    Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- Crop canvas -->
                    <Border Grid.Column="0" Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="10"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" ClipToBounds="True">
                        <Canvas x:Name="CropCanvas" Width="560" Height="380" Background="Transparent" Cursor="Cross">
                            <Image x:Name="CropImage" Width="560" Height="380" Stretch="Uniform"
                                   Source="{Binding CurrentCropImagePath}"/>
                            <Rectangle x:Name="CropRect" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"
                                       Fill="#300078D4" StrokeDashArray="4 2"/>
                        </Canvas>
                    </Border>

                    <!-- Right panel -->
                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" Width="28" Height="28"
                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                <TextBlock Text="&#xE91B;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{DynamicResource CandStepCrop}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>

                        <!-- Crop target selector -->
                        <TextBlock Style="{StaticResource WizLabel}" Text="{DynamicResource WizDocLabel}"/>
                        <ComboBox ItemsSource="{Binding CropTargets}" SelectedItem="{Binding SelectedCropTarget}"
                                  Style="{StaticResource WizCombo}"/>

                        <!-- Aspect ratio -->
                        <CheckBox Content="{DynamicResource WizKeepAspect}" IsChecked="{Binding KeepAspectRatio}"
                                  Margin="0,0,0,6" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}"/>
                        <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding CropAspectRatio}"
                                  Style="{StaticResource WizCombo}">
                            <ComboBoxItem Content="1:1" Tag="1"/>
                            <ComboBoxItem Content="4:3" Tag="1.3333"/>
                            <ComboBoxItem Content="3:4" Tag="0.75"/>
                        </ComboBox>

                        <!-- Rotate buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Command="{Binding RotateLeftCommand}" Cursor="Hand" ToolTip="{DynamicResource WizRotateLeft}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="8"
                                                Width="40" Height="36" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                                       Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Command="{Binding RotateRightCommand}" Cursor="Hand" Margin="6,0,0,0" ToolTip="{DynamicResource WizRotateRight}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="8"
                                                Width="40" Height="36" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <TextBlock Text="&#xE7A8;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                                       Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- Enhance button -->
                        <Button Command="{Binding EnhanceDocumentCommand}" Cursor="Hand" Margin="0,0,0,10"
                                Visibility="{Binding IsCropPhotoMode, Converter={StaticResource InverseBoolToVis}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="#4CAF50" CornerRadius="8" Padding="12,8">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{DynamicResource WizEnhanceBtn}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Apply crop -->
                        <Button Command="{Binding ApplyCropCommand}" Cursor="Hand" Margin="0,0,0,10">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="8" Padding="12,8">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE123;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{DynamicResource WizCropApply}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Cropped preview -->
                        <TextBlock Style="{StaticResource WizLabel}" Text="{DynamicResource CandCroppedPreview}" Margin="0,4,0,4"/>
                        <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="6"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                Width="120" Height="120" ClipToBounds="True">
                            <Grid>
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="30"
                                           Foreground="#CCC" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding HasCroppedPhoto, Converter={StaticResource InverseBoolToVis}}"/>
                                <Image Source="{Binding CroppedPhotoPath}" Stretch="UniformToFill"
                                       Visibility="{Binding HasCroppedPhoto, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== STEP 2: Candidate data ===== -->
            <Border Visibility="{Binding StepIndex, Converter={StaticResource StepVis}, ConverterParameter=2}"
                    Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Data fields -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Background="{DynamicResource AccentBrush}" CornerRadius="8" Width="32" Height="32" Opacity="0.15"/>
                                <Border Background="Transparent" CornerRadius="8" Width="32" Height="32" Margin="-32,0,0,0">
                                    <TextBlock Text="&#xE779;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                               Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource CandStepData}" FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>

                            <!-- Name -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource WizLabel}" Text="{DynamicResource CandFirstName}"/>
                                    <TextBox Style="{StaticResource WizInput}" Text="{Binding Data.FirstName, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource WizLabel}" Text="{DynamicResource CandLastName}"/>
                                    <TextBox Style="{StaticResource WizInput}" Text="{Binding Data.LastName, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Passport number + country -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource WizLabel}" Text="{DynamicResource CandPassportNum}"/>
                                    <TextBox Style="{StaticResource WizInput}" Text="{Binding Data.PassportNumber, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource WizLabel}" Text="{DynamicResource CandPassportCountry}"/>
                                    <TextBox Style="{StaticResource WizInput}" Text="{Binding Data.PassportCountry, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Phone -->
                            <TextBlock Style="{StaticResource WizLabel}" Text="{DynamicResource CandPhone}"/>
                            <TextBox Style="{StaticResource WizInput}" Text="{Binding Data.Phone, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- Position -->
                            <TextBlock Style="{StaticResource WizLabel}" Text="{DynamicResource CandPosition}"/>
                            <ComboBox Style="{StaticResource WizCombo}" IsEditable="True"
                                      ItemsSource="{Binding KnownPositions}"
                                      Text="{Binding Data.DesiredPosition, UpdateSourceTrigger=LostFocus}"/>

                            <!-- Location -->
                            <TextBlock Style="{StaticResource WizLabel}" Text="{DynamicResource CandLocation}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton Content="{DynamicResource CandAllCzech}" IsChecked="{Binding IsAllCzech}" Margin="0,0,20,0"
                                             Foreground="{DynamicResource ForegroundBrush}"/>
                                <RadioButton Content="{DynamicResource CandSpecific}" IsChecked="{Binding IsSpecificLocation}"
                                             Foreground="{DynamicResource ForegroundBrush}"/>
                            </StackPanel>
                            <TextBox Style="{StaticResource WizInput}"
                                     Visibility="{Binding IsSpecificLocation, Converter={StaticResource BoolToVis}}"
                                     Text="{Binding Data.LocationDetails, UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- Notes -->
                            <TextBlock Style="{StaticResource WizLabel}" Text="{DynamicResource CandNotes}"/>
                            <TextBox Height="70" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"
                                     Margin="0,0,0,10" Padding="10,8" FontSize="13"
                                     BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                     Background="{DynamicResource WindowBackgroundBrush}" Foreground="{DynamicResource ForegroundBrush}"
                                     Text="{Binding Data.Notes, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- RIGHT: Passport preview -->
                    <Border Grid.Column="1" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="10"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Padding="10" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource CandPassport}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border Grid.Row="1" Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="6" ClipToBounds="True">
                                <Grid>
                                    <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                               Foreground="#CCC" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding HasPassportImage, Converter={StaticResource InverseBoolToVis}}"/>
                                    <Image x:Name="PassportZoomImage" Source="{Binding PassportPreviewPath}" Stretch="Uniform" Margin="4"
                                           Visibility="{Binding HasPassportImage, Converter={StaticResource BoolToVis}}"
                                           MouseWheel="PassportImage_MouseWheel"
                                           MouseRightButtonDown="PassportImage_MouseRightButtonDown"
                                           MouseRightButtonUp="PassportImage_MouseRightButtonUp"
                                           MouseMove="PassportImage_MouseMove"
                                           MouseLeftButtonDown="PassportImage_ResetZoom"
                                           Cursor="Hand">
                                        <Image.RenderTransformOrigin>0.5,0.5</Image.RenderTransformOrigin>
                                        <Image.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                <TranslateTransform X="0" Y="0"/>
                                            </TransformGroup>
                                        </Image.RenderTransform>
                                    </Image>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- FOOTER: Navigation buttons -->
        <Border Grid.Row="2" Background="{DynamicResource ContentBackgroundBrush}" Padding="20,12"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Cancel -->
                <Button Grid.Column="0" Command="{Binding CancelCommand}" Height="36" Padding="16,0"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand"
                        Content="{DynamicResource BtnCancel}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Back -->
                    <Button Command="{Binding BackCommand}" Height="36" Padding="16,0" Margin="0,0,8,0"
                            Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand"
                            Content="{DynamicResource BtnBack}"/>

                    <!-- Next (visible when not last step) -->
                    <Button Command="{Binding NextCommand}" Cursor="Hand"
                            Visibility="{Binding IsLastStep, Converter={StaticResource InverseBoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="NxtBd" Background="{DynamicResource AccentBrush}" CornerRadius="8"
                                        Padding="16,0" Height="36">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="NxtBd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="NxtBd" Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource BtnNext}" VerticalAlignment="Center" Foreground="White" FontWeight="SemiBold"/>
                            <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <!-- Save (visible on last step) -->
                    <Button Command="{Binding SaveCommand}" Cursor="Hand"
                            Visibility="{Binding IsLastStep, Converter={StaticResource BoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="SvBd" Background="{DynamicResource AccentBrush}" CornerRadius="8"
                                        Padding="16,0" Height="36">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="SvBd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="SvBd" Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="White"/>
                            <TextBlock Text="{DynamicResource BtnSave}" VerticalAlignment="Center" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
