<Window x:Class="Win11DesktopApp.Views.ReportColumnSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ReportColumnsDialogTitle}"
        Width="500" Height="620" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Border Style="{StaticResource PageHeaderIconBadge}">
                <TextBlock Text="&#xE70F;" Style="{StaticResource PageHeaderIconText}"/>
            </Border>
            <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                <TextBlock Text="{DynamicResource ReportColumnsDialogTitle}"
                           FontSize="{DynamicResource FS20}"
                           Style="{StaticResource PageHeaderTitleText}"/>
                <TextBlock Text="{DynamicResource ReportColumnsDialogDesc}"
                           FontSize="{DynamicResource FS11}"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource DialogSectionCard}" Padding="10">
            <ListBox x:Name="ColumnsList"
                     ItemsSource="{Binding}"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource DialogPreviewSurface}" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsVisible}"
                                          IsEnabled="{Binding CanToggle}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontWeight="SemiBold"
                                               FontSize="{DynamicResource FS13}"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{Binding Key}"
                                               FontSize="{DynamicResource FS11}"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Tag="{Binding Key}"
                                        Click="MoveUp_Click"
                                        Style="{StaticResource ToolbarInlineIconButton}"
                                        Foreground="{DynamicResource AccentBrush}"
                                        Margin="8,0,6,0"
                                        ToolTip="{DynamicResource ReportColumnsMoveUp}">
                                    <TextBlock Text="&#xE74A;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="{DynamicResource FS13}"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                </Button>

                                <Button Grid.Column="3"
                                        Tag="{Binding Key}"
                                        Click="MoveDown_Click"
                                        Style="{StaticResource ToolbarInlineIconButton}"
                                        Foreground="{DynamicResource AccentBrush}"
                                        ToolTip="{DynamicResource ReportColumnsMoveDown}">
                                    <TextBlock Text="&#xE74B;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="{DynamicResource FS13}"
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Click="Reset_Click"
                    HorizontalAlignment="Left"
                    Style="{StaticResource DialogAccentSoftButton}"
                    Content="{DynamicResource ReportColumnsResetButton}"/>

            <Button Grid.Column="1"
                    Click="Cancel_Click"
                    Margin="0,0,10,0"
                    Style="{StaticResource DialogAccentSoftButton}"
                    Content="{DynamicResource BtnCancel}"/>

            <Button Grid.Column="2"
                    Click="Save_Click"
                    Style="{StaticResource FilledActionButton}">
                <TextBlock Text="{DynamicResource BtnDone}"
                           FontSize="{DynamicResource FS13}"
                           Foreground="White"
                           FontWeight="SemiBold"/>
            </Button>
        </Grid>
    </Grid>
</Window>
