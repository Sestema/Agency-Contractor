<UserControl x:Class="Win11DesktopApp.Views.StepPassportDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Win11DesktopApp.Views">
    <Border Style="{StaticResource StepFade}" Visibility="{Binding StepIndex, Converter={StaticResource StepVis}, ConverterParameter=2}"
            Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="22"
            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>
            <ScrollViewer Grid.Column="0" Style="{StaticResource ThinScroll}" Margin="0,0,12,0"
                          VerticalScrollBarVisibility="Hidden"
                          PreviewMouseWheel="InnerScrollViewer_PreviewMouseWheel">
                <StackPanel>
                    <StackPanel Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource PageHeaderIconBadge}" Background="{DynamicResource SuccessBrush}">
                                <TextBlock Text="&#xE8A7;" Style="{StaticResource PageHeaderIconText}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding PrimaryDocumentStepTitle}"
                                           FontSize="{DynamicResource FS18}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{DynamicResource AIScanBtn}"
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Style="{StaticResource DialogPreviewSurface}" Padding="12,10" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Command="{Binding AIScanDocumentCommand}"
                                        Style="{StaticResource FilledActionButton}"
                                        Padding="12,6"
                                        Margin="0,0,10,0"
                                        Visibility="{Binding IsAIScanning, Converter={StaticResource InverseBoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="White"/>
                                        <TextBlock Text="{DynamicResource AIScanBtn}" FontSize="{DynamicResource FS12}" Foreground="White"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding AIScanStatus}"
                                           FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding AIScanStatus, Converter={StaticResource StringToVis}}"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="{DynamicResource WizFirstName}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.FirstName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizLastName}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.LastName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizBirthDate}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.BirthDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource DetFieldRodneCislo}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding RodneCislo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizGender}" Style="{StaticResource WizLabel}"/>
                    <Border Style="{StaticResource DialogPreviewSurface}" Padding="12,10" Margin="0,4,0,10">
                        <StackPanel Orientation="Horizontal">
                        <RadioButton Content="{DynamicResource GenderMale}" GroupName="Gender"
                                     IsChecked="{Binding IsGenderMale, Mode=TwoWay}"
                                     Foreground="{DynamicResource ForegroundBrush}" FontSize="{DynamicResource FS13}"
                                     Margin="0,0,20,0" VerticalContentAlignment="Center"/>
                        <RadioButton Content="{DynamicResource GenderFemale}" GroupName="Gender"
                                     IsChecked="{Binding IsGenderFemale, Mode=TwoWay}"
                                     Foreground="{DynamicResource ForegroundBrush}" FontSize="{DynamicResource FS13}"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{DynamicResource WizPassportNum}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.PassportNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizPassportAuthority}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.PassportAuthority, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizBirthCity}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.PassportCity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizBirthCountry}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.PassportCountry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizCitizenship}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.Citizenship, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizIssuingCountry}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.IssuingCountry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizPassportExpiry}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.PassportExpiry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>

                    <!-- EU ID Card extra fields -->
                    <StackPanel Visibility="{Binding ShowIdCardFallbackFields, Converter={StaticResource BoolToVis}}">
                        <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,14,0,12"/>
                        <TextBlock Text="{DynamicResource WizWorkPermitName}" Style="{StaticResource WizLabel}"/>
                        <TextBox Text="{Binding Data.WorkPermitName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"
                          Margin="0"/>
            <views:DocumentPreviewPanel Grid.Column="2" Margin="12,0,0,0"/>
        </Grid>
    </Border>
</UserControl>
