<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#E0F7FA"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#B2EBF2"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#006064"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardHoverBrush" Color="#E0F2F1"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#00BCD4"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#0097A7"/>
    
    <DropShadowEffect x:Key="CardShadow" BlurRadius="5" ShadowDepth="3" Direction="315" Color="#006064" Opacity="0.3"/>
</ResourceDictionary>
