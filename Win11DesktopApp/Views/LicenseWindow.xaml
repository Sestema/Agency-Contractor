<Window x:Class="Win11DesktopApp.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agency Contractor — Ліцензія"
        Width="580" Height="660"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        MinWidth="460" MinHeight="500"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Style="{StaticResource ThinScroll}" VerticalScrollBarVisibility="Auto" Padding="28,24,28,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
                    <Border Style="{StaticResource PageHeaderIconBadge}">
                        <TextBlock Text="&#xE8D7;" Style="{StaticResource PageHeaderIconText}"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Agency Contractor" FontSize="{DynamicResource FS24}" Style="{StaticResource PageHeaderTitleText}"/>
                        <TextBlock Text="Ліцензія та активація"
                                   FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Style="{StaticResource DialogSectionCard}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource DialogPreviewSurface}" Padding="14,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource AccentLightBrush}">
                                        <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                                   Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Статус ліцензії"
                                                   FontSize="{DynamicResource FS14}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="Поточний стан активації на цьому пристрої."
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock x:Name="TxtStatus"
                                           Text="Перевірка..."
                                           FontSize="{DynamicResource FS16}"
                                           FontWeight="SemiBold"
                                           Foreground="#D32F2F"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource DialogPreviewSurface}" Padding="14,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource InfoLightBrush}">
                                        <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                                   Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="ID комп'ютера"
                                                   FontSize="{DynamicResource FS14}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="Використовується для перевірки ключа активації."
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock x:Name="TxtMachineId"
                                           Text="..."
                                           FontSize="{DynamicResource FS12}"
                                           FontFamily="Consolas"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource DialogSectionCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource SuccessLightBrush}">
                                <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                           Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Активація"
                                           FontSize="{DynamicResource FS15}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="Виберіть термін дії та завантажте ключ для цього комп'ютера."
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Термін"
                                   FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   Margin="0,0,0,6"/>
                        <ComboBox x:Name="CbPlan"
                                  FontSize="{DynamicResource FS13}"
                                  Style="{StaticResource ThemedComboBox}"
                                  Margin="0,0,0,14">
                            <ComboBoxItem Content="30 днів" Tag="30"/>
                            <ComboBoxItem Content="90 днів" Tag="90"/>
                            <ComboBoxItem Content="180 днів" Tag="180"/>
                            <ComboBoxItem Content="362 дні" Tag="362"/>
                            <ComboBoxItem Content="Безліміт" Tag="0" IsSelected="True"/>
                        </ComboBox>

                        <Button x:Name="BtnActivate" Click="BtnActivate_Click"
                                Padding="16,11"
                                Style="{StaticResource FilledActionButton}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS15}"
                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Виберіть ключ для активації" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DialogPreviewSurface}" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="Результат"
                                   FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtResult" Text="" FontSize="{DynamicResource FS12}" TextWrapping="Wrap"
                                   Foreground="#388E3C"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="{DynamicResource WindowBackgroundBrush}" Padding="32,8,32,16"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Agency Contractor - 0.1.17"
                               FontSize="{DynamicResource FS11}"
                               Foreground="{DynamicResource TertiaryForegroundBrush}"/>
                    <TextBlock Text="Продовження доступне після успішної перевірки ліцензії."
                               FontSize="{DynamicResource FS10}"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="BtnContinue" Content="Продовжити ▸" Click="BtnContinue_Click"
                        FontSize="{DynamicResource FS13}" Padding="20,8" IsEnabled="False"
                        Background="{DynamicResource SuccessBrush}" Foreground="White" BorderThickness="0"
                        Style="{StaticResource FilledActionButton}">
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
