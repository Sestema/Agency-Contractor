<UserControl x:Class="Win11DesktopApp.Views.CardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="180" d:DesignWidth="170">
    <UserControl.Resources>
        <conv:IntToVisibilityConverter x:Key="IntToVis"/>
        <CubicEase x:Key="SmoothEase" EasingMode="EaseOut"/>
        <BackEase x:Key="BounceBack" EasingMode="EaseOut" Amplitude="0.3"/>
    </UserControl.Resources>
    <Grid>
        <Button Command="{Binding Command, RelativeSource={RelativeSource AncestorType=UserControl}}"
                BorderThickness="0" Background="Transparent" Padding="0" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="CardBorder" 
                            Background="{DynamicResource CardBackgroundBrush}" 
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Width="160" Height="170"
                            RenderTransformOrigin="0.5,0.5"
                            SnapsToDevicePixels="True">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
                                <TranslateTransform x:Name="CardTranslate" Y="0"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect x:Name="CardShadow" BlurRadius="12" ShadowDepth="3" Direction="270" Color="#000000" Opacity="0.08"/>
                        </Border.Effect>
                        <Grid>
                            <Grid Margin="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Gradient icon circle -->
                                <Border x:Name="IconCircle" Grid.Row="0"
                                        Width="64" Height="64" CornerRadius="18"
                                        HorizontalAlignment="Center" Margin="0,4,0,0"
                                        RenderTransformOrigin="0.5,0.5"
                                        Background="{Binding IconGradient, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <Path Data="{Binding Icon, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          Fill="White"
                                          Stretch="Uniform"
                                          Width="30" Height="30"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Title -->
                                <TextBlock x:Name="TitleText" Grid.Row="2"
                                           Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="{DynamicResource FS14}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Bottom"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,2"/>
                            </Grid>

                            <!-- Win11 Reveal highlight layer (follows cursor) -->
                            <Border x:Name="RevealLayer"
                                    CornerRadius="16"
                                    IsHitTestVisible="False"
                                    Opacity="0"
                                    SnapsToDevicePixels="True">
                                <Border.Background>
                                    <RadialGradientBrush x:Name="RevealBrush"
                                                         Center="0.5,0.5"
                                                         GradientOrigin="0.5,0.5"
                                                         RadiusX="0.55" RadiusY="0.55">
                                        <GradientStop Color="#66FFFFFF" Offset="0.0"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1.0"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Reveal border highlight (edge glow that also follows cursor) -->
                            <Border x:Name="RevealBorder"
                                    CornerRadius="16"
                                    BorderThickness="1"
                                    IsHitTestVisible="False"
                                    Opacity="0"
                                    SnapsToDevicePixels="True">
                                <Border.BorderBrush>
                                    <RadialGradientBrush x:Name="RevealBorderBrush"
                                                         Center="0.5,0.5"
                                                         GradientOrigin="0.5,0.5"
                                                         RadiusX="0.5" RadiusY="0.5">
                                        <GradientStop Color="#CCFFFFFF" Offset="0.0"/>
                                        <GradientStop Color="#44FFFFFF" Offset="0.5"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1.0"/>
                                    </RadialGradientBrush>
                                </Border.BorderBrush>
                            </Border>

                            <!-- Static inner highlight rim: visible only in Glass themes
                                 where GlassInnerHighlightBrush is defined. In other themes
                                 the DynamicResource does not resolve, so nothing is drawn. -->
                            <Border x:Name="GlassHighlight"
                                    CornerRadius="16"
                                    BorderThickness="1,1,1,0"
                                    BorderBrush="{DynamicResource GlassInnerHighlightBrush}"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    SnapsToDevicePixels="True"/>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Hover: lift + scale + deeper shadow + icon pulse -->
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <!-- Card lifts up -->
                                    <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                     Storyboard.TargetProperty="Y"
                                                     To="-6" Duration="0:0:0.25"
                                                     EasingFunction="{StaticResource BounceBack}"/>
                                    <!-- Card scales slightly -->
                                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1.04" Duration="0:0:0.25"
                                                     EasingFunction="{StaticResource SmoothEase}"/>
                                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1.04" Duration="0:0:0.25"
                                                     EasingFunction="{StaticResource SmoothEase}"/>
                                    <!-- Deeper shadow -->
                                    <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="28" Duration="0:0:0.25"
                                                     EasingFunction="{StaticResource SmoothEase}"/>
                                    <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="ShadowDepth"
                                                     To="8" Duration="0:0:0.25"
                                                     EasingFunction="{StaticResource SmoothEase}"/>
                                    <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.18" Duration="0:0:0.25"
                                                     EasingFunction="{StaticResource SmoothEase}"/>
                                    <!-- Icon breathes -->
                                    <DoubleAnimation Storyboard.TargetName="IconScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1.1" Duration="0:0:0.3"
                                                     EasingFunction="{StaticResource BounceBack}"/>
                                    <DoubleAnimation Storyboard.TargetName="IconScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1.1" Duration="0:0:0.3"
                                                     EasingFunction="{StaticResource BounceBack}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Mouse Leave: smooth return -->
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                     Storyboard.TargetProperty="Y"
                                                     To="0" Duration="0:0:0.3"
                                                     EasingFunction="{StaticResource SmoothEase}"/>
                                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1" Duration="0:0:0.3"
                                                     EasingFunction="{StaticResource SmoothEase}"/>
                                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1" Duration="0:0:0.3"
                                                     EasingFunction="{StaticResource SmoothEase}"/>
                                    <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="12" Duration="0:0:0.3"
                                                     EasingFunction="{StaticResource SmoothEase}"/>
                                    <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="ShadowDepth"
                                                     To="3" Duration="0:0:0.3"
                                                     EasingFunction="{StaticResource SmoothEase}"/>
                                    <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.08" Duration="0:0:0.3"
                                                     EasingFunction="{StaticResource SmoothEase}"/>
                                    <DoubleAnimation Storyboard.TargetName="IconScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1" Duration="0:0:0.3"
                                                     EasingFunction="{StaticResource SmoothEase}"/>
                                    <DoubleAnimation Storyboard.TargetName="IconScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1" Duration="0:0:0.3"
                                                     EasingFunction="{StaticResource SmoothEase}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Press: subtle press-in -->
                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="0.96" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="0.96" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                     Storyboard.TargetProperty="Y"
                                                     To="0" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="6" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="ShadowDepth"
                                                     To="1" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Release: bounce back up -->
                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1.04" Duration="0:0:0.2"
                                                     EasingFunction="{StaticResource BounceBack}"/>
                                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1.04" Duration="0:0:0.2"
                                                     EasingFunction="{StaticResource BounceBack}"/>
                                    <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                     Storyboard.TargetProperty="Y"
                                                     To="-6" Duration="0:0:0.2"
                                                     EasingFunction="{StaticResource BounceBack}"/>
                                    <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="28" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="ShadowDepth"
                                                     To="8" Duration="0:0:0.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="CardBorder" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Badge -->
        <Border CornerRadius="12" Background="{DynamicResource ErrorBrush}" MinWidth="24" Height="24" 
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-6,0"
                Padding="6,0" IsHitTestVisible="False"
                Visibility="{Binding BadgeCount, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource IntToVis}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#EF4444" Opacity="0.4"/>
            </Border.Effect>
            <TextBlock Text="{Binding BadgeCount, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                       Foreground="White" FontSize="{DynamicResource FS11}" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
