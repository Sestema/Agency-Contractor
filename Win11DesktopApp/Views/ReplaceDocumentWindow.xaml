<Window x:Class="Win11DesktopApp.Views.ReplaceDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
        Title="{DynamicResource ReplDocTitle}" Width="780" Height="580"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        MinWidth="650" MinHeight="480"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:ImagePathConverter x:Key="ImagePathConverter"/>
    </Window.Resources>

        <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Style="{StaticResource PageHeaderIconBadge}">
                    <TextBlock Text="&#xE8F1;" Style="{StaticResource PageHeaderIconText}"/>
                </Border>
                <TextBlock x:Name="TitleBlock" FontSize="{DynamicResource FS20}" Style="{StaticResource PageHeaderTitleText}" VerticalAlignment="Center"/>
            </StackPanel>

            <Button Grid.Column="1" x:Name="BtnCancelHeader" Click="BtnCancel_Click"
                    Style="{StaticResource HeaderGhostButton}"
                    Width="36" Height="36">
                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
            </Button>
        </Grid>

        <!-- Main content: two columns -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="260"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Document preview + actions -->
            <Border Grid.Column="0" Style="{StaticResource DialogSectionCard}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Preview image -->
                    <Border Style="{StaticResource DialogPreviewSurface}" Margin="0,0,0,10" ClipToBounds="True">
                        <Grid>
                            <TextBlock x:Name="NoImageText" Text="{DynamicResource ReplDocUploadHint}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="{DynamicResource FS13}" Foreground="{DynamicResource MutedForegroundBrush}"/>
                            <Image x:Name="PreviewImage" Stretch="Uniform" StretchDirection="DownOnly"/>
                        </Grid>
                    </Border>

                    <!-- Action buttons -->
                    <WrapPanel Grid.Row="1" HorizontalAlignment="Center">
                        <Button x:Name="BtnUpload" Click="BtnUpload_Click" Padding="10,6" Margin="3"
                                Style="{StaticResource FilledActionButton}"
                                Cursor="Hand" FontWeight="SemiBold" ToolTip="{DynamicResource ReplDocUpload}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource ReplDocUpload}" FontSize="{DynamicResource FS12}"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnEditor" Click="BtnEditor_Click" Padding="10,6" Margin="3"
                                Style="{StaticResource HeaderGhostButton}" Cursor="Hand"
                                ToolTip="{DynamicResource ReplDocEdit}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                                <TextBlock Text="{DynamicResource ReplDocEdit}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnAIScan" Click="BtnAIScan_Click" Padding="10,6" Margin="3"
                                Style="{StaticResource DialogAccentSoftButton}" Cursor="Hand"
                                ToolTip="AI Scan">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="AI Scan" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- Right: Fields + comparison -->
            <Border Grid.Column="2" Style="{StaticResource DialogSectionCard}" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Style="{DynamicResource ThinScroll}">
                    <StackPanel x:Name="FieldsPanel" Margin="16">
                        <!-- AI status -->
                        <StackPanel x:Name="AIScanStatusPanel" Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
                            <TextBlock x:Name="AIScanSpinner" Text="&#xE895;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"
                                       RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotate"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock x:Name="AIScanStatus" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource AccentBrush}"
                                       TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Dynamic fields will be added here in code-behind -->
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer: Save / Cancel -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="BtnCancel" Click="BtnCancel_Click" Padding="20,8" Margin="0,0,10,0"
                    Style="{StaticResource HeaderGhostButton}"
                    Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                <TextBlock Text="{DynamicResource DetBtnCancel}" FontSize="{DynamicResource FS13}"/>
            </Button>
            <Button x:Name="BtnSave" Click="BtnSave_Click" Padding="20,8"
                    Style="{StaticResource FilledActionButton}"
                    Foreground="White"
                    Cursor="Hand" FontWeight="SemiBold">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource DetBtnSave}" FontSize="{DynamicResource FS13}"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
