                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:AddEmployeeWizardViewModel}" xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels">
                        <views:AddEmployeeWizardView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>

        <!-- Employee Details Overlay -->
        <Grid Visibility="{Binding IsEmployeeDetailsOpen, Converter={StaticResource BoolToVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEmployeeDetailsOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#66000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding EmployeeDetailsVm.CloseCommand}"/>
                </Border.InputBindings>
            </Border>
            <ContentControl Content="{Binding EmployeeDetailsVm}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:EmployeeDetailsViewModel}" xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels">
                        <views:EmployeeDetailsView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>

        <!-- Delete Confirm Dialog -->
        <Grid Visibility="{Binding IsDeleteConfirmOpen, Converter={StaticResource BoolToVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDeleteConfirmOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#66000000"/>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" Padding="24" 
                    Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.25"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS32}" 
                               HorizontalAlignment="Center" Foreground="#D32F2F" Margin="0,0,0,12"/>
                    <TextBlock Text="{DynamicResource MsgDeleteEmployee}" FontSize="{DynamicResource FS16}" FontWeight="SemiBold" 
                               Margin="0,0,0,6" TextAlignment="Center" Foreground="{DynamicResource ForegroundBrush}"/>
                    <TextBlock Text="{Binding EmployeeToDelete.FullName}" Foreground="#666" FontSize="{DynamicResource FS14}"
                               Margin="0,0,0,20" TextAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Command="{Binding CancelDeleteCommand}" Padding="18,8" Margin="0,0,10,0"
                                Background="{DynamicResource ContentBackgroundBrush}" 
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                            <TextBlock Text="{DynamicResource BtnCancel}" FontSize="{DynamicResource FS13}"/>
                        </Button>
                        <Button Command="{Binding ConfirmDeleteCommand}" Padding="18,8"
                                Background="#D32F2F" Foreground="White" BorderThickness="0"
                                FontWeight="SemiBold" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource BtnDelete}" FontSize="{DynamicResource FS13}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Batch Generate Dialog -->
        <Grid Visibility="{Binding IsBatchGenerateOpen, Converter={StaticResource BoolToVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBatchGenerateOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#66000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseBatchGenerateCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" 
                    Width="500" MaxHeight="500" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS18}" 
                                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource EmpBatchTitle}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Command="{Binding CloseBatchGenerateCommand}"
                                Width="30" Height="30" Background="Transparent" BorderThickness="0" Foreground="#999" Cursor="Hand">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                        </Button>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="{Binding BatchStatusMessage}" Foreground="#888" FontSize="{DynamicResource FS12}" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <ScrollViewer Grid.Row="2" Style="{StaticResource ThinScroll}" MaxHeight="300">
                        <ItemsControl ItemsSource="{Binding BatchTemplates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" 
                                            Padding="12,8" Margin="0,0,0,6" Cursor="Hand"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6" 
                                                    Background="#E3F2FD" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Format}" VerticalAlignment="Center" 
                                                           HorizontalAlignment="Center" FontWeight="Bold" FontSize="{DynamicResource FS11}"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="{DynamicResource FS14}"
                                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="{DynamicResource FS11}" Foreground="#888" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" 
                                                    Command="{Binding DataContext.BatchGenerateFromTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,5" FontWeight="SemiBold"
                                                    Background="{DynamicResource AccentBrush}" Foreground="White" 
                                                    BorderThickness="0" VerticalAlignment="Center" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource EmpGenerate}" FontSize="{DynamicResource FS12}"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
