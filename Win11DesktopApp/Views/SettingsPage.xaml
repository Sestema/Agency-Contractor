                                                <TextBlock Text="{DynamicResource SettingsTelegramDigestTime}"
                                                           VerticalAlignment="Center"
                                                           FontSize="{DynamicResource FS12}"
                                                           Foreground="{DynamicResource ForegroundBrush}"/>
