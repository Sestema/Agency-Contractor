<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardHoverBrush" Color="#Fbfbfb"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
    
    <!-- Shadow for Cards -->
    <DropShadowEffect x:Key="CardShadow" BlurRadius="10" ShadowDepth="2" Direction="270" Color="#D0D0D0" Opacity="0.4"/>
</ResourceDictionary>
