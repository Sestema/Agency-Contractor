<UserControl x:Class="Win11DesktopApp.Views.EmployeeDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:InverseBooleanConverter x:Key="InverseBool"/>
        <conv:StepEqualsToVisibilityConverter x:Key="StepVis"/>
        <conv:StatusColorConverter x:Key="StatusColor"/>
        <conv:StatusBackgroundConverter x:Key="StatusBg"/>
        <conv:PercentToScaleConverter x:Key="PercentToScale"/>
        <conv:ExpiryWarningToColorConverter x:Key="ExpiryWarnColor"/>
        <conv:ExpiryWarningToBgConverter x:Key="ExpiryWarnBg"/>
        <conv:ExpiryWarningToVisConverter x:Key="ExpiryWarnVis"/>
        <conv:ExpiryWarningToTextConverter x:Key="ExpiryWarnText"/>
        <conv:HexToBrushConverter x:Key="HexToBrush"/>
        <conv:StringNullOrEmptyToVisibilityConverter x:Key="StringToVis"/>
        <conv:InverseStringNullOrEmptyToVisibilityConverter x:Key="InverseStringToVis"/>

        <!-- Base text style -->
        <Style x:Key="BaseText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Field input -->
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Document card button -->
        <Style x:Key="DocCardBtn" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        </Style>

        <!-- Tab button base -->
        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <!-- Main Card -->
        <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12"
                Width="1060" Height="700"
                Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="*"/>     <!-- Content -->
                </Grid.RowDefinitions>

                <!-- ===== HEADER ===== -->
                <Border Grid.Row="0" Padding="20,16,20,12" 
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS18}" 
                                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FullName}" FontSize="{DynamicResource FS20}" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Command="{Binding CloseCommand}"
                                Width="32" Height="32" Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource SecondaryForegroundBrush}" Cursor="Hand" ToolTip="{DynamicResource DetTooltipClose}">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ===== BODY ===== -->
                <Grid Grid.Row="1" Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ===== LEFT SIDEBAR ===== -->
                    <Border Grid.Column="0" Padding="16,14" Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,1,0">
                        <ScrollViewer Style="{StaticResource ThinScroll}">
                            <StackPanel>
                                <!-- Photo -->
                                <Border Height="220" CornerRadius="8" Background="{DynamicResource ContentBackgroundBrush}" Margin="0,0,0,14"
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" ClipToBounds="True">
                                    <Grid>
                                        <Image Source="{Binding PhotoFilePath, Converter={StaticResource ImagePathConverter}}" Stretch="Uniform" 
                                               Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"/>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    Visibility="{Binding HasPhoto, Converter={StaticResource InverseBoolToVis}}">
                                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS28}" 
                                                       Foreground="{DynamicResource TertiaryForegroundBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource DetNoPhoto}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource TertiaryForegroundBrush}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Name -->
                                <TextBlock Text="{Binding FullName}" FontSize="{DynamicResource FS16}" FontWeight="Bold" 
                                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"
                                           TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>

                                <!-- Position -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="&#xE821;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" 
                                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                               TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding Data.PositionTag, Mode=OneWay}"/>
                                        <Run Text=" (CZ-ISCO: "/><Run Text="{Binding Data.PositionNumber, Mode=OneWay}"/><Run Text=")"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Contract type (hidden for passport_only) -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Data.EmployeeType}" Value="passport_only">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" 
                                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Data.ContractType}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Separator -->
                                <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,10"/>

                                <!-- Contact info -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" 
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Data.Phone}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" 
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Data.Email}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" 
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Data.StartDate}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" 
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Data.ContractSignDate}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}"/>
                                </StackPanel>

                                <!-- Separator -->
                                <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,10"/>

                                <!-- Generate button -->
                                <Button Command="{Binding OpenGenerateDialogCommand}" Padding="12,8" Cursor="Hand"
                                        Background="{DynamicResource AccentBrush}" Foreground="White" 
                                        BorderThickness="0" FontWeight="SemiBold" HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource DetBtnGenerate}" FontSize="{DynamicResource FS12}"/>
                                    </StackPanel>
                                </Button>

                                <!-- Open folder button -->
                                <Button Command="{Binding OpenFolderCommand}" Padding="12,8" Cursor="Hand" Margin="0,8,0,0"
                                        Background="{DynamicResource ContentBackgroundBrush}" 
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                        Foreground="{DynamicResource ForegroundBrush}" HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource DetBtnOpenFolder}" FontSize="{DynamicResource FS12}"/>
                                    </StackPanel>
                                </Button>

                                <!-- AI Validate button -->
                                <Button Command="{Binding AIValidateCommand}" Padding="12,8" Cursor="Hand" Margin="0,8,0,0"
                                        Background="{DynamicResource PurpleLightBrush}"
                                        BorderBrush="{DynamicResource PurpleBrush}" BorderThickness="1"
                                        Foreground="{DynamicResource PurpleBrush}" HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource AIValidateBtn}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>


                                <!-- Export PDF button -->
                                <Button Command="{Binding ExportProfilePdfCommand}" Padding="12,8" Cursor="Hand" Margin="0,8,0,0"
                                        Background="{DynamicResource AccentLightBrush}" 
                                        BorderBrush="{DynamicResource AccentDarkBrush}" BorderThickness="1"
                                        Foreground="{DynamicResource AccentDarkBrush}" HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xEA00;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource DetBtnExportPdf}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>

                                <!-- Archive button -->
                                <Button Command="{Binding ArchiveEmployeeCommand}" Padding="12,8" Cursor="Hand" Margin="0,8,0,0"
                                        Background="{DynamicResource ErrorLightBrush}" 
                                        BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1"
                                        Foreground="{DynamicResource ErrorBrush}" HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource DetBtnArchive}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>

                                <!-- Status -->
                                <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,10"/>
                                <TextBlock Text="{DynamicResource DetLabelStatus}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                                <Border CornerRadius="6" Padding="8,4" 
                                        Background="{Binding Data.Status, Converter={StaticResource StatusBg}}">
                                    <TextBlock Text="{Binding Data.Status, Converter={StaticResource StatusDisplayConverter}, FallbackValue='—'}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"
                                               Foreground="{Binding Data.Status, Converter={StaticResource StatusColor}}"/>
                                </Border>

                                <!-- Profile completion -->
                                <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,10"/>
                                <TextBlock FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4">
                                    <Run Text="{DynamicResource DetProfileCompletion}"/>
                                    <Run Text="{Binding ProfileCompletionPercent, Mode=OneWay, FallbackValue=0}"/><Run Text="%"/>
                                </TextBlock>
                                <Grid Height="8" Margin="0,0,0,4" ClipToBounds="True">
                                    <Border CornerRadius="4" Background="{DynamicResource CardBorderBrush}"/>
                                    <Border CornerRadius="4" HorizontalAlignment="Stretch"
                                            RenderTransformOrigin="0,0.5">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#11998E" Offset="0"/>
                                                <GradientStop Color="#38EF7D" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="{Binding ProfileCompletionPercent, Converter={StaticResource PercentToScale}, FallbackValue=0}" ScaleY="1"/>
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- ===== RIGHT CONTENT ===== -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Tabs -->
                            <RowDefinition Height="*"/>     <!-- Tab content -->
                        </Grid.RowDefinitions>

                        <!-- Tab Buttons -->
                        <Border Grid.Row="0" Padding="20,0,20,0"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding ShowDocumentsCommand}" Margin="0,0,4,0">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource DetTabDocs}" FontSize="{DynamicResource FS13}"/>
                                        </StackPanel>
                                    </Button.Content>
                                    <!-- Active state: accent color underline -->
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TabBtn}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TabIndex}" Value="0">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Command="{Binding ShowProfileCommand}" Margin="0,0,4,0">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE779;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource DetTabProfile}" FontSize="{DynamicResource FS13}"/>
                                        </StackPanel>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TabBtn}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TabIndex}" Value="1">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Command="{Binding ShowHistoryCommand}" Margin="0,0,4,0">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource DetTabHistory}" FontSize="{DynamicResource FS13}"/>
                                        </StackPanel>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TabBtn}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TabIndex}" Value="2">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Command="{Binding ShowSalaryCommand}" Margin="0,0,4,0">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource DetTabSalary}" FontSize="{DynamicResource FS13}"/>
                                        </StackPanel>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TabBtn}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TabIndex}" Value="3">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Tab Content -->
                        <ScrollViewer Grid.Row="1" Style="{StaticResource ThinScroll}" Padding="20,16">
                            <Grid>
                                <!-- ========== TAB 0: DOCUMENTS ========== -->
                                <StackPanel Visibility="{Binding TabIndex, Converter={StaticResource StepVis}, ConverterParameter=0}">
                                    <TextBlock Text="{DynamicResource DetDocsTitle}" Style="{StaticResource SectionHeader}" FontSize="{DynamicResource FS16}" Margin="0,0,0,14"/>
                                    <WrapPanel>
                                        <!-- Passport -->
                                        <Border Width="300" Margin="0,0,12,12" Padding="14" 
                                                Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}" 
                                                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{DynamicResource DetDocPassport}" FontWeight="SemiBold" FontSize="{DynamicResource FS14}" 
                                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                                    </StackPanel>
                                                    <Border HorizontalAlignment="Right" CornerRadius="4" Padding="6,2"
                                                            Background="{Binding PassportExpiryWarning, Converter={StaticResource ExpiryWarnBg}}"
                                                            Visibility="{Binding PassportExpiryWarning, Converter={StaticResource ExpiryWarnVis}}">
                                                        <TextBlock Text="{Binding PassportExpiryWarning, Converter={StaticResource ExpiryWarnText}}" 
                                                                   FontSize="{DynamicResource FS9}" FontWeight="SemiBold"
                                                                   Foreground="{Binding PassportExpiryWarning, Converter={StaticResource ExpiryWarnColor}}"/>
                                                    </Border>
                                                </Grid>
                                                <Border Height="120" CornerRadius="4" Background="{DynamicResource ContentBackgroundBrush}" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Image Source="{Binding PassportFilePath, Converter={StaticResource ImagePathConverter}}" Stretch="Uniform"
                                                               Visibility="{Binding PassportIsPdf, Converter={StaticResource InverseBoolToVis}}"/>
                                                        <TextBlock Text="PDF" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                   FontSize="{DynamicResource FS16}" FontWeight="Bold" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   Visibility="{Binding PassportIsPdf, Converter={StaticResource BoolToVis}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding ReplacePassportCommand}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnReplace}" FontSize="{DynamicResource FS11}"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding OpenPassportCommand}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnOpenFile}" FontSize="{DynamicResource FS11}"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Visa (hidden for passport_only) -->
                                        <Border Width="300" Margin="0,0,12,12" Padding="14" 
                                                Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Data.EmployeeType}" Value="passport_only">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}" 
                                                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{DynamicResource DetDocVisa}" FontWeight="SemiBold" FontSize="{DynamicResource FS14}" 
                                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                                    </StackPanel>
                                                    <Border HorizontalAlignment="Right" CornerRadius="4" Padding="6,2"
                                                            Background="{Binding VisaExpiryWarning, Converter={StaticResource ExpiryWarnBg}}"
                                                            Visibility="{Binding VisaExpiryWarning, Converter={StaticResource ExpiryWarnVis}}">
                                                        <TextBlock Text="{Binding VisaExpiryWarning, Converter={StaticResource ExpiryWarnText}}" 
                                                                   FontSize="{DynamicResource FS9}" FontWeight="SemiBold"
                                                                   Foreground="{Binding VisaExpiryWarning, Converter={StaticResource ExpiryWarnColor}}"/>
                                                    </Border>
                                                </Grid>
                                                <Border Height="120" CornerRadius="4" Background="{DynamicResource ContentBackgroundBrush}" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Image Source="{Binding VisaFilePath, Converter={StaticResource ImagePathConverter}}" Stretch="Uniform"
                                                               Visibility="{Binding VisaIsPdf, Converter={StaticResource InverseBoolToVis}}"/>
                                                        <TextBlock Text="PDF" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                   FontSize="{DynamicResource FS16}" FontWeight="Bold" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   Visibility="{Binding VisaIsPdf, Converter={StaticResource BoolToVis}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding ReplaceVisaCommand}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnReplace}" FontSize="{DynamicResource FS11}"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding OpenVisaCommand}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnOpenFile}" FontSize="{DynamicResource FS11}"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding ExtendVisaCommand}"
                                                            ToolTip="{DynamicResource DetTooltipExtendVisa}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnExtend}" FontSize="{DynamicResource FS11}"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Insurance (hidden for passport_only) -->
                                        <Border Width="300" Margin="0,0,12,12" Padding="14" 
                                                Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Data.EmployeeType}" Value="passport_only">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <Grid Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE8C9;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}" 
                                                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{DynamicResource DetDocInsurance}" FontWeight="SemiBold" FontSize="{DynamicResource FS14}" 
                                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                                    </StackPanel>
                                                    <Border HorizontalAlignment="Right" CornerRadius="4" Padding="6,2"
                                                            Background="{Binding InsuranceExpiryWarning, Converter={StaticResource ExpiryWarnBg}}"
                                                            Visibility="{Binding InsuranceExpiryWarning, Converter={StaticResource ExpiryWarnVis}}">
                                                        <TextBlock Text="{Binding InsuranceExpiryWarning, Converter={StaticResource ExpiryWarnText}}" 
                                                                   FontSize="{DynamicResource FS9}" FontWeight="SemiBold"
                                                                   Foreground="{Binding InsuranceExpiryWarning, Converter={StaticResource ExpiryWarnColor}}"/>
                                                    </Border>
                                                </Grid>
                                                <Border Height="120" CornerRadius="4" Background="{DynamicResource ContentBackgroundBrush}" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Image Source="{Binding InsuranceFilePath, Converter={StaticResource ImagePathConverter}}" Stretch="Uniform"
                                                               Visibility="{Binding InsuranceIsPdf, Converter={StaticResource InverseBoolToVis}}"/>
                                                        <TextBlock Text="PDF" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                   FontSize="{DynamicResource FS16}" FontWeight="Bold" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   Visibility="{Binding InsuranceIsPdf, Converter={StaticResource BoolToVis}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding ReplaceInsuranceCommand}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnReplace}" FontSize="{DynamicResource FS11}"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding OpenInsuranceCommand}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnOpenFile}" FontSize="{DynamicResource FS11}"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding ExtendInsuranceCommand}"
                                                            ToolTip="{DynamicResource DetTooltipExtendIns}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnExtend}" FontSize="{DynamicResource FS11}"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Work Permit (only for work_permit type) -->
                                        <Border Width="300" Margin="0,0,12,12" Padding="14" 
                                                Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsWorkPermitType}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}" 
                                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource DetDocWorkPermit}" FontWeight="SemiBold" FontSize="{DynamicResource FS14}" 
                                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                                </StackPanel>
                                                <Border Height="120" CornerRadius="4" Background="{DynamicResource ContentBackgroundBrush}" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Image Source="{Binding WorkPermitFilePath, Converter={StaticResource ImagePathConverter}}" Stretch="Uniform"
                                                               Visibility="{Binding WorkPermitIsPdf, Converter={StaticResource InverseBoolToVis}}"/>
                                                        <TextBlock Text="PDF" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                   FontSize="{DynamicResource FS16}" FontWeight="Bold" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   Visibility="{Binding WorkPermitIsPdf, Converter={StaticResource BoolToVis}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding OpenWorkPermitCommand}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnOpenFile}" FontSize="{DynamicResource FS11}"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding RenewWorkPermitCommand}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnRenewPermit}" FontSize="{DynamicResource FS11}"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Photo -->
                                        <Border Width="300" Margin="0,0,12,12" Padding="14" 
                                                Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}" 
                                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource DetDocPhoto}" FontWeight="SemiBold" FontSize="{DynamicResource FS14}" 
                                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                                </StackPanel>
                                                <Border Height="120" CornerRadius="4" Background="{DynamicResource ContentBackgroundBrush}" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Image Source="{Binding PhotoFilePath, Converter={StaticResource ImagePathConverter}}" Stretch="Uniform"
                                                               Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"/>
                                                        <TextBlock Text="{DynamicResource DetNoPhoto}" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                   FontSize="{DynamicResource FS12}" Foreground="{DynamicResource TertiaryForegroundBrush}"
                                                                   Visibility="{Binding HasPhoto, Converter={StaticResource InverseBoolToVis}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding ReplacePhotoCommand}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnReplace}" FontSize="{DynamicResource FS11}"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding OpenPhotoCommand}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnOpenFile}" FontSize="{DynamicResource FS11}"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>

                                    <!-- ========== CUSTOM SIGNED DOCUMENTS ========== -->
                                    <StackPanel Margin="0,20,0,0">
                                        <Grid Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource DetCustomDocsTitle}" Style="{StaticResource SectionHeader}"
                                                           FontSize="{DynamicResource FS15}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Button HorizontalAlignment="Right" Command="{Binding AddCustomDocCommand}"
                                                    Background="{DynamicResource AccentBrush}" Foreground="White"
                                                    BorderThickness="0" Padding="10,6" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource DetBtnAddCustomDoc}" FontSize="{DynamicResource FS11}"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <!-- Empty hint -->
                                        <TextBlock Text="{DynamicResource DetCustomDocEmpty}"
                                                   Foreground="{DynamicResource TertiaryForegroundBrush}"
                                                   FontSize="{DynamicResource FS12}" Margin="0,0,0,6">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CustomDocuments.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- List of custom docs -->
                                        <ItemsControl ItemsSource="{Binding CustomDocuments}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8" Padding="14,10" CornerRadius="8"
                                                            Background="{DynamicResource CardBackgroundBrush}"
                                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                           FontSize="{DynamicResource FS13}"
                                                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                    <TextBlock Text="{DynamicResource DetCustomDocSigned}" FontSize="{DynamicResource FS11}"
                                                                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,4,0"/>
                                                                    <TextBlock Text="{Binding SignDate}" FontSize="{DynamicResource FS11}"
                                                                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,16,0"/>
                                                                    <TextBlock Text="{DynamicResource DetCustomDocExpires}" FontSize="{DynamicResource FS11}"
                                                                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,4,0"
                                                                               Visibility="{Binding ExpiryDate, Converter={StaticResource StringToVis}}"/>
                                                                    <TextBlock Text="{Binding ExpiryDate}" FontSize="{DynamicResource FS11}"
                                                                               Foreground="{DynamicResource ForegroundBrush}"
                                                                               Visibility="{Binding ExpiryDate, Converter={StaticResource StringToVis}}"/>
                                                                    <TextBlock Text="{DynamicResource DetCustomDocNoExpiry}" FontSize="{DynamicResource FS11}"
                                                                               Foreground="{DynamicResource TertiaryForegroundBrush}"
                                                                               Visibility="{Binding ExpiryDate, Converter={StaticResource InverseStringToVis}}"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Button Style="{StaticResource DocCardBtn}" Margin="0,0,6,0"
                                                                        Command="{Binding DataContext.OpenCustomDocCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{DynamicResource DetBtnOpenFile}" FontSize="{DynamicResource FS11}"/>
                                                                    </StackPanel>
                                                                </Button>
                                                                <Button Style="{StaticResource DocCardBtn}" Margin="0,0,6,0"
                                                                        Command="{Binding DataContext.OpenCustomDocFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{DynamicResource DetBtnOpenCustomDocFolder}" FontSize="{DynamicResource FS11}"/>
                                                                    </StackPanel>
                                                                </Button>
                                                                <Button Style="{StaticResource DocCardBtn}" Margin="0,0,6,0"
                                                                        Command="{Binding DataContext.HideCustomDocCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        ToolTip="{DynamicResource DetBtnHideDoc}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="&#xED1A;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{DynamicResource DetBtnHideDoc}" FontSize="{DynamicResource FS11}"/>
                                                                    </StackPanel>
                                                                </Button>
                                                                <Button Style="{StaticResource DocCardBtn}"
                                                                        Command="{Binding DataContext.DeleteCustomDocCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{DynamicResource DetBtnDeleteDoc}" FontSize="{DynamicResource FS11}"/>
                                                                    </StackPanel>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- ===== Hidden docs toggle button ===== -->
                                        <Button Margin="0,10,0,0" Padding="8,5" HorizontalAlignment="Left"
                                                Command="{Binding ToggleHiddenDocsSectionCommand}"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Visibility="{Binding HasHiddenDocs, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}"
                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,6,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="&#xE974;"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHiddenSectionVisible}" Value="True">
                                                                    <Setter Property="Text" Value="&#xE972;"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{DynamicResource DetHiddenDocsSection}"
                                                           FontSize="{DynamicResource FS12}"
                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                           Margin="0,0,6,0"/>
                                                <Border CornerRadius="8" Padding="6,1"
                                                        Background="{DynamicResource ContentBackgroundBrush}"
                                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                    <TextBlock Text="{Binding HiddenCustomDocsCount}"
                                                               FontSize="{DynamicResource FS10}"
                                                               Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                </Border>
                                            </StackPanel>
                                        </Button>

                                        <!-- ===== Hidden docs list ===== -->
                                        <ItemsControl Margin="0,6,0,0"
                                                      ItemsSource="{Binding HiddenCustomDocuments}"
                                                      Visibility="{Binding IsHiddenSectionVisible, Converter={StaticResource BoolToVis}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,6" Padding="12,8" CornerRadius="8"
                                                            Background="{DynamicResource ContentBackgroundBrush}"
                                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                                            Opacity="0.65">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}" FontSize="{DynamicResource FS12}"
                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                           FontStyle="Italic"/>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                    <TextBlock Text="{DynamicResource DetCustomDocSigned}" FontSize="{DynamicResource FS10}"
                                                                               Foreground="{DynamicResource TertiaryForegroundBrush}" Margin="0,0,4,0"/>
                                                                    <TextBlock Text="{Binding SignDate}" FontSize="{DynamicResource FS10}"
                                                                               Foreground="{DynamicResource TertiaryForegroundBrush}"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Button Style="{StaticResource DocCardBtn}" Margin="0,0,6,0"
                                                                        Command="{Binding DataContext.OpenCustomDocCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{DynamicResource DetBtnOpenFile}" FontSize="{DynamicResource FS11}"/>
                                                                    </StackPanel>
                                                                </Button>
                                                                <Button Style="{StaticResource DocCardBtn}" Margin="0,0,6,0"
                                                                        Command="{Binding DataContext.UnhideCustomDocCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{DynamicResource DetBtnShowDoc}" FontSize="{DynamicResource FS11}"/>
                                                                    </StackPanel>
                                                                </Button>
                                                                <Button Style="{StaticResource DocCardBtn}"
                                                                        Command="{Binding DataContext.DeleteCustomDocCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{DynamicResource DetBtnDeleteDoc}" FontSize="{DynamicResource FS11}"/>
                                                                    </StackPanel>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>

                                <!-- ========== TAB 1: PROFILE (ANKETA) ========== -->
                                <StackPanel Visibility="{Binding TabIndex, Converter={StaticResource StepVis}, ConverterParameter=1}">

                                    <!-- Action buttons -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <Button Command="{Binding EditProfileCommand}" Padding="12,7" Margin="0,0,8,0" Cursor="Hand"
                                                Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVis}}"
                                                Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource DetBtnEditProfile}" FontSize="{DynamicResource FS12}"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding SaveProfileCommand}" Padding="12,7" Margin="0,0,8,0" Cursor="Hand"
                                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                                Background="{DynamicResource SuccessBrush}" Foreground="White" BorderThickness="0" FontWeight="SemiBold">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource DetBtnSave}" FontSize="{DynamicResource FS12}"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding CancelEditCommand}" Padding="12,7" Cursor="Hand"
                                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                                Background="{DynamicResource ContentBackgroundBrush}" 
                                                Foreground="{DynamicResource ForegroundBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <TextBlock Text="{DynamicResource DetBtnCancel}" FontSize="{DynamicResource FS12}"/>
                                        </Button>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- ===== LEFT COLUMN ===== -->
                                        <StackPanel Grid.Column="0">
                                            <!-- Personal -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{DynamicResource SuccessLightBrush}" CornerRadius="6" Width="24" Height="24" Margin="0,0,8,0">
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{DynamicResource DetSecPersonal}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldFirstName}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.FirstName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldLastName}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.LastName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldBirthDate}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.BirthDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldGender}" Style="{StaticResource FieldLabel}"/>
                                                    <!-- View mode: text only -->
                                                    <TextBlock FontSize="{DynamicResource FS13}" Foreground="{DynamicResource ForegroundBrush}" Margin="0,2,0,6"
                                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVis}}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{DynamicResource GenderMale}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Data.Gender}" Value="female">
                                                                        <Setter Property="Text" Value="{DynamicResource GenderFemale}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Edit mode: radio buttons -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,6"
                                                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                                                        <RadioButton Content="{DynamicResource GenderMale}" GroupName="DetGender"
                                                                     IsChecked="{Binding IsGenderMale, Mode=TwoWay}"
                                                                     Foreground="{DynamicResource ForegroundBrush}" FontSize="{DynamicResource FS13}"
                                                                     Margin="0,0,20,0" VerticalContentAlignment="Center"/>
                                                        <RadioButton Content="{DynamicResource GenderFemale}" GroupName="DetGender"
                                                                     IsChecked="{Binding IsGenderFemale, Mode=TwoWay}"
                                                                     Foreground="{DynamicResource ForegroundBrush}" FontSize="{DynamicResource FS13}"
                                                                     VerticalContentAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- Passport -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{DynamicResource SuccessLightBrush}" CornerRadius="6" Width="24" Height="24" Margin="0,0,8,0">
                                                    <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{DynamicResource DetSecPassport}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldPassportNum}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.PassportNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldBirthCity}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.PassportCity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldBirthCountry}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.PassportCountry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldExpiry}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.PassportExpiry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
