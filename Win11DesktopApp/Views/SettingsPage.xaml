                    <!-- Accent color picker -->
                    <Border Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="16,14" Margin="0,18,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{StaticResource SettingsSectionIconBadge}"
                                        Background="{DynamicResource AccentLightBrush}"
                                        Width="32" Height="32" CornerRadius="8">
                                    <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="{DynamicResource FS14}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource SettingsAccentColor}"
                                               FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{DynamicResource SettingsAccentColorHint}"
                                               FontSize="{DynamicResource FS12}"
                                               Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding AccentPresets}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.ChangeAccentColorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding Hex}"
                                                ToolTip="{Binding Name}"
                                                Cursor="Hand"
                                                Margin="0,0,8,8"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid Width="40" Height="40" RenderTransformOrigin="0.5,0.5">
                                                        <Grid.RenderTransform>
                                                            <ScaleTransform x:Name="SwatchScale" ScaleX="1" ScaleY="1"/>
                                                        </Grid.RenderTransform>
                                                        <!-- Selection ring -->
                                                        <Ellipse x:Name="Ring"
                                                                 Stroke="{DynamicResource AccentBrush}"
                                                                 StrokeThickness="2"
                                                                 Opacity="0"/>
                                                        <!-- Swatch (default = accent with dashed border) -->
                                                        <Ellipse x:Name="SwatchDefault" Width="28" Height="28"
                                                                 Fill="{DynamicResource AccentBrush}"
                                                                 Stroke="{DynamicResource ForegroundBrush}"
                                                                 StrokeThickness="1"
                                                                 StrokeDashArray="2 2"
                                                                 Visibility="Collapsed"/>
                                                        <!-- Swatch (actual color) -->
                                                        <Ellipse x:Name="Swatch" Width="28" Height="28"
                                                                 Fill="{Binding Brush}">
                                                            <Ellipse.Effect>
                                                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.18"/>
                                                            </Ellipse.Effect>
                                                        </Ellipse>
                                                        <!-- Check for selected -->
                                                        <TextBlock x:Name="Check" Text="&#xE73E;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="12"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Opacity="0"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                            <Setter TargetName="Swatch" Property="Visibility" Value="Collapsed"/>
                                                            <Setter TargetName="SwatchDefault" Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter TargetName="Ring" Property="Opacity" Value="1"/>
                                                            <Setter TargetName="Check" Property="Opacity" Value="1"/>
                                                        </DataTrigger>
                                                        <EventTrigger RoutedEvent="MouseEnter">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="SwatchScale" Storyboard.TargetProperty="ScaleX" To="1.12" Duration="0:0:0.15"/>
                                                                    <DoubleAnimation Storyboard.TargetName="SwatchScale" Storyboard.TargetProperty="ScaleY" To="1.12" Duration="0:0:0.15"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                        <EventTrigger RoutedEvent="MouseLeave">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="SwatchScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.2"/>
                                                                    <DoubleAnimation Storyboard.TargetName="SwatchScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.2"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Display Scale Section -->
            <Border Grid.Row="5" Style="{StaticResource SettingsSectionCard}"
                    Visibility="{Binding IsProgramSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource InfoLightBrush}">
                            <TextBlock Text="&#xE7F8;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="{DynamicResource FS17}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}">
                                <Run Text="{DynamicResource SettingsInterfaceSize}"/>
                                <Run Text=" + "/>
                                <Run Text="{DynamicResource SettingsTextSize}"/>
                            </TextBlock>
                            <TextBlock FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.55"
                                       Margin="0,2,0,0">
                                <Run Text="{DynamicResource SettingsInterfaceSizeHint}"/>
                                <Run Text=" "/>
                                <Run Text="{DynamicResource SettingsTextSizeHint}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <Border Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="16,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource InfoLightBrush}"
                                        Width="32" Height="32" CornerRadius="8">
                                    <TextBlock Text="&#xE740;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                               Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource SettingsInterfaceSize}" 
                                               FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{DynamicResource SettingsInterfaceSizeHint}" 
                                               FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <WrapPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource SizeSmall}" 
                                        Command="{Binding ChangeInterfaceSizeCommand}" CommandParameter="Small">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentInterfaceSize}" Value="Small">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="{DynamicResource SizeMedium}" 
                                        Command="{Binding ChangeInterfaceSizeCommand}" CommandParameter="Medium">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentInterfaceSize}" Value="Medium">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="{DynamicResource SizeLarge}" 
                                        Command="{Binding ChangeInterfaceSizeCommand}" CommandParameter="Large">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentInterfaceSize}" Value="Large">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="{DynamicResource SizeExtraLarge}" 
                                        Command="{Binding ChangeInterfaceSizeCommand}" CommandParameter="ExtraLarge">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentInterfaceSize}" Value="ExtraLarge">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>

                            <Border Height="1" Margin="0,16,0,16" Background="{DynamicResource CardBorderBrush}" Opacity="0.7"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="{DynamicResource ErrorLightBrush}" CornerRadius="8" Width="32" Height="32"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                               Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource SettingsTextSize}" 
                                               FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{DynamicResource SettingsTextSizeHint}" 
                                               FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <WrapPanel Orientation="Horizontal">
                                <Button Command="{Binding ChangeTextSizeCommand}" CommandParameter="Small">
                                    <Button.Content>
                                        <TextBlock Text="{DynamicResource SizeSmall}" FontSize="12"/>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentTextSize}" Value="Small">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding ChangeTextSizeCommand}" CommandParameter="Medium">
                                    <Button.Content>
                                        <TextBlock Text="{DynamicResource SizeMedium}" FontSize="14"/>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentTextSize}" Value="Medium">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding ChangeTextSizeCommand}" CommandParameter="Large">
                                    <Button.Content>
                                        <TextBlock Text="{DynamicResource SizeLarge}" FontSize="16"/>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentTextSize}" Value="Large">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding ChangeTextSizeCommand}" CommandParameter="ExtraLarge">
                                    <Button.Content>
                                        <TextBlock Text="{DynamicResource SizeExtraLarge}" FontSize="18"/>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentTextSize}" Value="ExtraLarge">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Tags Visibility Card -->
            <Border Grid.Row="7" Style="{StaticResource SettingsSectionCard}"
                    Visibility="{Binding IsProgramSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Width="36" Height="36"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource SettingsTagsTitle}" 
                                       FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource SettingsTagsDesc}" 
                                       FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding OpenTagVisibilityCommand}" Cursor="Hand"
                            VerticalAlignment="Center" Style="{StaticResource FilledActionButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource SettingsTagsBtn}" 
                                       FontSize="{DynamicResource FS13}" FontWeight="Medium"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Company Visibility Card -->
            <Border Grid.Row="8" Style="{StaticResource SettingsSectionCard}"
                    Visibility="{Binding IsProgramSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Background="{DynamicResource InfoChipBackgroundBrush}" CornerRadius="8" Width="36" Height="36" VerticalAlignment="Center">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource InfoChipForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource SettingsFirmsVisibilityTitle}"
                                       FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource SettingsFirmsVisibilityDesc}"
                                       FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding OpenCompanyVisibilityCommand}" Cursor="Hand"
                            VerticalAlignment="Center" Style="{StaticResource FilledActionButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource SettingsFirmsVisibilityBtn}"
                                       FontSize="{DynamicResource FS13}" FontWeight="Medium"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Root Folder Card -->
            <Border Grid.Row="9" Style="{StaticResource SettingsSectionCard}" Padding="20,18"
                    Visibility="{Binding IsProgramSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource SuccessLightBrush}">
                                <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                           Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource LabelRootFolder}" 
                                           FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{DynamicResource SettingsFolderHint}" 
                                           FontSize="{DynamicResource FS11}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Style="{StaticResource DialogPreviewSurface}" Padding="12,10" Margin="0,0,12,0">
                            <TextBlock Text="{Binding RootFolderPath}" 
                                       FontSize="{DynamicResource FS12}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="1" Command="{Binding SelectRootFolderCommand}" Cursor="Hand"
                            VerticalAlignment="Center"
                            Style="{StaticResource HeaderGhostButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}"
                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource BtnSelectFolder}" 
                                       FontSize="{DynamicResource FS12}" FontWeight="Medium"
                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- AI (Gemini) Card -->
            <Border Grid.Row="10" Style="{StaticResource SettingsSectionCard}" Padding="24,22"
                    Visibility="{Binding IsProgramSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource AccentLightBrush}">
                                <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                           Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource AIProviderTitle}" FontSize="{DynamicResource FS17}"
                                           FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="Google Gemini API" FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource ForegroundBrush}" Opacity="0.55"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1" Padding="10,6" CornerRadius="999" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFF4F4F4"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGeminiConfigured}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SuccessLightBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#9E9E9E"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGeminiConfigured}" Value="True">
                                                    <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="{DynamicResource FS11}" FontWeight="SemiBold" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource AIStatusNotLoaded}"/>
                                            <Setter Property="Foreground" Value="#7A7A7A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGeminiConfigured}" Value="True">
                                                    <Setter Property="Text" Value="{DynamicResource AIStatusReady}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource DialogPreviewSurface}" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource AIGeminiApiKey}" FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,6"/>
                                <Grid>
                                    <Border Visibility="{Binding ShowMaskedGeminiApiKey, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Background="{DynamicResource ContentBackgroundBrush}"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,6"
                                            Cursor="IBeam"
                                            MouseLeftButtonDown="GeminiApiKeyMaskedBorder_OnMouseLeftButtonDown">
                                        <TextBlock Text="{Binding GeminiApiKeyMaskedDisplay}"
                                                   FontSize="{DynamicResource FS12}"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                    </Border>

                                    <PasswordBox x:Name="GeminiApiKeyPasswordBox"
                                                 Visibility="{Binding ShowGeminiApiKeyEditor, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                 FontSize="{DynamicResource FS12}"
                                                 Padding="8,6"
                                                 Background="{DynamicResource ContentBackgroundBrush}"
                                                 Foreground="{DynamicResource ForegroundBrush}"
                                                 BorderBrush="{DynamicResource CardBorderBrush}"
                                                 BorderThickness="1"
                                                 ContextMenu="{x:Null}"
                                                 PasswordChanged="GeminiApiKeyPasswordBox_OnPasswordChanged"
                                                 LostFocus="GeminiApiKeyPasswordBox_OnLostFocus"
                                                 PreviewKeyDown="GeminiApiKeyPasswordBox_OnPreviewKeyDown"/>
                                </Grid>

                                <TextBlock Text="{Binding GeminiAccessHint}"
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding ShowGeminiAccessHint, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Command="{Binding TestGeminiCommand}"
                                            Padding="12,7"
                                            Margin="0,0,8,0"
                                            Background="{DynamicResource SuccessBrush}"
                                            Foreground="White"
                                            FontSize="{DynamicResource FS11}"
                                            Style="{StaticResource FilledActionButton}">
                                        <TextBlock Text="{DynamicResource AIGeminiTest}" Foreground="White" FontSize="{DynamicResource FS11}"/>
                                    </Button>
                                    <Button Command="{Binding OpenGeminiSiteCommand}"
                                            Padding="12,7"
                                            FontSize="{DynamicResource FS11}"
                                            Style="{StaticResource HeaderGhostButton}">
                                        <TextBlock Text="{DynamicResource AIGeminiGetKey}"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   FontSize="{DynamicResource FS11}"/>
                                    </Button>
                                </StackPanel>

                                <TextBlock Text="{Binding GeminiTestResult}" FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource SuccessBrush}" Margin="0,8,0,0" TextWrapping="Wrap"
                                           Visibility="{Binding GeminiTestResult, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource DialogPreviewSurface}" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource AIGeminiModel}" FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,6"/>
                                <ComboBox Style="{StaticResource ThemedComboBox}"
                                          ItemsSource="{Binding GeminiModels}" SelectedItem="{Binding GeminiModel}"/>

                                <Border Height="1" Margin="0,14,0,14" Background="{DynamicResource CardBorderBrush}" Opacity="0.7"/>

                                <TextBlock Text="{DynamicResource AIProviderTitle}"
                                           FontSize="{DynamicResource FS12}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="Google Gemini API"
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="AI chat, document assistance and smart prompts use these settings globally."
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Telegram Bot Section -->
            <Border Grid.Row="11" Style="{StaticResource SettingsSectionCard}" Padding="24,22"
                    Visibility="{Binding IsServerSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource AccentLightBrush}">
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                           Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource SettingsTelegramTitle}" FontSize="{DynamicResource FS17}"
                                           FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{DynamicResource SettingsTelegramSubtitle}"
                                           FontSize="{DynamicResource FS11}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.55"/>
                            </StackPanel>
                        </StackPanel>

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding TelegramEnabled}"
                                  VerticalAlignment="Center"
                                  Content="{DynamicResource SettingsTelegramEnable}"/>
                    </Grid>

                    <Border Style="{StaticResource DialogPreviewSurface}" Padding="16,14" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{Binding TelegramBotStatus}"
                                       FontSize="{DynamicResource FS12}"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="{Binding TelegramBotUsername}"
                                       Margin="0,8,0,0"
                                       FontSize="{DynamicResource FS12}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Visibility="{Binding HasTelegramBotToken, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <StackPanel Margin="0,14,0,0"
                                        Visibility="{Binding TelegramNeedsToken, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{DynamicResource SettingsTelegramStepToken}"
                                           FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBox Text="{Binding TelegramBotTokenInput, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="{DynamicResource FS12}"
                                         Padding="8,6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Command="{Binding ConnectTelegramBotCommand}"
                                            Padding="14,8"
                                            Style="{StaticResource FilledActionButton}">
                                        <TextBlock Text="{DynamicResource SettingsTelegramConnect}"
                                                   FontSize="{DynamicResource FS12}"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Button>
                                    <Button Command="{Binding OpenBotFatherCommand}"
                                            Padding="14,8"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource HeaderGhostButton}">
                                        <TextBlock Text="{DynamicResource SettingsTelegramOpenBotFather}"
                                                   FontSize="{DynamicResource FS12}"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <Grid Margin="0,14,0,0"
                                  Visibility="{Binding TelegramIsConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="{DynamicResource WindowBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12">
                                    <StackPanel>
                                            <TextBlock Text="{DynamicResource SettingsTelegramStepQr}"
                                                   FontSize="{DynamicResource FS13}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <Border Margin="0,10,0,0"
                                                Padding="8"
                                                Background="White"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding HasTelegramQrCode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Image Source="{Binding TelegramQrCodeImage}" Width="180" Height="180"/>
                                        </Border>
                                        <TextBlock Text="{Binding TelegramPairingExpiryText}"
                                                   Margin="0,10,0,0"
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                        <TextBlock Text="{Binding TelegramPairingCode}"
                                                   Margin="0,4,0,0"
