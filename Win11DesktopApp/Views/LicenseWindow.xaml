<Window x:Class="Win11DesktopApp.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agency Contractor — Ліцензія"
        Width="540" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        MinWidth="460" MinHeight="500"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="32,24,32,8">
            <StackPanel>
                <!-- Logo / Title -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="42"
                               HorizontalAlignment="Center" Foreground="#1976D2" Margin="0,0,0,8"/>
                    <TextBlock Text="Agency Contractor" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Foreground="#333"/>
                    <TextBlock Text="© 2026 Oleksandr Kachalin" FontSize="11"
                               HorizontalAlignment="Center" Foreground="#999" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Status -->
                <Border Background="White" CornerRadius="8" Padding="16,12" Margin="0,0,0,12"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Статус ліцензії:" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtStatus" Text="Перевірка..." FontSize="15" FontWeight="SemiBold" Foreground="#D32F2F"/>
                    </StackPanel>
                </Border>

                <!-- Machine ID -->
                <Border Background="White" CornerRadius="8" Padding="16,10" Margin="0,0,0,12"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="ID комп'ютера:" FontSize="12" Foreground="#888" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtMachineId" Text="..." FontSize="13" FontFamily="Consolas" Foreground="#333"/>
                    </StackPanel>
                </Border>

                <!-- Activation section -->
                <Border Background="White" CornerRadius="8" Padding="16,14" Margin="0,0,0,12"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Активація" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>

                        <TextBlock Text="Термін:" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CbPlan" FontSize="13" Padding="8,6" Margin="0,0,0,14">
                            <ComboBoxItem Content="30 днів" Tag="30"/>
                            <ComboBoxItem Content="90 днів" Tag="90"/>
                            <ComboBoxItem Content="180 днів" Tag="180"/>
                            <ComboBoxItem Content="362 дні" Tag="362"/>
                            <ComboBoxItem Content="Безліміт" Tag="0" IsSelected="True"/>
                        </ComboBox>

                        <Button x:Name="BtnActivate" Click="BtnActivate_Click"
                                Padding="16,10" Cursor="Hand"
                                Background="#1976D2" Foreground="White" BorderThickness="0"
                                HorizontalAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#1565C0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Виберіть ключ для активації" FontSize="14" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Result message -->
                <TextBlock x:Name="TxtResult" Text="" FontSize="12" TextWrapping="Wrap"
                           Foreground="#388E3C" Margin="0,4,0,8"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom bar (always visible) -->
        <Border Grid.Row="1" Background="#F5F5F5" Padding="32,8,32,16"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="v0.1.04" FontSize="11" Foreground="#BBB" VerticalAlignment="Center"/>

                <Button Grid.Column="1" x:Name="BtnContinue" Content="Продовжити ▸" Click="BtnContinue_Click"
                        FontSize="13" Padding="20,8" Cursor="Hand" IsEnabled="False"
                        Background="#4CAF50" Foreground="White" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}" Opacity="{TemplateBinding Opacity}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#388E3C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
