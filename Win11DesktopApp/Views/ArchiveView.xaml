<UserControl x:Class="Win11DesktopApp.Views.ArchiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             xmlns:h="clr-namespace:Win11DesktopApp.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

        <Style x:Key="CardActionBtn" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid Margin="32,20,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding GoBackCommand}" Height="36" Padding="12,0" Margin="0,0,10,0"
                            Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource BtnBack}" FontSize="{DynamicResource FS14}"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS22}" 
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource ArchiveTitle}" FontSize="{DynamicResource FS24}" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Foreground="{DynamicResource ForegroundBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock Text="{DynamicResource ArchiveSearch}" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="{DynamicResource FS12}" Margin="2,0,0,2"/>
                    <TextBox Height="38" VerticalContentAlignment="Center"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <!-- ===== ARCHIVE LIST ===== -->
            <Grid Grid.Row="1">
                <ScrollViewer Style="{StaticResource ThinScroll}"
                              Visibility="{Binding HasArchived, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding ArchivedEmployees}" Margin="24,8,24,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" 
                                        Padding="16" Margin="0,4,0,10"
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                        RenderTransformOrigin="0.5,0.5"
                                        h:StaggerAnimation.Enable="True">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            <TranslateTransform Y="0"/>
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar -->
                                        <Border Grid.Column="0" Width="56" Height="56" CornerRadius="28" 
                                                Background="{DynamicResource ContentBackgroundBrush}" VerticalAlignment="Top" Margin="0,0,14,0"
                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="2">
                                            <Border.Clip>
                                                <EllipseGeometry Center="28,28" RadiusX="28" RadiusY="28"/>
                                            </Border.Clip>
                                            <Grid>
                                                <Image Source="{Binding PhotoPath, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill" 
                                                       Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS22}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="#BDBDBD"
                                                           Visibility="{Binding HasPhoto, Converter={StaticResource InverseBoolToVis}}"/>
                                            </Grid>
                                        </Border>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="{DynamicResource FS16}" 
                                                       Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding PositionTitle}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,6"/>

                                            <WrapPanel Margin="0,0,0,6">
                                                <!-- Start date -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" 
                                                               Foreground="{DynamicResource SuccessBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{DynamicResource ArchiveStarted}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                        <TextBlock Text="{Binding StartDate, Mode=OneWay}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <!-- End date -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" 
                                                               Foreground="{DynamicResource ErrorBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{DynamicResource ArchiveEnded}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                        <TextBlock Text="{Binding EndDate, Mode=OneWay}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </WrapPanel>

                                            <WrapPanel>
                                                <!-- Firm -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                                                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" 
                                                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding FirmName}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                </StackPanel>
                                                <!-- Phone -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                                                    <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" 
                                                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Phone}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                </StackPanel>
                                                <!-- Email -->
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" 
                                                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Email}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                </StackPanel>
                                            </WrapPanel>
                                        </StackPanel>

                                        <!-- Action buttons -->
                                        <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                                            <Button Style="{StaticResource CardActionBtn}" Margin="0,0,0,4"
                                                    Command="{Binding DataContext.RestoreEmployeeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource ArchiveRestore}" FontSize="{DynamicResource FS12}"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource CardActionBtn}"
                                                    Command="{Binding DataContext.OpenEmployeeFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" ToolTip="{DynamicResource ArchiveOpenFolder}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource EmpBtnFolder}" FontSize="{DynamicResource FS12}"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1.015" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1.015" Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty state -->
                <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="8" Padding="30"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        Visibility="{Binding HasArchived, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS42}" 
                                   HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBlock Text="{DynamicResource ArchiveEmpty}" FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                   Margin="0,12,0,4" TextAlignment="Center" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBlock Text="{DynamicResource ArchiveEmptyDesc}"
                                   FontSize="{DynamicResource FS13}" TextAlignment="Center" Foreground="{DynamicResource TertiaryForegroundBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ===== RESTORE DIALOG ===== -->
        <Grid Visibility="{Binding IsRestoreDialogOpen, Converter={StaticResource BoolToVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRestoreDialogOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CancelRestoreCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" 
                    Width="480" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS22}" 
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource ArchiveRestoreTitle}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{Binding EmployeeToRestore.FullName}" FontSize="{DynamicResource FS13}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Form -->
                    <TextBlock Text="{DynamicResource ArchiveFirm}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailableCompanies}" 
                              SelectedItem="{Binding SelectedCompany}"
                              DisplayMemberPath="Name"
                              Padding="8,6" Margin="0,0,0,12" FontSize="{DynamicResource FS13}"/>

                    <TextBlock Text="{DynamicResource ArchiveStartDate}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewStartDate, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8,6" Margin="0,0,0,12" FontSize="{DynamicResource FS13}"/>

                    <TextBlock Text="{DynamicResource ArchiveSignDate}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewContractSignDate, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8,6" Margin="0,0,0,12" FontSize="{DynamicResource FS13}"/>

                    <TextBlock Text="{DynamicResource ArchivePosition}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding CompanyPositions}"
                              SelectedItem="{Binding SelectedPosition}"
                              Padding="8,6" Margin="0,0,0,12" FontSize="{DynamicResource FS13}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" — " Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                    <TextBlock Foreground="{DynamicResource SecondaryForegroundBrush}">
                                        <Run Text="{Binding MonthlySalaryBrutto, StringFormat={}{0:N0} Kč/міс, Mode=OneWay}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding HourlySalary, StringFormat={}{0:N2} Kč/год, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{DynamicResource ArchiveWorkPlace}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding CompanyAddresses}"
                              SelectedItem="{Binding SelectedAddress}"
                              Padding="8,6" Margin="0,0,0,16" FontSize="{DynamicResource FS13}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding Street, Mode=OneWay}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Number, Mode=OneWay}"/>
                                    <Run Text=", "/>
                                    <Run Text="{Binding City, Mode=OneWay}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding ZipCode, Mode=OneWay}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Status message -->
                    <TextBlock Text="{Binding RestoreStatus}" Foreground="{DynamicResource ErrorBrush}" FontSize="{DynamicResource FS12}" 
                               Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Command="{Binding CancelRestoreCommand}" Padding="16,8" Margin="0,0,8,0"
                                Background="{DynamicResource ContentBackgroundBrush}" 
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                            <TextBlock Text="{DynamicResource BtnCancel}" FontSize="{DynamicResource FS13}"/>
                        </Button>
                        <Button Command="{Binding ConfirmRestoreCommand}" Padding="16,8"
                                Background="{DynamicResource AccentBrush}" Foreground="White" 
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource ArchiveRestoreBtn}" FontSize="{DynamicResource FS13}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
