<UserControl x:Class="Win11DesktopApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels"
             xmlns:views="clr-namespace:Win11DesktopApp.Views"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:HexToBrushConverter x:Key="HexToBrush"/>
        <conv:IntToVisibilityConverter x:Key="IntToVis"/>
        <CubicEase x:Key="Ease" EasingMode="EaseOut"/>

        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18,13"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.22" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DragHandle" TargetType="TextBlock">
            <Setter Property="Text" Value="&#xE700;"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TertiaryForegroundBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="SizeAll"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="ToolTip" Value="{DynamicResource DashDragToSwap}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardPrimaryGhostButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Background" Value="{DynamicResource PurpleLightBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PurpleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource PurpleBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PurpleLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardWidgetCard" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="13,11"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
        </Style>

        <!-- ===== WIDGET: Expiring Documents ===== -->
        <DataTemplate x:Key="ExpiringWidget">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <TextBlock Style="{StaticResource DragHandle}" Tag="grip"
                               MouseLeftButtonDown="Grip_MouseLeftButtonDown"/>
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource ErrorBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource DashExpiringSoon}" FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Style="{StaticResource CompactEmptyStateCard}"
                        Padding="20,18"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding DataContext.ExpiringDocs.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource IntToVis}, ConverterParameter=invert}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="40"
                                   Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{DynamicResource DashAllOk}" FontSize="{DynamicResource FS14}"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" Style="{StaticResource ThinScroll}"
                              Visibility="{Binding DataContext.ExpiringDocs.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource IntToVis}}">
                    <ItemsControl ItemsSource="{Binding DataContext.ExpiringDocs, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource DashboardWidgetCard}" Cursor="Hand" Margin="0,0,0,6">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.OpenEmployeeDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="10"
                                                Margin="0,0,12,0" VerticalAlignment="Center"
                                                Background="{Binding SeverityColor, Converter={StaticResource HexToBrush}, ConverterParameter=0.12}">
                                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                                       Foreground="{Binding SeverityColor, Converter={StaticResource HexToBrush}}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                            <TextBlock FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,2,0,0">
                                                <Run Text="{Binding Subtitle, Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding CompanyName, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <Border Grid.Column="2" CornerRadius="8" Padding="8,4"
                                                VerticalAlignment="Center"
                                                Background="{Binding SeverityColor, Converter={StaticResource HexToBrush}, ConverterParameter=0.12}">
                                            <TextBlock Text="{Binding SeverityLabel}" FontSize="{DynamicResource FS11}" FontWeight="SemiBold"
                                                       Foreground="{Binding SeverityColor, Converter={StaticResource HexToBrush}}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </DataTemplate>

        <!-- ===== WIDGET: Company Stats ===== -->
        <DataTemplate x:Key="CompaniesWidget">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Style="{StaticResource DragHandle}" Tag="grip"
                               MouseLeftButtonDown="Grip_MouseLeftButtonDown"/>
                    <TextBlock Text="{DynamicResource DashWidgetEfficiency}" FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Columns="2" Margin="0,0,0,12">
                        <Border Style="{StaticResource DashboardWidgetCard}" Margin="0,0,6,8">
                            <StackPanel>
                                <TextBlock Text="{Binding DataContext.TotalEmployeesAllTime, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           FontSize="{DynamicResource FS22}" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{DynamicResource DashEfficiencyEmployeesAllTime}" FontSize="{DynamicResource FS10}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardWidgetCard}" Margin="6,0,0,8">
                            <StackPanel>
                                <TextBlock Text="{Binding DataContext.GeneratedDocumentsCount, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           FontSize="{DynamicResource FS22}" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{DynamicResource DashEfficiencyGeneratedDocs}" FontSize="{DynamicResource FS10}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardWidgetCard}" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="{Binding DataContext.ProgramTimeText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           FontSize="{DynamicResource FS18}" FontWeight="Bold" Foreground="{DynamicResource InfoBrush}"/>
                                <TextBlock Text="{DynamicResource DashEfficiencyProgramTime}" FontSize="{DynamicResource FS10}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource DashboardWidgetCard}" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding DataContext.SavedTimeText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           FontSize="{DynamicResource FS18}" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                                <TextBlock Text="{DynamicResource DashEfficiencySavedTime}" FontSize="{DynamicResource FS10}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <TextBlock Grid.Row="1"
                               Text="{DynamicResource DashEfficiencyFormula}"
                               FontSize="{DynamicResource FS10}"
                               Foreground="{DynamicResource TertiaryForegroundBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>

                    <Grid Grid.Row="2" VerticalAlignment="Bottom">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,4">
                            <TextBlock Text="{DynamicResource DashEfficiencySavedTime}" FontSize="{DynamicResource FS10}"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                            <TextBlock Text="{Binding DataContext.SavedTimeText, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="{DynamicResource FS10}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <ProgressBar Grid.Row="1" Minimum="0" Maximum="{Binding DataContext.EfficiencyChartMaxMinutes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     Value="{Binding DataContext.SavedMinutes, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{DynamicResource SuccessBrush}"
                                     Background="{DynamicResource DividerBrush}" BorderThickness="0"/>
                        <DockPanel Grid.Row="2" Margin="0,8,0,4">
                            <TextBlock Text="{DynamicResource DashEfficiencyProgramTime}" FontSize="{DynamicResource FS10}"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                            <TextBlock Text="{Binding DataContext.ProgramTimeText, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="{DynamicResource FS10}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <ProgressBar Grid.Row="3" Minimum="0" Maximum="{Binding DataContext.EfficiencyChartMaxMinutes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     Value="{Binding DataContext.ProgramMinutes, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{DynamicResource InfoBrush}"
                                     Background="{DynamicResource DividerBrush}" BorderThickness="0"/>
                    </Grid>
                </Grid>
            </Grid>
        </DataTemplate>

        <!-- ===== WIDGET: Salary Overview ===== -->
        <DataTemplate x:Key="SalaryWidget">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Style="{StaticResource DragHandle}" Tag="grip"
                               MouseLeftButtonDown="Grip_MouseLeftButtonDown"/>
                    <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource DashWidgetSalary}" FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding DataContext.SalaryTotalText, RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="{DynamicResource FS11}"
                           Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,12"
                           Visibility="{Binding DataContext.SalaryMonths.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource IntToVis}}"/>

                <Border Grid.Row="2"
                        Style="{StaticResource CompactEmptyStateCard}"
                        Padding="20,18"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding DataContext.SalaryMonths.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource IntToVis}, ConverterParameter=invert}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                   Foreground="{DynamicResource TertiaryForegroundBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource DashSalaryEmpty}" FontSize="{DynamicResource FS13}"
                                   Foreground="{DynamicResource TertiaryForegroundBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Text="{DynamicResource DashSalaryEmptyMsg}" FontSize="{DynamicResource FS11}"
                                   Foreground="{DynamicResource TertiaryForegroundBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2" Style="{StaticResource ThinScroll}"
                              Visibility="{Binding DataContext.SalaryMonths.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource IntToVis}}">
                    <ItemsControl ItemsSource="{Binding DataContext.SalaryMonths, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource DashboardWidgetCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10"
                                                Margin="0,0,12,0" VerticalAlignment="Center"
                                                Background="{Binding StatusColor, Converter={StaticResource HexToBrush}, ConverterParameter=0.12}">
                                            <TextBlock Text="{Binding StatusIcon}" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                       Foreground="{Binding StatusColor, Converter={StaticResource HexToBrush}}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding MonthLabel}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding GrossText}" FontSize="{DynamicResource FS12}"
                                                           FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="{Binding CountText}" FontSize="{DynamicResource FS10}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                       Margin="0,0,0,4"/>
                                            <Grid Height="6" Margin="0,0,0,4">
                                                <Border CornerRadius="3" Background="{DynamicResource WindowBackgroundBrush}"
                                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0.5"/>
                                                <Border CornerRadius="3" HorizontalAlignment="Left"
                                                        Background="{Binding StatusColor, Converter={StaticResource HexToBrush}}">
                                                    <Border.Width>
                                                        <MultiBinding Converter="{x:Static conv:RatioToWidthConverter.Instance}">
                                                            <Binding Path="PaidRatio"/>
                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Grid>
                                            <Grid Margin="0,0,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding PaidText}" FontSize="{DynamicResource FS11}"
                                                           Foreground="{Binding StatusColor, Converter={StaticResource HexToBrush}}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding NetText}" FontSize="{DynamicResource FS10}"
                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                            </Grid>
                                            <TextBlock Text="{Binding ExpenseText}" FontSize="{DynamicResource FS10}"
                                                       Foreground="{DynamicResource WarningBrush}" Margin="0,0,0,1"
                                                       Visibility="{Binding HasExpenses, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{Binding GrandTotalText}" FontSize="{DynamicResource FS11}"
                                                       FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </DataTemplate>

        <!-- Widget slot style with drop highlight -->
        <Style x:Key="WidgetSlot" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="AllowDrop" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.2" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PageBackgroundBrush}" Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding GoBackCommand}" Style="{StaticResource HeaderBackButton}" Margin="0,0,10,0">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                </Button>
                <Border Style="{StaticResource PageHeaderIconBadge}"
                        Background="{DynamicResource BrandPrimaryGradientBrush}">
                    <TextBlock Text="&#xE9D2;" Style="{StaticResource PageHeaderIconText}"/>
                </Border>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource DashboardTitle}" Style="{StaticResource PageHeaderTitleText}"/>
                    <TextBlock FontSize="{DynamicResource FS12}"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               Margin="0,3,0,0">
                        <Run Text="{Binding TotalEmployees}"/>
                        <Run Text=" "/>
                        <Run Text="{DynamicResource DashWidgetEmployees}"/>
                        <Run Text=" · "/>
                        <Run Text="{Binding TotalProblems}"/>
                        <Run Text=" "/>
                        <Run Text="{DynamicResource DashWidgetProblems}"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding AIReportCommand}"
                        Style="{StaticResource DashboardPrimaryGhostButton}"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                   Foreground="{DynamicResource PurpleBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource AIReportBtn}" FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource PurpleBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding RefreshCommand}"
                        Style="{StaticResource HeaderGhostButton}"
                        Width="36"
                        Height="36"
                        ToolTip="{DynamicResource DashLoading}">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Stats Cards Row -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,18">
            <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenMonthlyMovementDetailsCommand}"/>
                </Border.InputBindings>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource MainStatMonthlyMovement}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBlock Text="{Binding MonthlyMovementSummaryText}" FontSize="{DynamicResource FS26}" FontWeight="Bold"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{DynamicResource MainStatAddedShort}" FontSize="{DynamicResource FS11}"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                            <TextBlock Text="{Binding MonthlyEmployeesAddedCount}" FontSize="{DynamicResource FS11}"
                                       FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" Margin="5,0,10,0"/>
                            <TextBlock Text="{DynamicResource MainStatArchivedShort}" FontSize="{DynamicResource FS11}"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                            <TextBlock Text="{Binding MonthlyEmployeesArchivedCount}" FontSize="{DynamicResource FS11}"
                                       FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}" Margin="5,0,0,0"/>
                        </StackPanel>
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="6"/>
                            </Grid.RowDefinitions>
                            <ProgressBar Grid.Row="0"
                                         Minimum="0"
                                         Maximum="{Binding MonthlyMovementMax}"
                                         Value="{Binding MonthlyEmployeesAddedCount}"
                                         Foreground="{DynamicResource SuccessBrush}"
                                         Background="{DynamicResource DividerBrush}"
                                         BorderThickness="0"/>
                            <ProgressBar Grid.Row="2"
                                         Minimum="0"
                                         Maximum="{Binding MonthlyMovementMax}"
                                         Value="{Binding MonthlyEmployeesArchivedCount}"
                                         Foreground="{DynamicResource ErrorBrush}"
                                         Background="{DynamicResource DividerBrush}"
                                         BorderThickness="0"/>
                        </Grid>
                    </StackPanel>
                    <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" VerticalAlignment="Center"
                            Background="{DynamicResource BrandWarmGradientBrush}">
                        <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenProblemsCommand}"/>
                </Border.InputBindings>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource DashWidgetDocuments}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBlock Text="{Binding TotalProblems}" FontSize="{DynamicResource FS26}" FontWeight="Bold"
                                   Foreground="{DynamicResource ErrorBrush}" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding ProblemTrend}" FontSize="{DynamicResource FS11}"
                                   Foreground="{DynamicResource WarningBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" VerticalAlignment="Center"
                            Background="{DynamicResource BrandDangerGradientBrush}">
                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource StatCard}" Margin="0,0,10,0">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenAllEmployeesCommand}"/>
                </Border.InputBindings>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource DashWidgetActiveEmployees}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBlock Text="{Binding TotalEmployees}" FontSize="{DynamicResource FS26}" FontWeight="Bold"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,4,0,0"/>
                        <TextBlock Text="{DynamicResource DashAllCompanies}" FontSize="{DynamicResource FS11}"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" VerticalAlignment="Center"
                            Background="{DynamicResource BrandSuccessGradientBrush}">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource StatCard}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenCompanyDetailsCommand}"/>
                </Border.InputBindings>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource SearchCatCompanies}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBlock Text="{Binding TotalCompanies}" FontSize="{DynamicResource FS26}" FontWeight="Bold"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,4,0,0"/>
                        <TextBlock Text="{DynamicResource DashVisibleCompanies}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" VerticalAlignment="Center"
                            Background="{DynamicResource BrandAiGradientBrush}">
                        <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- Bottom: two columns with GridSplitter -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftCol" Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="RightCol" Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SLOT 0: Left column (full height) -->
            <Border x:Name="Slot0Border" Grid.Column="0" Style="{StaticResource WidgetSlot}" Margin="0,0,5,0"
                    Tag="0" DragEnter="Slot_DragEnter" DragLeave="Slot_DragLeave" Drop="Slot_Drop">
                <ContentControl x:Name="Slot0Content" IsTabStop="False">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Slot0}" Value="expiring">
                                    <Setter Property="ContentTemplate" Value="{StaticResource ExpiringWidget}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Slot0}" Value="companies">
                                    <Setter Property="ContentTemplate" Value="{StaticResource CompaniesWidget}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Slot0}" Value="salary">
                                    <Setter Property="ContentTemplate" Value="{StaticResource SalaryWidget}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Border>

            <!-- Vertical GridSplitter between columns -->
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"
                          DragCompleted="ColumnSplitter_DragCompleted"/>

            <!-- Right column with 2 slots -->
            <Grid Grid.Column="2" Margin="5,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="RightTopRow" Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition x:Name="RightBottomRow" Height="1.5*"/>
                </Grid.RowDefinitions>

                <!-- SLOT 1: Right top -->
                <Border x:Name="Slot1Border" Grid.Row="0" Style="{StaticResource WidgetSlot}" Margin="0,0,0,5"
                        Tag="1" DragEnter="Slot_DragEnter" DragLeave="Slot_DragLeave" Drop="Slot_Drop">
                    <ContentControl x:Name="Slot1Content" IsTabStop="False">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Slot1}" Value="expiring">
                                        <Setter Property="ContentTemplate" Value="{StaticResource ExpiringWidget}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Slot1}" Value="companies">
                                        <Setter Property="ContentTemplate" Value="{StaticResource CompaniesWidget}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Slot1}" Value="salary">
                                        <Setter Property="ContentTemplate" Value="{StaticResource SalaryWidget}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Border>

                <!-- Horizontal GridSplitter between right rows -->
                <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                              Background="Transparent" Cursor="SizeNS"
                              DragCompleted="RowSplitter_DragCompleted"/>

                <!-- SLOT 2: Right bottom -->
                <Border x:Name="Slot2Border" Grid.Row="2" Style="{StaticResource WidgetSlot}" Margin="0,5,0,0"
                        Tag="2" DragEnter="Slot_DragEnter" DragLeave="Slot_DragLeave" Drop="Slot_Drop">
                    <ContentControl x:Name="Slot2Content" IsTabStop="False">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Slot2}" Value="expiring">
                                        <Setter Property="ContentTemplate" Value="{StaticResource ExpiringWidget}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Slot2}" Value="companies">
                                        <Setter Property="ContentTemplate" Value="{StaticResource CompaniesWidget}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Slot2}" Value="salary">
                                        <Setter Property="ContentTemplate" Value="{StaticResource SalaryWidget}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Border>
            </Grid>
        </Grid>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}" CornerRadius="12"/>
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="22,18"
                    CornerRadius="14"
                    Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <ProgressBar IsIndeterminate="True" Width="84" Height="6" Margin="0,0,12,0"
                                 Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource DividerBrush}"
                                 VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource DashLoading}" FontSize="{DynamicResource FS13}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Employee Details Overlay -->
        <Grid Grid.RowSpan="3" Visibility="{Binding IsEmployeeDetailsOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}" Margin="-24,-16">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding EmployeeDetailsVm.CloseCommand}"/>
                </Border.InputBindings>
            </Border>
            <ContentControl Content="{Binding EmployeeDetailsVm}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:EmployeeDetailsViewModel}">
                        <views:EmployeeDetailsView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>

        <!-- Monthly Movement Details Overlay -->
        <Grid Grid.RowSpan="3" Visibility="{Binding IsMonthlyMovementDetailsOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}" Margin="-24,-16">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseMonthlyMovementDetailsCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="16"
                    Width="720" MaxWidth="820" MaxHeight="560" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="42" Height="42" CornerRadius="12"
                                    Background="{DynamicResource BrandWarmGradientBrush}" Margin="0,0,12,0">
                                <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="19"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource MainStatMonthlyMovement}" FontSize="{DynamicResource FS20}"
                                           FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{Binding MonthlyMovementSummaryText}" FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding CloseMonthlyMovementDetailsCommand}"
                                Style="{StaticResource HeaderGhostButton}" Width="34" Height="34">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}"/>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource DashboardWidgetCard}" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="{DynamicResource DashMovementAddedTitle}" FontSize="{DynamicResource FS15}"
                                               FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                    <Border DockPanel.Dock="Right" CornerRadius="8" Padding="8,3"
                                            Background="{DynamicResource SuccessLightBrush}">
                                        <TextBlock Text="{Binding MonthlyEmployeesAddedCount}" FontSize="{DynamicResource FS11}"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}"/>
                                    </Border>
                                </DockPanel>
                                <TextBlock Grid.Row="1" Text="{DynamicResource DashMovementAddedEmpty}"
                                           FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           VerticalAlignment="Center" TextAlignment="Center"
                                           Visibility="{Binding MonthlyAddedEmployees.Count, Converter={StaticResource IntToVis}, ConverterParameter=invert}"/>
                                <ScrollViewer Grid.Row="1" Style="{StaticResource ThinScroll}"
                                              Visibility="{Binding MonthlyAddedEmployees.Count, Converter={StaticResource IntToVis}}">
                                    <ItemsControl ItemsSource="{Binding MonthlyAddedEmployees}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource DashboardWidgetCard}" Margin="0,0,0,8" Cursor="Hand">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.OpenMovementEmployeeDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="9"
                                                                Background="{Binding StatusColor, Converter={StaticResource HexToBrush}, ConverterParameter=0.12}"
                                                                Margin="0,0,10,0">
                                                            <TextBlock Text="+" FontSize="{DynamicResource FS18}" FontWeight="Bold"
                                                                       Foreground="{Binding StatusColor, Converter={StaticResource HexToBrush}}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding FullName}" FontSize="{DynamicResource FS13}"
                                                                       FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                                            <TextBlock FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,2,0,0">
                                                                <Run Text="{Binding FirmName}"/>
                                                                <Run Text=" · "/>
                                                                <Run Text="{Binding DateText}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource DashboardWidgetCard}" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="{DynamicResource DashMovementArchivedTitle}" FontSize="{DynamicResource FS15}"
                                               FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                    <Border DockPanel.Dock="Right" CornerRadius="8" Padding="8,3"
                                            Background="{DynamicResource ErrorLightBrush}">
                                        <TextBlock Text="{Binding MonthlyEmployeesArchivedCount}" FontSize="{DynamicResource FS11}"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}"/>
                                    </Border>
                                </DockPanel>
                                <TextBlock Grid.Row="1" Text="{DynamicResource DashMovementArchivedEmpty}"
                                           FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           VerticalAlignment="Center" TextAlignment="Center"
                                           Visibility="{Binding MonthlyArchivedEmployees.Count, Converter={StaticResource IntToVis}, ConverterParameter=invert}"/>
                                <ScrollViewer Grid.Row="1" Style="{StaticResource ThinScroll}"
                                              Visibility="{Binding MonthlyArchivedEmployees.Count, Converter={StaticResource IntToVis}}">
                                    <ItemsControl ItemsSource="{Binding MonthlyArchivedEmployees}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource DashboardWidgetCard}" Margin="0,0,0,8" Cursor="Hand">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.OpenMovementEmployeeDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="9"
                                                                Background="{Binding StatusColor, Converter={StaticResource HexToBrush}, ConverterParameter=0.12}"
                                                                Margin="0,0,10,0">
                                                            <TextBlock Text="-" FontSize="{DynamicResource FS18}" FontWeight="Bold"
                                                                       Foreground="{Binding StatusColor, Converter={StaticResource HexToBrush}}"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding FullName}" FontSize="{DynamicResource FS13}"
                                                                       FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                                            <TextBlock FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,2,0,0">
                                                                <Run Text="{Binding FirmName}"/>
                                                                <Run Text=" · "/>
                                                                <Run Text="{Binding DateText}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="{DynamicResource DashMovementOpenEmployeeHint}"
                               FontSize="{DynamicResource FS11}" Foreground="{DynamicResource TertiaryForegroundBrush}"
                               HorizontalAlignment="Center" Margin="0,14,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Company Details Overlay -->
        <Grid Grid.RowSpan="3" Visibility="{Binding IsCompanyDetailsOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}" Margin="-24,-16">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseCompanyDetailsCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="16"
                    Width="660" MaxWidth="780" MaxHeight="560" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="42" Height="42" CornerRadius="12"
                                    Background="{DynamicResource BrandAiGradientBrush}" Margin="0,0,12,0">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="19"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource SearchCatCompanies}" FontSize="{DynamicResource FS20}"
                                           FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,2,0,0">
                                    <Run Text="{Binding TotalCompanies}"/>
                                    <Run Text="{DynamicResource DashActiveCompaniesInline}"/>
                                    <Run Text="{Binding TotalEmployees}"/>
                                    <Run Text="{DynamicResource DashEmployeesInline}"/>
                                    <Run Text="{Binding TotalProblems}"/>
                                    <Run Text="{DynamicResource DashProblemsInline}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding CloseCompanyDetailsCommand}"
                                Style="{StaticResource HeaderGhostButton}" Width="34" Height="34">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}"/>
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource DashboardWidgetCard}" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource DashCompanyColumn}" FontSize="{DynamicResource FS11}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                <TextBlock Grid.Column="1" Text="{DynamicResource DashEmployeesColumn}" FontSize="{DynamicResource FS11}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="2" Text="{DynamicResource DashProblemsColumn}" FontSize="{DynamicResource FS11}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Right"/>
                                <TextBlock Grid.Column="3" Text="{DynamicResource DashTemplatesColumn}" FontSize="{DynamicResource FS11}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Right"/>
                            </Grid>

                            <TextBlock Grid.Row="1" Text="{DynamicResource DashCompaniesEmpty}"
                                       FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                       VerticalAlignment="Center" TextAlignment="Center"
                                       Visibility="{Binding CompanyStats.Count, Converter={StaticResource IntToVis}, ConverterParameter=invert}"/>
                            <ScrollViewer Grid.Row="1" Style="{StaticResource ThinScroll}"
                                          Visibility="{Binding CompanyStats.Count, Converter={StaticResource IntToVis}}">
                                <ItemsControl ItemsSource="{Binding CompanyStats}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource DashboardWidgetCard}" Margin="0,0,0,8" Cursor="Hand">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.OpenCompanyEmployeesCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="95"/>
                                                        <ColumnDefinition Width="95"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding CompanyName}" FontSize="{DynamicResource FS13}"
                                                                   FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding EmployeeRatio, Mode=OneWay}"
                                                                     Height="4" Margin="0,6,18,0"
                                                                     Foreground="{DynamicResource AccentBrush}"
                                                                     Background="{DynamicResource DividerBrush}" BorderThickness="0"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding EmployeeCount}" FontSize="{DynamicResource FS15}"
                                                               FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="2" CornerRadius="8" Padding="8,4" HorizontalAlignment="Right"
                                                            VerticalAlignment="Center" Background="{DynamicResource ErrorLightBrush}">
                                                        <TextBlock Text="{Binding ProblemCount}" FontSize="{DynamicResource FS12}"
                                                                   FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="3" Text="{Binding TemplateCount}" FontSize="{DynamicResource FS13}"
                                                               FontWeight="SemiBold" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="2" Text="{DynamicResource DashCompanyOpenEmployeesHint}"
                               FontSize="{DynamicResource FS11}" Foreground="{DynamicResource TertiaryForegroundBrush}"
                               HorizontalAlignment="Center" Margin="0,14,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- AI Report Overlay -->
        <Grid Visibility="{Binding IsAIReportOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAIReportCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="16"
                    MaxWidth="600" MaxHeight="520" Padding="28"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="{DynamicResource PurpleBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="{DynamicResource AIReportTitle}" FontSize="{DynamicResource FS20}"
                                   FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="380"
                                  Style="{StaticResource ThinScroll}">
                        <TextBox Text="{Binding AIReportText, Mode=OneWay}" 
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 BorderThickness="0" Background="Transparent" Padding="0"
                                 FontSize="{DynamicResource FS13}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 VerticalScrollBarVisibility="Disabled"/>
                    </ScrollViewer>

                    <Button Grid.Row="2" Command="{Binding CloseAIReportCommand}"
                            Padding="24,8" Margin="0,14,0,0" HorizontalAlignment="Center"
                            Background="{DynamicResource AccentBrush}" Foreground="White"
                            BorderThickness="0" Cursor="Hand" FontWeight="SemiBold">
                        <TextBlock Text="{DynamicResource DetBtnClose}" FontSize="{DynamicResource FS13}"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
