<UserControl x:Class="Win11DesktopApp.Views.RecentlyDeletedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             xmlns:views="clr-namespace:Win11DesktopApp.Views"
             xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

        <Style x:Key="RecentMetaLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FS11}"/>
            <Setter Property="Foreground" Value="{DynamicResource TertiaryForegroundBrush}"/>
        </Style>

        <Style x:Key="RecentMetaValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FS12}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding GoBackCommand}" Style="{StaticResource HeaderBackButton}" Margin="0,0,10,0">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                    </Button>
                    <Border Style="{StaticResource PageHeaderIconBadge}" Background="#EF5350">
                        <TextBlock Text="&#xE74D;" Style="{StaticResource PageHeaderIconText}"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource RecentlyDeletedTitle}" FontSize="{DynamicResource FS24}" Style="{StaticResource PageHeaderTitleText}"/>
                        <TextBlock FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Margin="0,3,0,0">
                            <Run Text="{Binding TotalCount}"/>
                            <Run Text=" "/>
                            <Run Text="{DynamicResource RecentlyDeletedItemsLabel}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Style="{StaticResource ToolbarSearchContainer}"
                        CornerRadius="12"
                        Padding="8,6"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;"
                                   Grid.Column="0"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="{DynamicResource FS13}"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 Height="32"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Border>
            </Grid>

            <WrapPanel Grid.Row="1" Margin="0,0,0,12">
                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="12,8" Margin="0,0,8,6" MinWidth="170">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource RecentlyDeletedStatTotal}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBlock Text="{Binding TotalCount}" FontSize="{DynamicResource FS20}" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="12,8" Margin="0,0,8,6" MinWidth="170">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource RecentlyDeletedStatExpiringSoon}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBlock Text="{Binding ExpiringSoonCount}" FontSize="{DynamicResource FS20}" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="12,8" Margin="0,0,8,6" MinWidth="170">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource ArchiveResultsLabel}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBlock Text="{Binding FilteredCount}" FontSize="{DynamicResource FS20}" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Grid Grid.Row="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding HasItems, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16"
                                        Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="84"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="68"
                                                Height="68"
                                                CornerRadius="12"
                                                Background="{DynamicResource WindowBackgroundBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Image Source="{Binding PhotoPath, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill" Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Text="&#xE77B;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="{DynamicResource FS24}"
                                                           Foreground="{DynamicResource TertiaryForegroundBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding HasPhoto, Converter={StaticResource InverseBoolToVis}}"/>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                            <TextBlock Text="{Binding FullName}"
                                                       FontSize="{DynamicResource FS16}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                            <TextBlock Text="{Binding PositionTitle}"
                                                       FontSize="{DynamicResource FS12}"
                                                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                       Margin="0,2,0,6"/>

                                            <WrapPanel>
                                                <StackPanel Margin="0,0,18,4">
                                                    <TextBlock Text="{DynamicResource RecentlyDeletedMetaFirm}" Style="{StaticResource RecentMetaLabel}"/>
                                                    <TextBlock Text="{Binding FirmName}" Style="{StaticResource RecentMetaValue}"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,18,4">
                                                    <TextBlock Text="{DynamicResource RecentlyDeletedMetaDeletedAt}" Style="{StaticResource RecentMetaLabel}"/>
                                                    <TextBlock Text="{Binding DeletedAtLocal, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Style="{StaticResource RecentMetaValue}"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,18,4">
                                                    <TextBlock Text="{DynamicResource RecentlyDeletedMetaRestoreUntil}" Style="{StaticResource RecentMetaLabel}"/>
                                                    <TextBlock Text="{Binding PurgeAfterLocal, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Style="{StaticResource RecentMetaValue}"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,18,4">
                                                    <TextBlock Text="{DynamicResource RecentlyDeletedMetaDaysLeft}" Style="{StaticResource RecentMetaLabel}"/>
                                                    <TextBlock Text="{Binding DaysRemaining}" Style="{StaticResource RecentMetaValue}"/>
                                                </StackPanel>
                                            </WrapPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <Button Command="{Binding DataContext.ViewProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource HeaderGhostButton}"
                                                    Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{DynamicResource ArchiveViewProfile}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource FilledActionButton}"
                                                    Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{DynamicResource ArchiveRestore}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding DataContext.ArchiveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource HeaderGhostButton}"
                                                    Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{DynamicResource DetBtnArchive}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteForeverCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource HeaderGhostButton}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{DynamicResource RecentlyDeletedDeleteForever}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Visibility="{Binding HasItems, Converter={StaticResource InverseBoolToVis}}"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="420">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS32}"
                                   HorizontalAlignment="Center" Foreground="{DynamicResource TertiaryForegroundBrush}" Margin="0,0,0,10"/>
                        <TextBlock Text="{DynamicResource RecentlyDeletedEmpty}"
                                   FontSize="{DynamicResource FS18}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                        <TextBlock Text="{DynamicResource RecentlyDeletedEmptyDesc}"
                                   Margin="0,8,0,0"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Visibility="{Binding IsArchiveDialogOpen, Converter={StaticResource BoolToVis}}">
                <Border Background="#66000000"/>
                <Border Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="22"
                        Width="460"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource DetArchiveTitle}"
                                   FontSize="{DynamicResource FS18}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                        <TextBlock Text="{Binding EmployeeToArchive.FullName}"
                                   FontSize="{DynamicResource FS13}"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   Margin="0,6,0,14"/>

                        <TextBlock Text="{DynamicResource DetArchiveDateLabel}"
                                   FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        <TextBox Text="{Binding ArchiveDate, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,8,0,12"
                                 Padding="10,8"/>

                        <TextBlock Text="{Binding ArchiveStatus}"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   FontSize="{DynamicResource FS12}"
                                   Margin="0,0,0,10"
                                   TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding CancelArchiveCommand}"
                                    Style="{StaticResource HeaderGhostButton}"
                                    Margin="0,0,8,0">
                                <TextBlock Text="{DynamicResource BtnCancel}" FontSize="{DynamicResource FS13}"/>
                            </Button>
                            <Button Command="{Binding ConfirmArchiveCommand}"
                                    Style="{StaticResource FilledActionButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0"/>
                                    <TextBlock Text="{DynamicResource DetBtnArchive}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Visibility="{Binding IsEmployeeDetailsOpen, Converter={StaticResource BoolToVis}}">
                <Border Background="#66000000">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding EmployeeDetailsVm.CloseCommand}"/>
                    </Border.InputBindings>
                </Border>
                <ContentControl Content="{Binding EmployeeDetailsVm}" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:EmployeeDetailsViewModel}">
                            <views:EmployeeDetailsView/>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
