<UserControl x:Class="Win11DesktopApp.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <!-- Active/inactive button style for language & theme selectors -->
        <Style x:Key="SelectorButton" TargetType="Button">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active version (accent bg) -->
        <Style x:Key="SelectorButtonActive" TargetType="Button" BasedOn="{StaticResource SelectorButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid MaxWidth="700" HorizontalAlignment="Left" Margin="48,32,48,48">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Back Button -->
            <Button Grid.Row="0" Command="{Binding GoBackCommand}" 
                    HorizontalAlignment="Left" Margin="0,0,0,16"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="8,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource BtnBack}" FontSize="14" Margin="8,0,0,0"
                                           Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Title -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,32">
                <Border Background="{DynamicResource AccentBrush}" CornerRadius="10" Width="44" Height="44"
                        VerticalAlignment="Center">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{DynamicResource SettingsTitle}" 
                           FontSize="28" FontWeight="SemiBold" 
                           Foreground="{DynamicResource ForegroundBrush}"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>

            <!-- Language Card -->
            <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="24,20" Margin="0,0,0,16"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="#E3F2FD" CornerRadius="8" Width="36" Height="36"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource LangLabel}" 
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource SettingsLangHint}" 
                                       FontSize="12" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <WrapPanel Orientation="Horizontal">
                        <Button Content="🇺🇦 Українська" 
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="uk">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentLanguage}" Value="uk">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="🇨🇿 Čeština" 
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="cs">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentLanguage}" Value="cs">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="🇷🇺 Русский" 
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="ru">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentLanguage}" Value="ru">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="🇬🇧 English" 
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="en">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentLanguage}" Value="en">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Theme Card -->
            <Border Grid.Row="3" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="24,20" Margin="0,0,0,16"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="#FFF3E0" CornerRadius="8" Width="36" Height="36"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#E65100" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource ThemeLabel}" 
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource SettingsThemeHint}" 
                                       FontSize="12" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <WrapPanel Orientation="Horizontal">
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="Light">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="14" Height="14" Fill="#F3F3F3" Stroke="#CCC" StrokeThickness="1" Margin="0,0,6,0"/>
                                    <TextBlock Text="{DynamicResource ThemeLight}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button.Content>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentTheme}" Value="Light">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="DarkWord">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="14" Height="14" Fill="#2B2B2B" Stroke="#555" StrokeThickness="1" Margin="0,0,6,0"/>
                                    <TextBlock Text="{DynamicResource ThemeDarkWord}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button.Content>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentTheme}" Value="DarkWord">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="Dark2">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="14" Height="14" Fill="#121212" Stroke="#333" StrokeThickness="1" Margin="0,0,6,0"/>
                                    <TextBlock Text="{DynamicResource ThemeDark2}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button.Content>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentTheme}" Value="Dark2">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="Custom">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="14" Height="14" Fill="#B2EBF2" Stroke="#0097A7" StrokeThickness="1" Margin="0,0,6,0"/>
                                    <TextBlock Text="{DynamicResource ThemeCustom}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button.Content>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentTheme}" Value="Custom">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Root Folder Card -->
            <Border Grid.Row="4" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="24,20" Margin="0,0,0,16"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="#E8F5E9" CornerRadius="8" Width="36" Height="36"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="#2E7D32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource LabelRootFolder}" 
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource SettingsFolderHint}" 
                                       FontSize="12" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource WindowBackgroundBrush}" 
                                CornerRadius="8" Padding="12,10" Margin="0,0,10,0"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <TextBlock Text="{Binding RootFolderPath}" 
                                       FontSize="13" VerticalAlignment="Center"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <Button Grid.Column="1" Command="{Binding SelectRootFolderCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="8" Padding="16,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{DynamicResource BtnSelectFolder}" 
                                                       FontSize="13" FontWeight="Medium"
                                                       Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- App Version Card -->
            <Border Grid.Row="5" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="24,20" Margin="0,0,0,16"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#F3E5F5" CornerRadius="8" Width="36" Height="36"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="#7B1FA2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource SettingsAppVersion}" 
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Border Background="{DynamicResource AccentBrush}" CornerRadius="10" Padding="10,3">
                                <TextBlock Text="{Binding AppVersion}" 
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                            <TextBlock Text="Agency Contractor" 
                                       FontSize="12" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.4"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
