        <GradientStop Color="#A78BFA" Offset="0"/>
        <GradientStop Color="#8B6B9E" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandPrimaryHorizontalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#A78BFA" Offset="0"/>
        <GradientStop Color="#8B6B9E" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandSuccessGradientBrush" StartPoint="0,0" EndPoint="1,1">
