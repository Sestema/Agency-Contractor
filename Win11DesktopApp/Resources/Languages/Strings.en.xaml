    <sys:String x:Key="InvoicesWelcomeTitle">Welcome to Faktury</sys:String>
    <sys:String x:Key="InvoicesWelcomeSubtitle">A standalone document module with internal sections similar to the website.</sys:String>
    <sys:String x:Key="InvoicesDashboardHomeHint">From the home screen you can quickly create a document or jump to the part of the module you need.</sys:String>
    <sys:String x:Key="InvoicesQuickNewInvoice">New invoice</sys:String>
    <sys:String x:Key="InvoicesQuickNewDeliveryNote">New delivery note</sys:String>
