<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#191C20"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#1E2228"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#E8EAED"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#8C939E"/>
    <SolidColorBrush x:Key="TertiaryForegroundBrush" Color="#636B76"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#252A31"/>
    <SolidColorBrush x:Key="CardHoverBrush" Color="#2D333B"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#373E47"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#252A31"/>
    <SolidColorBrush x:Key="DividerBrush" Color="#373E47"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="#88000000"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#3B8EEA"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#5BA3ED"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#1F3044"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#3FB950"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="#1C2E20"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#D29922"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="#302916"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#F85149"/>
    <SolidColorBrush x:Key="ErrorLightBrush" Color="#3D1518"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#39D2C0"/>
    <SolidColorBrush x:Key="InfoLightBrush" Color="#162E2C"/>
    <SolidColorBrush x:Key="PurpleBrush" Color="#BC8CFF"/>
    <SolidColorBrush x:Key="PurpleLightBrush" Color="#281E3C"/>

    <DropShadowEffect x:Key="CardShadow" BlurRadius="16" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.3"/>
</ResourceDictionary>
