<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Black glass: near-black translucent surfaces with muted steel accents. -->
    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D0040609" Offset="0"/>
        <GradientStop Color="#BC070A10" Offset="0.52"/>
        <GradientStop Color="#A80B0E15" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="ContentBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#A80B0F17" Offset="0"/>
        <GradientStop Color="#8F060910" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#F2F4F7"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#AEB6C2"/>
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="#7B8491"/>
    <SolidColorBrush x:Key="TertiaryForegroundBrush" Color="#59616D"/>
    <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D0040609" Offset="0"/>
        <GradientStop Color="#B6070A10" Offset="0.55"/>
        <GradientStop Color="#990C1018" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="CardBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#A9121823" Offset="0"/>
        <GradientStop Color="#830A0E15" Offset="0.58"/>
        <GradientStop Color="#6E06090F" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="CardHoverBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#BC18202B" Offset="0"/>
        <GradientStop Color="#96101822" Offset="0.58"/>
        <GradientStop Color="#800B0F18" Offset="1"/>
    </LinearGradientBrush>
    <!-- Smoke-glass rim: visible enough for depth without neon glow. -->
    <LinearGradientBrush x:Key="CardBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#4FFFFFFF" Offset="0"/>
        <GradientStop Color="#268A96A8" Offset="0.48"/>
        <GradientStop Color="#12000000" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="GlassInnerHighlightBrush" Color="#30FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#78070B12"/>
    <SolidColorBrush x:Key="DividerBrush" Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="#CC000000"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#2F6F9F"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#86AFCB"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#24151E29"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#59C77A"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="#181F2A1E"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#C9A653"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="#1F241C11"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#C96874"/>
    <SolidColorBrush x:Key="ErrorLightBrush" Color="#241F1218"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#78A9C8"/>
    <SolidColorBrush x:Key="InfoLightBrush" Color="#20101A24"/>
    <SolidColorBrush x:Key="PurpleBrush" Color="#8D86A8"/>
    <SolidColorBrush x:Key="PurpleLightBrush" Color="#201B1A26"/>
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#4A525E"/>
    <SolidColorBrush x:Key="StatusMessageBrush" Color="#909AA8"/>
    <SolidColorBrush x:Key="DangerOutlineBrush" Color="#C96874"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#D9828D"/>
    <SolidColorBrush x:Key="ErrorChipBackgroundBrush" Color="#2A141922"/>
    <SolidColorBrush x:Key="ErrorChipBorderBrush" Color="#56414A55"/>
    <SolidColorBrush x:Key="ErrorChipForegroundBrush" Color="#E08F9A"/>
    <SolidColorBrush x:Key="WarningChipBackgroundBrush" Color="#291F1710"/>
    <SolidColorBrush x:Key="WarningChipBorderBrush" Color="#52453528"/>
    <SolidColorBrush x:Key="WarningChipForegroundBrush" Color="#D8BD74"/>
    <SolidColorBrush x:Key="InfoChipBackgroundBrush" Color="#26111B25"/>
    <SolidColorBrush x:Key="InfoChipBorderBrush" Color="#4D405064"/>
    <SolidColorBrush x:Key="InfoChipForegroundBrush" Color="#9FC7DD"/>
    <SolidColorBrush x:Key="SuccessChipBackgroundBrush" Color="#2417201B"/>
    <SolidColorBrush x:Key="SuccessChipBorderBrush" Color="#4A385444"/>
    <SolidColorBrush x:Key="SuccessChipForegroundBrush" Color="#8CD99E"/>
    <SolidColorBrush x:Key="MutedDescriptionBrush" Color="#8A94A2"/>

    <LinearGradientBrush x:Key="BrandPrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#344B5F" Offset="0"/>
        <GradientStop Color="#151B24" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandPrimaryHorizontalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#344B5F" Offset="0"/>
        <GradientStop Color="#151B24" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandSuccessGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#355645" Offset="0"/>
        <GradientStop Color="#17231C" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandSuccessHorizontalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#355645" Offset="0"/>
        <GradientStop Color="#17231C" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandWarmGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#5A4930" Offset="0"/>
        <GradientStop Color="#241A16" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandDangerGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#593640" Offset="0"/>
        <GradientStop Color="#251519" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandInfoGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#455B70" Offset="0"/>
        <GradientStop Color="#1A232D" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandInfoHorizontalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#455B70" Offset="0"/>
        <GradientStop Color="#1A232D" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandAiGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#3D4658" Offset="0"/>
        <GradientStop Color="#151820" Offset="1"/>
    </LinearGradientBrush>

    <DropShadowEffect x:Key="CardShadow" BlurRadius="32" ShadowDepth="6" Direction="270" Color="#000000" Opacity="0.48"/>
    <DropShadowEffect x:Key="CardShadowHover" BlurRadius="44" ShadowDepth="10" Direction="270" Color="#000000" Opacity="0.62"/>
    <DropShadowEffect x:Key="DialogShadow" BlurRadius="72" ShadowDepth="20" Direction="270" Color="#000000" Opacity="0.82"/>
</ResourceDictionary>
