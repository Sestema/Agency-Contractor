<UserControl x:Class="Win11DesktopApp.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <conv:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,4,14,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{Binding GoBackCommand}"
                        Style="{StaticResource HeaderBackButton}"
                        Width="40" Height="40"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="0,0,12,0">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                </Button>

                <Border Grid.Column="1"
                        MaxWidth="660"
                        HorizontalAlignment="Center"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource PageHeaderIconBadge}"
                                Margin="0"
                                Width="30"
                                Height="30"
                                CornerRadius="9">
                            <TextBlock Text="&#xE713;"
                                       Style="{StaticResource PageHeaderIconText}"
                                       FontSize="{DynamicResource FS13}"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource SettingsTitle}"
                                       FontSize="{DynamicResource FS22}"
                                       Style="{StaticResource PageHeaderTitleText}"/>
                            <TextBlock FontSize="{DynamicResource FS11}"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Opacity="0.82"
                                       Margin="0,1,0,0">
                                <Run Text="Agency Contractor - "/>
                                <Run Text="{Binding AppVersion, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Width="46" Opacity="0"/>
            </Grid>
        </Border>

    <ScrollViewer Grid.Row="1" Style="{StaticResource ThinScroll}">
        <Grid MaxWidth="1100" HorizontalAlignment="Center" Margin="48,10,48,48">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Language & Localization Section -->
            <Border Grid.Row="2" Style="{StaticResource SettingsSectionCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource AccentLightBrush}">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="{DynamicResource FS17}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}">
                                <Run Text="{DynamicResource LangLabel}"/>
                                <Run Text=" + "/>
                                <Run Text="{DynamicResource SettingsDocLangTitle}"/>
                            </TextBlock>
                            <TextBlock FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.55"
                                       Margin="0,2,0,0">
                                <Run Text="{DynamicResource SettingsLangHint}"/>
                                <Run Text=" "/>
                                <Run Text="{DynamicResource SettingsDocLangHint}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <Border Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="16,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource AccentLightBrush}"
                                        Width="32" Height="32" CornerRadius="8">
                                    <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                               Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource LangLabel}" 
                                               FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{DynamicResource SettingsLangHint}" 
                                               FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <WrapPanel Orientation="Horizontal">
                                <Button Content="🇺🇦 Українська" 
                                        Command="{Binding ChangeLanguageCommand}" CommandParameter="uk">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentLanguage}" Value="uk">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇨🇿 Čeština" 
                                        Command="{Binding ChangeLanguageCommand}" CommandParameter="cs">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentLanguage}" Value="cs">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇷🇺 Русский" 
                                        Command="{Binding ChangeLanguageCommand}" CommandParameter="ru">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentLanguage}" Value="ru">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇬🇧 English" 
                                        Command="{Binding ChangeLanguageCommand}" CommandParameter="en">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentLanguage}" Value="en">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>

                            <Border Height="1" Margin="0,16,0,16" Background="{DynamicResource CardBorderBrush}" Opacity="0.7"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource InfoLightBrush}"
                                        Width="32" Height="32" CornerRadius="8">
                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                               Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource SettingsDocLangTitle}" 
                                               FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{DynamicResource SettingsDocLangHint}" 
                                               FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <WrapPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource DocLangSameAsUI}" 
                                        Command="{Binding ChangeDocLanguageCommand}" CommandParameter="">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇺🇦 Українська" 
                                        Command="{Binding ChangeDocLanguageCommand}" CommandParameter="uk">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="uk">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇨🇿 Čeština" 
                                        Command="{Binding ChangeDocLanguageCommand}" CommandParameter="cs">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="cs">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇷🇺 Русский" 
                                        Command="{Binding ChangeDocLanguageCommand}" CommandParameter="ru">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="ru">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇬🇧 English" 
                                        Command="{Binding ChangeDocLanguageCommand}" CommandParameter="en">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="en">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Theme Card -->
            <Border Grid.Row="4" Style="{StaticResource SettingsSectionCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource WarningLightBrush}">
                            <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource ThemeLabel}" 
                                       FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource SettingsThemeHint}" 
                                       FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <UniformGrid Columns="4" HorizontalAlignment="Left" MaxWidth="700">
                        <!-- Light theme preview -->
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="Light"
                                Margin="0,0,10,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="OuterBd" CornerRadius="10" BorderThickness="2.5"
                                            BorderBrush="Transparent" Padding="3"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border x:Name="InnerBd" CornerRadius="8" Width="136" Height="90"
                                                Background="#F3F3F3" ClipToBounds="True">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="28"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="22"/>
                                                </Grid.RowDefinitions>
                                                <!-- Title bar -->
                                                <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E5E5E5" BorderThickness="0,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                                                        <Ellipse Width="6" Height="6" Fill="#FF605C" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#FFBD44" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#00CA4E"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Content area -->
                                                <StackPanel Grid.Row="1" Margin="8,5,8,0">
                                                    <Border Background="#E5E5E5" CornerRadius="2" Height="4" Width="60" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <Border Background="#E5E5E5" CornerRadius="2" Height="4" Width="44" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <Border Background="#FFFFFF" CornerRadius="3" Width="36" Height="18" BorderBrush="#E5E5E5" BorderThickness="1" Margin="0,0,4,0"/>
                                                        <Border Background="#FFFFFF" CornerRadius="3" Width="36" Height="18" BorderBrush="#E5E5E5" BorderThickness="1"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <!-- Accent bar -->
                                                <Border Grid.Row="2" Background="#0078D4" CornerRadius="0,0,8,8">
                                                    <TextBlock Text="{DynamicResource ThemeLight}" FontSize="{DynamicResource FS10}" FontWeight="SemiBold"
                                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding CurrentTheme}" Value="Light">
                                            <Setter TargetName="OuterBd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- DarkWord theme preview -->
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="DarkWord"
                                Margin="0,0,10,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="OuterBd" CornerRadius="10" BorderThickness="2.5"
                                            BorderBrush="Transparent" Padding="3"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border x:Name="InnerBd" CornerRadius="8" Width="136" Height="90"
                                                Background="#191C20" ClipToBounds="True">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="28"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="22"/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0" Background="#1E2228" BorderBrush="#373E47" BorderThickness="0,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                                                        <Ellipse Width="6" Height="6" Fill="#FF605C" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#FFBD44" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#00CA4E"/>
                                                    </StackPanel>
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="8,5,8,0">
                                                    <Border Background="#373E47" CornerRadius="2" Height="4" Width="60" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <Border Background="#373E47" CornerRadius="2" Height="4" Width="44" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <Border Background="#252A31" CornerRadius="3" Width="36" Height="18" BorderBrush="#373E47" BorderThickness="1" Margin="0,0,4,0"/>
                                                        <Border Background="#252A31" CornerRadius="3" Width="36" Height="18" BorderBrush="#373E47" BorderThickness="1"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border Grid.Row="2" Background="#3B8EEA" CornerRadius="0,0,8,8">
                                                    <TextBlock Text="{DynamicResource ThemeDarkWord}" FontSize="{DynamicResource FS10}" FontWeight="SemiBold"
                                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding CurrentTheme}" Value="DarkWord">
                                            <Setter TargetName="OuterBd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Dark2 (Night) theme preview -->
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="Dark2"
                                Margin="0,0,10,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="OuterBd" CornerRadius="10" BorderThickness="2.5"
                                            BorderBrush="Transparent" Padding="3"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border x:Name="InnerBd" CornerRadius="8" Width="136" Height="90"
                                                Background="#0D1117" ClipToBounds="True">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="28"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="22"/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0" Background="#131920" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                                                        <Ellipse Width="6" Height="6" Fill="#FF605C" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#FFBD44" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#00CA4E"/>
                                                    </StackPanel>
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="8,5,8,0">
                                                    <Border Background="#30363D" CornerRadius="2" Height="4" Width="60" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <Border Background="#30363D" CornerRadius="2" Height="4" Width="44" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <Border Background="#161B22" CornerRadius="3" Width="36" Height="18" BorderBrush="#30363D" BorderThickness="1" Margin="0,0,4,0"/>
                                                        <Border Background="#161B22" CornerRadius="3" Width="36" Height="18" BorderBrush="#30363D" BorderThickness="1"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border Grid.Row="2" Background="#8B5CF6" CornerRadius="0,0,8,8">
                                                    <TextBlock Text="{DynamicResource ThemeDark2}" FontSize="{DynamicResource FS10}" FontWeight="SemiBold"
                                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding CurrentTheme}" Value="Dark2">
                                            <Setter TargetName="OuterBd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Custom (Warm) theme preview -->
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="Custom"
                                Margin="0,0,0,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="OuterBd" CornerRadius="10" BorderThickness="2.5"
                                            BorderBrush="Transparent" Padding="3"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border x:Name="InnerBd" CornerRadius="8" Width="136" Height="90"
                                                Background="#FAF7F2" ClipToBounds="True">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="28"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="22"/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E8DFD3" BorderThickness="0,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                                                        <Ellipse Width="6" Height="6" Fill="#FF605C" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#FFBD44" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#00CA4E"/>
                                                    </StackPanel>
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="8,5,8,0">
                                                    <Border Background="#E8DFD3" CornerRadius="2" Height="4" Width="60" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <Border Background="#E8DFD3" CornerRadius="2" Height="4" Width="44" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <Border Background="#FFFFFF" CornerRadius="3" Width="36" Height="18" BorderBrush="#E8DFD3" BorderThickness="1" Margin="0,0,4,0"/>
                                                        <Border Background="#FFFFFF" CornerRadius="3" Width="36" Height="18" BorderBrush="#E8DFD3" BorderThickness="1"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border Grid.Row="2" Background="#C07838" CornerRadius="0,0,8,8">
                                                    <TextBlock Text="{DynamicResource ThemeCustom}" FontSize="{DynamicResource FS10}" FontWeight="SemiBold"
                                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding CurrentTheme}" Value="Custom">
                                            <Setter TargetName="OuterBd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Display Scale Section -->
            <Border Grid.Row="5" Style="{StaticResource SettingsSectionCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource InfoLightBrush}">
                            <TextBlock Text="&#xE7F8;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="{DynamicResource FS17}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}">
                                <Run Text="{DynamicResource SettingsInterfaceSize}"/>
                                <Run Text=" + "/>
                                <Run Text="{DynamicResource SettingsTextSize}"/>
                            </TextBlock>
                            <TextBlock FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.55"
                                       Margin="0,2,0,0">
                                <Run Text="{DynamicResource SettingsInterfaceSizeHint}"/>
                                <Run Text=" "/>
                                <Run Text="{DynamicResource SettingsTextSizeHint}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <Border Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="16,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource InfoLightBrush}"
                                        Width="32" Height="32" CornerRadius="8">
                                    <TextBlock Text="&#xE740;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                               Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource SettingsInterfaceSize}" 
                                               FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{DynamicResource SettingsInterfaceSizeHint}" 
                                               FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <WrapPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource SizeSmall}" 
                                        Command="{Binding ChangeInterfaceSizeCommand}" CommandParameter="Small">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentInterfaceSize}" Value="Small">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="{DynamicResource SizeMedium}" 
                                        Command="{Binding ChangeInterfaceSizeCommand}" CommandParameter="Medium">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentInterfaceSize}" Value="Medium">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="{DynamicResource SizeLarge}" 
                                        Command="{Binding ChangeInterfaceSizeCommand}" CommandParameter="Large">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentInterfaceSize}" Value="Large">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="{DynamicResource SizeExtraLarge}" 
                                        Command="{Binding ChangeInterfaceSizeCommand}" CommandParameter="ExtraLarge">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentInterfaceSize}" Value="ExtraLarge">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>

                            <Border Height="1" Margin="0,16,0,16" Background="{DynamicResource CardBorderBrush}" Opacity="0.7"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Background="{DynamicResource ErrorLightBrush}" CornerRadius="8" Width="32" Height="32"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                               Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource SettingsTextSize}" 
                                               FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{DynamicResource SettingsTextSizeHint}" 
                                               FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <WrapPanel Orientation="Horizontal">
                                <Button Command="{Binding ChangeTextSizeCommand}" CommandParameter="Small">
                                    <Button.Content>
                                        <TextBlock Text="{DynamicResource SizeSmall}" FontSize="12"/>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentTextSize}" Value="Small">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding ChangeTextSizeCommand}" CommandParameter="Medium">
                                    <Button.Content>
                                        <TextBlock Text="{DynamicResource SizeMedium}" FontSize="14"/>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentTextSize}" Value="Medium">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding ChangeTextSizeCommand}" CommandParameter="Large">
                                    <Button.Content>
                                        <TextBlock Text="{DynamicResource SizeLarge}" FontSize="16"/>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentTextSize}" Value="Large">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Command="{Binding ChangeTextSizeCommand}" CommandParameter="ExtraLarge">
                                    <Button.Content>
                                        <TextBlock Text="{DynamicResource SizeExtraLarge}" FontSize="18"/>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentTextSize}" Value="ExtraLarge">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Tags Visibility Card -->
            <Border Grid.Row="7" Style="{StaticResource SettingsSectionCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Background="#E8EAF6" CornerRadius="8" Width="36" Height="36"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource SettingsTagsTitle}" 
                                       FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource SettingsTagsDesc}" 
                                       FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding OpenTagVisibilityCommand}" Cursor="Hand"
                            VerticalAlignment="Center" Style="{StaticResource FilledActionButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource SettingsTagsBtn}" 
                                       FontSize="{DynamicResource FS13}" FontWeight="Medium"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Company Visibility Card -->
            <Border Grid.Row="8" Style="{StaticResource SettingsSectionCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Background="#E3F2FD" CornerRadius="8" Width="36" Height="36" VerticalAlignment="Center">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource SettingsFirmsVisibilityTitle}"
                                       FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource SettingsFirmsVisibilityDesc}"
                                       FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding OpenCompanyVisibilityCommand}" Cursor="Hand"
                            VerticalAlignment="Center" Style="{StaticResource FilledActionButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource SettingsFirmsVisibilityBtn}"
                                       FontSize="{DynamicResource FS13}" FontWeight="Medium"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Root Folder Card -->
            <Border Grid.Row="9" Style="{StaticResource SettingsSectionCard}" Padding="20,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource SuccessLightBrush}">
                                <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                           Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource LabelRootFolder}" 
                                           FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{DynamicResource SettingsFolderHint}" 
                                           FontSize="{DynamicResource FS11}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Style="{StaticResource DialogPreviewSurface}" Padding="12,10" Margin="0,0,12,0">
                            <TextBlock Text="{Binding RootFolderPath}" 
                                       FontSize="{DynamicResource FS12}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="1" Command="{Binding SelectRootFolderCommand}" Cursor="Hand"
                            VerticalAlignment="Center"
                            Style="{StaticResource HeaderGhostButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}"
                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource BtnSelectFolder}" 
                                       FontSize="{DynamicResource FS12}" FontWeight="Medium"
                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- AI (Gemini) Card -->
            <Border Grid.Row="10" Style="{StaticResource SettingsSectionCard}" Padding="24,22">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource AccentLightBrush}">
                                <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                           Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource AIProviderTitle}" FontSize="{DynamicResource FS17}"
                                           FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="Google Gemini API" FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource ForegroundBrush}" Opacity="0.55"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1" Padding="10,6" CornerRadius="999" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFF4F4F4"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGeminiConfigured}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource SuccessLightBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#9E9E9E"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGeminiConfigured}" Value="True">
                                                    <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="{DynamicResource FS11}" FontWeight="SemiBold" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{DynamicResource AIStatusNotLoaded}"/>
                                            <Setter Property="Foreground" Value="#7A7A7A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGeminiConfigured}" Value="True">
                                                    <Setter Property="Text" Value="{DynamicResource AIStatusReady}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource DialogPreviewSurface}" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource AIGeminiApiKey}" FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding GeminiApiKey, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="{DynamicResource FS12}" Padding="8,6"
                                         Background="{DynamicResource ContentBackgroundBrush}"
                                         Foreground="{DynamicResource ForegroundBrush}"
                                         BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"/>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Command="{Binding TestGeminiCommand}"
                                            Padding="12,7"
                                            Margin="0,0,8,0"
                                            Background="{DynamicResource SuccessBrush}"
                                            Foreground="White"
                                            FontSize="{DynamicResource FS11}"
                                            Style="{StaticResource FilledActionButton}">
                                        <TextBlock Text="{DynamicResource AIGeminiTest}" Foreground="White" FontSize="{DynamicResource FS11}"/>
                                    </Button>
                                    <Button Command="{Binding OpenGeminiSiteCommand}"
                                            Padding="12,7"
                                            FontSize="{DynamicResource FS11}"
                                            Style="{StaticResource HeaderGhostButton}">
                                        <TextBlock Text="{DynamicResource AIGeminiGetKey}"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   FontSize="{DynamicResource FS11}"/>
                                    </Button>
                                </StackPanel>

                                <TextBlock Text="{Binding GeminiTestResult}" FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource SuccessBrush}" Margin="0,8,0,0" TextWrapping="Wrap"
                                           Visibility="{Binding GeminiTestResult, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource DialogPreviewSurface}" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource AIGeminiModel}" FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,6"/>
                                <ComboBox Style="{StaticResource ThemedComboBox}"
                                          ItemsSource="{Binding GeminiModels}" SelectedItem="{Binding GeminiModel}"/>

                                <Border Height="1" Margin="0,14,0,14" Background="{DynamicResource CardBorderBrush}" Opacity="0.7"/>

                                <TextBlock Text="{DynamicResource AIProviderTitle}"
                                           FontSize="{DynamicResource FS12}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="Google Gemini API"
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="0,4,0,0"/>
                                <TextBlock Text="AI chat, document assistance and smart prompts use these settings globally."
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Profile Section -->
            <Border Grid.Row="11" Style="{StaticResource SettingsSectionCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource AccentLightBrush}">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource SettingsProfileTitle}"
                                       FontSize="{DynamicResource FS17}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource SettingsProfileSubtitle}"
                                       FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}"
                                       Opacity="0.55" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Style="{StaticResource DialogPreviewSurface}" Padding="16,14"
                            Visibility="{Binding HasProfile, Converter={StaticResource InverseBoolToVis}}">
                        <TextBlock Text="{DynamicResource SettingsProfileNotLoaded}"
                                   FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                    </Border>

                    <StackPanel Visibility="{Binding HasProfile, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Style="{StaticResource DialogPreviewSurface}" Padding="16,14" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{DynamicResource SettingsProfileAssignedUserTitle}"
                                               FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock FontSize="{DynamicResource FS11}"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               Margin="0,4,0,0">
                                        <Run Text="{DynamicResource SettingsProfileClientIdLabel}"/>
                                        <Run Text="{Binding ProfileClientId, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <CheckBox Grid.Column="1"
                                          VerticalAlignment="Center"
                                          Margin="16,0,0,0"
                                          Content="{DynamicResource ProfileRememberMe}"
                                          IsChecked="{Binding ProfileRememberMeEnabled}"/>
                            </Grid>
                        </Border>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource DialogPreviewSurface}" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource SettingsProfileDetailsTitle}"
                                               FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10"/>

                                    <TextBlock Text="{DynamicResource ProfileFirstNameLabel}" FontSize="{DynamicResource FS12}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding ProfileFirstName, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,12"
                                             PreviewTextInput="LatinNameTextBox_OnPreviewTextInput"
                                             DataObject.Pasting="LatinNameTextBox_OnPasting"/>

                                    <TextBlock Text="{DynamicResource ProfileLastNameLabel}" FontSize="{DynamicResource FS12}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding ProfileLastName, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,8"
                                             PreviewTextInput="LatinNameTextBox_OnPreviewTextInput"
                                             DataObject.Pasting="LatinNameTextBox_OnPasting"/>

                                    <TextBlock Text="{DynamicResource ProfileNameLatinHint}"
                                               FontSize="{DynamicResource FS11}"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               Margin="0,-2,0,12"
                                               TextWrapping="Wrap"/>

                                    <Button Command="{Binding SaveProfileCommand}"
                                            Padding="14,8"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource FilledActionButton}">
                                        <TextBlock Text="{DynamicResource SettingsProfileSaveButton}"
                                                   FontSize="{DynamicResource FS12}"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource DialogPreviewSurface}" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource SettingsProfileChangePasswordTitle}"
                                               FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10"/>

                                    <TextBlock Text="{DynamicResource ProfileCurrentPasswordLabel}" FontSize="{DynamicResource FS12}" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="ProfileCurrentPasswordBox"
                                                 Margin="0,0,0,12"
                                                 PasswordChanged="ProfileCurrentPasswordBox_OnPasswordChanged"/>

                                    <TextBlock Text="{DynamicResource ProfileNewPasswordLabel}" FontSize="{DynamicResource FS12}" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="ProfileNewPasswordBox"
                                                 Margin="0,0,0,12"
                                                 PasswordChanged="ProfileNewPasswordBox_OnPasswordChanged"/>

                                    <TextBlock Text="{DynamicResource ProfileConfirmPasswordLabel}" FontSize="{DynamicResource FS12}" Margin="0,0,0,6"/>
                                    <PasswordBox x:Name="ProfileConfirmPasswordBox"
                                                 Margin="0,0,0,12"
                                                 PasswordChanged="ProfileConfirmPasswordBox_OnPasswordChanged"/>

                                    <Button Command="{Binding ChangeProfilePasswordCommand}"
                                            Padding="14,8"
                                            HorizontalAlignment="Left"
                                            Style="{StaticResource FilledActionButton}">
                                        <TextBlock Text="{DynamicResource SettingsProfileChangePasswordButton}"
                                                   FontSize="{DynamicResource FS12}"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource DialogPreviewSurface}" Padding="12,10"
                                Visibility="{Binding ProfileStatusMessage, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}">
                            <TextBlock Text="{Binding ProfileStatusMessage}" FontSize="{DynamicResource FS12}" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ProfileStatusIsError}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- System Section -->
            <Border Grid.Row="12" Style="{StaticResource SettingsSectionCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource InfoLightBrush}">
                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="{DynamicResource FS17}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}">
                                <Run Text="{DynamicResource SettingsLicenseTitle}"/>
                                <Run Text=" + "/>
                                <Run Text="{DynamicResource SettingsUpdateTitle}"/>
                            </TextBlock>
                            <TextBlock Text="Стан доступу до програми та поточної версії."
                                       FontSize="{DynamicResource FS12}"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       Opacity="0.55"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource DialogPreviewSurface}" Padding="16,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionHeaderIconBadge}" Background="#E8F5E9">
                                        <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                                   Foreground="#388E3C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource SettingsLicenseTitle}"
                                                   FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="{Binding LicenseStatus}"
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Margin="0,2,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="10,8">
                                    <TextBlock FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}">
                                        <Run Text="ID: "/>
                                        <Run Text="{Binding MachineId, Mode=OneWay}"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource DialogPreviewSurface}" Padding="16,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionHeaderIconBadge}" Background="#E3F2FD">
                                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                                   Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource SettingsUpdateTitle}"
                                                   FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="{DynamicResource SettingsUpdateDesc}"
                                                   FontSize="{DynamicResource FS11}" Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding CheckForUpdatesCommand}"
                                            Padding="14,8"
                                            Foreground="White"
                                            Style="{StaticResource FilledActionButton}">
                                        <TextBlock Text="{DynamicResource SettingsUpdateBtn}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold" Foreground="White"/>
                                    </Button>
                                    <Button Command="{Binding InstallUpdateCommand}"
                                            Padding="14,8"
                                            Background="{DynamicResource SuccessBrush}"
                                            Foreground="White"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource FilledActionButton}"
                                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{DynamicResource SettingsInstallBtn}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold" Foreground="White"/>
                                    </Button>
                                </StackPanel>

                                <TextBlock Text="{Binding UpdateStatus}" FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Copyright Card -->
            <Border Grid.Row="13" Style="{StaticResource SettingsSectionCard}" Padding="18,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Style="{StaticResource SectionHeaderIconBadge}" Background="#E8EAF6">
                            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                       Foreground="#3949AB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource SettingsCopyrightTitle}" 
                                   FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource SettingsCopyrightText}"
                               FontSize="{DynamicResource FS12}" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,2,0,2"/>
                    <TextBlock Text="{DynamicResource SettingsCopyrightDesc}"
                               FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>

    <!-- ===== COMPANY VISIBILITY OVERLAY ===== -->
    <Grid Grid.RowSpan="2" Visibility="{Binding IsCompanyVisibilityOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border Background="#80000000">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding CloseCompanyVisibilityCommand}"/>
            </Border.InputBindings>
        </Border>
        <Border Style="{StaticResource DialogSectionCard}"
                Padding="28,24" Width="480" MaxHeight="600"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <!-- Header -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource SettingsSectionIconBadge}" Background="#E3F2FD">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource SettingsFirmsVisibilityTitle}"
                                   FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding CloseCompanyVisibilityCommand}" Cursor="Hand"
                            VerticalAlignment="Center" Width="36" Height="36"
                            Style="{StaticResource HeaderGhostButton}">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                   Foreground="{DynamicResource ForegroundBrush}" Opacity="0.7"/>
                    </Button>
                </Grid>

                <!-- Hint -->
                <TextBlock Text="{DynamicResource SettingsFirmsVisibilityHint}"
                           FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}"
                           Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- Company list -->
                <ScrollViewer MaxHeight="360" Style="{StaticResource ThinScroll}">
                    <ItemsControl ItemsSource="{Binding CompanyVisibilityItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Checkbox -->
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsVisible}"
                                                  IsEnabled="{Binding HasActiveEmployees, Converter={StaticResource InverseBoolConverter}}"
                                                  VerticalAlignment="Center" Margin="0,0,12,0"/>

                                        <!-- Company name -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{DynamicResource FS14}" FontWeight="Medium"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                            <!-- Warning if has active employees -->
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding HasActiveEmployees, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                           Foreground="#F57F17" VerticalAlignment="Center" Margin="0,2,4,0"/>
                                                <TextBlock FontSize="{DynamicResource FS11}" Foreground="#F57F17" Margin="0,2,0,0">
                                                    <Run Text="{DynamicResource SettingsFirmsHasEmployees}"/>
                                                    <Run Text="{Binding ActiveEmployeeCount, Mode=OneWay}"/>
                                                    <Run Text="{DynamicResource SettingsFirmsEmployeesCount}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Active count badge -->
                                        <Border Grid.Column="2" Background="#E3F2FD" CornerRadius="10"
                                                Padding="10,3" VerticalAlignment="Center"
                                                Visibility="{Binding HasActiveEmployees, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding ActiveEmployeeCount, Mode=OneWay}"
                                                       FontSize="{DynamicResource FS12}" FontWeight="Bold"
                                                       Foreground="#1565C0"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- OK button -->
                <Button Command="{Binding CloseCompanyVisibilityCommand}" Cursor="Hand"
                        HorizontalAlignment="Center" Margin="0,16,0,0" MinWidth="120"
                        Padding="32,12" Style="{StaticResource FilledActionButton}">
                    <TextBlock Text="OK"
                               FontSize="{DynamicResource FS14}" FontWeight="SemiBold" Foreground="White"
                               HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>

    </Grid>
</UserControl>
