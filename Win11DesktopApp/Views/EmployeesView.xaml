<UserControl x:Class="Win11DesktopApp.Views.EmployeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:Win11DesktopApp.Views"
             xmlns:local="clr-namespace:Win11DesktopApp.Converters"
             xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <local:StatusColorConverter x:Key="StatusColor"/>
        <local:StatusBackgroundConverter x:Key="StatusBg"/>
        <Style x:Key="StatusMessageText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsError}" Value="True">
                    <Setter Property="Foreground" Value="#c62828"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                    <Setter Property="Foreground" Value="#0078D4"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardActionBtn" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        </Style>

        <Style x:Key="HeaderBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid>
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="Auto"/>  <!-- Statistics -->
                    <RowDefinition Height="Auto"/>  <!-- Sort bar -->
                    <RowDefinition Height="Auto"/>  <!-- Selection bar -->
                    <RowDefinition Height="*"/>     <!-- List -->
                </Grid.RowDefinitions>

                <!-- ===== HEADER ===== -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding GoBackCommand}" Style="{StaticResource HeaderBtn}" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource BtnBack}" FontSize="14"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding Title, FallbackValue='Працівники'}" 
                                   FontSize="24" FontWeight="SemiBold" 
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Vertical" Margin="20,0">
                        <TextBlock Text="{DynamicResource EmployeesSearchPlaceholder}" Foreground="#888" FontSize="12" Margin="2,0,0,2"/>
                        <TextBox Height="38" VerticalContentAlignment="Center"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                            <ProgressBar IsIndeterminate="True" Height="4" Width="120" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource MsgEmployeesLoading}" FontSize="12" VerticalAlignment="Center" Foreground="#0078D4"/>
                        </StackPanel>
                        <TextBlock Margin="0,4,0,0" Text="{Binding StatusMessage}" 
                                   FontSize="12" TextWrapping="Wrap" Style="{StaticResource StatusMessageText}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Export to Excel -->
                        <Button Command="{Binding ExportToExcelCommand}" Style="{StaticResource HeaderBtn}" Margin="0,0,8,0"
                                ToolTip="{DynamicResource EmpTooltipExport}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="Excel" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <!-- Toggle Selection -->
                        <Button Command="{Binding ToggleSelectionModeCommand}" Style="{StaticResource HeaderBtn}" Margin="0,0,8,0"
                                ToolTip="{DynamicResource EmpTooltipSelect}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE762;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource EmpBtnSelect}" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <!-- Add Employee -->
                        <Button Command="{Binding AddEmployeeCommand}" Height="42"
                                Background="{DynamicResource AccentBrush}" Foreground="White" 
                                FontSize="14" FontWeight="SemiBold" BorderThickness="0"
                                Padding="18,0" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource BtnAddEmployee}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ===== STATISTICS ===== -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12"
                            Visibility="{Binding HasEmployees, Converter={StaticResource BoolToVis}}">
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                            Padding="16,8" Margin="0,0,10,0" MinWidth="120"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding TotalCount}" FontSize="22" FontWeight="Bold" 
                                       Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="{DynamicResource EmpStatTotal}" FontSize="11" Foreground="#888"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#E8F5E9" CornerRadius="8" Padding="16,8" Margin="0,0,10,0" MinWidth="120"
                            BorderBrush="#C8E6C9" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding ActiveCount}" FontSize="22" FontWeight="Bold" Foreground="#2E7D32"/>
                            <TextBlock Text="{DynamicResource EmpStatActive}" FontSize="11" Foreground="#2E7D32"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF3E0" CornerRadius="8" Padding="16,8" Margin="0,0,10,0" MinWidth="120"
                            BorderBrush="#FFE0B2" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding ProblemsCount}" FontSize="22" FontWeight="Bold" Foreground="#EF6C00"/>
                            <TextBlock Text="{DynamicResource EmpStatProblems}" FontSize="11" Foreground="#EF6C00"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#E3F2FD" CornerRadius="8" Padding="16,8" MinWidth="120"
                            BorderBrush="#BBDEFB" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding NewThisMonth}" FontSize="22" FontWeight="Bold" Foreground="#1565C0"/>
                            <TextBlock Text="{DynamicResource EmpStatNewMonth}" FontSize="11" Foreground="#1565C0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ===== SORT BAR ===== -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10"
                            Visibility="{Binding HasEmployees, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{DynamicResource EmpSortLabel}" FontSize="12" Foreground="#888" 
                               VerticalAlignment="Center" Margin="0,0,8,0"/>

                    <Button Command="{Binding SortByCommand}" CommandParameter="Name"
                            Padding="10,5" Margin="0,0,4,0" Cursor="Hand"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Foreground="{DynamicResource ForegroundBrush}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SortField}" Value="Name">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource EmpSortName}" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SortByCommand}" CommandParameter="StartDate"
                            Padding="10,5" Margin="0,0,4,0" Cursor="Hand"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Foreground="{DynamicResource ForegroundBrush}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SortField}" Value="StartDate">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource EmpSortDate}" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SortByCommand}" CommandParameter="Status"
                            Padding="10,5" Margin="0,0,4,0" Cursor="Hand"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Foreground="{DynamicResource ForegroundBrush}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SortField}" Value="Status">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource EmpSortStatus}" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SortByCommand}" CommandParameter="Problems"
                            Padding="10,5" Margin="0,0,4,0" Cursor="Hand"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Foreground="{DynamicResource ForegroundBrush}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SortField}" Value="Problems">
                                        <Setter Property="Background" Value="#FFF3E0"/>
                                        <Setter Property="BorderBrush" Value="#EF6C00"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="#EF6C00"/>
                            <TextBlock Text="{DynamicResource EmpSortProblems}" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- ===== SELECTION BAR ===== -->
                <Border Grid.Row="3" CornerRadius="8" Padding="12,8" Margin="0,0,0,10"
                        Background="{DynamicResource AccentBrush}"
                        Visibility="{Binding IsSelectionMode, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedCount, StringFormat='Обрано: {0}'}" 
                                       Foreground="White" FontWeight="SemiBold" FontSize="13" 
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <Button Command="{Binding SelectAllCommand}" Padding="10,4" Margin="0,0,6,0"
                                    Background="#FFFFFF" Foreground="{DynamicResource AccentBrush}" 
                                    BorderThickness="0" Cursor="Hand" FontSize="12">
                                <TextBlock Text="{DynamicResource EmpSelectAll}"/>
                            </Button>
                            <Button Command="{Binding BatchGenerateCommand}" Padding="10,4" Margin="0,0,6,0"
                                    Background="#FFFFFF" Foreground="{DynamicResource AccentBrush}" 
                                    BorderThickness="0" Cursor="Hand" FontSize="12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource EmpGenerate}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Command="{Binding DeselectAllCommand}" 
                                Padding="10,4" Background="Transparent" BorderThickness="0" 
                                Foreground="White" Cursor="Hand" FontSize="12">
                            <TextBlock Text="{DynamicResource BtnCancel}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ===== EMPLOYEE LIST ===== -->
                <Grid Grid.Row="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="EmployeesList" ItemsSource="{Binding Employees}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" 
                                            Padding="16" Margin="0,0,0,10"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/> <!-- Checkbox -->
                                                <ColumnDefinition Width="Auto"/> <!-- Avatar -->
                                                <ColumnDefinition Width="*"/>    <!-- Info -->
                                                <ColumnDefinition Width="Auto"/> <!-- Actions -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Checkbox for selection -->
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" 
                                                      VerticalAlignment="Center" Margin="0,0,10,0"
                                                      Visibility="{Binding DataContext.IsSelectionMode, 
                                                                   RelativeSource={RelativeSource AncestorType=ItemsControl}, 
                                                                   Converter={StaticResource BoolToVis}}"/>

                                            <!-- Avatar -->
                                            <Border Grid.Column="1" Width="60" Height="60" CornerRadius="30" 
                                                    Background="#E3F2FD" VerticalAlignment="Top" Margin="0,0,14,0"
                                                    BorderBrush="#BBDEFB" BorderThickness="2">
                                                <Border.Clip>
                                                    <EllipseGeometry Center="30,30" RadiusX="30" RadiusY="30"/>
                                                </Border.Clip>
                                                <Grid>
                                                    <Image Source="{Binding PhotoPath}" Stretch="UniformToFill" 
                                                           Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="#90CAF9"
                                                               Visibility="{Binding HasPhoto, Converter={StaticResource InverseBoolToVis}}"/>
                                                </Grid>
                                            </Border>

                                            <!-- Info -->
                                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                                <!-- Name + Status badge -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                    <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="16" 
                                                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,10,0"/>
                                                    <!-- Status badge -->
                                                    <Border CornerRadius="10" Padding="8,2" VerticalAlignment="Center"
                                                            Background="{Binding Status, Converter={StaticResource StatusBg}}">
                                                        <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{Binding Status, Converter={StaticResource StatusColor}}"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding PositionTitle}" FontSize="12" Foreground="#888" Margin="0,0,0,6"/>

                                                <!-- Details row -->
                                                <WrapPanel Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                                                   Foreground="#999" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding StartDate}" FontSize="12" Foreground="#666"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                        <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                                                   Foreground="#999" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Phone}" FontSize="12" Foreground="#666"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                        <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                                                   Foreground="#999" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Email}" FontSize="12" Foreground="#666"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE821;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                                                   Foreground="#999" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding ContractType}" FontSize="12" Foreground="#666"/>
                                                    </StackPanel>
                                                </WrapPanel>

                                                <!-- Document badges -->
                                                <WrapPanel>
                                                    <!-- Passport badge -->
                                                    <Border CornerRadius="10" Padding="8,3" Margin="0,0,6,0"
                                                            Visibility="{Binding HasPassport, Converter={StaticResource BoolToVis}}"
                                                            Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="10" 
                                                                       Foreground="#2E7D32" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource EmpBadgePassport}" FontSize="11" Foreground="#2E7D32"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border CornerRadius="10" Padding="8,3" Margin="0,0,6,0"
                                                            Visibility="{Binding HasPassport, Converter={StaticResource InverseBoolToVis}}"
                                                            Background="#FFF3E0" BorderBrush="#FFE0B2" BorderThickness="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="10" 
                                                                       Foreground="#EF6C00" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource EmpBadgePassport}" FontSize="11" Foreground="#EF6C00"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Visa badge -->
                                                    <Border CornerRadius="10" Padding="8,3" Margin="0,0,6,0"
                                                            Visibility="{Binding HasVisa, Converter={StaticResource BoolToVis}}"
                                                            Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="10" 
                                                                       Foreground="#2E7D32" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource EmpBadgeVisa}" FontSize="11" Foreground="#2E7D32"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border CornerRadius="10" Padding="8,3" Margin="0,0,6,0"
                                                            Visibility="{Binding HasVisa, Converter={StaticResource InverseBoolToVis}}"
                                                            Background="#FFF3E0" BorderBrush="#FFE0B2" BorderThickness="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="10" 
                                                                       Foreground="#EF6C00" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource EmpBadgeVisa}" FontSize="11" Foreground="#EF6C00"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Insurance badge -->
                                                    <Border CornerRadius="10" Padding="8,3" Margin="0,0,6,0"
                                                            Visibility="{Binding HasInsurance, Converter={StaticResource BoolToVis}}"
                                                            Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="10" 
                                                                       Foreground="#2E7D32" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource EmpBadgeInsurance}" FontSize="11" Foreground="#2E7D32"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border CornerRadius="10" Padding="8,3"
                                                            Visibility="{Binding HasInsurance, Converter={StaticResource InverseBoolToVis}}"
                                                            Background="#FFF3E0" BorderBrush="#FFE0B2" BorderThickness="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="10" 
                                                                       Foreground="#EF6C00" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource EmpBadgeInsurance}" FontSize="11" Foreground="#EF6C00"/>
                                                        </StackPanel>
                                                    </Border>
                                                </WrapPanel>
                                            </StackPanel>

                                            <!-- Action buttons -->
                                            <StackPanel Grid.Column="3" Orientation="Vertical" VerticalAlignment="Center">
                                                <Button Style="{StaticResource CardActionBtn}" Margin="0,0,0,4"
                                                        Command="{Binding DataContext.OpenEmployeeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{DynamicResource EmpBtnOpen}" FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource CardActionBtn}" Margin="0,0,0,4"
                                                        Command="{Binding DataContext.EditEmployeeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{DynamicResource EmpBtnEdit}" FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource CardActionBtn}" Margin="0,0,0,4"
                                                        Command="{Binding DataContext.OpenEmployeeFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" ToolTip="{DynamicResource EmpTooltipFolder}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{DynamicResource EmpBtnFolder}" FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource CardActionBtn}"
                                                        Command="{Binding DataContext.DeleteEmployeeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Foreground="#D32F2F" BorderBrush="#FFCDD2" Background="#FFF5F5"
                                                        ToolTip="{DynamicResource EmpTooltipDelete}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{DynamicResource EmpBtnDelete}" FontSize="12"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty state -->
                    <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="8" Padding="30"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Visibility="{Binding HasEmployees, Converter={StaticResource InverseBoolToVis}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="42" HorizontalAlignment="Center" Foreground="#999"/>
                            <TextBlock Text="{Binding StatusMessage, FallbackValue=У цієї фірми ще немає працівників.}" FontSize="14" Margin="0,10,0,10" TextAlignment="Center" TextWrapping="Wrap"
                                       Style="{StaticResource StatusMessageText}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="{DynamicResource BtnSelectCompany}" Command="{Binding SelectCompanyCommand}" Height="40" Padding="15,0"
                                        Background="Transparent" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                        Visibility="{Binding IsCompanySelected, Converter={StaticResource InverseBoolToVis}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Add Employee Dialog -->
        <Grid Visibility="{Binding IsAddEmployeeDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#66000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAddEmployeeDialogCommand}"/>
                </Border.InputBindings>
            </Border>
            <ContentControl Content="{Binding AddEmployeeVm}" 
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                            Margin="30">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:AddEmployeeWizardViewModel}" xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels">
                        <views:AddEmployeeWizardView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>

        <!-- Employee Details Overlay -->
        <Grid Visibility="{Binding IsEmployeeDetailsOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#66000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding EmployeeDetailsVm.CloseCommand}"/>
                </Border.InputBindings>
            </Border>
            <ContentControl Content="{Binding EmployeeDetailsVm}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:EmployeeDetailsViewModel}" xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels">
                        <views:EmployeeDetailsView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>

        <!-- Delete Confirm Dialog -->
        <Grid Visibility="{Binding IsDeleteConfirmOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#66000000"/>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" Padding="24" 
                    Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.25"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="32" 
                               HorizontalAlignment="Center" Foreground="#D32F2F" Margin="0,0,0,12"/>
                    <TextBlock Text="{DynamicResource MsgDeleteEmployee}" FontSize="16" FontWeight="SemiBold" 
                               Margin="0,0,0,6" TextAlignment="Center" Foreground="{DynamicResource ForegroundBrush}"/>
                    <TextBlock Text="{Binding EmployeeToDelete.FullName}" Foreground="#666" FontSize="14"
                               Margin="0,0,0,20" TextAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Command="{Binding CancelDeleteCommand}" Padding="18,8" Margin="0,0,10,0"
                                Background="{DynamicResource ContentBackgroundBrush}" 
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                            <TextBlock Text="{DynamicResource BtnCancel}" FontSize="13"/>
                        </Button>
                        <Button Command="{Binding ConfirmDeleteCommand}" Padding="18,8"
                                Background="#D32F2F" Foreground="White" BorderThickness="0"
                                FontWeight="SemiBold" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource BtnDelete}" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Batch Generate Dialog -->
        <Grid Visibility="{Binding IsBatchGenerateOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#66000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseBatchGenerateCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" 
                    Width="500" MaxHeight="500" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="18" 
                                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource EmpBatchTitle}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Command="{Binding CloseBatchGenerateCommand}"
                                Width="30" Height="30" Background="Transparent" BorderThickness="0" Foreground="#999" Cursor="Hand">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                        </Button>
                    </Grid>

                    <TextBlock Grid.Row="1" Text="{Binding BatchStatusMessage}" Foreground="#888" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="300">
                        <ItemsControl ItemsSource="{Binding BatchTemplates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" 
                                            Padding="12,8" Margin="0,0,0,6" Cursor="Hand"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6" 
                                                    Background="#E3F2FD" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Format}" VerticalAlignment="Center" 
                                                           HorizontalAlignment="Center" FontWeight="Bold" FontSize="11"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#888" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" 
                                                    Command="{Binding DataContext.BatchGenerateFromTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,5" FontWeight="SemiBold"
                                                    Background="{DynamicResource AccentBrush}" Foreground="White" 
                                                    BorderThickness="0" VerticalAlignment="Center" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource EmpGenerate}" FontSize="12"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
