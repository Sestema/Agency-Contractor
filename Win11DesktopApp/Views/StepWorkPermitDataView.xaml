<UserControl x:Class="Win11DesktopApp.Views.StepWorkPermitDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource StepFade}" Visibility="{Binding StepIndex, Converter={StaticResource StepVis}, ConverterParameter=7}"
            Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="24"
            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>
            <ScrollViewer Grid.Column="0" Style="{StaticResource ThinScroll}" Margin="0,0,8,0"
                          PreviewMouseWheel="InnerScrollViewer_PreviewMouseWheel">
                <StackPanel>
                    <StackPanel Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{DynamicResource ErrorLightBrush}" CornerRadius="8" Width="36" Height="36">
                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                           Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{DynamicResource StepWorkPermitData}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Command="{Binding AIScanDocumentCommand}" Style="{StaticResource AccentBtn}"
                                    Padding="12,6" Margin="0,0,8,0"
                                    Visibility="{Binding IsAIScanning, Converter={StaticResource InverseBoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{DynamicResource AIScanBtn}" FontSize="{DynamicResource FS13}"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Text="{Binding AIScanStatus}" FontSize="{DynamicResource FS12}" 
                                       Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center"
                                       Visibility="{Binding AIScanStatus, Converter={StaticResource StringToVis}}"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource WizWorkPermitNumber}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.WorkPermitNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizWorkPermitType}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.WorkPermitType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizWorkPermitIssueDate}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.WorkPermitIssueDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizWorkPermitExpiry}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.WorkPermitExpiry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizWorkPermitAuthority}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.WorkPermitAuthority, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                </StackPanel>
            </ScrollViewer>
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{DynamicResource CardBorderBrush}" Cursor="SizeWE"
                          Margin="2,0"/>
            <Border Grid.Column="2" CornerRadius="10" Background="{DynamicResource ContentBackgroundBrush}" Margin="8,0,0,0"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ItemsControl Grid.Row="0" Panel.ZIndex="1" ItemsSource="{Binding CarouselItems}" Margin="4,6,4,2"
                                  Visibility="{Binding HasCarouselItems, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Label}" Style="{StaticResource CarouselTabBtn}"
                                        Command="{Binding DataContext.SelectCarouselTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Grid.Row="1" ClipToBounds="True">
                        <Grid>
                            <!-- Single image preview (non-PDF) -->
                            <Image Source="{Binding CarouselPreviewPath, Converter={StaticResource ImagePathConverter}}" Stretch="Uniform" 
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Visibility="{Binding WorkPermitDoc.IsPdf, Converter={StaticResource InverseBoolToVis}}"
                                   MouseWheel="DocImage_MouseWheel"
                                   MouseRightButtonDown="DocImage_MouseRightButtonDown"
                                   MouseRightButtonUp="DocImage_MouseRightButtonUp"
                                   MouseMove="DocImage_MouseMove"
                                   MouseLeftButtonDown="DocImage_ResetZoom">
                                <Image.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        <TranslateTransform X="0" Y="0"/>
                                    </TransformGroup>
                                </Image.RenderTransform>
                            </Image>
                            <!-- Multi-page PDF preview -->
                            <ScrollViewer Style="{StaticResource ThinScroll}"
                                          Visibility="{Binding WorkPermitDoc.IsPdf, Converter={StaticResource BoolToVis}}">
                                <ItemsControl ItemsSource="{Binding WorkPermitPagePreviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="4" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="4"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding Converter={StaticResource ImagePathConverter}}" Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       MouseWheel="DocImage_MouseWheel"
                                                       MouseRightButtonDown="DocImage_MouseRightButtonDown"
                                                       MouseRightButtonUp="DocImage_MouseRightButtonUp"
                                                       MouseMove="DocImage_MouseMove"
                                                       MouseLeftButtonDown="DocImage_ResetZoom">
                                                    <Image.RenderTransform>
                                                        <TransformGroup>
                                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                            <TranslateTransform X="0" Y="0"/>
                                                        </TransformGroup>
                                                    </Image.RenderTransform>
                                                </Image>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
