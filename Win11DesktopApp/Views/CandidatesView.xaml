<UserControl x:Class="Win11DesktopApp.Views.CandidatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels"
             xmlns:views="clr-namespace:Win11DesktopApp.Views"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding GoBackCommand}" Style="{StaticResource HeaderBackButton}" Margin="0,0,10,0">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                    </Button>
                    <Border Style="{StaticResource PageHeaderIconBadge}" Background="#FFB74D">
                        <TextBlock Text="&#xE77B;" Style="{StaticResource PageHeaderIconText}"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource BtnCandidates}" FontSize="{DynamicResource FS24}" Style="{StaticResource PageHeaderTitleText}"/>
                        <TextBlock FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Margin="0,3,0,0">
                            <Run Text="{Binding TotalCount}"/>
                            <Run Text=" "/>
                            <Run Text="{DynamicResource BtnCandidates}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding AddCandidateCommand}" Style="{StaticResource FilledActionButton}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                   Foreground="White" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource CandAdd}" FontSize="{DynamicResource FS13}"
                                   FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- FILTER BAR -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Height="36" VerticalContentAlignment="Center" Margin="0,0,12,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                <ComboBox Grid.Column="1" Width="200" Height="36" VerticalContentAlignment="Center" Margin="0,0,12,0"
                          ItemsSource="{Binding Positions}"
                          SelectedItem="{Binding SelectedPosition}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="">
                                                <Setter Property="Text" Value="{DynamicResource CandAllPositions}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- View mode toggle + Zoom -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding SetViewModeCommand}" CommandParameter="List" ToolTip="{DynamicResource ViewList}"
                            Padding="6,4" Margin="0,0,2,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViewMode}" Value="List">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="&#xEA37;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                    </Button>
                    <Button Command="{Binding SetViewModeCommand}" CommandParameter="Tiles" ToolTip="{DynamicResource ViewTiles}"
                            Padding="6,4" Margin="0,0,12,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViewMode}" Value="Tiles">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                    </Button>
                    <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}"
                               Foreground="#999" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Slider Value="{Binding ZoomLevel}" Minimum="0.6" Maximum="1.6" Width="100"
                            TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                    <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                               Foreground="#999" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- CANDIDATES LIST VIEW -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding Candidates}" ClipToBounds="False"
                          Visibility="{Binding IsListView, Converter={StaticResource BoolToVis}}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True">
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <ScrollViewer Style="{StaticResource ThinScroll}" CanContentScroll="True" Focusable="False">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </ItemsControl.Template>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding DataContext.ZoomLevel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    ScaleY="{Binding DataContext.ZoomLevel, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </ItemsControl.LayoutTransform>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Padding="10" Margin="0,0,0,6" BorderThickness="1" Cursor="Hand"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenCandidateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Photo -->
                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" Background="#E3F2FD"
                                            VerticalAlignment="Top" Margin="0,0,10,0" BorderBrush="#BBDEFB" BorderThickness="1.5">
                                        <Border.Clip>
                                            <EllipseGeometry Center="22,22" RadiusX="22" RadiusY="22"/>
                                        </Border.Clip>
                                        <Grid>
                                            <Image Source="{Binding PhotoPath}" Stretch="UniformToFill"
                                                   Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS18}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#90CAF9">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPhoto}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="{DynamicResource FS14}"
                                                       Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,8,0"/>
                                        </StackPanel>
                                        <WrapPanel Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                                <TextBlock Text="&#xE821;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}"
                                                           Foreground="#999" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding DesiredPosition}" FontSize="{DynamicResource FS11}" Foreground="#666"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                                <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}"
                                                           Foreground="#999" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Phone}" FontSize="{DynamicResource FS11}" Foreground="#666"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                                <TextBlock Text="&#xE81D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}"
                                                           Foreground="#999" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                                <TextBlock FontSize="{DynamicResource FS11}" Foreground="#666">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding LocationDetails}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding LocationPreference}" Value="all">
                                                                    <Setter Property="Text" Value="{DynamicResource CandAllCzech}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </WrapPanel>
                                        <WrapPanel>
                                            <Border CornerRadius="8" Padding="5,2" Margin="0,0,4,0" BorderThickness="1"
                                                    Background="#E3F2FD" BorderBrush="#BBDEFB">
                                                <TextBlock FontSize="{DynamicResource FS10}" Foreground="#1565C0">
                                                    <Run Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding PassportNumber, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                            <Border CornerRadius="8" Padding="5,2" Margin="0,0,4,0" BorderThickness="1"
                                                    Background="#E8F5E9" BorderBrush="#C8E6C9">
                                                <TextBlock FontSize="{DynamicResource FS10}" Foreground="#2E7D32"
                                                           Text="{Binding PassportCountry}"/>
                                            </Border>
                                            <Border CornerRadius="8" Padding="5,2" BorderThickness="1"
                                                    Background="#FFF3E0" BorderBrush="#FFE0B2">
                                                <TextBlock FontSize="{DynamicResource FS10}" Foreground="#E65100">
                                                    <Run Text="{DynamicResource CandAddedOn}"/>
                                                    <Run Text="{Binding DateAdded, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Right: empty for alignment -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            <!-- CANDIDATES TILES VIEW -->
            <ScrollViewer Grid.Row="2" Style="{StaticResource ThinScroll}" ClipToBounds="False"
                          Visibility="{Binding IsTilesView, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding Candidates}" ClipToBounds="False">
                    <ItemsControl.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding DataContext.ZoomLevel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        ScaleY="{Binding DataContext.ZoomLevel, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </ItemsControl.LayoutTransform>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel ClipToBounds="False"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Padding="10" Margin="6,14,8,8" Width="260" BorderThickness="1"
                                    RenderTransformOrigin="0.5,0.5" Cursor="Hand"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenCandidateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        <TranslateTransform Y="0"/>
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.08"/>
                                </Border.Effect>
                                <StackPanel>
                                    <!-- Photo + Name -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Width="36" Height="36" CornerRadius="18" Background="#E3F2FD"
                                                Margin="0,0,8,0" BorderBrush="#BBDEFB" BorderThickness="1.5">
                                            <Border.Clip>
                                                <EllipseGeometry Center="18,18" RadiusX="18" RadiusY="18"/>
                                            </Border.Clip>
                                            <Grid>
                                                <Image Source="{Binding PhotoPath}" Stretch="UniformToFill"
                                                       Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="{DynamicResource FS15}" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="#90CAF9">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasPhoto}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="{DynamicResource FS13}"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                            <TextBlock Text="{Binding DesiredPosition}" FontSize="{DynamicResource FS10}" Foreground="#888"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Phone + Location -->
                                    <TextBlock FontSize="{DynamicResource FS10}" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,2">
                                        <Run Text="&#xE717; " FontFamily="Segoe MDL2 Assets"/>
                                        <Run Text="{Binding Phone, Mode=OneWay}"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="&#xE81D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}"
                                                   Foreground="#999" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                        <TextBlock FontSize="{DynamicResource FS10}" Foreground="#666">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding LocationDetails}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LocationPreference}" Value="all">
                                                            <Setter Property="Text" Value="{DynamicResource CandAllCzech}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Badges -->
                                    <WrapPanel Margin="0,4,0,0">
                                        <Border CornerRadius="6" Padding="4,1" Margin="0,0,3,0" BorderThickness="1"
                                                Background="#E3F2FD" BorderBrush="#BBDEFB">
                                            <TextBlock FontSize="{DynamicResource FS9}" Foreground="#1565C0">
                                                <Run Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding PassportNumber, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Border>
                                        <Border CornerRadius="6" Padding="4,1" Margin="0,0,3,0" BorderThickness="1"
                                                Background="#E8F5E9" BorderBrush="#C8E6C9">
                                            <TextBlock FontSize="{DynamicResource FS9}" Foreground="#2E7D32"
                                                       Text="{Binding PassportCountry}"/>
                                        </Border>
                                        <Border CornerRadius="6" Padding="4,1" BorderThickness="1"
                                                Background="#FFF3E0" BorderBrush="#FFE0B2">
                                            <TextBlock FontSize="{DynamicResource FS9}" Foreground="#E65100">
                                                <Run Text="{DynamicResource CandAddedOn}"/>
                                                <Run Text="{Binding DateAdded, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                 To="1.05" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                 To="1.05" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                                 To="-5" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                 To="18" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                                                 To="5" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                 To="0.2" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                 To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                 To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                                 To="0" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                 To="6" Duration="0:0:0.25"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                                                 To="2" Duration="0:0:0.25"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                 To="0.08" Duration="0:0:0.25"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <Border Grid.Row="2" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CompactEmptyStateCard}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasCandidates}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE77B;" Style="{StaticResource CompactEmptyStateIconText}" FontSize="{DynamicResource FS28}" Foreground="#FFB74D"/>
                    <TextBlock Text="{DynamicResource CandEmpty}" Style="{StaticResource CompactEmptyStateTitleText}"/>
                    <TextBlock Text="{DynamicResource CandAddTitle}"
                               Style="{StaticResource CompactEmptyStateDescriptionText}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ADD CANDIDATE OVERLAY -->
        <Grid Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <Border Background="#88000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{x:Null}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12"
                    MaxWidth="900" MaxHeight="700" Margin="20"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    ClipToBounds="True">
                <ContentControl Content="{Binding AddCandidateVm}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:AddCandidateViewModel}">
                            <views:AddCandidateView/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>
        </Grid>

        <!-- DETAILS OVERLAY -->
        <Grid Visibility="{Binding IsDetailsOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <Border Background="#88000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{x:Null}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12"
                    MaxWidth="880" MaxHeight="850" Margin="30"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <ContentControl Content="{Binding DetailsVm}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:CandidateDetailsViewModel}">
                            <views:CandidateDetailsView/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>
