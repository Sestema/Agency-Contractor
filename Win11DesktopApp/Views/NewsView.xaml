<UserControl x:Class="Win11DesktopApp.Views.NewsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid Background="{DynamicResource WindowBackgroundBrush}" Margin="24,14,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding GoBackCommand}" Style="{StaticResource HeaderBackButton}" Margin="0,0,10,0">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                </Button>
                <Border Style="{StaticResource PageHeaderIconBadge}" Background="{DynamicResource AccentBrush}">
                    <TextBlock Text="&#xE12A;" Style="{StaticResource PageHeaderIconText}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" Style="{StaticResource PageHeaderTitleText}"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Margin="0,2,0,0"
                               FontSize="{DynamicResource FS11}"
                               Foreground="{DynamicResource MutedForegroundBrush}"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1"
                    Command="{Binding RefreshCommand}"
                    Padding="10,6"
                    Style="{StaticResource FilledActionButton}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                               Foreground="White" Margin="0,0,6,0"/>
                    <TextBlock Text="{DynamicResource NewsRefresh}" FontSize="{DynamicResource FS12}"
                               FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      Height="34"
                      ItemsSource="{Binding SourceFilters}"
                      SelectedItem="{Binding SelectedSource}"
                      FontSize="{DynamicResource FS12}"/>

            <Border Grid.Column="2"
                    Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,0">
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource ForegroundBrush}"
                         FontSize="{DynamicResource FS12}"
                         VerticalContentAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Tag" Value="{DynamicResource NewsSearchPlaceholder}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Grid>
                                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="placeholder"
                                                       Text="{TemplateBinding Tag}"
                                                       Foreground="{DynamicResource TertiaryForegroundBrush}"
                                                       VerticalAlignment="Center"
                                                       IsHitTestVisible="False"
                                                       Visibility="Collapsed"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="8">
                <Grid>
                    <TextBlock Text="{DynamicResource NewsEmpty}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MutedForegroundBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Articles.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ListBox ItemsSource="{Binding Articles}"
                             SelectedItem="{Binding SelectedArticle}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,6"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <DockPanel LastChildFill="True">
                                            <Border DockPanel.Dock="Right"
                                                    Background="{DynamicResource AccentLightBrush}"
                                                    CornerRadius="10"
                                                    Padding="8,2"
                                                    Margin="8,0,0,0">
                                                <TextBlock Text="{Binding SourceName}"
                                                           FontSize="{DynamicResource FS10}"
                                                           Foreground="{DynamicResource AccentDarkBrush}"/>
                                            </Border>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="{DynamicResource FS13}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                        </DockPanel>

                                        <TextBlock Text="{Binding Summary}"
                                                   Margin="0,6,0,0"
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                   TextWrapping="Wrap"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding PublishedAtUtc, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                                       FontSize="{DynamicResource FS10}"
                                                       Foreground="{DynamicResource MutedForegroundBrush}"/>
                                            <Border Background="{DynamicResource WarningLightBrush}"
                                                    CornerRadius="8"
                                                    Padding="6,1"
                                                    Margin="8,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsImportant}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{DynamicResource NewsImportant}"
                                                           FontSize="{DynamicResource FS9}"
                                                           Foreground="{DynamicResource WarningBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="12,12,0,0"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="14,12">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding ArticlePanelTitle}"
                                               FontSize="{DynamicResource FS16}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SelectedArticleMeta}"
                                               Margin="0,4,0,0"
                                               FontSize="{DynamicResource FS11}"
                                               Foreground="{DynamicResource MutedForegroundBrush}"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Command="{Binding OpenOriginalCommand}"
                                        Padding="10,6"
                                        Margin="12,0,0,0"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="{DynamicResource FS12}"
                                                   Margin="0,0,6,0"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="{DynamicResource NewsOpenOriginal}"
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          Height="32"
                                          ItemsSource="{Binding TranslationLanguages}"
                                          SelectedItem="{Binding SelectedTranslationLanguage}"
                                          DisplayMemberPath="DisplayName"
                                          FontSize="{DynamicResource FS11}"/>

                                <Button Grid.Column="2"
                                        Command="{Binding TranslateSelectedArticleCommand}"
                                        Padding="10,6"
                                        Background="{DynamicResource AccentBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        Foreground="White">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8D0;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="{DynamicResource FS12}"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Text="{DynamicResource NewsTranslate}"
                                                   FontSize="{DynamicResource FS11}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="4"
                                        Command="{Binding AnalyzeSelectedArticleCommand}"
                                        Padding="10,6"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1"
                                        Foreground="{DynamicResource AccentDarkBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7BA;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="{DynamicResource FS12}"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Text="{DynamicResource NewsAiAnalyze}"
                                                   FontSize="{DynamicResource FS11}"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>

                                <Border Grid.Column="6"
                                        Background="{DynamicResource ContentBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="2">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding ShowOriginalCommand}"
                                                Padding="10,5"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOriginalView}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentDarkBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="{DynamicResource NewsViewOriginal}" FontSize="{DynamicResource FS11}"/>
                                        </Button>

                                        <Button Command="{Binding ShowTranslatedCommand}"
                                                Padding="10,5"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowTranslatedArticle}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentDarkBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="{DynamicResource NewsViewTranslated}" FontSize="{DynamicResource FS11}"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <wv2:WebView2 x:Name="ArticleWebView" Margin="0">
                            <wv2:WebView2.Style>
                                <Style TargetType="wv2:WebView2">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowTranslatedArticle}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </wv2:WebView2.Style>
                        </wv2:WebView2>

                        <ScrollViewer Margin="0"
                                      VerticalScrollBarVisibility="Auto"
                                      Background="{DynamicResource ContentBackgroundBrush}">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowTranslatedArticle}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>

                            <TextBlock Text="{Binding TranslatedArticleBody}"
                                       Padding="20,18,20,24"
                                       TextWrapping="Wrap"
                                       LineHeight="24"
                                       FontSize="{DynamicResource FS12}"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                        </ScrollViewer>

                        <Border Background="{DynamicResource ContentBackgroundBrush}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedArticle}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding SelectedArticleSummary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="360"
                                       Foreground="{DynamicResource MutedForegroundBrush}">
                            </TextBlock>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1,1,0,0"
                            Padding="10,8"
                            CornerRadius="0,0,12,12">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAiPanelOpen}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{DynamicResource NewsAiAssistantTitle}"
                                           FontSize="{DynamicResource FS13}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           VerticalAlignment="Center"/>

                                <Button Grid.Column="1"
                                        Command="{Binding CloseAiPanelCommand}"
                                        Width="28"
                                        Height="28"
                                        Margin="8,0,0,0"
                                        HorizontalAlignment="Right"
                                        Background="{DynamicResource ContentBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        ToolTip="{DynamicResource NewsAiClose}">
                                    <TextBlock Text="&#xE711;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="{DynamicResource FS12}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </Grid>

                            <TextBlock Text="{DynamicResource NewsAiEmpty}"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       FontSize="{DynamicResource FS11}"
                                       Foreground="{DynamicResource MutedForegroundBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding HasAiInsight}" Value="False"/>
                                                    <Condition Binding="{Binding HasAiConversation}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <StackPanel Margin="0,6,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasAiInsight}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <Border Background="{DynamicResource ContentBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="10,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="26"
                                                Height="26"
                                                Margin="0,0,8,0"
                                                CornerRadius="13"
                                                Background="{DynamicResource AccentBrush}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="AI"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="{DynamicResource FS10}"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{DynamicResource NewsAiSummaryTitle}"
                                                       FontSize="{DynamicResource FS11}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                            <TextBlock Text="{Binding AiSummary}"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap"
                                                       FontSize="{DynamicResource FS11}"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Expander Header="{DynamicResource NewsAiKeyPointsTitle}"
                                          Margin="0,6,0,0"
                                          Background="{DynamicResource ContentBackgroundBrush}"
                                          BorderBrush="{DynamicResource CardBorderBrush}"
                                          BorderThickness="1"
                                          Padding="8,4">
                                    <ItemsControl ItemsSource="{Binding AiKeyPoints}" Margin="2,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Margin="0,2,0,0"
                                                           TextWrapping="Wrap"
                                                           FontSize="{DynamicResource FS11}"
                                                           Foreground="{DynamicResource ForegroundBrush}">
                                                    <Run Text="• "/>
                                                    <Run Text="{Binding .}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </StackPanel>

                            <TextBlock Text="{DynamicResource NewsAiConversationTitle}"
                                       Margin="0,8,0,0"
                                       FontSize="{DynamicResource FS11}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>

                            <Border Margin="0,6,0,0"
                                    Background="{DynamicResource ContentBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="8">
                                <ScrollViewer MaxHeight="140"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding AiConversationMessages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="10,8"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        MaxWidth="520"
                                                        HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                                            <Setter Property="Margin" Value="0,0,56,8"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                                    <Setter Property="Margin" Value="56,0,0,8"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="22"
                                                                    Height="22"
                                                                    CornerRadius="11"
                                                                    VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                                <Setter Property="Background" Value="White"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding Header}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="{DynamicResource FS9}"
                                                                           FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentDarkBrush}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                            <TextBlock Text="{Binding Header}"
                                                                       Margin="6,2,0,0"
                                                                       FontSize="{DynamicResource FS10}"
                                                                       FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                                <Setter Property="Foreground" Value="White"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Text}"
                                                                   Margin="0,6,0,0"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="{DynamicResource FS11}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                                                    <Setter Property="FontStyle" Value="Normal"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsPending}" Value="True">
                                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <Border Margin="0,8,0,0"
                                    Background="{DynamicResource ContentBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox x:Name="AiQuestionTextBox"
                                             Grid.Column="0"
                                             Text="{Binding AiQuestion, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="34"
                                             VerticalContentAlignment="Center"
                                             FontSize="{DynamicResource FS11}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             PreviewKeyDown="AiQuestionTextBox_PreviewKeyDown"
                                             ToolTip="{DynamicResource NewsAiAskPlaceholder}"/>

                                    <Button Grid.Column="2"
                                            Command="{Binding AskAboutArticleCommand}"
                                            Padding="10,6"
                                            BorderThickness="0"
