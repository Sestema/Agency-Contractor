                                        <TextBlock Text="{DynamicResource SettingsPostgresDbLabel}"
                                                   FontSize="{DynamicResource FS10}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                                        <TextBox Text="{Binding PostgresDatabase, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,4,0,0"
                                                 Padding="8,5"
                                                 FontSize="{DynamicResource FS12}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{DynamicResource SettingsUserLabel}"
                                                   FontSize="{DynamicResource FS10}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                                        <TextBox Text="{Binding PostgresUsername, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,4,0,0"
                                                 Padding="8,5"
                                                 FontSize="{DynamicResource FS12}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="{DynamicResource SettingsPasswordLabel}"
                                                   FontSize="{DynamicResource FS10}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                                        <TextBox Text="{Binding PostgresPassword, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,4,0,0"
                                                 Padding="8,5"
                                                 FontSize="{DynamicResource FS12}"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <Button Command="{Binding TestPostgresConnectionCommand}"
                                        Padding="14,8"
                                        Foreground="White"
                                        Style="{StaticResource FilledActionButton}">
                                    <TextBlock Text="{DynamicResource SettingsPostgresTest}"
                                               FontSize="{DynamicResource FS12}"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Button>
                                <TextBlock Text="{Binding PostgresTestStatus}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           TextWrapping="Wrap"
                                           MaxWidth="720"/>
                            </StackPanel>

                            <Border Margin="0,14,0,0"
                                    Padding="12,10"
                                    CornerRadius="12"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource SettingsMigrationTitle}"
                                               FontSize="{DynamicResource FS12}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{DynamicResource SettingsMigrationDesc}"
                                               Margin="0,4,0,10"
                                               FontSize="{DynamicResource FS11}"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding RunPostgresMigrationCommand}"
                                                IsEnabled="{Binding CanRunPostgresMigration}"
                                                Padding="14,8"
                                                Foreground="White"
                                                Style="{StaticResource FilledActionButton}">
                                            <TextBlock Text="{Binding PostgresMigrationActionText}"
                                                       FontSize="{DynamicResource FS12}"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                        </Button>
                                        <TextBlock Text="{Binding PostgresMigrationStatus}"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="700"/>
                                    </StackPanel>

                                    <Border Margin="0,12,0,0"
                                            Padding="10,8"
                                            CornerRadius="10"
                                            BorderBrush="#B91C1C"
                                            BorderThickness="1"
                                            Background="{DynamicResource CardBackgroundBrush}">
                                        <StackPanel>
                                            <TextBlock Text="{DynamicResource SettingsRepeatMigrationTitle}"
                                                       FontSize="{DynamicResource FS11}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#F87171"/>
                                            <TextBlock Text="{DynamicResource SettingsRepeatMigrationDesc}"
                                                       Margin="0,4,0,8"
                                                       FontSize="{DynamicResource FS11}"
                                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                                       TextWrapping="Wrap"/>
                                            <Button Command="{Binding ReplacePostgresFromSqliteCommand}"
                                                    IsEnabled="{Binding CanReplacePostgresFromSqlite}"
                                                    Padding="14,8"
                                                    HorizontalAlignment="Left"
                                                    Style="{StaticResource DialogAccentSoftButton}">
                                                <TextBlock Text="{Binding ReplacePostgresFromSqliteActionText}"
                                                           FontSize="{DynamicResource FS12}"
                                                           FontWeight="SemiBold"
                                                           Foreground="#B91C1C"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,14,0,0"
                                    Padding="12,10"
                                    CornerRadius="12"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource SettingsSqliteBackupTitle}"
                                               FontSize="{DynamicResource FS12}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{DynamicResource SettingsSqliteBackupDesc}"
                                               Margin="0,4,0,10"
                                               FontSize="{DynamicResource FS11}"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding CreateSqliteBackupFromPostgresCommand}"
                                                IsEnabled="{Binding CanCreateSqliteBackupFromPostgres}"
                                                Padding="14,8"
                                                Style="{StaticResource DialogAccentSoftButton}">
                                            <TextBlock Text="{DynamicResource SettingsSqliteBackupButton}"
                                                       FontSize="{DynamicResource FS12}"
                                                       FontWeight="SemiBold"/>
                                        </Button>
                                        <TextBlock Text="{Binding SqliteBackupFromPostgresStatus}"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="680"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,14,0,0"
                                    Padding="12,10"
                                    CornerRadius="12"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="#B91C1C"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource SettingsPostgresResetTitle}"
                                               FontSize="{DynamicResource FS12}"
                                               FontWeight="SemiBold"
                                               Foreground="#F87171"/>
                                    <TextBlock Text="{Binding PostgresResetHint}"
                                               Margin="0,4,0,10"
                                               FontSize="{DynamicResource FS11}"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding ResetPostgresDatabaseCommand}"
                                                IsEnabled="{Binding CanResetPostgresDatabase}"
                                                Padding="14,8"
                                                Style="{StaticResource DialogAccentSoftButton}">
                                            <TextBlock Text="{DynamicResource SettingsPostgresResetButton}"
                                                       FontSize="{DynamicResource FS12}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#B91C1C"/>
                                        </Button>
                                        <TextBlock Text="{Binding PostgresResetStatus}"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="680"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- System Section -->
            <Border Grid.Row="14" Style="{StaticResource SettingsSectionCard}" Visibility="Collapsed">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource DialogPreviewSurface}" Padding="16,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource SuccessChipBackgroundBrush}">
                                        <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                                   Foreground="{DynamicResource SuccessChipForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource SettingsAccessTitle}"
                                                   FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="{Binding AccessStatusTitle}"
                                                   FontSize="{DynamicResource FS12}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   Margin="0,2,0,0"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding AccessStatusDetail}"
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"/>

                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,8,0,0"
                                                    Visibility="{Binding HasAccessPlan, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{DynamicResource SettingsPlanLabel}"
                                                       FontSize="{DynamicResource FS11}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource MutedForegroundBrush}"/>
                                            <Border Margin="8,0,0,0"
                                                    Padding="10,4"
                                                    CornerRadius="999"
                                                    BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource WarningChipBackgroundBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource WarningChipBorderBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AccessPlanCode}" Value="standard">
                                                                <Setter Property="Background" Value="{DynamicResource InfoChipBackgroundBrush}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource InfoChipBorderBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding AccessPlanCode}" Value="pro">
                                                                <Setter Property="Background" Value="{DynamicResource SuccessChipBackgroundBrush}"/>
                                                                <Setter Property="BorderBrush" Value="{DynamicResource SuccessChipBorderBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding AccessPlanDisplay}"
                                                           FontSize="{DynamicResource FS11}"
                                                           FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource WarningChipForegroundBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AccessPlanCode}" Value="standard">
                                                                    <Setter Property="Foreground" Value="{DynamicResource InfoChipForegroundBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding AccessPlanCode}" Value="pro">
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessChipForegroundBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}">
                                            <Run Text="ID: "/>
                                            <Run Text="{Binding MachineId, Mode=OneWay}"/>
                                        </TextBlock>
                                        <Border Margin="0,8,0,0"
                                                Padding="8,6"
                                                CornerRadius="6"
                                                Background="{DynamicResource CardBackgroundBrush}"
                                                Visibility="{Binding HasAccessStatusAdminMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource AccessStatusAdminMessageLabel}"
                                                           FontSize="{DynamicResource FS10}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource MutedForegroundBrush}"/>
                                                <TextBlock Text="{Binding AccessStatusAdminMessage}"
                                                           Margin="0,2,0,0"
                                                           FontSize="{DynamicResource FS11}"
                                                           Foreground="{DynamicResource ForegroundBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource DialogPreviewSurface}" Padding="16,14">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource InfoChipBackgroundBrush}">
                                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                                   Foreground="{DynamicResource InfoChipForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource SettingsUpdateTitle}"
                                                   FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="{DynamicResource SettingsUpdateDesc}"
                                                   FontSize="{DynamicResource FS11}" Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding CheckForUpdatesCommand}"
                                            Padding="14,8"
                                            Foreground="White"
                                            Style="{StaticResource FilledActionButton}">
                                        <TextBlock Text="{DynamicResource SettingsUpdateBtn}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold" Foreground="White"/>
                                    </Button>
                                    <Button Command="{Binding InstallUpdateCommand}"
                                            Padding="14,8"
                                            Background="{DynamicResource SuccessBrush}"
                                            Foreground="White"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource FilledActionButton}"
                                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{DynamicResource SettingsInstallBtn}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold" Foreground="White"/>
                                    </Button>
                                </StackPanel>

                                <TextBlock Text="{Binding UpdateStatus}" FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Copyright Card -->
            <Border Grid.Row="15" Style="{StaticResource SettingsSectionCard}" Padding="18,16"
                    Visibility="{Binding IsProgramSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource SurfaceBrush}">
                            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                       Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource SettingsCopyrightTitle}" 
                                   FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource SettingsCopyrightText}"
                               FontSize="{DynamicResource FS12}" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,2,0,2"/>
                    <TextBlock Text="{DynamicResource SettingsCopyrightDesc}"
                               FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>

    <!-- ===== COMPANY VISIBILITY OVERLAY ===== -->
    <Grid Grid.RowSpan="2" Visibility="{Binding IsCompanyVisibilityOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border Background="{DynamicResource OverlayBrush}">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding CloseCompanyVisibilityCommand}"/>
            </Border.InputBindings>
        </Border>
        <Border Style="{StaticResource DialogSectionCard}"
                Padding="28,24" Width="480" MaxHeight="600"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <!-- Header -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource InfoChipBackgroundBrush}">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource InfoChipForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource SettingsFirmsVisibilityTitle}"
                                   FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding CloseCompanyVisibilityCommand}" Cursor="Hand"
                            VerticalAlignment="Center" Width="36" Height="36"
                            Style="{StaticResource HeaderGhostButton}">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                   Foreground="{DynamicResource ForegroundBrush}" Opacity="0.7"/>
                    </Button>
                </Grid>

                <!-- Hint -->
                <TextBlock Text="{DynamicResource SettingsFirmsVisibilityHint}"
                           FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}"
                           Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- Company list -->
                <ScrollViewer MaxHeight="360" Style="{StaticResource ThinScroll}">
                    <ItemsControl ItemsSource="{Binding CompanyVisibilityItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Checkbox -->
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsVisible}"
                                                  IsEnabled="{Binding HasActiveEmployees, Converter={StaticResource InverseBoolConverter}}"
                                                  VerticalAlignment="Center" Margin="0,0,12,0"/>

                                        <!-- Company name -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{DynamicResource FS14}" FontWeight="Medium"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                            <!-- Warning if has active employees -->
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding HasActiveEmployees, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                           Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" Margin="0,2,4,0"/>
                                                <TextBlock FontSize="{DynamicResource FS11}" Foreground="{DynamicResource WarningBrush}" Margin="0,2,0,0">
                                                    <Run Text="{DynamicResource SettingsFirmsHasEmployees}"/>
                                                    <Run Text="{Binding ActiveEmployeeCount, Mode=OneWay}"/>
                                                    <Run Text="{DynamicResource SettingsFirmsEmployeesCount}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Active count badge -->
                                        <Border Grid.Column="2" Background="{DynamicResource InfoChipBackgroundBrush}" CornerRadius="10"
                                                Padding="10,3" VerticalAlignment="Center"
                                                Visibility="{Binding HasActiveEmployees, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding ActiveEmployeeCount, Mode=OneWay}"
                                                       FontSize="{DynamicResource FS12}" FontWeight="Bold"
                                                       Foreground="{DynamicResource InfoChipForegroundBrush}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- OK button -->
                <Button Command="{Binding CloseCompanyVisibilityCommand}" Cursor="Hand"
                        HorizontalAlignment="Center" Margin="0,16,0,0" MinWidth="120"
                        Padding="32,12" Style="{StaticResource FilledActionButton}">
                    <TextBlock Text="OK"
                               FontSize="{DynamicResource FS14}" FontWeight="SemiBold" Foreground="White"
                               HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>

    </Grid>
</UserControl>
