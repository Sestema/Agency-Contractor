    <sys:String x:Key="InvoicesDashboardDocumentsDescription">This section collects all document types: invoices, quotes, orders, delivery notes, and cash receipts.</sys:String>
    <sys:String x:Key="InvoicesDashboardCompaniesDescription">A separate directory of your companies for supplier details, numbering, and future ARES filling.</sys:String>
    <sys:String x:Key="InvoicesDashboardCustomersDescription">Customers are stored separately from the rest of the program so the Faktury module stays fully independent.</sys:String>
    <sys:String x:Key="InvoicesDashboardStatisticsDescription">A dedicated place for statistics, trash, and overall document state monitoring.</sys:String>
    <sys:String x:Key="InvoicesDashboardSectionsTitle">Quick sections</sys:String>
    <sys:String x:Key="InvoicesDashboardSectionsHint">Choose the part of the module you want to work with right now.</sys:String>
    <sys:String x:Key="InvoicesDashboardCardDocumentsHint">Overview of all documents, filters, statuses, and follow-up actions for invoices.</sys:String>
    <sys:String x:Key="InvoicesDashboardRecentDocumentsTitle">Recent documents</sys:String>
    <sys:String x:Key="InvoicesDashboardRecentDocumentsHint">A quick list of recently updated documents that you can open immediately.</sys:String>
    <sys:String x:Key="InvoicesDashboardRecentDocumentsEmpty">No saved documents yet.</sys:String>
    <sys:String x:Key="InvoicesOpenSection">Open</sys:String>
    <sys:String x:Key="InvoicesDocumentsSubtitle">All Faktury documents with filters and quick creation.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderCompanies">This section will hold the standalone company directory for Faktury.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderCompaniesHint">It will contain supplier details, templates, document language, numbering series, and future ARES lookup by IČO.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderCustomers">This section will hold the standalone customer directory for Faktury.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderCustomersHint">Customers will have their own separate database with addresses, IČO, DIČ, and quick insertion into invoices and other documents.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderItems">This section will hold items and services.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderItemsHint">Items will help assemble documents quickly without repeatedly typing the same goods or services.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderBankAccounts">This section will hold bank accounts.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderBankAccountsHint">Bank accounts will store IBAN, SWIFT, account names, and default payment parameters for documents.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderTags">This section will hold tags.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderTagsHint">Tags will let you group documents by work type, customer, project, or internal categories.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderTemplates">This section will hold Faktury templates.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderTemplatesHint">Templates will contain document design, logos, stamps, signatures, and per-document-type layouts.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderSettings">This section will hold Faktury settings.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderSettingsHint">This is where the default document language, numbering series, PDF parameters, and new document behavior will live.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderTrash">This section will hold the Faktury document trash.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderTrashHint">The trash will keep deleted JSON and PDF documents separately from the rest of the program.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderStatistics">This section will hold Faktury statistics.</sys:String>
    <sys:String x:Key="InvoicesPlaceholderStatisticsHint">Statistics will show document volumes by type, drafts, overdue documents, and other important metrics.</sys:String>
