<UserControl x:Class="Win11DesktopApp.Views.CandidateDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             mc:Ignorable="d"
             d:DesignWidth="880">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FS11}"/>
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="{DynamicResource FS13}"/>
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        </Style>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource ThinScroll}">
        <StackPanel Margin="28,24,28,28">

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding CloseCommand}" Style="{StaticResource HeaderBackButton}" Margin="0,0,10,0">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                    </Button>
                    <Border Style="{StaticResource PageHeaderIconBadge}" Background="#FFB74D">
                        <TextBlock Text="&#xE77B;" Style="{StaticResource PageHeaderIconText}"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FullName}" FontSize="{DynamicResource FS24}" Style="{StaticResource PageHeaderTitleText}"/>
                        <TextBlock FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Margin="0,3,0,0">
                            <Run Text="{DynamicResource CandAddedOn}"/>
                            <Run Text="{Binding Data.DateAdded}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding CloseCommand}"
                        Style="{StaticResource HeaderGhostButton}"
                        Width="36" Height="36"
                        ToolTip="{DynamicResource BtnCancel}">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                </Button>
            </Grid>

            <!-- ===== HERO: Photo + Personal Data side by side ===== -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Large square photo -->
                <Border Grid.Column="0" Width="160" Height="160" CornerRadius="12" ClipToBounds="True"
                        Margin="0,0,22,0" Cursor="Hand"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.15" Color="#000"/>
                    </Border.Effect>
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding BrowsePhotoCommand}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Border Background="#E8EAF6" CornerRadius="12">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                           Foreground="#9FA8DA" HorizontalAlignment="Center"/>
                                <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="#B0B8E8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Image Source="{Binding PhotoImage}" Stretch="UniformToFill" Width="160" Height="160"/>
                    </Grid>
                </Border>

                <!-- Personal info to the right of photo -->
                <Border Grid.Column="1" Style="{StaticResource SectionCard}" Margin="0">
                    <StackPanel>
                        <!-- Section header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Background="#E3F2FD" CornerRadius="6" Width="26" Height="26" Margin="0,0,8,0">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{DynamicResource CandPersonalSection}" FontSize="{DynamicResource FS13}" 
                                       FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Name row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource CandFirstName}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource FieldInput}"
                                         Text="{Binding Data.FirstName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource CandLastName}" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource FieldInput}"
                                         Text="{Binding Data.LastName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Phone -->
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="{DynamicResource CandPhone}" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldInput}"
                                     Text="{Binding Data.Phone, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Date added -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="#BBBBBB" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock FontSize="{DynamicResource FS11}" Foreground="#BBBBBB">
                                <Run Text="{DynamicResource CandAddedOn}"/>
                                <Run Text="{Binding Data.DateAdded, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== Two-column: Passport + Work ===== -->
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Passport section -->
                <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Background="#FFF3E0" CornerRadius="6" Width="26" Height="26" Margin="0,0,8,0">
                                <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="#E65100" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{DynamicResource CandPassport}" FontSize="{DynamicResource FS13}" 
                                       FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="{DynamicResource CandPassportNum}" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldInput}"
                                     Text="{Binding Data.PassportNumber, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="{DynamicResource CandPassportCountry}" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldInput}"
                                     Text="{Binding Data.PassportCountry, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Passport photo -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="8" 
                                    MinHeight="40" Padding="6"
                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                <Image Source="{Binding PassportPreviewPath}" MaxHeight="140" Stretch="Uniform"
                                       HorizontalAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="1" Command="{Binding BrowsePassportCommand}" 
                                    Width="34" Height="34" Margin="6,0,0,0"
                                    Background="{DynamicResource WindowBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                    Cursor="Hand" VerticalAlignment="Top" ToolTip="{DynamicResource CandChangePassport}">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13" 
                                           Foreground="{DynamicResource AccentBrush}"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Work section -->
                <Border Grid.Column="2" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Background="#E8F5E9" CornerRadius="6" Width="26" Height="26" Margin="0,0,8,0">
                                <TextBlock Text="&#xE821;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="#2E7D32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{DynamicResource CandWorkSection}" FontSize="{DynamicResource FS13}" 
                                       FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="{DynamicResource CandPosition}" Style="{StaticResource FieldLabel}"/>
                            <TextBox Style="{StaticResource FieldInput}"
                                     Text="{Binding Data.DesiredPosition, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="{DynamicResource CandLocation}" Style="{StaticResource FieldLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <RadioButton Content="{DynamicResource CandAllCzech}" IsChecked="{Binding IsAllCzech}" Margin="0,0,16,0"
                                             Foreground="{DynamicResource ForegroundBrush}" FontSize="{DynamicResource FS12}"/>
                                <RadioButton Content="{DynamicResource CandSpecific}" IsChecked="{Binding IsSpecificLocation}"
                                             Foreground="{DynamicResource ForegroundBrush}" FontSize="{DynamicResource FS12}"/>
                            </StackPanel>
                            <TextBox Style="{StaticResource FieldInput}" Margin="0,8,0,0"
                                     Visibility="{Binding IsSpecificLocation, Converter={StaticResource BoolToVis}}"
                                     Text="{Binding Data.LocationDetails, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Notes inside work section to balance columns -->
                        <StackPanel Margin="0,14,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Border Background="#F3E5F5" CornerRadius="6" Width="26" Height="26" Margin="0,0,8,0">
                                    <TextBlock Text="&#xE70B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               Foreground="#7B1FA2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource CandNotes}" FontSize="{DynamicResource FS13}" 
                                           FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBox Height="80" AcceptsReturn="True" TextWrapping="Wrap" 
                                     VerticalContentAlignment="Top" Padding="10,8"
                                     FontSize="{DynamicResource FS13}"
                                     Background="{DynamicResource WindowBackgroundBrush}"
                                     BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     Text="{Binding Data.Notes, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== ACTION BUTTONS ===== -->
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding DeleteCommand}" Height="38" Padding="18,0"
                        Cursor="Hand" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#FFEBEE" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                    Height="{TemplateBinding Height}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13" 
                                               Foreground="#D32F2F" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource CandDelete}" FontSize="{DynamicResource FS12}" 
                                               FontWeight="SemiBold" Foreground="#D32F2F" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FFCDD2"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Command="{Binding CloseCommand}"
                            Style="{StaticResource HeaderGhostButton}"
                            Margin="0,0,8,0"
                            Padding="16,8">
                        <TextBlock Text="{DynamicResource BtnCancel}" FontSize="{DynamicResource FS12}"/>
                    </Button>
                    <Button Command="{Binding SaveCommand}"
                            Style="{StaticResource FilledActionButton}"
                            Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource BtnSave}" FontSize="{DynamicResource FS12}"
                                       FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
