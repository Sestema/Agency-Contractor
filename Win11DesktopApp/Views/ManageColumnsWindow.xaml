<Window x:Class="Win11DesktopApp.Views.ManageColumnsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource FinManageColumnsTitle}"
        Width="520" Height="560" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="{DynamicResource FinManageColumnsTitle}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundBrush}"/>
            <TextBlock Text="{DynamicResource FinManageColumnsDesc}" FontSize="{DynamicResource FS11}" Foreground="#888" Margin="0,4,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Existing fields list -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="6">
            <ListBox x:Name="FieldsList" ItemsSource="{Binding}" Background="Transparent" BorderThickness="0"
                     HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="8" Padding="10,7" Margin="0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"
                                           HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}">
                                            <Binding Path="OperationSymbol"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="{DynamicResource FS13}"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{Binding FirmDisplay}" FontSize="{DynamicResource FS10}" Foreground="#888"/>
                                </StackPanel>

                                <Button Grid.Column="2" Content="&#xE70F;" FontFamily="Segoe MDL2 Assets"
                                        Tag="{Binding Id}" Click="EditField_Click"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Foreground="{DynamicResource AccentBrush}" FontSize="14"
                                        Padding="8,4" Margin="4,0" VerticalAlignment="Center"/>

                                <Button Grid.Column="3" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                        Tag="{Binding Id}" Click="DeleteField_Click"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Foreground="#E53935" FontSize="14"
                                        Padding="8,4" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Add new field panel -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                Padding="14,10" Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="NewFieldName" Grid.Column="0" Padding="8,6" FontSize="{DynamicResource FS13}" Margin="0,0,8,0"
                             VerticalContentAlignment="Center"/>

                    <ComboBox x:Name="NewFieldOperation" Grid.Column="1" Width="120" Padding="6,5" FontSize="{DynamicResource FS13}"
                              SelectedIndex="1">
                        <ComboBoxItem Content="+ Dodávat" Tag="Add"/>
                        <ComboBoxItem Content="− Odečítat" Tag="Subtract"/>
                        <ComboBoxItem Content="× Násobit" Tag="Multiply"/>
                        <ComboBoxItem Content="÷ Dělit" Tag="Divide"/>
                    </ComboBox>
                </Grid>

                <Grid Grid.Row="1" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="NewFieldFirm" Grid.Column="0" Padding="6,5" FontSize="{DynamicResource FS12}" Margin="0,0,8,0"/>

                    <Button Grid.Column="1" Click="AddField_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="8" Padding="16,7">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{DynamicResource FinBtnAddField}" FontSize="{DynamicResource FS12}"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Click="Close_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="8" Padding="24,9">
                            <TextBlock Text="{DynamicResource BtnDone}" FontSize="{DynamicResource FS13}" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
