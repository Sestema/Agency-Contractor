                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource InvoicesStampCompany}" Style="{StaticResource InvoiceFieldLabel}"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" Style="{StaticResource CompactComboBox}" ItemsSource="{Binding AssetOptions}" SelectedItem="{Binding SelectedStampAssetName}"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource InvoicesIssuedBy}" Style="{StaticResource InvoiceFieldLabel}"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource CompactTextBox}" Text="{Binding IssuedBy}"/>
                                    </Grid>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InvoiceSectionCard}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource InvoicesInvoiceItemsSection}" Style="{StaticResource InvoiceSectionTitle}"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" Style="{StaticResource CompactComboBox}" ItemsSource="{Binding AvailableItems}" SelectedItem="{Binding SelectedCatalogItem}" DisplayMemberPath="Name"/>
                                    <Button Grid.Column="1" Command="{Binding InsertSelectedCatalogItemCommand}" Style="{StaticResource FilledActionButton}" MinWidth="34" Margin="8,0,0,6" Padding="10,5">
                                        <TextBlock Text="+" FontSize="{DynamicResource FS14}" FontWeight="Bold"/>
                                    </Button>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource InvoicesItemDescription}" Style="{StaticResource InvoiceFieldLabel}"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource InvoicesItemUnit}" Style="{StaticResource InvoiceFieldLabel}"/>
                                    <TextBlock Grid.Column="2" Text="{DynamicResource InvoicesItemQuantity}" Style="{StaticResource InvoiceFieldLabel}"/>
                                    <TextBlock Grid.Column="3" Text="{DynamicResource InvoicesItemUnitPrice}" Style="{StaticResource InvoiceFieldLabel}"/>
                                    <TextBlock Grid.Column="4" Text="{DynamicResource InvoicesItemTotal}" Style="{StaticResource InvoiceFieldLabel}"/>
                                </Grid>

                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="6" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="4*"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="32"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Padding="6,4" MinHeight="36" Margin="0,0,8,0"/>
                                                    <TextBox Grid.Column="1" Text="{Binding Unit, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Margin="0,0,8,0"/>
                                                    <TextBox Grid.Column="2" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Margin="0,0,8,0"/>
                                                    <TextBox Grid.Column="3" Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" Padding="6,4" Margin="0,0,8,0"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding TotalAmount}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                    <Button Grid.Column="5"
                                                            Command="{Binding DataContext.RemoveLineItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource HeaderGhostButton}"
                                                            Padding="4,2"
                                                            HorizontalAlignment="Right">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <WrapPanel Margin="0,4,0,0">
                                    <Button Command="{Binding AddLineItemCommand}" Style="{StaticResource FilledActionButton}" Margin="0,0,8,8" Padding="12,6">
                                        <TextBlock Text="{DynamicResource InvoicesAddItem}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"/>
                                    </Button>
                                    <Button Command="{Binding AddTextItemCommand}" Style="{StaticResource HeaderGhostButton}" Margin="0,0,8,8" Padding="12,6">
                                        <TextBlock Text="{DynamicResource InvoicesAddTextItem}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"/>
                                    </Button>
                                </WrapPanel>

                                <StackPanel HorizontalAlignment="Right" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding TotalAmountLabel}" FontSize="{DynamicResource FS14}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding DiscountAmountLabel}" FontSize="{DynamicResource FS13}" Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Right" Margin="0,3,0,0"/>
                                    <TextBlock Text="{Binding AmountToPayLabel}" FontSize="{DynamicResource FS18}" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <Border Style="{StaticResource InvoiceSectionCard}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource InvoicesTagsSection}" Style="{StaticResource InvoiceSectionTitle}"/>
                            <WrapPanel Margin="0,0,0,10">
                                <ItemsControl ItemsSource="{Binding Tags}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="14" Margin="0,0,8,8" Padding="10,5">
                                                <DockPanel>
                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                                    <Button DockPanel.Dock="Right"
                                                            Command="{Binding DataContext.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource HeaderGhostButton}"
                                                            Padding="4,0"
                                                            Margin="8,0,0,0"
                                                            MinWidth="20">
                                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}"/>
                                                    </Button>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </WrapPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          Style="{StaticResource CompactComboBox}"
                                          ItemsSource="{Binding AvailableTagSuggestions}"
                                          Text="{Binding NewTag, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True"
                                          IsTextSearchEnabled="False"
                                          Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Command="{Binding AddTagCommand}" Style="{StaticResource FilledActionButton}" Padding="12,6">
                                    <TextBlock Text="{DynamicResource InvoicesTagAddButton}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource InvoiceSectionCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource InvoicesAppearanceSection}" Style="{StaticResource InvoiceSectionTitle}" Visibility="{Binding IsStandardInvoiceEditorMode, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{DynamicResource InvoicesCashReceiptAppearanceSection}" Style="{StaticResource InvoiceSectionTitle}" Visibility="{Binding IsCashReceiptMode, Converter={StaticResource BoolToVis}}"/>
                                <ListBox ItemsSource="{Binding AvailableTemplateOptions}" SelectedValuePath="Id" SelectedValue="{Binding SelectedTemplateId}" BorderThickness="0" Background="Transparent" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="86" Height="100" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,0,10,6">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Border Width="34" Height="42" BorderBrush="Black" BorderThickness="1.3" Margin="0,6,0,8">
                                                        <Grid>
                                                            <Rectangle Margin="4,5,4,0" Height="2" Fill="#D7D7D7" VerticalAlignment="Top"/>
                                                            <Rectangle Margin="4,11,4,0" Height="2" Fill="#D7D7D7" VerticalAlignment="Top"/>
                                                            <TextBlock Text="{Binding PreviewGlyph}" FontSize="{DynamicResource FS18}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" FontSize="{DynamicResource FS10}" TextAlignment="Center" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="18,30,0,0" Width="180" Visibility="{Binding CanEditThemeSelection, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{DynamicResource InvoicesThemeSelection}" Style="{StaticResource InvoiceFieldLabel}"/>
                                <ComboBox Style="{StaticResource CompactComboBox}" ItemsSource="{Binding ThemeOptions}" SelectedValuePath="Value" DisplayMemberPath="Label" SelectedValue="{Binding SelectedTheme}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InvoiceSectionCard}" Visibility="{Binding IsStandardInvoiceEditorMode, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource InvoicesCreateAlsoWithInvoiceSection}" Style="{StaticResource InvoiceSectionTitle}"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="230"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="2" Text="{DynamicResource InvoicesReceiptDocumentNumberColumn}" Style="{StaticResource InvoiceFieldLabel}" Margin="0,3,0,0"/>
                                <TextBlock Grid.Column="3" Text="{DynamicResource InvoicesPurposeColumn}" Style="{StaticResource InvoiceFieldLabel}" Margin="0,3,0,0"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="230"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding CreateIncomeReceipt}" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                <TextBlock Grid.Column="1" Text="{DynamicResource InvoicesLinkedIncomeReceipt}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" Style="{StaticResource CompactTextBox}" Text="{Binding LinkedIncomeReceiptNumber}" Visibility="{Binding CreateIncomeReceipt, Converter={StaticResource BoolToVis}}" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource CompactTextBox}" Text="{Binding LinkedIncomeReceiptPurpose}" Visibility="{Binding CreateIncomeReceipt, Converter={StaticResource BoolToVis}}" Margin="0,0,0,0"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="230"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding CreateExpenseReceipt}" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                <TextBlock Grid.Column="1" Text="{DynamicResource InvoicesLinkedExpenseReceipt}" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" Style="{StaticResource CompactTextBox}" Text="{Binding LinkedExpenseReceiptNumber}" Visibility="{Binding CreateExpenseReceipt, Converter={StaticResource BoolToVis}}" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource CompactTextBox}" Text="{Binding LinkedExpenseReceiptPurpose}" Visibility="{Binding CreateExpenseReceipt, Converter={StaticResource BoolToVis}}" Margin="0,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <WrapPanel HorizontalAlignment="Center" Margin="0,12,0,16">
                        <Button Command="{Binding SaveCommand}" Style="{StaticResource FilledActionButton}" Margin="0,0,10,0" Padding="22,12">
                            <TextBlock Text="{DynamicResource InvoicesSave}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"/>
                        </Button>
                        <Button Command="{Binding SaveAndPreviewCommand}" Style="{StaticResource FilledActionButton}" Padding="22,12">
                            <TextBlock Text="{DynamicResource InvoicesSaveAndPreview}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"/>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
