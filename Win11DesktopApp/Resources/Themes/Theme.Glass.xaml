<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#80F6F9FF"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#BFFFFFFF"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#121214"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#5E6670"/>
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="#72788A"/>
    <SolidColorBrush x:Key="TertiaryForegroundBrush" Color="#9AA0AE"/>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#80F6F9FF"/>
    <LinearGradientBrush x:Key="CardBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#BFFFFFFF" Offset="0"/>
        <GradientStop Color="#80FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="CardHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#D9FFFFFF" Offset="0"/>
        <GradientStop Color="#B3FFFFFF" Offset="1"/>
    </LinearGradientBrush>
    <!-- Glass rim: bright top → soft bottom so light appears to hit the top edge. -->
    <LinearGradientBrush x:Key="CardBorderBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#59FFFFFF" Offset="0"/>
        <GradientStop Color="#33FFFFFF" Offset="0.4"/>
        <GradientStop Color="#26000000" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="GlassInnerHighlightBrush" Color="#66FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#99F4F7FB"/>
    <SolidColorBrush x:Key="DividerBrush" Color="#33000000"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="#4D000000"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#007AFF"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#0056CC"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#D6EAFF"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#34C759"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="#DFFBE8"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FF9500"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="#FFF3D6"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF3B30"/>
    <SolidColorBrush x:Key="ErrorLightBrush" Color="#FFE5E3"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#5AC8FA"/>
    <SolidColorBrush x:Key="InfoLightBrush" Color="#E0F4FF"/>
    <SolidColorBrush x:Key="PurpleBrush" Color="#AF52DE"/>
    <SolidColorBrush x:Key="PurpleLightBrush" Color="#F3E5F9"/>
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#A0AAB8"/>
    <SolidColorBrush x:Key="StatusMessageBrush" Color="#666666"/>
    <SolidColorBrush x:Key="DangerOutlineBrush" Color="#FF3B30"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#D32F2F"/>
    <SolidColorBrush x:Key="ErrorChipBackgroundBrush" Color="#FFE5E3"/>
    <SolidColorBrush x:Key="ErrorChipBorderBrush" Color="#F5C2C7"/>
    <SolidColorBrush x:Key="ErrorChipForegroundBrush" Color="#CC3320"/>
    <SolidColorBrush x:Key="WarningChipBackgroundBrush" Color="#FFF4E5"/>
    <SolidColorBrush x:Key="WarningChipBorderBrush" Color="#F5C97A"/>
    <SolidColorBrush x:Key="WarningChipForegroundBrush" Color="#B54708"/>
    <SolidColorBrush x:Key="InfoChipBackgroundBrush" Color="#E0F4FF"/>
    <SolidColorBrush x:Key="InfoChipBorderBrush" Color="#B2CCFF"/>
    <SolidColorBrush x:Key="InfoChipForegroundBrush" Color="#175CD3"/>
    <SolidColorBrush x:Key="SuccessChipBackgroundBrush" Color="#DFFBE8"/>
    <SolidColorBrush x:Key="SuccessChipBorderBrush" Color="#C8E6C9"/>
    <SolidColorBrush x:Key="SuccessChipForegroundBrush" Color="#2E7D32"/>
    <SolidColorBrush x:Key="MutedDescriptionBrush" Color="#999999"/>

    <LinearGradientBrush x:Key="BrandPrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#007AFF" Offset="0"/>
        <GradientStop Color="#5856D6" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandPrimaryHorizontalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#007AFF" Offset="0"/>
        <GradientStop Color="#5856D6" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandSuccessGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#34C759" Offset="0"/>
        <GradientStop Color="#30D158" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandSuccessHorizontalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#34C759" Offset="0"/>
        <GradientStop Color="#30D158" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandWarmGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF9500" Offset="0"/>
        <GradientStop Color="#FF2D55" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandDangerGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF9500" Offset="0"/>
        <GradientStop Color="#FF3B30" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandInfoGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#5AC8FA" Offset="0"/>
        <GradientStop Color="#64D2FF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandInfoHorizontalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#5AC8FA" Offset="0"/>
        <GradientStop Color="#64D2FF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrandAiGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#AF52DE" Offset="0"/>
        <GradientStop Color="#5856D6" Offset="1"/>
    </LinearGradientBrush>

    <DropShadowEffect x:Key="CardShadow" BlurRadius="24" ShadowDepth="4" Direction="270" Color="#0A0E1C" Opacity="0.18"/>
    <DropShadowEffect x:Key="CardShadowHover" BlurRadius="36" ShadowDepth="10" Direction="270" Color="#0A0E1C" Opacity="0.26"/>
    <DropShadowEffect x:Key="DialogShadow" BlurRadius="56" ShadowDepth="18" Direction="270" Color="#05081A" Opacity="0.38"/>
</ResourceDictionary>
