<UserControl x:Class="Win11DesktopApp.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <conv:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBoolConverter"/>
        <!-- Active/inactive button style for language & theme selectors -->
        <Style x:Key="SelectorButton" TargetType="Button">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active version (accent bg) -->
        <Style x:Key="SelectorButtonActive" TargetType="Button" BasedOn="{StaticResource SelectorButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <!-- Themed ComboBox -->
        <Style x:Key="ThemedComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="{DynamicResource FS12}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="2">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleBtn" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" Background="{DynamicResource ContentBackgroundBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                               Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,6,28,6" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      SnapsToDevicePixels="True">
                                    <Border x:Name="DropDownBorder" Background="{DynamicResource CardBackgroundBrush}"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="2,4" Margin="0,4,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.15"/>
                                        </Border.Effect>
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Static Back Button -->
        <Button Grid.Row="0" Command="{Binding GoBackCommand}"
                HorizontalAlignment="Left" VerticalAlignment="Center"
                Margin="16,8,0,8"
                Background="Transparent" BorderThickness="0"
                Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource BtnBack}" FontSize="{DynamicResource FS14}" Margin="8,0,0,0"
                                       Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

    <ScrollViewer Grid.Row="1" Style="{StaticResource ThinScroll}">
        <Grid MaxWidth="1100" HorizontalAlignment="Center" Margin="48,32,48,48">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,32">
                <Border Background="{DynamicResource AccentBrush}" CornerRadius="10" Width="44" Height="44"
                        VerticalAlignment="Center">
                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS20}"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{DynamicResource SettingsTitle}" 
                           FontSize="{DynamicResource FS28}" FontWeight="SemiBold" 
                           Foreground="{DynamicResource ForegroundBrush}"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>

            <!-- Language Card -->
            <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="24,20" Margin="0,0,0,16"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="{DynamicResource AccentLightBrush}" CornerRadius="8" Width="36" Height="36"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource LangLabel}" 
                                       FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource SettingsLangHint}" 
                                       FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <WrapPanel Orientation="Horizontal">
                        <Button Content="🇺🇦 Українська" 
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="uk">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentLanguage}" Value="uk">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="🇨🇿 Čeština" 
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="cs">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentLanguage}" Value="cs">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="🇷🇺 Русский" 
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="ru">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentLanguage}" Value="ru">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="🇬🇧 English" 
                                Command="{Binding ChangeLanguageCommand}" CommandParameter="en">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentLanguage}" Value="en">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Document Language Card -->
            <Border Grid.Row="3" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="24,20" Margin="0,0,0,16"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="{DynamicResource InfoLightBrush}" CornerRadius="8" Width="36" Height="36"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource SettingsDocLangTitle}" 
                                       FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource SettingsDocLangHint}" 
                                       FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <WrapPanel Orientation="Horizontal">
                        <Button Content="{DynamicResource DocLangSameAsUI}" 
                                Command="{Binding ChangeDocLanguageCommand}" CommandParameter="">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="🇺🇦 Українська" 
                                Command="{Binding ChangeDocLanguageCommand}" CommandParameter="uk">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="uk">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="🇨🇿 Čeština" 
                                Command="{Binding ChangeDocLanguageCommand}" CommandParameter="cs">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="cs">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="🇷🇺 Русский" 
                                Command="{Binding ChangeDocLanguageCommand}" CommandParameter="ru">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="ru">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="🇬🇧 English" 
                                Command="{Binding ChangeDocLanguageCommand}" CommandParameter="en">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="en">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Theme Card -->
            <Border Grid.Row="4" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="24,20" Margin="0,0,0,16"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="{DynamicResource WarningLightBrush}" CornerRadius="8" Width="36" Height="36"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource ThemeLabel}" 
                                       FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource SettingsThemeHint}" 
                                       FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <UniformGrid Columns="4" HorizontalAlignment="Left" MaxWidth="700">
                        <!-- Light theme preview -->
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="Light"
                                Margin="0,0,10,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="OuterBd" CornerRadius="10" BorderThickness="2.5"
                                            BorderBrush="Transparent" Padding="3"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border x:Name="InnerBd" CornerRadius="8" Width="136" Height="90"
                                                Background="#F3F3F3" ClipToBounds="True">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="28"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="22"/>
                                                </Grid.RowDefinitions>
                                                <!-- Title bar -->
                                                <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E5E5E5" BorderThickness="0,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                                                        <Ellipse Width="6" Height="6" Fill="#FF605C" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#FFBD44" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#00CA4E"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Content area -->
                                                <StackPanel Grid.Row="1" Margin="8,5,8,0">
                                                    <Border Background="#E5E5E5" CornerRadius="2" Height="4" Width="60" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <Border Background="#E5E5E5" CornerRadius="2" Height="4" Width="44" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <Border Background="#FFFFFF" CornerRadius="3" Width="36" Height="18" BorderBrush="#E5E5E5" BorderThickness="1" Margin="0,0,4,0"/>
                                                        <Border Background="#FFFFFF" CornerRadius="3" Width="36" Height="18" BorderBrush="#E5E5E5" BorderThickness="1"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <!-- Accent bar -->
                                                <Border Grid.Row="2" Background="#0078D4" CornerRadius="0,0,8,8">
                                                    <TextBlock Text="{DynamicResource ThemeLight}" FontSize="{DynamicResource FS10}" FontWeight="SemiBold"
                                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding CurrentTheme}" Value="Light">
                                            <Setter TargetName="OuterBd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- DarkWord theme preview -->
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="DarkWord"
                                Margin="0,0,10,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="OuterBd" CornerRadius="10" BorderThickness="2.5"
                                            BorderBrush="Transparent" Padding="3"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border x:Name="InnerBd" CornerRadius="8" Width="136" Height="90"
                                                Background="#191C20" ClipToBounds="True">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="28"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="22"/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0" Background="#1E2228" BorderBrush="#373E47" BorderThickness="0,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                                                        <Ellipse Width="6" Height="6" Fill="#FF605C" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#FFBD44" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#00CA4E"/>
                                                    </StackPanel>
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="8,5,8,0">
                                                    <Border Background="#373E47" CornerRadius="2" Height="4" Width="60" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <Border Background="#373E47" CornerRadius="2" Height="4" Width="44" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
