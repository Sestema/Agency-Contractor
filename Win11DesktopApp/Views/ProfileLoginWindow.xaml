<Window x:Class="Win11DesktopApp.Views.ProfileLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ProfileLoginWindowTitle}"
        Width="580"
        MinWidth="520"
        MaxWidth="660"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Style="{StaticResource ThinScroll}" VerticalScrollBarVisibility="Auto" Padding="28,24,28,8">
            <StackPanel>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Style="{StaticResource PageHeaderIconBadge}">
                            <TextBlock Text="&#xE77B;" Style="{StaticResource PageHeaderIconText}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Agency Contractor" FontSize="{DynamicResource FS24}" Style="{StaticResource PageHeaderTitleText}"/>
                            <TextBlock Text="{DynamicResource ProfileLoginHeaderSubtitle}"
                                       FontSize="{DynamicResource FS12}"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Top" MinWidth="150">
                        <TextBlock Text="{DynamicResource LangLabel}"
                                   FontSize="{DynamicResource FS11}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Margin="0,0,0,6"/>
                        <ComboBox Style="{StaticResource ThemedComboBox}"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{Binding CurrentLanguage, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBoxItem Tag="uk" Content="Українська"/>
                            <ComboBoxItem Tag="en" Content="English"/>
                            <ComboBoxItem Tag="cs" Content="Čeština"/>
                            <ComboBoxItem Tag="ru" Content="Русский"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Border Style="{StaticResource DialogSectionCard}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource InfoLightBrush}">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                           Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource ProfileLoginCardTitle}"
                                           FontSize="{DynamicResource FS15}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{DynamicResource ProfileLoginCardDescription}"
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="0,2,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource DialogPreviewSurface}" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource ProfileUserLabel}"
                                           FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           Margin="0,0,0,6"/>
                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,8"
                                        Margin="0,0,0,12">
                                    <TextBlock Text="{Binding FullName}"
                                               FontSize="{DynamicResource FS14}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                </Border>

                                <TextBlock Text="{DynamicResource ProfilePasswordLabel}"
                                           FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,10">
                                    <PasswordBox x:Name="PasswordBox"
                                                 PasswordChanged="PasswordBox_OnPasswordChanged"
                                                 Visibility="{Binding ShowPassword, Converter={StaticResource InverseBoolToVis}}"/>
                                    <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVis}}"/>
                                </Grid>

                                <CheckBox Content="{DynamicResource ProfileShowPassword}"
                                          IsChecked="{Binding ShowPassword}"
                                          Margin="0,0,0,12"/>

                                <CheckBox Content="{DynamicResource ProfileRememberMe}"
                                          IsChecked="{Binding RememberMe}"
                                          Margin="0,0,0,12"/>

                                <Border Background="{DynamicResource WarningLightBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12"
                                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}">
                                    <TextBlock Text="{Binding ErrorMessage}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="{DynamicResource WindowBackgroundBrush}" Padding="28,10,28,18"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{DynamicResource ProfileLoginFooterHint}"
                           FontSize="{DynamicResource FS11}"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding CancelCommand}"
                            Padding="18,9"
                            Margin="0,0,12,0"
                            Style="{StaticResource HeaderGhostButton}"
                            Content="{DynamicResource ProfileCloseButton}"/>

                    <Button Command="{Binding LoginCommand}"
                            Padding="18,9"
                            Style="{StaticResource FilledActionButton}"
                            Content="{DynamicResource ProfileLoginButton}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
