<UserControl x:Class="Win11DesktopApp.Views.CandidatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels"
             xmlns:views="clr-namespace:Win11DesktopApp.Views"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="CandidateViewModeButton" TargetType="Button">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CandidateMetaIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="{DynamicResource FS10}"/>
            <Setter Property="Foreground" Value="{DynamicResource TertiaryForegroundBrush}"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CandidateMetaText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FS11}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CandidateChipBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="CandidateChipText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FS10}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding GoBackCommand}" Style="{StaticResource HeaderBackButton}" Margin="0,0,10,0">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                    </Button>
                    <Border Style="{StaticResource PageHeaderIconBadge}" Background="{DynamicResource WarningBrush}">
                        <TextBlock Text="&#xE77B;" Style="{StaticResource PageHeaderIconText}"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource BtnCandidates}" FontSize="{DynamicResource FS24}" Style="{StaticResource PageHeaderTitleText}"/>
                        <TextBlock FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Margin="0,3,0,0">
                            <Run Text="{Binding TotalCount}"/>
                            <Run Text=" "/>
                            <Run Text="{DynamicResource BtnCandidates}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding AddCandidateCommand}" Style="{StaticResource FilledActionButton}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                   Foreground="White" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource CandAdd}" FontSize="{DynamicResource FS13}"
                                   FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- FILTER BAR -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource ToolbarSearchContainer}"
                        Margin="0,0,12,0"
                        CornerRadius="12"
                        Height="38">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource TertiaryForegroundBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Border>

                <ComboBox Grid.Column="1" Width="210" Height="38" VerticalContentAlignment="Center" Margin="0,0,12,0"
                          ItemsSource="{Binding Positions}"
                          SelectedItem="{Binding SelectedPosition}"
                          Padding="10,6">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding}" Value="">
                                                <Setter Property="Text" Value="{DynamicResource CandAllPositions}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- View mode toggle + Zoom -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding SetViewModeCommand}" CommandParameter="List" ToolTip="{DynamicResource ViewList}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource CandidateViewModeButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViewMode}" Value="List">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="&#xEA37;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                    </Button>
                    <Button Command="{Binding SetViewModeCommand}" CommandParameter="Tiles" ToolTip="{DynamicResource ViewTiles}"
                            Margin="0,0,12,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource CandidateViewModeButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViewMode}" Value="Tiles">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                    </Button>
                    <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}"
                               Foreground="#999" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Slider Value="{Binding ZoomLevel}" Minimum="0.6" Maximum="1.6" Width="100"
                            TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                    <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                               Foreground="#999" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- CANDIDATES LIST VIEW -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding Candidates}" ClipToBounds="False"
                          Visibility="{Binding IsListView, Converter={StaticResource BoolToVis}}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True">
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <ScrollViewer Style="{StaticResource ThinScroll}" CanContentScroll="True" Focusable="False">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </ItemsControl.Template>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding DataContext.ZoomLevel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    ScaleY="{Binding DataContext.ZoomLevel, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </ItemsControl.LayoutTransform>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="12" Padding="12,11" Margin="0,0,0,8" BorderThickness="1" Cursor="Hand"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.07"/>
                                </Border.Effect>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenCandidateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Photo -->
                                    <Border Grid.Column="0" Width="46" Height="46" CornerRadius="23" Background="{DynamicResource InfoChipBackgroundBrush}"
                                            VerticalAlignment="Top" Margin="0,0,12,0" BorderBrush="{DynamicResource InfoChipBorderBrush}" BorderThickness="1.5">
                                        <Border.Clip>
                                            <EllipseGeometry Center="22,22" RadiusX="22" RadiusY="22"/>
                                        </Border.Clip>
                                        <Grid>
                                            <Image Source="{Binding PhotoPath}" Stretch="UniformToFill"
                                                   Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS18}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource InfoChipForegroundBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPhoto}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                            <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="{DynamicResource FS14}"
                                                       Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,8,0"/>
                                        </StackPanel>
                                        <WrapPanel Margin="0,0,0,5">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                                <TextBlock Text="&#xE821;" Style="{StaticResource CandidateMetaIcon}"/>
                                                <TextBlock Text="{Binding DesiredPosition}" Style="{StaticResource CandidateMetaText}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                                <TextBlock Text="&#xE717;" Style="{StaticResource CandidateMetaIcon}"/>
                                                <TextBlock Text="{Binding Phone}" Style="{StaticResource CandidateMetaText}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                                <TextBlock Text="&#xE81D;" Style="{StaticResource CandidateMetaIcon}"/>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CandidateMetaText}">
                                                            <Setter Property="Text" Value="{Binding LocationDetails}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding LocationPreference}" Value="all">
                                                                    <Setter Property="Text" Value="{DynamicResource CandAllCzech}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,2,0,0">
                                            <Border Style="{StaticResource CandidateChipBorder}"
                                                    Background="{DynamicResource InfoChipBackgroundBrush}" BorderBrush="{DynamicResource InfoChipBorderBrush}">
                                                <TextBlock Style="{StaticResource CandidateChipText}" Foreground="{DynamicResource InfoChipForegroundBrush}">
                                                    <Run Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding PassportNumber, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                            <Border Style="{StaticResource CandidateChipBorder}"
                                                    Background="{DynamicResource SuccessChipBackgroundBrush}" BorderBrush="{DynamicResource SuccessChipBorderBrush}">
                                                <TextBlock Style="{StaticResource CandidateChipText}" Foreground="{DynamicResource SuccessChipForegroundBrush}"
                                                           Text="{Binding PassportCountry}"/>
                                            </Border>
                                            <Border Style="{StaticResource CandidateChipBorder}"
                                                    Background="{DynamicResource WarningChipBackgroundBrush}" BorderBrush="{DynamicResource WarningChipBorderBrush}">
                                                <TextBlock Style="{StaticResource CandidateChipText}" Foreground="{DynamicResource WarningChipForegroundBrush}">
                                                    <Run Text="{DynamicResource CandAddedOn}"/>
                                                    <Run Text="{Binding DateAdded, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- Right: empty for alignment -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            <!-- CANDIDATES TILES VIEW -->
            <ScrollViewer Grid.Row="2" Style="{StaticResource ThinScroll}" ClipToBounds="False"
                          Visibility="{Binding IsTilesView, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding Candidates}" ClipToBounds="False">
                    <ItemsControl.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding DataContext.ZoomLevel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        ScaleY="{Binding DataContext.ZoomLevel, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </ItemsControl.LayoutTransform>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel ClipToBounds="False"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="12" Padding="10" Margin="6,14,8,8" Width="258" BorderThickness="1"
                                    RenderTransformOrigin="0.5,0.5" Cursor="Hand"
                                    Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenCandidateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        <TranslateTransform Y="0"/>
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="3" Direction="270" Color="#000000" Opacity="0.1"/>
                                </Border.Effect>
                                <StackPanel>
                                    <!-- Photo + Name -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                                        <Border Width="36" Height="36" CornerRadius="18" Background="{DynamicResource InfoChipBackgroundBrush}"
                                                Margin="0,0,9,0" BorderBrush="{DynamicResource InfoChipBorderBrush}" BorderThickness="1.5">
                                            <Border.Clip>
                                                <EllipseGeometry Center="18,18" RadiusX="18" RadiusY="18"/>
                                            </Border.Clip>
                                            <Grid>
                                                <Image Source="{Binding PhotoPath}" Stretch="UniformToFill"
                                                       Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                                                           FontSize="{DynamicResource FS15}" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="{DynamicResource InfoChipForegroundBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasPhoto}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="{DynamicResource FS13}"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                            <TextBlock Text="{Binding DesiredPosition}" FontSize="{DynamicResource FS10}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Phone + Location -->
                                    <TextBlock FontSize="{DynamicResource FS10}" Foreground="{DynamicResource SecondaryForegroundBrush}" TextWrapping="Wrap" Margin="0,0,0,2">
                                        <Run Text="&#xE717; " FontFamily="Segoe MDL2 Assets"/>
                                        <Run Text="{Binding Phone, Mode=OneWay}"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="&#xE81D;" Style="{StaticResource CandidateMetaIcon}"/>
                                        <TextBlock FontSize="{DynamicResource FS10}" Foreground="{DynamicResource SecondaryForegroundBrush}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding LocationDetails}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LocationPreference}" Value="all">
                                                            <Setter Property="Text" Value="{DynamicResource CandAllCzech}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Badges -->
                                    <WrapPanel Margin="0,5,0,0">
                                        <Border Style="{StaticResource CandidateChipBorder}"
                                                Background="{DynamicResource InfoChipBackgroundBrush}" BorderBrush="{DynamicResource InfoChipBorderBrush}">
                                            <TextBlock FontSize="{DynamicResource FS9}" FontWeight="SemiBold" Foreground="{DynamicResource InfoChipForegroundBrush}">
                                                <Run Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding PassportNumber, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Border>
                                        <Border Style="{StaticResource CandidateChipBorder}"
                                                Background="{DynamicResource SuccessChipBackgroundBrush}" BorderBrush="{DynamicResource SuccessChipBorderBrush}">
                                            <TextBlock FontSize="{DynamicResource FS9}" FontWeight="SemiBold" Foreground="{DynamicResource SuccessChipForegroundBrush}"
                                                       Text="{Binding PassportCountry}"/>
                                        </Border>
                                        <Border Style="{StaticResource CandidateChipBorder}"
                                                Background="{DynamicResource WarningChipBackgroundBrush}" BorderBrush="{DynamicResource WarningChipBorderBrush}">
                                            <TextBlock FontSize="{DynamicResource FS9}" FontWeight="SemiBold" Foreground="{DynamicResource WarningChipForegroundBrush}">
                                                <Run Text="{DynamicResource CandAddedOn}"/>
                                                <Run Text="{Binding DateAdded, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                 To="1.05" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                 To="1.05" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                                 To="-5" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                 To="18" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                                                 To="5" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                 To="0.2" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                 To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                 To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                                 To="0" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                                 To="6" Duration="0:0:0.25"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                                                 To="2" Duration="0:0:0.25"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                                 To="0.08" Duration="0:0:0.25"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <Border Grid.Row="2" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CompactEmptyStateCard}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasCandidates}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE77B;" Style="{StaticResource CompactEmptyStateIconText}" FontSize="{DynamicResource FS28}" Foreground="#FFB74D"/>
                    <TextBlock Text="{DynamicResource CandEmpty}" Style="{StaticResource CompactEmptyStateTitleText}"/>
                    <TextBlock Text="{DynamicResource CandAddTitle}"
                               Style="{StaticResource CompactEmptyStateDescriptionText}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ADD CANDIDATE OVERLAY -->
        <Grid Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{x:Null}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12"
                    MaxWidth="900" MaxHeight="700" Margin="20"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    ClipToBounds="True">
                <ContentControl Content="{Binding AddCandidateVm}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:AddCandidateViewModel}">
                            <views:AddCandidateView/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>
        </Grid>

        <!-- DETAILS OVERLAY -->
        <Grid Visibility="{Binding IsDetailsOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{x:Null}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12"
                    MaxWidth="880" MaxHeight="850" Margin="30"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <ContentControl Content="{Binding DetailsVm}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate DataType="{x:Type vm:CandidateDetailsViewModel}">
                            <views:CandidateDetailsView/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>
