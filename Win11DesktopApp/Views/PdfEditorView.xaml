<UserControl x:Class="Win11DesktopApp.Views.PdfEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1100">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER BAR ===== -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" 
                Padding="12,8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                        Style="{StaticResource HeaderBackButton}"
                        Margin="0,0,10,0" ToolTip="{DynamicResource XlsxBack}">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                </Button>

                <TextBlock Grid.Column="1" Text="{Binding Title}" 
                           FontSize="{DynamicResource FS16}" FontWeight="SemiBold" 
                           Foreground="{DynamicResource ForegroundBrush}"
                           VerticalAlignment="Center"/>

                <!-- AI Assistant Button -->
                <Button x:Name="BtnAIOverlay" Grid.Column="2"
                        Command="{Binding ToggleAIPdfSuggestionsCommand}"
                        Padding="10,5" Margin="0,0,6,0" Cursor="Hand"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        VerticalAlignment="Center" ToolTip="{DynamicResource AIOverlayBtn}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}" 
                                   VerticalAlignment="Center" Margin="0,0,4,0">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C4DFF" Offset="0"/>
                                    <GradientStop Color="#448AFF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="AI" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" Content="{DynamicResource XlsxCancel}" 
                        Command="{Binding GoBackCommand}"
                        Padding="14,5" Margin="0,0,6,0" FontSize="{DynamicResource FS12}"
                        Background="{DynamicResource CardBackgroundBrush}"
                        Foreground="{DynamicResource ForegroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        VerticalAlignment="Center" Cursor="Hand"/>

                <Button Grid.Column="4"
                        Command="{Binding SaveCommand}"
                        Padding="14,5"
                        Background="{DynamicResource AccentBrush}" Foreground="White" 
                        BorderThickness="0" FontWeight="SemiBold"
                        VerticalAlignment="Center" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource XlsxSave}" FontSize="{DynamicResource FS12}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===== PAGE NAVIGATION + TOOLS BAR ===== -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" 
                Padding="6,4" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Pages + Zoom + Grid -->
                <WrapPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,2">
                    <Button Command="{Binding PrevPageCommand}" 
                            Content="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                            Width="28" Height="26" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand"/>
                    <TextBlock VerticalAlignment="Center" FontSize="{DynamicResource FS12}" Margin="6,0"
                               Foreground="{DynamicResource ForegroundBrush}">
                        <Run Text="{Binding CurrentPageDisplay, Mode=OneWay}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding PageCount, Mode=OneWay}"/>
                    </TextBlock>
                    <Button Command="{Binding NextPageCommand}" 
                            Content="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                            Width="28" Height="26" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand"/>

                    <Border Width="1" Background="{DynamicResource CardBorderBrush}" Margin="10,4"/>

                    <!-- Zoom -->
                    <Button Command="{Binding ZoomOutCommand}" 
                            Content="&#xE71F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}"
                            Width="26" Height="24" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand"
                            ToolTip="{DynamicResource PdfZoomOut}"/>
                    <TextBlock Text="{Binding ZoomPercent}" FontSize="{DynamicResource FS11}" 
                               Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"
                               Margin="2,0" MinWidth="34" TextAlignment="Center"/>
                    <Button Command="{Binding ZoomInCommand}" 
                            Content="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}"
                            Width="26" Height="24" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand"
                            ToolTip="{DynamicResource PdfZoomIn}"/>
                    <Button Command="{Binding ZoomResetCommand}" 
                            Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}"
                            Width="22" Height="22" Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SecondaryForegroundBrush}" Cursor="Hand" Margin="2,0,0,0"
                            ToolTip="{DynamicResource PdfZoomReset}"/>

                    <Border Width="1" Background="{DynamicResource CardBorderBrush}" Margin="10,4"/>

                    <!-- Grid toggle -->
                    <ToggleButton IsChecked="{Binding ShowGrid}" 
                                  Width="26" Height="24" Background="Transparent" BorderThickness="1"
                                  BorderBrush="{DynamicResource CardBorderBrush}" Cursor="Hand"
                                  ToolTip="{DynamicResource PdfShowGrid}">
                        <TextBlock Text="&#xF0E2;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                    </ToggleButton>

                    <!-- Snap toggle -->
                    <ToggleButton IsChecked="{Binding SnapToGrid}" Margin="4,0,0,0"
                                  Width="26" Height="24" Background="Transparent" BorderThickness="1"
                                  BorderBrush="{DynamicResource CardBorderBrush}" Cursor="Hand"
                                  ToolTip="{DynamicResource PdfSnapGrid}">
                        <TextBlock Text="&#xE752;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                    </ToggleButton>

                    <!-- Grid step -->
                    <TextBlock Text="{DynamicResource PdfGridStep}" FontSize="10" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               VerticalAlignment="Center" Margin="8,0,3,0"/>
                    <ComboBox Width="48" Height="22" FontSize="10" VerticalContentAlignment="Center"
                              SelectedItem="{Binding GridSpacingPt}" IsEditable="True">
                        <ComboBox.Items>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">6</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">8</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">10</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">12</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">14</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">18</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">24</system:Double>
                        </ComboBox.Items>
                    </ComboBox>

                    <Border Width="1" Background="{DynamicResource CardBorderBrush}" Margin="10,4"/>

                    <TextBlock Text="{DynamicResource PdfModeLabel}" FontSize="10" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="140" Height="24" VerticalContentAlignment="Center" FontSize="10"
                              ItemsSource="{Binding AvailablePdfModes}"
                              SelectedValuePath="Key"
                              DisplayMemberPath="Label"
                              SelectedValue="{Binding PdfMode}"/>
                </WrapPanel>

                <!-- Row 1: Tag properties (font size, font family, max width) + editing indicator -->
                <WrapPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0"
                           Visibility="{Binding IsOverlayMode, Converter={StaticResource BoolToVis}}">
                    <!-- Editing indicator -->
                    <Border CornerRadius="3" Padding="6,2" Margin="0,0,8,0"
                            Visibility="{Binding IsEditingPlacement, Converter={StaticResource BoolToVis}}">
                        <Border.Background>
                            <SolidColorBrush Color="#FFF3E0"/>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="10" 
                                       Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{DynamicResource PdfEditing}" FontSize="10" Foreground="{DynamicResource WarningBrush}"
                                       VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBlock Text="{Binding EditingTagLabel}" FontSize="10" Foreground="{DynamicResource WarningBrush}"
                                       FontWeight="SemiBold" FontFamily="Consolas" VerticalAlignment="Center"/>
                            <Button Command="{Binding DeselectCommand}" Content="&#xE711;"
                                    FontFamily="Segoe MDL2 Assets" FontSize="9"
                                    Width="18" Height="18" Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource WarningBrush}" Cursor="Hand" Margin="6,0,0,0"
                                    ToolTip="{DynamicResource PdfDeselect}"/>
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding AddInlineTextRowCommand}"
                            Padding="10,3" Margin="0,0,8,0"
                            Background="{DynamicResource AccentBrush}" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip="{DynamicResource PdfAddInlineTextRow}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource PdfInlineTextRowShort}" FontSize="{DynamicResource FS10}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding AddFieldCommand}"
                            Padding="10,3" Margin="0,0,8,0"
                            Background="{DynamicResource AccentDarkBrush}" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            ToolTip="{DynamicResource PdfAddField}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource PdfFieldShort}" FontSize="{DynamicResource FS10}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsEditingTemplatePlacement, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,8,0">
                        <TextBlock Text="{Binding TemplateEditorLabel}" FontSize="10" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="InlineTemplateTextBox"
                                 Width="280"
                                 Text="{Binding InlineTemplateText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,3"
                                 FontSize="{DynamicResource FS10}"
                                 SelectionChanged="InlineTemplateTextBox_SelectionChanged"
                                 GotKeyboardFocus="InlineTemplateTextBox_GotKeyboardFocus"
                                 LostKeyboardFocus="InlineTemplateTextBox_LostKeyboardFocus"
                                 ToolTip="{DynamicResource PdfInlineTemplateHint}"/>
                    </StackPanel>

                    <!-- Font size -->
                    <TextBlock Text="{DynamicResource EditorFontSize}" FontSize="10" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               VerticalAlignment="Center" Margin="0,0,3,0"/>
                    <ComboBox Width="50" Height="22" VerticalContentAlignment="Center" FontSize="10"
                              SelectedItem="{Binding NewTagFontSize}" IsEditable="True">
                        <ComboBox.Items>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">7</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">8</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">9</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">10</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">11</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">12</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">14</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">16</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">18</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">20</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">24</system:Double>
                        </ComboBox.Items>
                    </ComboBox>

                    <!-- Font family -->
                    <TextBlock Text="{DynamicResource EditorFontFamily}" FontSize="10" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               VerticalAlignment="Center" Margin="8,0,3,0"/>
                    <ComboBox Width="110" Height="22" VerticalContentAlignment="Center" FontSize="10"
                              ItemsSource="{Binding AvailableFonts}"
                              SelectedItem="{Binding NewTagFontFamily}"/>

                    <!-- Max width -->
                    <TextBlock Text="{Binding WidthEditorLabel}" FontSize="10" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               VerticalAlignment="Center" Margin="8,0,3,0"/>
                    <ComboBox Width="55" Height="22" VerticalContentAlignment="Center" FontSize="10"
                              SelectedItem="{Binding NewTagMaxWidth}" IsEditable="True">
                        <ComboBox.Items>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">0</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">50</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">100</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">150</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">200</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">250</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">300</system:Double>
                        </ComboBox.Items>
                    </ComboBox>

                    <TextBlock Text="{DynamicResource PdfFieldHeight}" FontSize="10" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               VerticalAlignment="Center" Margin="8,0,3,0"
                               Visibility="{Binding IsEditingFieldPlacement, Converter={StaticResource BoolToVis}}"/>
                    <ComboBox Width="55" Height="22" VerticalContentAlignment="Center" FontSize="10"
                              SelectedItem="{Binding NewFieldHeight}" IsEditable="True"
                              Visibility="{Binding IsEditingFieldPlacement, Converter={StaticResource BoolToVis}}">
                        <ComboBox.Items>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">12</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">14</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">16</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">18</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">20</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">24</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">28</system:Double>
                            <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib">32</system:Double>
                        </ComboBox.Items>
                    </ComboBox>

                    <TextBlock Text="{DynamicResource EditorAlignment}" FontSize="10" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               VerticalAlignment="Center" Margin="8,0,3,0"
                               Visibility="{Binding IsEditingFieldPlacement, Converter={StaticResource BoolToVis}}"/>
                    <ComboBox Width="110" Height="22" VerticalContentAlignment="Center" FontSize="10"
                              ItemsSource="{Binding AvailableTextAlignments}"
                              SelectedValuePath="Key"
                              DisplayMemberPath="Label"
                              SelectedValue="{Binding SelectedTextAlign}"
                              Visibility="{Binding IsEditingFieldPlacement, Converter={StaticResource BoolToVis}}"/>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- ===== MAIN: PDF Canvas + Tag Catalog ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" MinWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="RightSidebarColumn" Width="360" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <!-- ===== PDF CANVAS ===== -->
            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" 
                          VerticalScrollBarVisibility="Auto" Background="{DynamicResource WindowBackgroundBrush}"
                          x:Name="PdfScrollViewer">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">
                    <Grid.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}"/>
                    </Grid.LayoutTransform>
                    <Border Background="White" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.2"/>
                        </Border.Effect>
                        <Canvas x:Name="PdfCanvas" 
                                ClipToBounds="True"
                                MouseLeftButtonDown="PdfCanvas_MouseLeftButtonDown"
                                MouseWheel="PdfCanvas_MouseWheel"
                                Background="Transparent">
                            <Image x:Name="PdfImage" Source="{Binding CurrentPageImage}" 
                                   Stretch="None"/>
                        </Canvas>
                    </Border>
                </Grid>
            </ScrollViewer>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" 
                          VerticalAlignment="Stretch" Background="{DynamicResource CardBorderBrush}" 
                          Cursor="SizeWE" ShowsPreview="True"
                          DragCompleted="SidebarGridSplitter_DragCompleted"/>

            <!-- ===== TAG CATALOG + PLACED TAGS ===== -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource ContentBackgroundBrush}" Padding="0"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="TagsPanelRow" Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition x:Name="FieldsPanelRow" Height="260"/>
                        <RowDefinition x:Name="AiPanelSplitterRow" Height="Auto"/>
                        <RowDefinition x:Name="AiPanelRow" Height="280"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="6,6,6,0"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" Padding="12,8"
                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource EditorTagCatalog}" FontWeight="SemiBold" FontSize="{DynamicResource FS14}"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{DynamicResource PdfClickToPlace}"
                                               FontSize="{DynamicResource FS10}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Padding="10,6" Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <TextBox Text="{Binding TagSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="6,4" FontSize="{DynamicResource FS11}"
                                             Background="{DynamicResource ContentBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                             VerticalContentAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource EditorSearchTags}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource TertiaryForegroundBrush}"
                                               IsHitTestVisible="False" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TagSearchQuery}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TagSearchQuery}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="2" Style="{StaticResource ThinScroll}" Padding="6,4">
                                <ItemsControl ItemsSource="{Binding FilteredTagGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Expander IsExpanded="True" Margin="0,0,0,6">
                                                <Expander.Header>
                                                    <TextBlock Text="{Binding GroupName}" FontWeight="SemiBold" FontSize="{DynamicResource FS13}"
                                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                                </Expander.Header>
                                                <ItemsControl ItemsSource="{Binding Tags}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{DynamicResource CardBackgroundBrush}" 
                                                                    CornerRadius="4" Padding="8,5" Margin="0,0,0,3"
                                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                                               Text="{Binding Description}" 
                                                                               FontSize="{DynamicResource FS12}" FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource ForegroundBrush}"
                                                                               TextTrimming="CharacterEllipsis"/>

                                                                    <Button Grid.Row="0" Grid.Column="1"
                                                                            Command="{Binding DataContext.PlaceTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Padding="8,2" Margin="4,0,2,0"
                                                                            Background="{DynamicResource AccentBrush}" 
                                                                            Foreground="White" BorderThickness="0"
                                                                            VerticalAlignment="Center" Cursor="Hand"
                                                                            ToolTip="{DynamicResource PdfPlaceTag}">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="&#xE819;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{DynamicResource EditorInsert}" FontSize="{DynamicResource FS10}"/>
                                                                        </StackPanel>
                                                                    </Button>

                                                                    <Button Grid.Row="0" Grid.Column="2" Content="&#xE8C8;"
                                                                            FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}"
                                                                            Command="{Binding DataContext.CopyTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Width="26" Height="24"
                                                                            Background="Transparent" BorderThickness="0"
                                                                            Foreground="{DynamicResource ForegroundBrush}"
                                                                            VerticalAlignment="Center" Cursor="Hand"
                                                                            ToolTip="{DynamicResource EditorCopyTag}"/>

                                                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                                               FontSize="{DynamicResource FS10}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                               FontFamily="Consolas"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Margin="0,2,0,0">
                                                                        <Run Text="${"/><Run Text="{Binding Tag}"/><Run Text="}"/>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Row="1"
                                  Height="5"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="{DynamicResource CardBorderBrush}"
                                  ShowsPreview="True"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  DragCompleted="FieldsPanelGridSplitter_DragCompleted"/>

                    <Border Grid.Row="2"
                            Margin="6,4,6,0"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid>
                            <Grid Visibility="{Binding IsOverlayMode, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Padding="12,6"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Background="{DynamicResource CardBackgroundBrush}">
                                    <TextBlock Text="{DynamicResource PdfPlacedTags}" FontWeight="SemiBold" FontSize="{DynamicResource FS13}"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                </Border>

                                <ScrollViewer Grid.Row="1" Style="{StaticResource ThinScroll}" Padding="6,4">
                                    <ItemsControl ItemsSource="{Binding AllPlacements}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4" Padding="6,3" Margin="0,0,0,2"
                                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                                        Cursor="Hand" MouseLeftButtonDown="PlacedTag_Click">
                                                    <Border.Tag>
                                                        <Binding/>
                                                    </Border.Tag>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Background">
                                                                        <Setter.Value>
                                                                            <SolidColorBrush Color="#FFF3E0"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Setter Property="BorderBrush">
                                                                        <Setter.Value>
                                                                            <SolidColorBrush Color="#FFB74D"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock FontSize="{DynamicResource FS11}" FontWeight="SemiBold" Foreground="{DynamicResource AccentDarkBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Text="{Binding DisplayLabel, Mode=OneWay}"/>
                                                            <TextBlock FontSize="9" Foreground="{DynamicResource SecondaryForegroundBrush}">
                                                                <Run Text="P"/><Run Text="{Binding Page, Mode=OneWay}"/>
                                                                <Run Text=" | "/>
                                                                <Run Text="{Binding FontSize, StringFormat={}{0}pt, Mode=OneWay}"/>
                                                                <Run Text=" | "/>
                                                                <Run Text="{Binding FontFamily, Mode=OneWay}"/>
                                                            </TextBlock>
                                                            <TextBlock FontSize="9" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                       Text="{Binding OverlayText, Mode=OneWay}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Visibility="{Binding IsTemplatePlacement, Converter={StaticResource BoolToVis}}"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="&#xE74D;" 
                                                                FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                                Command="{Binding DataContext.RemovePlacementCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Width="20" Height="20"
                                                                Background="Transparent" BorderThickness="0"
                                                                Foreground="{DynamicResource ErrorBrush}" Cursor="Hand"
                                                                VerticalAlignment="Center"
                                                                ToolTip="{DynamicResource BtnDelete}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <Grid Visibility="{Binding IsFormMode, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Padding="12,6"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Background="{DynamicResource CardBackgroundBrush}">
                                    <TextBlock Text="{DynamicResource PdfFormFieldsHeader}" FontWeight="SemiBold" FontSize="{DynamicResource FS13}"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                </Border>

                                <ListBox x:Name="FormFieldListBox"
                                         Grid.Row="1"
                                         Margin="6,6,6,6"
                                         Background="Transparent" BorderThickness="0"
                                         ItemsSource="{Binding FormFieldBindings}"
                                         SelectedItem="{Binding SelectedFormFieldBinding, Mode=TwoWay}"
                                         SelectionChanged="FormFieldListBox_SelectionChanged"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,4"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,6"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                                    Cursor="Hand" MouseLeftButtonDown="FormField_Click">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="#FFF3E0"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Setter Property="BorderBrush">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="#FFB74D"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.Tag>
                                                    <Binding/>
                                                </Border.Tag>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding PreferredDisplayName}" FontSize="{DynamicResource FS11}" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentDarkBrush}"/>
                                                    <TextBlock FontSize="9" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,1,0,4"
                                                               Text="{Binding ContextText}" TextWrapping="Wrap"/>
                                                    <TextBlock FontSize="9" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,1,0,4">
                                                        <Run Text="{DynamicResource PdfFormFieldType}"/>
                                                        <Run Text=": "/>
                                                        <Run Text="{Binding FieldType}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="9" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"
                                                               Text="{Binding LocationText}"/>
                                                    <TextBox Text="{Binding TemplateText, UpdateSourceTrigger=PropertyChanged}"
                                                             Padding="6,3" FontSize="{DynamicResource FS10}"
                                                             SelectionChanged="FormFieldTemplateTextBox_SelectionChanged"
                                                             GotKeyboardFocus="FormFieldTemplateTextBox_GotKeyboardFocus"
                                                             LostKeyboardFocus="FormFieldTemplateTextBox_LostKeyboardFocus"
                                                             ToolTip="{DynamicResource PdfFieldTemplateHint}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Row="3"
                                  Height="5"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="{DynamicResource CardBorderBrush}"
                                  ShowsPreview="True"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  Visibility="{Binding IsAIPdfSuggestionsVisible, Converter={StaticResource BoolToVis}}"
                                  DragCompleted="AiPanelGridSplitter_DragCompleted"/>

                    <Border Grid.Row="4"
                            Margin="6,0,6,8"
                            Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Visibility="{Binding IsAIPdfSuggestionsVisible, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Padding="12,8"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Background="{DynamicResource CardBackgroundBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{DynamicResource PdfAiHeader}" FontWeight="SemiBold" FontSize="{DynamicResource FS13}"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="{DynamicResource PdfAiHint}" FontSize="{DynamicResource FS10}"
                                                   Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding AnalyzePdfFieldsWithAICommand}"
                                            Padding="10,4"
                                            Margin="8,0,0,0"
                                            Background="{DynamicResource AccentBrush}"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}" Margin="0,0,4,0"/>
                                            <TextBlock Text="{DynamicResource PdfAiAnalyze}" FontSize="{DynamicResource FS10}"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Command="{Binding CloseAIPdfSuggestionsCommand}"
                                            Width="26" Height="24"
                                            Margin="8,0,0,0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource ForegroundBrush}"
                                            Cursor="Hand"
                                            ToolTip="{DynamicResource PdfDeselect}">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Margin="12,8,12,6"
                                       Text="{Binding AIPdfSuggestionsStatus}"
                                       FontSize="{DynamicResource FS10}"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                                       TextWrapping="Wrap"/>

                            <ListBox Grid.Row="2"
                                     Margin="6,0,6,6"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemsSource="{Binding VisibleAIPdfFieldSuggestions}"
                                     SelectedItem="{Binding SelectedAIPdfFieldSuggestion, Mode=TwoWay}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6"
                                            Padding="8"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="1"
                                            Background="{DynamicResource CardBackgroundBrush}">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Left"
                                                           Text="{Binding FieldName}"
                                                           FontSize="{DynamicResource FS11}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentDarkBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Border DockPanel.Dock="Right"
                                                        CornerRadius="10"
                                                        Padding="6,2"
                                                        Margin="8,0,0,0"
                                                        Background="{DynamicResource AccentLightBrush}">
                                                    <TextBlock Text="{Binding Confidence}"
                                                               FontSize="9"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </DockPanel>

                                            <TextBlock FontSize="9"
                                                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                       Margin="0,2,0,4"
                                                       Text="{Binding FieldLocationText}"/>

                                            <TextBlock Text="{DynamicResource PdfAiSuggestedText}"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                            <TextBlock Text="{Binding SuggestedText}"
                                                       FontSize="{DynamicResource FS10}"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,1,0,4"/>

                                            <TextBlock Text="{DynamicResource PdfAiTagsUsed}"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                            <ItemsControl ItemsSource="{Binding TagDisplayLines}"
                                                          Margin="0,1,0,4">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   FontSize="9"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   TextWrapping="Wrap"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="{DynamicResource PdfAiReason}"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                            <TextBlock Text="{Binding Reason}"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,1,0,6"/>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Command="{Binding DataContext.IgnoreAIPdfSuggestionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,3"
                                                        Margin="0,0,6,0"
                                                        Background="{DynamicResource CardBackgroundBrush}"
                                                        Foreground="{DynamicResource ForegroundBrush}"
                                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        Cursor="Hand">
                                                    <TextBlock Text="{DynamicResource PdfAiIgnore}" FontSize="{DynamicResource FS10}"/>
                                                </Button>
                                                <Button Command="{Binding DataContext.ApplyAIPdfSuggestionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,3"
                                                        Background="{DynamicResource AccentBrush}"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Cursor="Hand">
                                                    <TextBlock Text="{DynamicResource EditorInsert}" FontSize="{DynamicResource FS10}"/>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== FOOTER ===== -->
        <Border Grid.Row="3" Background="{DynamicResource CardBackgroundBrush}" 
                Padding="10,4" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                    <Border Width="14" Height="14" CornerRadius="2" Margin="0,0,4,0"
                            Background="{DynamicResource AccentLightBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"/>
                    <TextBlock Text="{DynamicResource PdfTagMarker}" FontSize="{DynamicResource FS10}" Foreground="{DynamicResource SecondaryForegroundBrush}" 
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding CoordinateText}" 
                           FontSize="{DynamicResource FS10}" Foreground="{DynamicResource SecondaryForegroundBrush}" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="2" Text="{Binding StatusMessage}" 
                           FontSize="{DynamicResource FS11}" Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
