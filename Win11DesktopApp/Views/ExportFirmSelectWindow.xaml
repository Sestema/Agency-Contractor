<Window x:Class="Win11DesktopApp.Views.ExportFirmSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource FinExportSelectTitle}"
        Width="640" Height="700"
        MinWidth="560" MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Border Style="{StaticResource PageHeaderIconBadge}" Background="{DynamicResource SuccessBrush}">
                <TextBlock Text="&#xE80A;" Style="{StaticResource PageHeaderIconText}"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource FinExportSelectTitle}"
                           FontSize="{DynamicResource FS20}"
                           Style="{StaticResource PageHeaderTitleText}"/>
                <TextBlock Text="{DynamicResource FinExportSelectDesc}"
                           FontSize="{DynamicResource FS11}"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>

        <!-- Summary -->
        <Border Grid.Row="1" Style="{StaticResource DialogSectionCard}" Margin="0,0,0,12" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource DialogPreviewSurface}" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource FinExportFirmsCount}"
                                   FontSize="{DynamicResource FS11}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <TextBlock x:Name="TotalFirmsText"
                                   FontSize="{DynamicResource FS18}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource DialogPreviewSurface}" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource FinExportSelectedCount}"
                                   FontSize="{DynamicResource FS11}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <TextBlock x:Name="SelectedFirmsText"
                                   FontSize="{DynamicResource FS18}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Style="{StaticResource DialogPreviewSurface}" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource FinExportRowsCount}"
                                   FontSize="{DynamicResource FS11}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                        <TextBlock x:Name="SelectedRowsText"
                                   FontSize="{DynamicResource FS18}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Select All -->
        <Border Grid.Row="2" Style="{StaticResource DialogSectionCard}" Margin="0,0,0,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource SuccessLightBrush}">
                        <TextBlock Text="&#xE8B5;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="{DynamicResource FS13}"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource FinExportSelectAll}"
                                   FontSize="{DynamicResource FS14}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                        <TextBlock x:Name="SelectionHintText"
                                   FontSize="{DynamicResource FS11}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Margin="0,2,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="SelectAllBox"
                              Checked="SelectAll_Checked"
                              Unchecked="SelectAll_Unchecked"
                              FontSize="{DynamicResource FS13}"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource ForegroundBrush}"
                              Cursor="Hand"
                              VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource FinExportSelectAll}"/>
                    </CheckBox>

                    <Button Grid.Column="1"
                            Click="ClearAll_Click"
                            Style="{StaticResource HeaderGhostButton}"
                            Padding="12,6">
                        <TextBlock Text="{DynamicResource FinExportClearAll}"
                                   FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Firm list -->
        <Border Grid.Row="3" Style="{StaticResource DialogSectionCard}" Padding="10">
            <ScrollViewer Style="{StaticResource ThinScroll}">
                <ItemsControl x:Name="FirmList">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="0,0,0,8"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10">
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource DialogPreviewSurface}">
                                        <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected}"
                                              FontSize="{DynamicResource FS13}"
                                              Foreground="{DynamicResource ForegroundBrush}"
                                              Cursor="Hand"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FirmName}"
                                                   FontSize="{DynamicResource FS13}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Background="{DynamicResource SuccessLightBrush}"
                                            CornerRadius="999"
                                            Padding="10,4"
                                            VerticalAlignment="Center">
                                        <TextBlock FontSize="{DynamicResource FS11}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SuccessBrush}">
                                            <Run Text="{Binding EmployeeCount}"/>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Click="Cancel_Click" Margin="0,0,8,0" Style="{StaticResource HeaderGhostButton}">
                <TextBlock Text="{DynamicResource BtnCancel}"
                           FontSize="{DynamicResource FS13}"
                           Foreground="{DynamicResource ForegroundBrush}"/>
            </Button>

            <Button x:Name="ExportButton"
                    Click="Export_Click"
                    Background="{DynamicResource SuccessBrush}"
                    Style="{StaticResource FilledActionButton}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE80A;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="{DynamicResource FS12}"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBlock Text="{DynamicResource FinExportBtn}"
                               FontSize="{DynamicResource FS13}"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
