<UserControl x:Class="Win11DesktopApp.Views.PaymentSignView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid Margin="32,20,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                        Background="Transparent" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="8,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource BtnBack}" FontSize="{DynamicResource FS14}" Margin="8,0,0,0"
                                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border CornerRadius="10" Width="44" Height="44">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2196F3" Offset="0"/>
                                <GradientStop Color="#00BCD4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS20}"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{DynamicResource PaySignTitle}" FontSize="{DynamicResource FS24}" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Description -->
            <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="20,14" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{DynamicResource PaySignDesc}" FontSize="{DynamicResource FS13}"
                               Foreground="{DynamicResource ForegroundBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Parameters: Month + Date -->
            <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="14" Padding="20,16" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Month selector -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource PaySignMonth}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}"
                                      Width="70" FontSize="{DynamicResource FS14}" Padding="8,6" Margin="0,0,10,0"/>
                            <TextBlock Text="/" FontSize="{DynamicResource FS16}" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <ComboBox ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}"
                                      Width="90" FontSize="{DynamicResource FS14}" Padding="8,6"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Payment date -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{DynamicResource PaySignPayDate}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding PaymentDate, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="{DynamicResource FS14}" Padding="10,8"
                                 Background="{DynamicResource WindowBackgroundBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Firms list -->
            <Border Grid.Row="3" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="14" Padding="20,16" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="{DynamicResource PaySignSelectFirms}" FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Right" Command="{Binding SelectAllCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Padding="12,5"
                                            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                                        <TextBlock Text="{DynamicResource AdvTableSelectAll}" FontSize="{DynamicResource FS12}"
                                                   Foreground="{DynamicResource AccentBrush}" FontWeight="Medium"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,0,0,6"/>

                    <ScrollViewer Grid.Row="2" Style="{StaticResource ThinScroll}">
                        <ItemsControl ItemsSource="{Binding Firms}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="10"
                                            Padding="14,10" Margin="0,0,0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center"
                                                      Margin="0,0,12,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding FirmName}" FontSize="{DynamicResource FS14}" FontWeight="Medium"
                                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                                            <Border Grid.Column="2" Background="#E3F2FD" CornerRadius="8" Padding="10,4">
                                                <TextBlock FontSize="{DynamicResource FS12}" Foreground="#1565C0" FontWeight="Medium">
                                                    <Run Text="{Binding EmployeeCount, Mode=OneWay}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{DynamicResource BtnEmployees}"/>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Bottom bar -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="{DynamicResource FS13}"
                           Foreground="#888" VerticalAlignment="Center"/>

                <Button Grid.Column="1" Command="{Binding GeneratePdfCommand}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="10" Padding="22,12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#2196F3" Offset="0"/>
                                        <GradientStop Color="#00BCD4" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS15}"
                                               Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{DynamicResource PaySignGenerate}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
