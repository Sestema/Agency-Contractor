    <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6"/>
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#A78BFA"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#1C2D42"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#3FB950"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="#1B2E1F"/>
