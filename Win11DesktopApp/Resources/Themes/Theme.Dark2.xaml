<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#121212"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="CardHoverBrush" Color="#2C2C2C"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#BB86FC"/>
    
    <DropShadowEffect x:Key="CardShadow" BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.8"/>
</ResourceDictionary>
