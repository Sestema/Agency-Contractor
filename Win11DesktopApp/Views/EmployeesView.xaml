<UserControl x:Class="Win11DesktopApp.Views.EmployeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:Win11DesktopApp.Views"
             xmlns:local="clr-namespace:Win11DesktopApp.Converters"
             xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels"
             xmlns:h="clr-namespace:Win11DesktopApp.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <local:StatusColorConverter x:Key="StatusColor"/>
        <local:StatusBackgroundConverter x:Key="StatusBg"/>
        <Style x:Key="StatusMessageText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsError}" Value="True">
                    <Setter Property="Foreground" Value="#c62828"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardActionBtn" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource CardHoverBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkAwareDeleteBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#EF5350"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource CardHoverBrush}"
                                BorderBrush="#EF5350" BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D32F2F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}" ClipToBounds="False">
        <Grid ClipToBounds="False">
            <Grid Margin="24,16,24,20" ClipToBounds="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="Auto"/>  <!-- Statistics -->
                    <RowDefinition Height="Auto"/>  <!-- Sort bar -->
                    <RowDefinition Height="Auto"/>  <!-- Selection bar -->
                    <RowDefinition Height="Auto"/>  <!-- View mode selector -->
                    <RowDefinition Height="*"/>     <!-- List -->
                </Grid.RowDefinitions>

                <!-- ===== HEADER ===== -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Command="{Binding GoBackCommand}" Style="{StaticResource HeaderBackButton}" Margin="0,0,10,0">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                        </Button>
                        <Border Style="{StaticResource PageHeaderIconBadge}">
                            <TextBlock Text="&#xE77B;" Style="{StaticResource PageHeaderIconText}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontSize="{DynamicResource FS24}" Style="{StaticResource PageHeaderTitleText}"/>
                            <TextBlock FontSize="{DynamicResource FS12}"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Margin="0,3,0,0">
                                <Run Text="{Binding TotalCount}"/>
                                <Run Text=" "/>
                                <Run Text="{DynamicResource EmpStatActive}"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding ProblemsCount}"/>
                                <Run Text=" "/>
                                <Run Text="{DynamicResource EmpStatProblems}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Style="{StaticResource ToolbarSearchContainer}"
                            Margin="18,0,0,0"
                            CornerRadius="12"
                            Height="38"
                            MaxWidth="380"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center">
                        <Grid Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{DynamicResource FS12}"
                                       Foreground="{DynamicResource TertiaryForegroundBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     VerticalAlignment="Center"
                                     BorderThickness="0"
                                     Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     CaretBrush="{DynamicResource ForegroundBrush}"
                                     FontSize="{DynamicResource FS12}"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Button Command="{Binding ExportToExcelCommand}"
                                Style="{StaticResource HeaderGhostButton}"
                                Margin="0,0,8,0"
                                ToolTip="{DynamicResource EmpTooltipExport}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" Margin="0,0,6,0"/>
                                <TextBlock Text="Excel" FontSize="{DynamicResource FS12}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ToggleSelectionModeCommand}"
                                Style="{StaticResource HeaderGhostButton}"
                                Margin="0,0,8,0"
                                ToolTip="{DynamicResource EmpTooltipSelect}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE762;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource EmpBtnSelect}" FontSize="{DynamicResource FS12}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding AddEmployeeCommand}" Style="{StaticResource FilledActionButton}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                           Foreground="White" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource BtnAddEmployee}" FontSize="{DynamicResource FS13}"
                                           FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Skeleton loading placeholders -->
                <StackPanel Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ProgressBar IsIndeterminate="True" Height="3" Width="100" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource MsgEmployeesLoading}" FontSize="{DynamicResource FS11}" 
                                   VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                    <Border Style="{StaticResource SkeletonCard}" Height="72" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="44" Height="44" RadiusX="22" RadiusY="22" Style="{StaticResource SkeletonBlock}"/>
                            <StackPanel Margin="14,4,0,0">
                                <Rectangle Width="160" Height="14" Style="{StaticResource SkeletonBlock}" Margin="0,0,0,8"/>
                                <Rectangle Width="100" Height="10" Style="{StaticResource SkeletonBlock}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SkeletonCard}" Height="72" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="44" Height="44" RadiusX="22" RadiusY="22" Style="{StaticResource SkeletonBlock}"/>
                            <StackPanel Margin="14,4,0,0">
                                <Rectangle Width="140" Height="14" Style="{StaticResource SkeletonBlock}" Margin="0,0,0,8"/>
                                <Rectangle Width="120" Height="10" Style="{StaticResource SkeletonBlock}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SkeletonCard}" Height="72" Margin="0,0,0,6">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="44" Height="44" RadiusX="22" RadiusY="22" Style="{StaticResource SkeletonBlock}"/>
                            <StackPanel Margin="14,4,0,0">
                                <Rectangle Width="180" Height="14" Style="{StaticResource SkeletonBlock}" Margin="0,0,0,8"/>
                                <Rectangle Width="90" Height="10" Style="{StaticResource SkeletonBlock}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ===== STATISTICS ===== -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12"
                            Visibility="{Binding HasEmployees, Converter={StaticResource BoolToVis}}">
                    <!-- Total -->
                    <Border CornerRadius="8" Padding="16,8" Margin="0,0,10,0" MinWidth="120" Cursor="Hand"
                            BorderThickness="2">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding FilterByStatCommand}" CommandParameter="all"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatFilter}" Value="all">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding TotalCount}" FontSize="{DynamicResource FS22}" FontWeight="Bold" 
                                       Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="{DynamicResource EmpStatTotal}" FontSize="{DynamicResource FS11}" Foreground="#888"/>
                        </StackPanel>
                    </Border>
                    <!-- Problems -->
                    <Border CornerRadius="8" Padding="16,8" Margin="0,0,10,0" MinWidth="120" Cursor="Hand"
                            BorderThickness="2">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding FilterByStatCommand}" CommandParameter="problems"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatFilter}" Value="problems">
                                        <Setter Property="BorderBrush" Value="#EF6C00"/>
                                        <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding ProblemsCount}" FontSize="{DynamicResource FS22}" FontWeight="Bold" Foreground="#EF6C00"/>
                            <TextBlock Text="{DynamicResource EmpStatProblems}" FontSize="{DynamicResource FS11}" Foreground="#EF6C00"/>
                        </StackPanel>
                    </Border>
                    <!-- New this month -->
                    <Border CornerRadius="8" Padding="16,8" MinWidth="120" Cursor="Hand"
                            BorderThickness="2">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding FilterByStatCommand}" CommandParameter="new"/>
                        </Border.InputBindings>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatFilter}" Value="new">
                                        <Setter Property="BorderBrush" Value="#1565C0"/>
                                        <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding NewThisMonth}" FontSize="{DynamicResource FS22}" FontWeight="Bold" Foreground="#42A5F5"/>
                            <TextBlock Text="{DynamicResource EmpStatNewMonth}" FontSize="{DynamicResource FS11}" Foreground="#42A5F5"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ===== SORT BAR ===== -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10"
                            Visibility="{Binding HasEmployees, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{DynamicResource EmpSortLabel}" FontSize="{DynamicResource FS12}" Foreground="#888" 
                               VerticalAlignment="Center" Margin="0,0,8,0"/>

                    <Button Command="{Binding SortByCommand}" CommandParameter="Name"
                            Padding="10,5" Margin="0,0,4,0" Cursor="Hand"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Foreground="{DynamicResource ForegroundBrush}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SortField}" Value="Name">
                                        <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource EmpSortName}" FontSize="{DynamicResource FS12}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SortByCommand}" CommandParameter="StartDate"
                            Padding="10,5" Margin="0,0,4,0" Cursor="Hand"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Foreground="{DynamicResource ForegroundBrush}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SortField}" Value="StartDate">
                                        <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource EmpSortDate}" FontSize="{DynamicResource FS12}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SortByCommand}" CommandParameter="Status"
                            Padding="10,5" Margin="0,0,4,0" Cursor="Hand"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Foreground="{DynamicResource ForegroundBrush}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SortField}" Value="Status">
                                        <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource EmpSortStatus}" FontSize="{DynamicResource FS12}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SortByCommand}" CommandParameter="Problems"
                            Padding="10,5" Margin="0,0,4,0" Cursor="Hand"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Foreground="{DynamicResource ForegroundBrush}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SortField}" Value="Problems">
                                        <Setter Property="Background" Value="#FFF3E0"/>
                                        <Setter Property="BorderBrush" Value="#EF6C00"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="#EF6C00"/>
                            <TextBlock Text="{DynamicResource EmpSortProblems}" FontSize="{DynamicResource FS12}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- ===== SELECTION BAR ===== -->
                <Border Grid.Row="3" CornerRadius="8" Padding="12,8" Margin="0,0,0,10"
                        Background="{DynamicResource AccentBrush}"
                        Visibility="{Binding IsSelectionMode, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedCount, StringFormat='Обрано: {0}'}" 
                                       Foreground="White" FontWeight="SemiBold" FontSize="{DynamicResource FS13}" 
                                       VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <Button Command="{Binding SelectAllCommand}" Padding="10,4" Margin="0,0,6,0"
                                    Background="#FFFFFF" Foreground="{DynamicResource AccentBrush}" 
                                    BorderThickness="0" Cursor="Hand" FontSize="{DynamicResource FS12}">
                                <TextBlock Text="{DynamicResource EmpSelectAll}"/>
                            </Button>
                            <Button Command="{Binding BatchGenerateCommand}" Padding="10,4" Margin="0,0,6,0"
                                    Background="#FFFFFF" Foreground="{DynamicResource AccentBrush}" 
                                    BorderThickness="0" Cursor="Hand" FontSize="{DynamicResource FS12}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource EmpGenerate}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Command="{Binding DeselectAllCommand}" 
                                Padding="10,4" Background="Transparent" BorderThickness="0" 
                                Foreground="White" Cursor="Hand" FontSize="{DynamicResource FS12}">
                            <TextBlock Text="{DynamicResource BtnCancel}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ===== VIEW MODE SELECTOR + ZOOM ===== -->
                <DockPanel Grid.Row="4" Margin="0,0,0,6">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Button Command="{Binding SetViewModeCommand}" CommandParameter="Table" ToolTip="{DynamicResource ViewTable}"
                                Padding="6,4" Margin="0,0,2,0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewMode}" Value="Table">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                        </Button>
                        <Button Command="{Binding SetViewModeCommand}" CommandParameter="List" ToolTip="{DynamicResource ViewList}"
                                Padding="6,4" Margin="0,0,2,0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewMode}" Value="List">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="&#xEA37;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                        </Button>
                        <Button Command="{Binding SetViewModeCommand}" CommandParameter="Tiles" ToolTip="{DynamicResource ViewTiles}"
                                Padding="6,4" Margin="0,0,2,0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewMode}" Value="Tiles">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                        </Button>
                        <Button Command="{Binding SetViewModeCommand}" CommandParameter="Icons" ToolTip="{DynamicResource ViewIcons}"
                                Padding="6,4" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewMode}" Value="Icons">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="&#xE80B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                        </Button>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Foreground="#999" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <Slider Value="{Binding ZoomLevel}" Minimum="0.6" Maximum="1.6" Width="100"
                                TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        <TextBlock Text="&#xE8A3;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" Foreground="#999" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                </DockPanel>

                <!-- ===== EMPLOYEE LIST ===== -->
                <Grid Grid.Row="5" ClipToBounds="False">
                    <ScrollViewer Style="{StaticResource ThinScroll}" ClipToBounds="False">
                        <Grid Margin="4,10,4,4" ClipToBounds="False">
                            <Grid.LayoutTransform>
                                <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}"/>
                            </Grid.LayoutTransform>

                            <!-- TABLE VIEW -->
                            <DataGrid ItemsSource="{Binding Employees}" AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserSortColumns="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      BorderThickness="0" Background="Transparent" RowBackground="{DynamicResource CardBackgroundBrush}"
                                      AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}"
                                      Foreground="{DynamicResource ForegroundBrush}" FontSize="{DynamicResource FS12}"
                                      Visibility="{Binding IsTableView, Converter={StaticResource BoolToVis}}"
                                      MouseDoubleClick="DataGrid_MouseDoubleClick">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EmployeeType}" Value="passport_only">
                                                <Setter Property="Background" Value="#E3F2FD"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding FullName}" Width="*" FontWeight="SemiBold">
                                        <DataGridTextColumn.Header><TextBlock Text="{DynamicResource EmpSortName}"/></DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding PositionTitle}" Width="Auto">
                                        <DataGridTextColumn.Header><TextBlock Text="{DynamicResource LabelPosTitle}"/></DataGridTextColumn.Header>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding Status}" Width="80">
