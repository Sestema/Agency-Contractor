<Window x:Class="Win11DesktopApp.Views.TagVisibilityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource TagVisTitle}"
        Width="600" Height="660"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Border Style="{StaticResource PageHeaderIconBadge}">
                <TextBlock Text="&#xE8D2;" Style="{StaticResource PageHeaderIconText}"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource TagVisHeader}"
                           FontSize="{DynamicResource FS20}"
                           Style="{StaticResource PageHeaderTitleText}"/>
                <TextBlock Text="{DynamicResource SettingsTagsDesc}"
                           FontSize="{DynamicResource FS11}"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource DialogSectionCard}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Button Content="{DynamicResource TagVisSelectAll}"
                        Click="SelectAll_Click"
                        Padding="14,6"
                        Margin="0,0,10,0"
                        FontSize="{DynamicResource FS13}"
                        FontWeight="Medium"
                        Style="{StaticResource FilledActionButton}"/>
                <Button Content="{DynamicResource TagVisDeselectAll}"
                        Click="DeselectAll_Click"
                        Padding="14,6"
                        FontSize="{DynamicResource FS13}"
                        FontWeight="Medium"
                        Style="{StaticResource HeaderGhostButton}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource DialogSectionCard}" Padding="12">
            <ScrollViewer Style="{StaticResource ThinScroll}">
                <ItemsControl x:Name="TagGroupsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource DialogPreviewSurface}" Margin="0,0,0,12" Padding="14,12">
                                <StackPanel>
                                    <TextBlock Text="{Binding GroupName}"
                                               FontSize="{DynamicResource FS14}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Margin="0,0,0,8"
                                                        Padding="12,8">
                                                    <CheckBox IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                                              Cursor="Hand">
                                                        <CheckBox.Content>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Description}" 
                                                                           FontSize="{DynamicResource FS13}"
                                                                           Foreground="{DynamicResource ForegroundBrush}"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Tag, StringFormat=' ({0})'}" 
                                                                           FontSize="{DynamicResource FS11}"
                                                                           Opacity="0.5"
                                                                           Foreground="{DynamicResource ForegroundBrush}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="6,0,0,0"/>
                                                            </StackPanel>
                                                        </CheckBox.Content>
                                                    </CheckBox>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{DynamicResource TagVisCancel}"
                    Click="Cancel_Click"
                    Padding="20,8"
                    Margin="0,0,10,0"
                    FontSize="{DynamicResource FS14}"
                    FontWeight="Medium"
                    Style="{StaticResource HeaderGhostButton}"/>
            <Button Content="{DynamicResource TagVisSave}"
                    Click="Save_Click"
                    Padding="20,8"
                    FontSize="{DynamicResource FS14}"
                    FontWeight="SemiBold"
                    Style="{StaticResource FilledActionButton}"/>
        </StackPanel>
    </Grid>
</Window>
