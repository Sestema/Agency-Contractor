<UserControl x:Class="Win11DesktopApp.Views.ActivityLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels"
             xmlns:views="clr-namespace:Win11DesktopApp.Views"
             mc:Ignorable="d"
             d:DesignHeight="750" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Grid Grid.Row="0" Margin="24,16,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                    Style="{StaticResource HeaderBackButton}">
                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
            </Button>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="#FFF3E0" CornerRadius="8" Width="36" Height="36">
                    <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                               Foreground="#E65100" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{DynamicResource BtnActivityLog}" FontSize="{DynamicResource FS20}" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                <Border Background="#FFF3E0" CornerRadius="10" Padding="10,3" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontSize="{DynamicResource FS12}" FontWeight="Bold" Foreground="#E65100">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}/{1}">
                                <Binding Path="FilteredCount"/>
                                <Binding Path="TotalCount"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </Border>
            </StackPanel>

            <!-- Export -->
            <Button Grid.Column="2" Command="{Binding ExportCommand}"
                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                    VerticalAlignment="Center" Padding="8,6" Margin="4,0"
                    ToolTip="{DynamicResource ActLogExport}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                               Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Clear All -->
            <Button Grid.Column="3" Command="{Binding ClearAllCommand}"
                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                    VerticalAlignment="Center" Padding="8,6" Margin="4,0"
                    ToolTip="{DynamicResource ActLogClearAll}">
                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                           Foreground="#C62828" VerticalAlignment="Center"/>
            </Button>

            <!-- Clear Filter -->
            <Button Grid.Column="4" Command="{Binding ClearFilterCommand}"
                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                    VerticalAlignment="Center" Padding="8,6"
                    ToolTip="{DynamicResource ActLogClearFilter}">
                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                           Foreground="{DynamicResource ForegroundBrush}"/>
            </Button>
        </Grid>

        <!-- Filters Row 1: Search + Date + Firm -->
        <Grid Grid.Row="1" Margin="24,4,24,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search -->
            <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="12,6" Margin="0,0,8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                               Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0"
                             FontSize="{DynamicResource FS13}" Foreground="{DynamicResource ForegroundBrush}"
                             VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Date From -->
            <TextBlock Grid.Column="1" Text="{DynamicResource ActLogDateFrom}"
                       FontSize="{DynamicResource FS11}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.6"
                       VerticalAlignment="Center" Margin="4,0,4,0"/>
            <DatePicker Grid.Column="2" SelectedDate="{Binding DateFrom}" Width="120"
                        FontSize="{DynamicResource FS11}" VerticalAlignment="Center" Margin="0,0,8,0"/>

            <!-- Date To -->
            <TextBlock Grid.Column="3" Text="{DynamicResource ActLogDateTo}"
                       FontSize="{DynamicResource FS11}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.6"
                       VerticalAlignment="Center" Margin="4,0,4,0"/>
            <DatePicker Grid.Column="4" SelectedDate="{Binding DateTo}" Width="120"
                        FontSize="{DynamicResource FS11}" VerticalAlignment="Center" Margin="0,0,8,0"/>

            <!-- Firm Filter -->
            <ComboBox Grid.Column="5" Width="180" FontSize="{DynamicResource FS11}"
                      VerticalAlignment="Center"
                      ItemsSource="{Binding FirmNames}"
                      SelectedItem="{Binding SelectedFirm}"
                      IsEditable="False"/>
        </Grid>

        <!-- Filters Row 2: Category chips -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                      Margin="24,4,24,8">
            <ItemsControl ItemsSource="{Binding Categories}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Margin="0,0,6,0" Cursor="Hand" Padding="10,5"
                                Command="{Binding DataContext.FilterByCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding Key}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="14" Padding="{TemplateBinding Padding}"
                                            BorderThickness="1.5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding DisplayName}" FontSize="{DynamicResource FS11}"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#E3F2FD"/>
                                        </Trigger>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{x:Static vm:EqualityConverter.Instance}">
                                                    <Binding Path="Key"/>
                                                    <Binding Path="DataContext.SelectedCategory" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Main list -->
        <Border Grid.Row="3" Margin="24,0,24,24"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                CornerRadius="12" Padding="0"
                Effect="{DynamicResource CardShadow}">
            <Grid>
                <!-- Empty state -->
                <TextBlock Text="{DynamicResource ActLogEmpty}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="{DynamicResource FS14}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.4">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasEntries}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ListView ItemsSource="{Binding GroupedEntries}"
                          Background="Transparent" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingPanel.IsVirtualizing="True"
                          Visibility="{Binding HasEntries, Converter={StaticResource BoolToVis}}">
                    <ListView.Resources>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.Resources>

                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource PageBackgroundBrush}" Padding="16,10,16,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="{DynamicResource FS12}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" FontSize="{DynamicResource FS13}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                            <Border Background="{DynamicResource AccentBrush}" CornerRadius="8"
                                                    Padding="7,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ItemCount}" FontSize="{DynamicResource FS10}"
                                                           Foreground="White" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="16,10" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,0.5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Colored icon by category -->
                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8"
                                            Margin="0,0,12,0" VerticalAlignment="Top">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F5F5F5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Category}" Value="Employee">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="Salary">
                                                        <Setter Property="Background" Value="#E3F2FD"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="Advance">
                                                        <Setter Property="Background" Value="#FFF3E0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="Archive">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="Document">
                                                        <Setter Property="Background" Value="#F3E5F5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="Export">
                                                        <Setter Property="Background" Value="#E0F7FA"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="Company">
                                                        <Setter Property="Background" Value="#EFEBE9"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="Template">
                                                        <Setter Property="Background" Value="#FFFDE7"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="Settings">
                                                        <Setter Property="Background" Value="#ECEFF1"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Category}" Value="Candidate">
                                                        <Setter Property="Background" Value="#FFF3E0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="&#xE7C3;"/>
                                                    <Setter Property="Foreground" Value="#757575"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Category}" Value="Employee">
                                                            <Setter Property="Text" Value="&#xE77B;"/>
                                                            <Setter Property="Foreground" Value="#43A047"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Category}" Value="Salary">
                                                            <Setter Property="Text" Value="&#xE8CB;"/>
                                                            <Setter Property="Foreground" Value="#1976D2"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Category}" Value="Advance">
                                                            <Setter Property="Text" Value="&#xE8C7;"/>
                                                            <Setter Property="Foreground" Value="#E65100"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Category}" Value="Archive">
                                                            <Setter Property="Text" Value="&#xE7B8;"/>
                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Category}" Value="Document">
                                                            <Setter Property="Text" Value="&#xE8A5;"/>
                                                            <Setter Property="Foreground" Value="#7B1FA2"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Category}" Value="Export">
                                                            <Setter Property="Text" Value="&#xE8A1;"/>
                                                            <Setter Property="Foreground" Value="#00838F"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Category}" Value="Company">
                                                            <Setter Property="Text" Value="&#xE731;"/>
                                                            <Setter Property="Foreground" Value="#4E342E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Category}" Value="Template">
                                                            <Setter Property="Text" Value="&#xE8A5;"/>
                                                            <Setter Property="Foreground" Value="#F57F17"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Category}" Value="Settings">
                                                            <Setter Property="Text" Value="&#xE713;"/>
                                                            <Setter Property="Foreground" Value="#546E7A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Category}" Value="Candidate">
                                                            <Setter Property="Text" Value="&#xE77B;"/>
                                                            <Setter Property="Foreground" Value="#FF9800"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Description -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Description}" FontSize="{DynamicResource FS12}"
                                                   Foreground="{DynamicResource ForegroundBrush}" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding FirmName}" FontSize="{DynamicResource FS10}"
                                                       Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"/>
                                            <Button Margin="6,0,0,0" Cursor="Hand" Background="Transparent" BorderThickness="0" Padding="0"
                                                    Command="{Binding DataContext.OpenEmployeeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <TextBlock x:Name="EmpName" Text="{Binding EmployeeName}"
                                                                   FontSize="{DynamicResource FS10}"
                                                                   Foreground="{DynamicResource AccentBrush}" Opacity="0.8"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="EmpName" Property="TextDecorations" Value="Underline"/>
                                                                <Setter TargetName="EmpName" Property="Opacity" Value="1"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                        <!-- Old -> New values -->
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding OldValue}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="{Binding OldValue}" FontSize="{DynamicResource FS11}"
                                                       Foreground="#C62828" TextDecorations="Strikethrough"/>
                                            <TextBlock Text=" → " FontSize="{DynamicResource FS11}"
                                                       Foreground="{DynamicResource ForegroundBrush}" Opacity="0.4"/>
                                            <TextBlock Text="{Binding NewValue}" FontSize="{DynamicResource FS11}"
                                                       Foreground="#2E7D32" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Time -->
                                    <TextBlock Grid.Column="2" VerticalAlignment="Top" Margin="12,0,0,0"
                                               FontSize="{DynamicResource FS10}"
                                               Foreground="{DynamicResource ForegroundBrush}" Opacity="0.4">
                                        <TextBlock.Text>
                                            <Binding Path="Timestamp" StringFormat="{}{0:HH:mm}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Employee Details Overlay -->
        <Grid Grid.RowSpan="4" Visibility="{Binding IsEmployeeDetailsOpen, Converter={StaticResource BoolToVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEmployeeDetailsOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#66000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding EmployeeDetailsVm.CloseCommand}"/>
                </Border.InputBindings>
            </Border>
            <ContentControl Content="{Binding EmployeeDetailsVm}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:EmployeeDetailsViewModel}">
                        <views:EmployeeDetailsView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>
    </Grid>
</UserControl>
