<UserControl x:Class="Win11DesktopApp.Views.FinanceTablesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid Margin="{StaticResource PageOuterMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="{StaticResource PageHeaderMarginLarge}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                        Style="{StaticResource HeaderBackButton}">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Style="{StaticResource PageHeaderIconBadge}"
                            Background="{DynamicResource BrandPrimaryGradientBrush}">
                        <TextBlock Text="&#xE9D2;" Style="{StaticResource PageHeaderIconText}"/>
                    </Border>
                    <TextBlock Text="{DynamicResource FinTabTitle}" FontSize="{DynamicResource FS26}" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- 2 CARDS -->
            <UniformGrid Grid.Row="1" Columns="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                         MaxWidth="700" MaxHeight="350">
                
                <!-- Finances Card -->
                <Border Style="{StaticResource HoverLiftCard}" Margin="12" CornerRadius="18" Padding="28,32">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding OpenFinancesCommand}"/>
                    </Border.InputBindings>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="64" Height="64" CornerRadius="16" HorizontalAlignment="Center" Margin="0,0,0,16"
                                Background="{DynamicResource BrandPrimaryGradientBrush}">
                            <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS28}"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource FinTabFinances}" FontSize="{DynamicResource FS20}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource FinTabFinancesDesc}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource MutedDescriptionBrush}"
                                   HorizontalAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Tables Card -->
                <Border Style="{StaticResource HoverLiftCard}" Margin="12" CornerRadius="18" Padding="28,32">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding OpenTablesCommand}"/>
                    </Border.InputBindings>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="64" Height="64" CornerRadius="16" HorizontalAlignment="Center" Margin="0,0,0,16"
                                Background="{DynamicResource BrandSuccessGradientBrush}">
                            <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS28}"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource FinTabTables}" FontSize="{DynamicResource FS20}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource FinTabTablesDesc}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource MutedDescriptionBrush}"
                                   HorizontalAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Grid>
</UserControl>
