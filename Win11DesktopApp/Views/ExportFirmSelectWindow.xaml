<Window x:Class="Win11DesktopApp.Views.ExportFirmSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource FinExportSelectTitle}"
        Width="400" Height="420" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Border Background="{DynamicResource SuccessLightBrush}" CornerRadius="8" Width="36" Height="36" Margin="0,0,10,0">
                    <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource FinExportSelectTitle}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}"/>
                    <TextBlock Text="{DynamicResource FinExportSelectDesc}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Select All -->
        <CheckBox x:Name="SelectAllBox" Grid.Row="1" Margin="4,0,0,8"
                  IsChecked="True" Checked="SelectAll_Checked" Unchecked="SelectAll_Unchecked"
                  FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                  Foreground="{DynamicResource ForegroundBrush}">
            <TextBlock Text="{DynamicResource FinExportSelectAll}"/>
        </CheckBox>

        <!-- Firm list -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="8">
            <ScrollViewer Style="{StaticResource ThinScroll}">
                <ItemsControl x:Name="FirmList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="8"
                                    Padding="10,8" Margin="0,2">
                                <CheckBox IsChecked="{Binding IsSelected}" FontSize="{DynamicResource FS13}"
                                          Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding FirmName}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding EmployeeCount, StringFormat=' ({0})'}" 
                                                   FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" 
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </CheckBox>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Click="Cancel_Click" Cursor="Hand" Margin="0,0,8,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="18,9"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <TextBlock Text="{DynamicResource BtnCancel}" FontSize="{DynamicResource FS13}"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Click="Export_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource SuccessBrush}" CornerRadius="8" Padding="22,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource FinExportBtn}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                           Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
