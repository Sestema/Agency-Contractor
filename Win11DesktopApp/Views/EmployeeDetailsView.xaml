                                                </StackPanel>
                                            </Border>

                                            <!-- Visa (hidden for passport_only) -->
                                            <StackPanel>
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Data.EmployeeType}" Value="passport_only">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Border Background="{DynamicResource AccentLightBrush}" CornerRadius="6" Width="24" Height="24" Margin="0,0,8,0">
                                                        <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{DynamicResource DetDocVisa}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold" Foreground="{DynamicResource AccentDarkBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                        Padding="14" Margin="0,0,0,16"
                                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                    <StackPanel>
                                                        <StackPanel>
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Data.EmployeeType}" Value="eu_citizen">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Text="{DynamicResource DetFieldVisaNum}" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox Text="{Binding Data.VisaNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                            <TextBlock Text="{DynamicResource DetFieldVisaType}" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox Text="{Binding Data.VisaType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{DynamicResource DetFieldExpiry}" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Text="{Binding Data.VisaExpiry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        <Border CornerRadius="4" Padding="6,2" Margin="0,0,0,8" HorizontalAlignment="Left"
                                                                Background="{Binding VisaExpiryWarning, Converter={StaticResource ExpiryWarnBg}}"
                                                                Visibility="{Binding VisaExpiryWarning, Converter={StaticResource ExpiryWarnVis}}">
                                                            <TextBlock Text="{Binding VisaExpiryWarning, Converter={StaticResource ExpiryWarnText}}" FontSize="{DynamicResource FS10}" FontWeight="SemiBold"
                                                                       Foreground="{Binding VisaExpiryWarning, Converter={StaticResource ExpiryWarnColor}}"/>
                                                        </Border>
                                                        <TextBlock Text="{DynamicResource DetFieldWorkPermitName}" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Text="{Binding Data.WorkPermitName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <!-- Insurance (hidden for passport_only) -->
                                            <StackPanel>
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Data.EmployeeType}" Value="passport_only">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Border Background="{DynamicResource WarningLightBrush}" CornerRadius="6" Width="24" Height="24" Margin="0,0,8,0">
                                                        <TextBlock Text="&#xE8C9;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{DynamicResource DetDocInsurance}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                        Padding="14" Margin="0,0,0,16"
                                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="{DynamicResource DetFieldInsCompany}" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Text="{Binding Data.InsuranceCompanyShort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        <TextBlock Text="{DynamicResource DetFieldInsNum}" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Text="{Binding Data.InsuranceNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        <TextBlock Text="{DynamicResource DetFieldExpiry}" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Text="{Binding Data.InsuranceExpiry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        <Border CornerRadius="4" Padding="6,2" Margin="0,0,0,8" HorizontalAlignment="Left"
                                                                Background="{Binding InsuranceExpiryWarning, Converter={StaticResource ExpiryWarnBg}}"
                                                                Visibility="{Binding InsuranceExpiryWarning, Converter={StaticResource ExpiryWarnVis}}">
                                                            <TextBlock Text="{Binding InsuranceExpiryWarning, Converter={StaticResource ExpiryWarnText}}" FontSize="{DynamicResource FS10}" FontWeight="SemiBold"
                                                                       Foreground="{Binding InsuranceExpiryWarning, Converter={StaticResource ExpiryWarnColor}}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <!-- Work Permit (only for work_permit type) -->
                                            <StackPanel>
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Data.EmployeeType}" Value="work_permit">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Border Background="{DynamicResource ErrorLightBrush}" CornerRadius="6" Width="24" Height="24" Margin="0,0,8,0">
                                                        <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ErrorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="{DynamicResource DetDocWorkPermit}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                        Padding="14" Margin="0,0,0,16"
                                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="{DynamicResource DetFieldWpNumber}" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Text="{Binding Data.WorkPermitNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        <TextBlock Text="{DynamicResource DetFieldWpType}" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Text="{Binding Data.WorkPermitType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        <TextBlock Text="{DynamicResource DetFieldWpIssueDate}" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Text="{Binding Data.WorkPermitIssueDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        <TextBlock Text="{DynamicResource DetFieldExpiry}" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Text="{Binding Data.WorkPermitExpiry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        <TextBlock Text="{DynamicResource DetFieldWpAuthority}" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Text="{Binding Data.WorkPermitAuthority, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- ===== RIGHT COLUMN ===== -->
                                        <StackPanel Grid.Column="2">
                                            <!-- Address local -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{DynamicResource PurpleLightBrush}" CornerRadius="6" Width="24" Height="24" Margin="0,0,8,0">
                                                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource PurpleBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{DynamicResource DetSecAddrLocal}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold" Foreground="{DynamicResource PurpleBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldStreet}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.AddressLocal.Street, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldHouseNum}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.AddressLocal.Number, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="10"/>
                                                            <ColumnDefinition Width="100"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{DynamicResource DetFieldCity}" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox Text="{Binding Data.AddressLocal.City, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="{DynamicResource DetFieldZip}" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox Text="{Binding Data.AddressLocal.Zip, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <!-- Address abroad -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{DynamicResource InfoLightBrush}" CornerRadius="6" Width="24" Height="24" Margin="0,0,8,0">
                                                    <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{DynamicResource DetSecAddrAbroad}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold" Foreground="{DynamicResource InfoBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldStreet}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.AddressAbroad.Street, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldHouseNum}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.AddressAbroad.Number, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="10"/>
                                                            <ColumnDefinition Width="100"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{DynamicResource DetFieldCity}" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox Text="{Binding Data.AddressAbroad.City, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="{DynamicResource DetFieldZip}" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox Text="{Binding Data.AddressAbroad.Zip, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <!-- Work info -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{DynamicResource AccentLightBrush}" CornerRadius="6" Width="24" Height="24" Margin="0,0,8,0">
                                                    <TextBlock Text="&#xE821;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{DynamicResource DetSecWork}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold" Foreground="{DynamicResource AccentDarkBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldPosition}" Style="{StaticResource FieldLabel}"/>
                                                    <!-- Read-only: show position text -->
                                                    <TextBox Text="{Binding Data.PositionTag, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}"
                                                             Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVis}}" IsReadOnly="True"/>
                                                    <!-- Edit mode: ComboBox to pick from company positions -->
                                                    <ComboBox ItemsSource="{Binding CompanyPositions}" SelectedItem="{Binding SelectedPosition}"
                                                              Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                                              Padding="8,6" Margin="0,0,0,8" FontSize="13" IsEditable="False">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock>
                                                                    <Run Text="{Binding Title}"/> (<Run Text="{Binding PositionNumber}"/>)
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBlock Text="{DynamicResource DetFieldPosNumber}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.PositionNumber}" Style="{StaticResource FieldInput}" IsReadOnly="True"/>
                                                    <TextBlock Text="{DynamicResource DetFieldSalary}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.MonthlySalaryBrutto, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldHourly}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.HourlySalary, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldWorkAddr}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.WorkAddressTag, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Contact & Dates -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Background="{DynamicResource PurpleLightBrush}" CornerRadius="6" Width="24" Height="24" Margin="0,0,8,0">
                                                    <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource PurpleBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{DynamicResource DetSecContacts}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold" Foreground="{DynamicResource PurpleBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldPhone}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldEmail}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldContractType}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.ContractType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldStartDate}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.StartDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldSignDate}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.ContractSignDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>

                                                    <TextBlock Text="{DynamicResource DetLabelStatus}" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox ItemsSource="{Binding AvailableStatuses}" 
                                                              SelectedItem="{Binding Data.Status, UpdateSourceTrigger=PropertyChanged}" 
                                                              IsEnabled="{Binding IsEditMode}"
                                                              Padding="8,6" Margin="0,0,0,10" FontSize="{DynamicResource FS13}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                                                                             Fill="{Binding Converter={StaticResource StatusColor}}"/>
                                                                    <TextBlock Text="{Binding Converter={StaticResource StatusDisplayConverter}}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Status message -->
                                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource ErrorBrush}" Margin="0,4,0,0" FontSize="{DynamicResource FS12}"/>
                                </StackPanel>

                                <!-- ========== TAB 2: HISTORY ========== -->
                                <StackPanel Visibility="{Binding TabIndex, Converter={StaticResource StepVis}, ConverterParameter=2}">
                                    <TextBlock Text="{DynamicResource DetHistoryTitle}" Style="{StaticResource SectionHeader}" FontSize="{DynamicResource FS16}" Margin="0,0,0,10"/>

                                    <!-- Filter buttons -->
                                    <WrapPanel Margin="0,0,0,14">
                                        <WrapPanel.Resources>
                                            <Style x:Key="FilterBtn" TargetType="Button">
                                                <Setter Property="Padding" Value="10,5"/>
                                                <Setter Property="Margin" Value="0,0,6,4"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="FontSize" Value="{DynamicResource FS11}"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bd" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="14"
                                                                    Padding="{TemplateBinding Padding}"
                                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </WrapPanel.Resources>
                                        <Button Style="{StaticResource FilterBtn}" Content="{DynamicResource HistFilterAll}" Command="{Binding SetHistoryFilterCommand}" CommandParameter="All"/>
                                        <Button Style="{StaticResource FilterBtn}" Content="{DynamicResource HistFilterCreated}" Command="{Binding SetHistoryFilterCommand}" CommandParameter="Created"/>
                                        <Button Style="{StaticResource FilterBtn}" Content="{DynamicResource HistFilterProfile}" Command="{Binding SetHistoryFilterCommand}" CommandParameter="Profile"/>
                                        <Button Style="{StaticResource FilterBtn}" Content="{DynamicResource HistFilterDocuments}" Command="{Binding SetHistoryFilterCommand}" CommandParameter="Documents"/>
                                        <Button Style="{StaticResource FilterBtn}" Content="{DynamicResource HistFilterStatus}" Command="{Binding SetHistoryFilterCommand}" CommandParameter="Status"/>
                                        <Button Style="{StaticResource FilterBtn}" Content="{DynamicResource HistFilterArchive}" Command="{Binding SetHistoryFilterCommand}" CommandParameter="Archive"/>
                                    </WrapPanel>

                                    <!-- Timeline list -->
                                    <ItemsControl ItemsSource="{Binding HistoryEntries}"
                                                  Visibility="{Binding HasHistory, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="40"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Timeline column: icon + vertical line -->
                                                    <Grid Grid.Column="0" HorizontalAlignment="Center">
                                                        <Border Width="2" Background="{DynamicResource DividerBrush}" VerticalAlignment="Stretch" HorizontalAlignment="Center"/>
                                                        <Border Width="28" Height="28" CornerRadius="14" VerticalAlignment="Top" Margin="0,8,0,0"
                                                                HorizontalAlignment="Center"
                                                                Background="{Binding EventColor, Converter={StaticResource HexToBrush}}">
                                                            <TextBlock Text="{Binding EventIcon}" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Card -->
                                                    <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                                                            Padding="14,10" Margin="0,4,0,8"
                                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,4">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}"
                                                                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                    <TextBlock FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                               Text="{Binding Timestamp, StringFormat='{}{0:dd.MM.yyyy  HH:mm}'}"/>
                                                                </StackPanel>
                                                                <Border HorizontalAlignment="Right" CornerRadius="4" Padding="8,2"
                                                                        Background="{Binding EventColor, Converter={StaticResource HexToBrush}, ConverterParameter=0.15}">
                                                                    <TextBlock Text="{Binding Action}" FontSize="{DynamicResource FS10}" FontWeight="SemiBold"
                                                                               Foreground="{Binding EventColor, Converter={StaticResource HexToBrush}}"/>
                                                                </Border>
                                                            </Grid>
                                                            <TextBlock Text="{Binding Description}" FontSize="{DynamicResource FS13}"
                                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Empty state -->
                                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="24"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                            Visibility="{Binding HasHistory, Converter={StaticResource InverseBoolToVis}}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS32}"
                                                       HorizontalAlignment="Center" Foreground="{DynamicResource TertiaryForegroundBrush}"/>
                                            <TextBlock Text="{DynamicResource DetHistoryEmpty}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                                       Margin="0,8,0,4" TextAlignment="Center" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                            <TextBlock Text="{DynamicResource DetHistoryEmptyMsg}"
                                                       FontSize="{DynamicResource FS12}" TextAlignment="Center" Foreground="{DynamicResource TertiaryForegroundBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ========== TAB 3: SALARY HISTORY ========== -->
                                <StackPanel Visibility="{Binding TabIndex, Converter={StaticResource StepVis}, ConverterParameter=3}">
                                    <TextBlock Text="{DynamicResource DetSalaryTitle}" Style="{StaticResource SectionHeader}" FontSize="{DynamicResource FS16}" Margin="0,0,0,14"/>

                                    <!-- Summary stats -->
                                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,16"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                            Visibility="{Binding HasSalaryHistory, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <StackPanel Margin="0,0,40,0" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}" 
                                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding TotalSalaryEarned, StringFormat='{}{0:N0}'}" FontSize="{DynamicResource FS20}" 
                                                           FontWeight="Bold" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                                <TextBlock Text="{DynamicResource DetSalaryTotalNet}" FontSize="{DynamicResource FS10}" 
                                                           Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,40,0" HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}" 
                                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding TotalHoursAll, StringFormat='{}{0:N1}'}" FontSize="{DynamicResource FS20}" 
                                                           FontWeight="Bold" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                                <TextBlock Text="{DynamicResource DetSalaryTotalHours}" FontSize="{DynamicResource FS10}" 
                                                           Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}" 
                                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding SalaryHistoryEntries.Count}" FontSize="{DynamicResource FS20}" 
                                                           FontWeight="Bold" HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                                <TextBlock Text="{DynamicResource DetSalaryMonthCount}" FontSize="{DynamicResource FS10}" 
                                                           Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Combined Salary + Advances per month -->
                                    <ItemsControl ItemsSource="{Binding SalaryMonthDisplays}" Margin="0,10,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                                                        Padding="0" Margin="0,0,0,8"
                                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="5"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0" CornerRadius="8,0,0,8">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#4CAF50"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsNegativeNet}" Value="True">
                                                                            <Setter Property="Background" Value="#C62828"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" Margin="14,10">

                                                            <!-- Month header -->
                                                            <Grid Margin="0,0,0,6">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" 
                                                                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding MonthLabel}" FontSize="{DynamicResource FS15}" FontWeight="Bold"
                                                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                                                </StackPanel>
                                                                <Border HorizontalAlignment="Right" CornerRadius="4" Padding="8,2"
                                                                        Background="{DynamicResource AccentLightBrush}"
                                                                        Visibility="{Binding HasSalary, Converter={StaticResource BoolToVis}}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="&#xE731;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}" 
                                                                                   Foreground="{DynamicResource AccentDarkBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding Salary.FirmName}" FontSize="{DynamicResource FS10}" FontWeight="SemiBold" 
                                                                                   Foreground="{DynamicResource AccentDarkBrush}"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </Grid>

                                                            <!-- Salary details (visible only if salary paid) -->
                                                            <Grid Visibility="{Binding HasSalary, Converter={StaticResource BoolToVis}}">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <Grid Grid.Row="0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                                        <TextBlock Text="{DynamicResource FinColHours}" FontSize="{DynamicResource FS9}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                                        <TextBlock Text="{Binding Salary.HoursWorked, StringFormat='{}{0:N1}'}" FontSize="{DynamicResource FS12}" 
                                                                                   FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                                                        <TextBlock Text="{DynamicResource FinColRate}" FontSize="{DynamicResource FS9}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                                        <TextBlock Text="{Binding Salary.HourlyRate, StringFormat='{}{0:N0}'}" FontSize="{DynamicResource FS12}" 
                                                                                   FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                                                        <TextBlock Text="{DynamicResource FinColGross}" FontSize="{DynamicResource FS9}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                                        <TextBlock Text="{Binding Salary.GrossSalary, StringFormat='{}{0:N0}'}" FontSize="{DynamicResource FS12}" 
                                                                                   FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                                                        <TextBlock Text="{DynamicResource FinColAdvance}" FontSize="{DynamicResource FS9}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                                        <TextBlock Text="{Binding Salary.Advance, StringFormat='{}{0:N0}'}" FontSize="{DynamicResource FS12}" 
                                                                                   FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}"/>
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="4">
                                                                        <TextBlock Text="{DynamicResource FinColNet}" FontSize="{DynamicResource FS9}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                                        <TextBlock Text="{Binding Salary.NetSalary, StringFormat='{}{0:N0}'}" FontSize="{DynamicResource FS13}" FontWeight="Bold">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsNegativeNet}" Value="True">
                                                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </Grid>

                                                                <!-- Custom fields + Note -->
                                                                <StackPanel Grid.Row="1" Margin="0,4,0,0">
                                                                    <ItemsControl ItemsSource="{Binding Salary.CustomFields}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <WrapPanel/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border CornerRadius="3" Padding="6,1" Margin="0,0,6,2" Background="{DynamicResource WarningLightBrush}">
                                                                                    <TextBlock FontSize="{DynamicResource FS9}" Foreground="{DynamicResource WarningBrush}">
                                                                                        <TextBlock.Text>
                                                                                            <MultiBinding StringFormat="{}{0}: {1:N0}">
                                                                                                <Binding Path="Name"/>
                                                                                                <Binding Path="Value"/>
                                                                                            </MultiBinding>
                                                                                        </TextBlock.Text>
                                                                                    </TextBlock>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                    <TextBlock Text="{Binding Salary.Note}" FontSize="{DynamicResource FS11}" 
                                                                               Foreground="{DynamicResource SecondaryForegroundBrush}" FontStyle="Italic" TextWrapping="Wrap" Margin="0,2,0,0">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Salary.Note}" Value="">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- Carried debt from previous months -->
                                                            <Border CornerRadius="6" Padding="8,4" Margin="0,6,0,0"
                                                                    Background="{DynamicResource WarningLightBrush}"
                                                                    Visibility="{Binding HasCarriedDebt, Converter={StaticResource BoolToVis}}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                               Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{DynamicResource FinDebtCarried}" FontSize="{DynamicResource FS11}" 
                                                                               Foreground="{DynamicResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                    <TextBlock FontSize="{DynamicResource FS11}" FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center">
                                                                        <Run Text="{Binding CarriedDebt, StringFormat='{}{0:N0}', Mode=OneWay}"/>
                                                                        <Run Text=" Kč"/>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Border>

                                                            <!-- Month debt indicator -->
                                                            <Border CornerRadius="6" Padding="8,4" Margin="0,4,0,0"
                                                                    Background="{DynamicResource ErrorLightBrush}"
                                                                    Visibility="{Binding HasDebt, Converter={StaticResource BoolToVis}}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                               Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{DynamicResource FinDebtLabel}" FontSize="{DynamicResource FS11}" 
                                                                               Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                    <TextBlock FontSize="{DynamicResource FS11}" FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center">
                                                                        <Run Text="{Binding MonthBalance, StringFormat='{}{0:N0}', Mode=OneWay}"/>
                                                                        <Run Text=" Kč"/>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Border>

                                                            <!-- Advances for this month -->
                                                            <ItemsControl ItemsSource="{Binding Advances}" 
                                                                          Visibility="{Binding HasAdvances, Converter={StaticResource BoolToVis}}"
                                                                          Margin="0,6,0,0">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border CornerRadius="6" Padding="8,5" Margin="0,0,0,3">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background" Value="#FFF8E1"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsDeducted}" Value="True">
                                                                                            <Setter Property="Background" Value="{DynamicResource SuccessLightBrush}"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>

                                                                                <!-- Status icon -->
                                                                                <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                                           VerticalAlignment="Center" Margin="0,0,6,0">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Text" Value="&#xE9CE;"/>
                                                                                            <Setter Property="Foreground" Value="#FF9800"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsDeducted}" Value="True">
                                                                                                    <Setter Property="Text" Value="&#xE73E;"/>
                                                                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>

                                                                                <!-- Date -->
                                                                                <TextBlock Grid.Column="1" Text="{Binding Date, StringFormat='{}{0:dd.MM.yy}'}" 
                                                                                           FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                                           VerticalAlignment="Center" Margin="0,0,10,0"/>

                                                                                <!-- Note -->
                                                                                <TextBlock Grid.Column="2" Text="{Binding Note}" FontSize="{DynamicResource FS11}" 
                                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center" 
                                                                                           TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>

                                                                                <!-- Amount -->
                                                                                <TextBlock Grid.Column="3" FontSize="{DynamicResource FS12}" FontWeight="SemiBold" 
                                                                                           VerticalAlignment="Center" Margin="0,0,6,0">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Foreground" Value="#E65100"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsDeducted}" Value="True">
                                                                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                    <Run Text="{Binding Amount, StringFormat='{}{0:N0}', Mode=OneWay}"/>
                                                                                    <Run Text=" Kč"/>
                                                                                </TextBlock>

                                                                                <!-- Deducted / Not deducted badge -->
                                                                                <Border Grid.Column="4" CornerRadius="3" Padding="5,1" VerticalAlignment="Center">
                                                                                    <Border.Style>
                                                                                        <Style TargetType="Border">
                                                                                            <Setter Property="Background" Value="{DynamicResource WarningLightBrush}"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsDeducted}" Value="True">
                                                                                                    <Setter Property="Background" Value="#C8E6C9"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Border.Style>
                                                                                    <TextBlock FontSize="{DynamicResource FS9}">
                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="TextBlock">
                                                                                                <Setter Property="Text" Value="{DynamicResource FinAdvanceNotDeducted}"/>
                                                                                                <Setter Property="Foreground" Value="#E65100"/>
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding IsDeducted}" Value="True">
                                                                                                        <Setter Property="Text" Value="{DynamicResource FinAdvanceDeducted}"/>
                                                                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                </Border>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Empty state -->
                                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="24"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                            Visibility="{Binding HasSalaryHistory, Converter={StaticResource InverseBoolToVis}}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS32}" 
                                                       HorizontalAlignment="Center" Foreground="{DynamicResource TertiaryForegroundBrush}"/>
                                            <TextBlock Text="{DynamicResource DetSalaryEmpty}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold" 
                                                       Margin="0,8,0,4" TextAlignment="Center" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                            <TextBlock Text="{DynamicResource DetSalaryEmptyMsg}"
                                                       FontSize="{DynamicResource FS12}" TextAlignment="Center" Foreground="{DynamicResource TertiaryForegroundBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- ===== Generate Document Dialog Overlay ===== -->
        <Grid Visibility="{Binding IsGenerateDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseGenerateDialogCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" 
                    Width="500" MaxHeight="500"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS18}" 
                                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource DetGenTitle}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Command="{Binding CloseGenerateDialogCommand}"
                                Width="30" Height="30" Background="Transparent" BorderThickness="0" 
                                Foreground="{DynamicResource SecondaryForegroundBrush}" Cursor="Hand">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                        </Button>
                    </Grid>

                    <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,10" FontSize="{DynamicResource FS12}"
                               Text="{DynamicResource DetGenDesc}"/>

                    <ScrollViewer Grid.Row="2" Style="{StaticResource ThinScroll}" MaxHeight="300">
                        <ItemsControl ItemsSource="{Binding AvailableTemplates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" 
                                            Padding="12,8" Margin="0,0,0,6" Cursor="Hand"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6" 
                                                    Background="{DynamicResource AccentLightBrush}" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Format}" VerticalAlignment="Center" 
                                                           HorizontalAlignment="Center" FontWeight="Bold" FontSize="{DynamicResource FS11}"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="{DynamicResource FS14}"
                                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" 
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" 
                                                    Command="{Binding DataContext.GenerateFromTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,5" FontWeight="SemiBold"
                                                    Background="{DynamicResource AccentBrush}" Foreground="White" 
                                                    BorderThickness="0" VerticalAlignment="Center" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource EmpGenerate}" FontSize="{DynamicResource FS12}"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Grid.Row="3" Text="{Binding GenerateStatusMessage}" 
                               TextWrapping="Wrap" Margin="0,10,0,0" 
                               FontSize="{DynamicResource FS12}" Foreground="{DynamicResource AccentBrush}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== Archive Dialog Overlay ===== -->
        <Grid Visibility="{Binding IsArchiveDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CancelArchiveCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" 
                    Width="420" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS32}" 
                               HorizontalAlignment="Center" Foreground="{DynamicResource ErrorBrush}" Margin="0,0,0,10"/>
                    <TextBlock Text="{DynamicResource DetArchiveTitle}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold" 
                               TextAlignment="Center" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,6"/>
                    <TextBlock TextAlignment="Center" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="{DynamicResource FS12}" Margin="0,0,0,16" TextWrapping="Wrap"
                               Text="{DynamicResource DetArchiveDesc}"/>
                    <TextBlock Text="{DynamicResource DetArchiveDateLabel}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ArchiveEndDate, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="10,8" FontSize="{DynamicResource FS14}" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding ArchiveStatus}" Foreground="{DynamicResource ErrorBrush}" FontSize="{DynamicResource FS12}" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Command="{Binding CancelArchiveCommand}" Padding="16,8" Margin="0,0,8,0"
                                Background="{DynamicResource ContentBackgroundBrush}" 
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                            <TextBlock Text="{DynamicResource DetBtnCancel}" FontSize="{DynamicResource FS13}"/>
                        </Button>
                        <Button Command="{Binding ConfirmArchiveCommand}" Padding="16,8"
                                Background="{DynamicResource ErrorBrush}" Foreground="White" 
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource DetBtnArchive}" FontSize="{DynamicResource FS13}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Extend Date Dialog Overlay ===== -->
        <Grid Visibility="{Binding IsExtendDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CancelExtendCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" 
                    Width="380" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS28}" 
                               HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding ExtendDialogTitle}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold" 
                               TextAlignment="Center" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="{DynamicResource DetExtendDateLabel}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NewExpiryDate, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="10,8" FontSize="{DynamicResource FS14}" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Command="{Binding CancelExtendCommand}" Padding="16,8" Margin="0,0,8,0"
                                Background="{DynamicResource ContentBackgroundBrush}" 
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                            <TextBlock Text="{DynamicResource DetBtnCancel}" FontSize="{DynamicResource FS13}"/>
                        </Button>
                        <Button Command="{Binding ConfirmExtendCommand}" Padding="16,8"
                                Background="{DynamicResource AccentBrush}" Foreground="White" 
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource DetBtnSave}" FontSize="{DynamicResource FS13}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Renew Work Permit Dialog Overlay ===== -->
        <Grid Visibility="{Binding IsRenewWpDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CancelRenewWpCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" 
                    Width="420" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS28}" 
                               HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                    <TextBlock Text="{DynamicResource DetRenewWpTitle}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold" 
                               TextAlignment="Center" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding RenewWpFilePath}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" 
                               TextTrimming="CharacterEllipsis" TextAlignment="Center" Margin="0,0,0,16"/>

                    <TextBlock Text="{DynamicResource DetFieldWpNumber}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding RenewWpNumber, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="10,8" FontSize="{DynamicResource FS14}" Margin="0,0,0,10"/>

                    <TextBlock Text="{DynamicResource DetFieldWpType}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding RenewWpType, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="10,8" FontSize="{DynamicResource FS14}" Margin="0,0,0,10"/>

                    <TextBlock Text="{DynamicResource DetFieldWpIssueDate}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding RenewWpIssueDate, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="10,8" FontSize="{DynamicResource FS14}" Margin="0,0,0,10"/>

                    <TextBlock Text="{DynamicResource DetFieldExpiry}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding RenewWpExpiry, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="10,8" FontSize="{DynamicResource FS14}" Margin="0,0,0,10"/>

                    <TextBlock Text="{DynamicResource DetFieldWpAuthority}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding RenewWpAuthority, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="10,8" FontSize="{DynamicResource FS14}" Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Command="{Binding CancelRenewWpCommand}" Padding="16,8" Margin="0,0,8,0"
                                Background="{DynamicResource ContentBackgroundBrush}" 
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                            <TextBlock Text="{DynamicResource DetBtnCancel}" FontSize="{DynamicResource FS13}"/>
                        </Button>
                        <Button Command="{Binding ConfirmRenewWpCommand}" Padding="16,8"
                                Background="{DynamicResource AccentBrush}" Foreground="White" 
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource DetBtnSave}" FontSize="{DynamicResource FS13}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- AI Validation Result Overlay -->
        <Grid Visibility="{Binding IsAIValidationOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#40000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAIValidationCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="16"
                    MaxWidth="620" MaxHeight="580" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="{DynamicResource PurpleBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource AIValidateTitle}" FontSize="{DynamicResource FS18}"
                                       FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}"/>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="420"
                                  Style="{StaticResource ThinScroll}">
                        <TextBox Text="{Binding AIValidationResult, Mode=OneWay}" 
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 BorderThickness="0" Background="Transparent" Padding="0"
                                 FontSize="{DynamicResource FS13}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 VerticalScrollBarVisibility="Disabled"/>
                    </ScrollViewer>

                    <!-- OK button with animated loading ring -->
                    <Grid Grid.Row="2" HorizontalAlignment="Center" Margin="0,14,0,0">
                        <!-- Spinning ring (visible while loading) -->
                        <Border x:Name="AIValRing" Width="52" Height="52" CornerRadius="26"
                                BorderThickness="3"
                                RenderTransformOrigin="0.5,0.5"
                                Visibility="{Binding IsAIValidating, Converter={StaticResource BoolToVis}}">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7B1FA2" Offset="0"/>
                                    <GradientStop Color="#CE93D8" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.RenderTransform>
                                <RotateTransform x:Name="AIValRingSpin" Angle="0"/>
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="AIValRingSpin"
                                                             Storyboard.TargetProperty="Angle"
                                                             From="0" To="360" Duration="0:0:1.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <SineEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                        <!-- OK button on top -->
                        <Button Command="{Binding CloseAIValidationCommand}"
                                Width="44" Height="44" Cursor="Hand" FontWeight="SemiBold"
                                Background="{DynamicResource AccentBrush}" Foreground="White"
                                BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="OkBd" Background="{TemplateBinding Background}"
                                            CornerRadius="22" Width="44" Height="44">
                                        <TextBlock Text="OK" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="OkBd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        <!-- ===== Add Custom Document Dialog Overlay ===== -->
        <Grid Visibility="{Binding IsAddCustomDocOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CancelAddCustomDocCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12"
                    Width="440" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS24}"
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource DetAddCustomDocTitle}" FontSize="{DynamicResource FS18}"
                                   FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Name -->
                    <TextBlock Text="{DynamicResource DetCustomDocFieldName}" FontSize="{DynamicResource FS12}"
                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewCustomDocName, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="{DynamicResource FS13}" Margin="0,0,0,12"/>

                    <!-- Sign date -->
                    <TextBlock Text="{DynamicResource DetCustomDocFieldSignDate}" FontSize="{DynamicResource FS12}"
                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewCustomDocSignDate, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="{DynamicResource FS13}" Margin="0,0,0,12"/>

                    <!-- Expiry date (optional) -->
                    <TextBlock Text="{DynamicResource DetCustomDocFieldExpiry}" FontSize="{DynamicResource FS12}"
                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewCustomDocExpiryDate, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8" FontSize="{DynamicResource FS13}" Margin="0,0,0,12"/>

                    <!-- File picker -->
                    <TextBlock Text="{DynamicResource DetCustomDocFieldFile}" FontSize="{DynamicResource FS12}"
                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="10,8">
                            <Grid>
                                <TextBlock Text="{DynamicResource DetCustomDocNoFile}"
                                           Foreground="{DynamicResource TertiaryForegroundBrush}"
                                           FontSize="{DynamicResource FS12}" VerticalAlignment="Center"
                                           Visibility="{Binding NewCustomDocFilePath, Converter={StaticResource InverseStringToVis}}"/>
                                <TextBlock Text="{Binding NewCustomDocFilePath}"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           FontSize="{DynamicResource FS12}" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding NewCustomDocFilePath, Converter={StaticResource StringToVis}}"/>
                            </Grid>
                        </Border>
                        <Button Grid.Column="1" Command="{Binding BrowseCustomDocFileCommand}"
                                Margin="8,0,0,0" Padding="12,8" Cursor="Hand"
                                Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                Foreground="{DynamicResource ForegroundBrush}">
                            <TextBlock Text="{DynamicResource DetBtnBrowseFile}" FontSize="{DynamicResource FS12}"/>
                        </Button>
                    </Grid>
                    <!-- Error message -->
                    <TextBlock Text="{Binding AddCustomDocError}" FontSize="{DynamicResource FS12}"
                               Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"
                               Margin="0,0,0,12"
                               Visibility="{Binding AddCustomDocError, Converter={StaticResource StringToVis}}"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelAddCustomDocCommand}" Padding="16,8" Margin="0,0,8,0"
                                Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                            <TextBlock Text="{DynamicResource DetBtnCancel}" FontSize="{DynamicResource FS13}"/>
                        </Button>
                        <Button Command="{Binding ConfirmAddCustomDocCommand}" Padding="16,8"
                                Background="{DynamicResource AccentBrush}" Foreground="White"
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource DetBtnSave}" FontSize="{DynamicResource FS13}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
