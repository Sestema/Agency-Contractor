<UserControl x:Class="Win11DesktopApp.Views.MainPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:Win11DesktopApp.Views"
             xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <CubicEase x:Key="DrawerEase" EasingMode="EaseOut"/>
        <conv:NameToColorConverter x:Key="NameToColor"/>
        <conv:FirstCharConverter x:Key="FirstCharConverter"/>
        <conv:HexToBrushConverter x:Key="HexToBrush"/>
        <conv:IconKeyToGeometryConverter x:Key="IconKeyToGeometry"/>
        <conv:ResourceKeyConverter x:Key="ResKey"/>
    </UserControl.Resources>
    
    <Grid Background="{DynamicResource PageBackgroundBrush}" ClipToBounds="True">
        <!-- Main Content -->
        <Grid>
            <!-- Top Bar -->
            <Grid VerticalAlignment="Top" Height="60" Margin="24,4,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Hamburger (Now on Left) -->
                <Button Grid.Column="0" Command="{Binding ToggleDrawerCommand}" 
                        Style="{StaticResource ToolbarIconButton}" Margin="0,0,10,0">
                    <Path Data="{StaticResource IconHamburger}" 
                          Fill="{DynamicResource ForegroundBrush}"
                          Stretch="Uniform" Width="20" Height="20"/>
                </Button>

                <!-- Center: Search Box -->
                <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="420">
                    <Border Style="{StaticResource ToolbarSearchContainer}" CornerRadius="20" Padding="6,0"
                            Height="38" Effect="{DynamicResource CardShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center" Margin="10,0,6,0"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalAlignment="Center" BorderThickness="0" Background="Transparent"
                                     Foreground="{DynamicResource ForegroundBrush}" FontSize="{DynamicResource FS13}"
                                     Padding="2,6">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Tag" Value="{DynamicResource GlobalSearchPlaceholder}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Grid>
                                                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="placeholder" Text="{TemplateBinding Tag}"
                                                                   Foreground="{DynamicResource TertiaryForegroundBrush}" VerticalAlignment="Center" Margin="4,0" FontSize="{DynamicResource FS13}"
                                                                   IsHitTestVisible="False" Visibility="Collapsed"/>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                                <Button Command="{Binding AISearchCommand}" Style="{StaticResource ToolbarInlineIconButton}"
                                        ToolTip="{DynamicResource AISearchTooltip}">
                                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource PurpleBrush}"/>
                                </Button>
                                <Button Command="{Binding ClearSearchCommand}" Style="{StaticResource ToolbarInlineIconButton}"
                                        Visibility="{Binding IsSearchOpen, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Search results dropdown -->
                    <Popup IsOpen="{Binding IsSearchOpen}" PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade"
                           HorizontalOffset="0" VerticalOffset="2">
                        <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                Width="420" MaxHeight="400" Padding="4">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.18"/>
                            </Border.Effect>
                            <Grid>
                                <!-- No results -->
                                <TextBlock Text="{DynamicResource GlobalSearchNoResults}" FontSize="{DynamicResource FS13}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Center" Margin="0,16"
                                           Visibility="{Binding HasNoSearchResults, Converter={StaticResource BoolToVis}}"/>
                                <!-- Results list -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="380">
                                    <ItemsControl ItemsSource="{Binding SearchResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.NavigateToSearchResultCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" Cursor="Hand"
                                                        Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch"
                                                        Padding="0" Margin="0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="hoverBd" Background="Transparent" CornerRadius="8" Padding="10,8" Margin="2">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0"
                                                                            Background="{Binding CategoryColor, Converter={StaticResource HexToBrush}, ConverterParameter=0.15}">
                                                                        <TextBlock Text="{Binding CategoryIcon}" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                   Foreground="{Binding CategoryColor, Converter={StaticResource HexToBrush}}"/>
                                                                    </Border>
                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Title}" FontSize="{DynamicResource FS13}" FontWeight="Medium"
                                                                                   Foreground="{DynamicResource ForegroundBrush}" TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Text="{Binding Subtitle}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                    <Border Grid.Column="2" CornerRadius="10" Padding="8,3" VerticalAlignment="Center"
                                                                            Background="{Binding CategoryColor, Converter={StaticResource HexToBrush}, ConverterParameter=0.1}">
                                                                        <TextBlock Text="{Binding Category}" FontSize="{DynamicResource FS10}"
                                                                                   Foreground="{Binding CategoryColor, Converter={StaticResource HexToBrush}}"/>
                                                                    </Border>
                                                                </Grid>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="hoverBd" Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Popup>
                </Grid>
                
                <!-- Right: Settings -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Margin="0,0,8,0">
                        <Button x:Name="NotificationBellButton"
                                Command="{Binding ToggleNotificationsCommand}"
                                Style="{StaticResource ToolbarIconButton}"
                                ToolTip="{DynamicResource NotificationsTitle}">
                            <Grid Width="24" Height="24">
                                <TextBlock Text="&#xEA8F;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="19"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Ellipse Width="9" Height="9"
                                         Fill="{DynamicResource ErrorBrush}"
                                         Stroke="{DynamicResource ContentBackgroundBrush}"
                                         StrokeThickness="1.2"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Visibility="{Binding HasUnreadNotifications, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Button>

                        <Popup IsOpen="{Binding IsNotificationCenterOpen}"
                               PlacementTarget="{Binding ElementName=NotificationBellButton}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               HorizontalOffset="-300"
                               VerticalOffset="8">
                            <Border Width="340"
                                    MaxHeight="420"
                                    Padding="12"
                                    CornerRadius="18"
                                    Background="{DynamicResource ContentBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1"
                                    Effect="{DynamicResource DialogShadow}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{DynamicResource NotificationsTitle}"
                                                   FontSize="{DynamicResource FS16}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Button Command="{Binding MarkNotificationsReadCommand}"
                                                Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,6,0"
                                                Padding="10,5"
                                                Background="{DynamicResource AccentLightBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                BorderThickness="1"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="12"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock Text="{DynamicResource NotificationsMarkRead}"
                                                       FontSize="{DynamicResource FS11}"
                                                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                        </Button>
                                        <Button Command="{Binding ClearNotificationsCommand}"
                                                Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                Padding="10,5"
                                                Background="{DynamicResource ErrorLightBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                BorderThickness="1"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="12"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock Text="{DynamicResource NotificationsClear}"
                                                       FontSize="{DynamicResource FS11}"
                                                       Foreground="{DynamicResource ErrorBrush}"/>
                                        </Button>
                                    </Grid>

                                    <TextBlock Grid.Row="1"
                                               Text="{DynamicResource NotificationsHint}"
                                               Margin="0,4,0,10"
                                               TextWrapping="Wrap"
                                               FontSize="{DynamicResource FS12}"
                                               Foreground="{DynamicResource SecondaryForegroundBrush}"/>

                                    <Grid Grid.Row="2">
                                        <TextBlock Text="{DynamicResource NotificationsEmpty}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,22"
                                                   FontSize="{DynamicResource FS13}"
                                                   Foreground="{DynamicResource TertiaryForegroundBrush}"
                                                   Visibility="{Binding HasNotifications, Converter={StaticResource InverseBoolToVis}}"/>

                                        <ScrollViewer MaxHeight="315"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Style="{StaticResource ThinScroll}"
                                                      Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVis}}">
                                            <ItemsControl ItemsSource="{Binding Notifications}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,8"
                                                                Padding="10"
                                                                CornerRadius="14"
                                                                Background="{DynamicResource CardBackgroundBrush}"
                                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                                BorderThickness="1">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Width="32" Height="32"
                                                                        CornerRadius="16"
                                                                        Background="{DynamicResource SuccessLightBrush}"
                                                                        VerticalAlignment="Top"
                                                                        Margin="0,0,10,0">
                                                                    <TextBlock Text="{Binding Icon}"
                                                                               FontFamily="Segoe MDL2 Assets"
                                                                               FontSize="14"
                                                                               Foreground="{DynamicResource SuccessBrush}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"/>
                                                                </Border>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{Binding Title}"
                                                                               FontSize="{DynamicResource FS13}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource ForegroundBrush}"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding Message}"
                                                                               Margin="0,2,0,0"
                                                                               FontSize="{DynamicResource FS12}"
                                                                               Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding CreatedAtText}"
                                                                           FontSize="{DynamicResource FS10}"
                                                                           Foreground="{DynamicResource TertiaryForegroundBrush}"
                                                                           Margin="8,2,0,0"
                                                                           VerticalAlignment="Top"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>

                    <Button Command="{Binding GoToSettingsCommand}"
                            Style="{StaticResource ToolbarIconButton}">
                        <Path Data="{StaticResource IconSettings}"
                              Fill="{DynamicResource ForegroundBrush}"
                              Stretch="Uniform" Width="20" Height="20"/>
                    </Button>
                </StackPanel>
            </Grid>

            <ScrollViewer Margin="24,92,24,20"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource ThinScroll}">
                <StackPanel HorizontalAlignment="Center" MaxWidth="1080">
                    <!-- Compact header: single row -->
                    <Border Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Margin="0,0,0,10"
                            Effect="{DynamicResource CardShadow}">
                        <Grid Margin="12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="34"
                                    Height="34"
                                    CornerRadius="11"
                                    Background="{Binding SelectedCompanyDisplayName, Converter={StaticResource NameToColor}}"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedCompanyDisplayName, Converter={StaticResource FirstCharConverter}}"
                                           FontSize="{DynamicResource FS14}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="White"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedCompanyDisplayName}"
                                           FontSize="{DynamicResource FS14}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding SelectedCompanyAgencyText}"
                                           Margin="0,1,0,0"
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Padding="10,4"
                                    CornerRadius="10"
                                    Background="{DynamicResource ContentBackgroundBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1"
                                    Margin="12,0,0,0"
                                    Visibility="{Binding HasSelectedCompany, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Padding="0,0,10,0"
                                            Margin="0,0,10,0"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="0,0,1,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE7BA;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="11"
                                                       Margin="0,0,6,0"
                                                       Foreground="{DynamicResource WarningBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource MainStatProblems}"
                                                       FontSize="{DynamicResource FS11}"
                                                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SelectedCompanyProblemsCount}"
                                                       Margin="6,0,0,0"
                                                       FontSize="{DynamicResource FS13}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Text="&#xE716;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11"
                                               Margin="0,0,6,0"
                                               Foreground="{DynamicResource SecondaryForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource MainStatEmployees}"
                                               FontSize="{DynamicResource FS11}"
                                               Foreground="{DynamicResource SecondaryForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedCompanyEmployeesCount}"
                                               Margin="6,0,0,0"
                                               FontSize="{DynamicResource FS13}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="3"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="12,0,12,0">
                                <Button Command="{Binding EditCompanyCommand}"
                                        Style="{StaticResource HeaderGhostButton}"
                                        Padding="6,4"
                                        ToolTip="{DynamicResource MainTooltipEdit}"
                                        Visibility="{Binding HasSelectedCompany, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="&#xE70F;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentTimeText}"
                                           HorizontalAlignment="Right"
                                           FontSize="{DynamicResource FS18}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{Binding CurrentDateText}"
                                           HorizontalAlignment="Right"
                                           Margin="0,1,0,0"
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Cards Grid (drag to reorder) -->
                    <ItemsControl x:Name="CardsGrid" ItemsSource="{Binding MenuCards}"
                                  HorizontalAlignment="Center"
                                  Margin="0,18,0,0"
                                  AllowDrop="True" Background="Transparent"
                                  DragOver="Grid_DragOver" Drop="Grid_Drop">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="3" HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="DragBorder" Background="Transparent" Margin="0" Padding="0"
                                        PreviewMouseLeftButtonDown="Card_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="Card_PreviewMouseMove"
                                        PreviewMouseLeftButtonUp="Card_PreviewMouseLeftButtonUp"
                                        GiveFeedback="Card_GiveFeedback">
                                    <views:CardControl Title="{Binding TitleKey, Converter={StaticResource ResKey}}" 
                                                       Icon="{Binding IconKey, Converter={StaticResource IconKeyToGeometry}}"
                                                       Command="{Binding Command}" 
                                                       BadgeCount="{Binding BadgeCount}"
                                                       Margin="10">
                                        <views:CardControl.IconGradient>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="{Binding GradientStart}" Offset="0"/>
                                                <GradientStop Color="{Binding GradientEnd}" Offset="1"/>
                                            </LinearGradientBrush>
                                        </views:CardControl.IconGradient>
                                    </views:CardControl>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        
        <!-- Drawer Overlay (Click to close) -->
        <Border x:Name="DrawerOverlay" Background="{DynamicResource OverlayBrush}" Opacity="0"
                IsHitTestVisible="{Binding IsDrawerOpen}">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleDrawerCommand}"/>
            </Border.InputBindings>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDrawerOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.25"
                                                         EasingFunction="{StaticResource DrawerEase}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
        
        <!-- Drawer Panel -->
        <Border x:Name="DrawerPanel" Width="370" HorizontalAlignment="Left"
                Background="{DynamicResource ContentBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,1,0"
                Effect="{DynamicResource DialogShadow}">
            <Border.RenderTransform>
                <TranslateTransform X="-370"/>
            </Border.RenderTransform>
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDrawerOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         From="-370" To="0" Duration="0:0:0.3"
                                                         EasingFunction="{StaticResource DrawerEase}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         From="0" To="-370" Duration="0:0:0.25"
                                                         EasingFunction="{StaticResource DrawerEase}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ===== HEADER ===== -->
                <Border Grid.Row="0" Padding="20,20,20,16" Background="{DynamicResource AccentBrush}">
                    <Grid>
                        <Ellipse Width="170" Height="170" HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Margin="0,-105,-55,0" Opacity="0.26" IsHitTestVisible="False">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#22FFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="42" Height="42" CornerRadius="12" Background="{DynamicResource AccentLightBrush}"
                                    BorderBrush="{DynamicResource GlassInnerHighlightBrush}" BorderThickness="1" Margin="0,0,14,0">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS20}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource DrawerTitle}" FontSize="{DynamicResource FS18}" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{DynamicResource MainSelectCompany}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Close button -->
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                                Command="{Binding ToggleDrawerCommand}"
                                Width="30" Height="30" Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" Foreground="#AAFFFFFF"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ===== SELECTED INDICATOR ===== -->
                <Border Grid.Row="1" Padding="16,10"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" 
                                   Foreground="{DynamicResource SuccessBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center">
                            <Run Text="{DynamicResource MainSelected}"/>
                            <Run Text="{Binding SelectedCompany.Name, FallbackValue='—', Mode=OneWay}" 
                                 FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- ===== COMPANY LIST ===== -->
                <ScrollViewer x:Name="CompanyScrollViewer" Grid.Row="2" Style="{StaticResource ThinScroll}" Padding="6,4,6,0">
                    <ListBox ItemsSource="{Binding VisibleCompanies}" 
                             SelectedItem="{Binding SelectedCompany}"
                             Background="Transparent" BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             PreviewMouseWheel="CompanyList_PreviewMouseWheel"
                             Margin="14,10,14,10">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <EventSetter Event="MouseDoubleClick" Handler="CompanyItem_DoubleClick"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="ToolTip" Value="{DynamicResource MainTooltipDblClick}"/>
                                <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu DataContext="{Binding PlacementTarget, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="{DynamicResource CompanyMoveUp}"
                                                      Command="{Binding Tag.MoveCompanyUpCommand}"
                                                      CommandParameter="{Binding DataContext}">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE70E;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="{DynamicResource CompanyMoveDown}"
                                                      Command="{Binding Tag.MoveCompanyDownCommand}"
                                                      CommandParameter="{Binding DataContext}">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="CardBorder"
                                                    Background="{DynamicResource CardBackgroundBrush}"
                                                    CornerRadius="12" 
                                                    Padding="12"
                                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                                    BorderThickness="1.5"
                                                    Effect="{DynamicResource CardShadow}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                        <Condition Property="IsSelected" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                                </MultiTrigger>
                                                <EventTrigger RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CardBorder" 
                                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                                                             To="16" Duration="0:0:0.2">
                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CardBorder" 
                                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.ShadowDepth)"
                                                                             To="5" Duration="0:0:0.2">
                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CardBorder" 
                                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                                             To="0.22" Duration="0:0:0.2">
                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CardBorder" 
                                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)"
                                                                             To="6" Duration="0:0:0.25">
                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CardBorder" 
                                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.ShadowDepth)"
                                                                             To="2" Duration="0:0:0.25">
                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CardBorder" 
                                                                             Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)"
                                                                             To="0.08" Duration="0:0:0.25">
                                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar circle with first letter -->
                                    <Border Grid.Column="0" Width="42" Height="42" CornerRadius="21" 
                                            Background="{Binding Name, Converter={StaticResource NameToColor}}" Margin="0,0,14,0">
                                        <TextBlock Text="{Binding Name, Converter={StaticResource FirstCharConverter}, FallbackValue=''}" FontSize="{DynamicResource FS18}" FontWeight="Bold" 
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Company info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="{DynamicResource FS14}"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="ICO:" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding ICO}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Chevron -->
                                    <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" 
                                               FontSize="{DynamicResource FS14}" Foreground="{DynamicResource TertiaryForegroundBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- ===== ADD BUTTON ===== -->
                <Border Grid.Row="3" Padding="14,12,14,16"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
                    <Button Command="{Binding OpenAddCompanyDialogCommand}" 
                            Height="46" Cursor="Hand"
                            Background="{DynamicResource AccentBrush}" Foreground="White" 
                            BorderThickness="0" HorizontalContentAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" 
                                        CornerRadius="12" Padding="16,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Direction="270" Opacity="0.15" Color="#000000"/>
                                    </Border.Effect>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}" 
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource BtnAddNewCompany}" FontSize="{DynamicResource FS14}" 
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- Modal Dialog Overlay -->
        <Grid Visibility="{Binding IsAddCompanyDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}">
                 <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAddCompanyDialogCommand}"/>
                </Border.InputBindings>
            </Border>
            <!-- Removed HorizontalAlignment/VerticalAlignment to allow resizing via Grid in View -->
            <ContentControl Content="{Binding AddCompanyVm}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:AddCompanyViewModel}" xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels">
                        <views:AddCompanyView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>
    </Grid>
</UserControl>
