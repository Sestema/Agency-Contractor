<UserControl x:Class="Win11DesktopApp.Views.ArchiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

        <Style x:Key="CardActionBtn" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding GoBackCommand}" Height="36" Padding="12,0" Margin="0,0,10,0"
                            Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource BtnBack}" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="22" 
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource ArchiveTitle}" FontSize="24" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Foreground="{DynamicResource ForegroundBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock Text="{DynamicResource ArchiveSearch}" Foreground="#888" FontSize="12" Margin="2,0,0,2"/>
                    <TextBox Height="38" VerticalContentAlignment="Center"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <!-- ===== ARCHIVE LIST ===== -->
            <Grid Grid.Row="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasArchived, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding ArchivedEmployees}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" 
                                        Padding="16" Margin="0,0,0,10"
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar -->
                                        <Border Grid.Column="0" Width="56" Height="56" CornerRadius="28" 
                                                Background="#F5F5F5" VerticalAlignment="Top" Margin="0,0,14,0"
                                                BorderBrush="#E0E0E0" BorderThickness="2">
                                            <Border.Clip>
                                                <EllipseGeometry Center="28,28" RadiusX="28" RadiusY="28"/>
                                            </Border.Clip>
                                            <Grid>
                                                <Image Source="{Binding PhotoPath}" Stretch="UniformToFill" 
                                                       Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="#BDBDBD"
                                                           Visibility="{Binding HasPhoto, Converter={StaticResource InverseBoolToVis}}"/>
                                            </Grid>
                                        </Border>

                                        <!-- Info -->
                                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="16" 
                                                       Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding PositionTitle}" FontSize="12" Foreground="#888" Margin="0,0,0,6"/>

                                            <WrapPanel Margin="0,0,0,6">
                                                <!-- Start date -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                                               Foreground="#4CAF50" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock FontSize="12" Foreground="#666">
                                                        <Run Text="Наступив: "/>
                                                        <Run Text="{Binding StartDate, Mode=OneWay}" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <!-- End date -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                                               Foreground="#F44336" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock FontSize="12" Foreground="#666">
                                                        <Run Text="Закінчив: "/>
                                                        <Run Text="{Binding EndDate, Mode=OneWay}" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </WrapPanel>

                                            <WrapPanel>
                                                <!-- Firm -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                                                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                                               Foreground="#999" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding FirmName}" FontSize="12" Foreground="#666"/>
                                                </StackPanel>
                                                <!-- Phone -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                                                    <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                                               Foreground="#999" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Phone}" FontSize="12" Foreground="#666"/>
                                                </StackPanel>
                                                <!-- Email -->
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                                               Foreground="#999" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Email}" FontSize="12" Foreground="#666"/>
                                                </StackPanel>
                                            </WrapPanel>
                                        </StackPanel>

                                        <!-- Action buttons -->
                                        <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                                            <Button Style="{StaticResource CardActionBtn}" Margin="0,0,0,4"
                                                    Command="{Binding DataContext.RestoreEmployeeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource ArchiveRestore}" FontSize="12"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource CardActionBtn}"
                                                    Command="{Binding DataContext.OpenEmployeeFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" ToolTip="{DynamicResource ArchiveOpenFolder}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource EmpBtnFolder}" FontSize="12"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty state -->
                <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="8" Padding="30"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        Visibility="{Binding HasArchived, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="42" 
                                   HorizontalAlignment="Center" Foreground="#999"/>
                        <TextBlock Text="{DynamicResource ArchiveEmpty}" FontSize="16" FontWeight="SemiBold"
                                   Margin="0,12,0,4" TextAlignment="Center" Foreground="#888"/>
                        <TextBlock Text="{DynamicResource ArchiveEmptyDesc}"
                                   FontSize="13" TextAlignment="Center" Foreground="#AAA"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ===== RESTORE DIALOG ===== -->
        <Grid Visibility="{Binding IsRestoreDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#66000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CancelRestoreCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" 
                    Width="480" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="22" 
                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource ArchiveRestoreTitle}" FontSize="18" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{Binding EmployeeToRestore.FullName}" FontSize="13" Foreground="#888"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Form -->
                    <TextBlock Text="{DynamicResource ArchiveFirm}" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding AvailableCompanies}" 
                              SelectedItem="{Binding SelectedCompany}"
                              DisplayMemberPath="Name"
                              Padding="8,6" Margin="0,0,0,12" FontSize="13"/>

                    <TextBlock Text="{DynamicResource ArchiveStartDate}" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewStartDate, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8,6" Margin="0,0,0,12" FontSize="13"/>

                    <TextBlock Text="{DynamicResource ArchiveSignDate}" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewContractSignDate, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="8,6" Margin="0,0,0,12" FontSize="13"/>

                    <TextBlock Text="{DynamicResource ArchivePosition}" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding CompanyPositions}"
                              SelectedItem="{Binding SelectedPosition}"
                              Padding="8,6" Margin="0,0,0,12" FontSize="13">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" — " Foreground="#888"/>
                                    <TextBlock Foreground="#888">
                                        <Run Text="{Binding MonthlySalaryBrutto, StringFormat={}{0:N0} zł/міс, Mode=OneWay}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding HourlySalary, StringFormat={}{0:N2} zł/год, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{DynamicResource ArchiveWorkPlace}" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding CompanyAddresses}"
                              SelectedItem="{Binding SelectedAddress}"
                              Padding="8,6" Margin="0,0,0,16" FontSize="13">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding Street, Mode=OneWay}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Number, Mode=OneWay}"/>
                                    <Run Text=", "/>
                                    <Run Text="{Binding City, Mode=OneWay}"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding ZipCode, Mode=OneWay}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Status message -->
                    <TextBlock Text="{Binding RestoreStatus}" Foreground="#D32F2F" FontSize="12" 
                               Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Command="{Binding CancelRestoreCommand}" Padding="16,8" Margin="0,0,8,0"
                                Background="{DynamicResource ContentBackgroundBrush}" 
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                            <TextBlock Text="{DynamicResource BtnCancel}" FontSize="13"/>
                        </Button>
                        <Button Command="{Binding ConfirmRestoreCommand}" Padding="16,8"
                                Background="{DynamicResource AccentBrush}" Foreground="White" 
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource ArchiveRestoreBtn}" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
