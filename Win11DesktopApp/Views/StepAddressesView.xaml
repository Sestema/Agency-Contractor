<UserControl x:Class="Win11DesktopApp.Views.StepAddressesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Border Style="{StaticResource StepFade}" Visibility="{Binding StepIndex, Converter={StaticResource StepVis}, ConverterParameter=5}"
            Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="24"
            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
        <ScrollViewer Style="{StaticResource ThinScroll}" PreviewMouseWheel="InnerScrollViewer_PreviewMouseWheel">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Width="36" Height="36">
                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                               Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{DynamicResource StepAddresses}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="10" Padding="16"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LabelAddressLocal}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10"/>
                        <TextBlock Text="{DynamicResource WizStreet}" Style="{StaticResource WizLabel}"/>
                        <TextBox Text="{Binding Data.AddressLocal.Street, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                        <TextBlock Text="{DynamicResource WizNumber}" Style="{StaticResource WizLabel}"/>
                        <TextBox Text="{Binding Data.AddressLocal.Number, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                        <TextBlock Text="{DynamicResource WizCity}" Style="{StaticResource WizLabel}"/>
                        <TextBox Text="{Binding Data.AddressLocal.City, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                        <TextBlock Text="{DynamicResource WizZip}" Style="{StaticResource WizLabel}"/>
                        <TextBox Text="{Binding Data.AddressLocal.Zip, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="10" Padding="16"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LabelAddressAbroad}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10"/>
                        <TextBlock Text="{DynamicResource WizStreet}" Style="{StaticResource WizLabel}"/>
                        <TextBox Text="{Binding Data.AddressAbroad.Street, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                        <TextBlock Text="{DynamicResource WizNumber}" Style="{StaticResource WizLabel}"/>
                        <TextBox Text="{Binding Data.AddressAbroad.Number, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                        <TextBlock Text="{DynamicResource WizCity}" Style="{StaticResource WizLabel}"/>
                        <TextBox Text="{Binding Data.AddressAbroad.City, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                        <TextBlock Text="{DynamicResource WizZip}" Style="{StaticResource WizLabel}"/>
                        <TextBox Text="{Binding Data.AddressAbroad.Zip, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="10" Padding="16" Margin="0,16,0,0"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource LabelWorkAddress}" Style="{StaticResource WizLabel}" FontWeight="SemiBold" FontSize="{DynamicResource FS13}"/>
                        <ComboBox ItemsSource="{Binding CompanyAddresses}" SelectedItem="{Binding SelectedWorkAddress}" Style="{StaticResource WizCombo}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock><Run Text="{Binding Street}"/> <Run Text="{Binding Number}"/>, <Run Text="{Binding City}"/> <Run Text="{Binding ZipCode}"/></TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="{DynamicResource LabelPosition}" Style="{StaticResource WizLabel}" FontWeight="SemiBold" FontSize="{DynamicResource FS13}"/>
                        <ComboBox ItemsSource="{Binding CompanyPositions}" SelectedItem="{Binding SelectedPosition}" Style="{StaticResource WizCombo}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock><Run Text="{Binding Title}"/> (<Run Text="{Binding PositionNumber}"/>)</TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="{DynamicResource LabelContractType}" Style="{StaticResource WizLabel}" FontWeight="SemiBold" FontSize="{DynamicResource FS13}"/>
                        <ComboBox SelectedItem="{Binding ContractType}" Style="{StaticResource WizCombo}">
                            <sys:String>HPP</sys:String>
                            <sys:String>DPP</sys:String>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <TextBlock Text="{DynamicResource WizPosNumber}" Style="{StaticResource WizLabel}"/>
                        <TextBlock Text="{Binding SelectedPosition.PositionNumber}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource WizSalaryMonth}" Style="{StaticResource WizLabel}"/>
                        <TextBlock Text="{Binding SelectedPosition.MonthlySalaryBrutto, StringFormat={}{0:N0} CZK}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource WizSalaryHour}" Style="{StaticResource WizLabel}"/>
                        <TextBlock Text="{Binding SelectedPosition.HourlySalary, StringFormat={}{0:N0} CZK/h}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentDarkBrush}" Margin="0,0,0,8"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
