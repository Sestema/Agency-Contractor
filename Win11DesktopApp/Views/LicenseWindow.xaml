<Window x:Class="Win11DesktopApp.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agency Contractor — Ліцензія"
        Width="540" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        MinWidth="460" MinHeight="500"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Style="{StaticResource ThinScroll}" VerticalScrollBarVisibility="Auto" Padding="32,24,32,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
                    <Border Style="{StaticResource PageHeaderIconBadge}">
                        <TextBlock Text="&#xE8D7;" Style="{StaticResource PageHeaderIconText}"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Agency Contractor" FontSize="{DynamicResource FS24}" Style="{StaticResource PageHeaderTitleText}"/>
                        <TextBlock Text="Ліцензія та активація"
                                   FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status -->
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="16,12" Margin="0,0,0,12"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Статус ліцензії:" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtStatus" Text="Перевірка..." FontSize="15" FontWeight="SemiBold" Foreground="#D32F2F"/>
                    </StackPanel>
                </Border>

                <!-- Machine ID -->
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="16,10" Margin="0,0,0,12"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="ID комп'ютера:" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtMachineId" Text="..." FontSize="13" FontFamily="Consolas" Foreground="{DynamicResource ForegroundBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Activation section -->
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" Padding="16,14" Margin="0,0,0,12"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Активація" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10"/>

                        <TextBlock Text="Термін:" FontSize="12" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CbPlan" FontSize="13" Padding="8,6" Margin="0,0,0,14">
                            <ComboBoxItem Content="30 днів" Tag="30"/>
                            <ComboBoxItem Content="90 днів" Tag="90"/>
                            <ComboBoxItem Content="180 днів" Tag="180"/>
                            <ComboBoxItem Content="362 дні" Tag="362"/>
                            <ComboBoxItem Content="Безліміт" Tag="0" IsSelected="True"/>
                        </ComboBox>

                        <Button x:Name="BtnActivate" Click="BtnActivate_Click"
                                Padding="16,10" Cursor="Hand"
                                Style="{StaticResource FilledActionButton}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Виберіть ключ для активації" FontSize="14" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Result message -->
                <TextBlock x:Name="TxtResult" Text="" FontSize="12" TextWrapping="Wrap"
                           Foreground="#388E3C" Margin="0,4,0,8"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom bar (always visible) -->
        <Border Grid.Row="1" Background="{DynamicResource WindowBackgroundBrush}" Padding="32,8,32,16"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="v0.1.16-beta.2" FontSize="11" Foreground="{DynamicResource TertiaryForegroundBrush}" VerticalAlignment="Center"/>

                <Button Grid.Column="1" x:Name="BtnContinue" Content="Продовжити ▸" Click="BtnContinue_Click"
                        FontSize="13" Padding="20,8" Cursor="Hand" IsEnabled="False"
                        Background="#4CAF50" Foreground="White" BorderThickness="0"
                        Style="{StaticResource FilledActionButton}">
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
