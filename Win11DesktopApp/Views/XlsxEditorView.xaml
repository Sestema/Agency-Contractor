<UserControl x:Class="Win11DesktopApp.Views.XlsxEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1100">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header bar -->
            <RowDefinition Height="Auto"/>   <!-- Formula bar -->
            <RowDefinition Height="*"/>      <!-- Main: spreadsheet + tags -->
            <RowDefinition Height="Auto"/>   <!-- Sheet tabs -->
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ===== HEADER BAR ===== -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" 
                Padding="12,8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                        Style="{StaticResource HeaderBackButton}"
                        Margin="0,0,10,0" ToolTip="{DynamicResource XlsxBack}">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                </Button>

                <TextBlock Grid.Column="1" Text="{Binding Title}" 
                           FontSize="{DynamicResource FS16}" FontWeight="SemiBold" 
                           Foreground="{DynamicResource ForegroundBrush}"
                           VerticalAlignment="Center"/>

                <!-- AI Assistant Overlay Button -->
                <Button x:Name="BtnAIOverlay" Grid.Column="2" Click="AIOverlay_Click"
                        Padding="10,5" Margin="0,0,6,0" Cursor="Hand"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        VerticalAlignment="Center" ToolTip="{DynamicResource AIOverlayBtn}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}" 
                                   VerticalAlignment="Center" Margin="0,0,4,0">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C4DFF" Offset="0"/>
                                    <GradientStop Color="#448AFF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="AI" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" Content="{DynamicResource XlsxCancel}" 
                        Command="{Binding GoBackCommand}"
                        Padding="14,5" Margin="0,0,6,0" FontSize="{DynamicResource FS12}"
                        Background="{DynamicResource CardBackgroundBrush}"
                        Foreground="{DynamicResource ForegroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        VerticalAlignment="Center" Cursor="Hand"/>

                <Button Grid.Column="4"
                        Command="{Binding SaveCommand}"
                        Padding="14,5"
                        Background="{DynamicResource AccentBrush}" Foreground="White" 
                        BorderThickness="0" FontWeight="SemiBold"
                        VerticalAlignment="Center" Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource XlsxSave}" FontSize="{DynamicResource FS12}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===== FORMULA BAR (Name Box + fx + Cell Content) ===== -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" 
                Padding="4,3" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="90"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Name Box -->
                <Border Grid.Column="0" BorderBrush="{DynamicResource DividerBrush}" 
                        BorderThickness="1" Background="White" Margin="2,0">
                    <TextBlock Text="{Binding CellAddress}" 
                               FontSize="{DynamicResource FS11}" FontWeight="Bold" FontFamily="Consolas"
                               Foreground="{DynamicResource ForegroundBrush}" Padding="6,3"
                               VerticalAlignment="Center" HorizontalAlignment="Left"
                               MinWidth="80"/>
                </Border>

                <!-- Separator + fx label -->
                <Border Grid.Column="1" Padding="6,0">
                    <TextBlock Text="fx" FontStyle="Italic" FontWeight="Bold"
                               FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Formula Bar TextBox -->
                <TextBox Grid.Column="2" 
                         Text="{Binding CellValue, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="{DynamicResource FS12}" FontFamily="Consolas"
                         BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1"
                         Padding="4,3" VerticalAlignment="Center"
                         Background="White" Foreground="{DynamicResource ForegroundBrush}"/>
            </Grid>
        </Border>

        <!-- ===== MAIN: Spreadsheet + Tag Catalog ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" MinWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="3*" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <!-- ===== SPREADSHEET DataGrid ===== -->
            <DataGrid x:Name="XlsxGrid" Grid.Column="0"
                      ItemsSource="{Binding CurrentData}"
                      AutoGenerateColumns="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionUnit="Cell"
                      SelectionMode="Single"
                      HeadersVisibility="All"
                      GridLinesVisibility="All"
                      RowHeaderWidth="42"
                      HorizontalGridLinesBrush="{DynamicResource DividerBrush}"
                      VerticalGridLinesBrush="{DynamicResource DividerBrush}"
                      FontSize="{DynamicResource FS12}" FontFamily="Segoe UI"
                      BorderThickness="0"
                      Background="White"
                      RowBackground="White"
                      AlternatingRowBackground="{DynamicResource SurfaceBrush}"
                      CurrentCellChanged="XlsxGrid_CurrentCellChanged"
                      LoadingRow="XlsxGrid_LoadingRow"
                      AutoGeneratingColumn="XlsxGrid_AutoGeneratingColumn"
                      CellEditEnding="XlsxGrid_CellEditEnding"
                      BeginningEdit="XlsxGrid_BeginningEdit">
                <DataGrid.Resources>
                    <!-- Column headers (like Excel) -->
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    </Style>
                    <!-- Row headers (row numbers) -->
                    <Style TargetType="DataGridRowHeader">
                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Width" Value="42"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="Padding" Value="4,0"/>
                    </Style>
                    <!-- Cell style — no extra padding so our template fills the cell -->
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentDarkBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
            </DataGrid>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" 
                          VerticalAlignment="Stretch" Background="{DynamicResource CardBorderBrush}" 
                          Cursor="SizeWE" ShowsPreview="True"/>

            <!-- ===== TAG CATALOG ===== -->
            <Border Grid.Column="2" 
                    Background="{DynamicResource ContentBackgroundBrush}" Padding="0"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tags header -->
                    <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" 
                            Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource EditorTagCatalog}" FontWeight="SemiBold" FontSize="{DynamicResource FS14}"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource XlsxTagHint}"
                                       FontSize="{DynamicResource FS10}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Selected cell + search -->
                    <Border Grid.Row="1" Padding="10,6" Background="{DynamicResource CardBackgroundBrush}" 
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="{DynamicResource XlsxCell}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           VerticalAlignment="Center"/>
                                <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="3" Padding="6,2" 
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" MinWidth="50">
                                    <TextBlock Text="{Binding CellAddress}" FontSize="{DynamicResource FS11}" FontWeight="Bold"
                                               FontFamily="Consolas" Foreground="{DynamicResource AccentBrush}"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <Grid>
                                <TextBox Text="{Binding TagSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="6,4" FontSize="{DynamicResource FS11}" 
                                         Background="{DynamicResource ContentBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                         VerticalContentAlignment="Center"/>
                                <TextBlock Text="{DynamicResource EditorSearchTags}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource TertiaryForegroundBrush}"
                                           IsHitTestVisible="False" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TagSearchQuery}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TagSearchQuery}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Tags list -->
                    <ScrollViewer Grid.Row="2" Style="{StaticResource ThinScroll}" Padding="6,4">
                        <ItemsControl ItemsSource="{Binding FilteredTagGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander IsExpanded="True" Margin="0,0,0,6">
                                        <Expander.Header>
                                            <TextBlock Text="{Binding GroupName}" FontWeight="SemiBold" FontSize="{DynamicResource FS13}"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                        </Expander.Header>
                                        <ItemsControl ItemsSource="{Binding Tags}" Margin="0,4,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource CardBackgroundBrush}" 
                                                            CornerRadius="4" Padding="8,5" Margin="0,0,0,3"
                                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Description (top) -->
                                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                                       Text="{Binding Description}" 
                                                                       FontSize="{DynamicResource FS12}" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>

                                                            <Button Grid.Row="0" Grid.Column="1"
                                                                    Command="{Binding DataContext.InsertTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Padding="8,2" Margin="4,0,2,0"
                                                                    Background="{DynamicResource AccentBrush}" 
                                                                    Foreground="White" BorderThickness="0"
                                                                    VerticalAlignment="Center" Cursor="Hand"
                                                                    ToolTip="{DynamicResource XlsxInsertTag}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{DynamicResource EditorInsert}" FontSize="{DynamicResource FS10}"/>
                                                                </StackPanel>
                                                            </Button>

                                                            <Button Grid.Row="0" Grid.Column="2" Content="&#xE8C8;"
                                                                    FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}"
                                                                    Command="{Binding DataContext.CopyTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Width="26" Height="24"
                                                                    Background="Transparent" BorderThickness="0"
                                                                    Foreground="{DynamicResource ForegroundBrush}"
                                                                    VerticalAlignment="Center" Cursor="Hand"
                                                                    ToolTip="{DynamicResource EditorCopyTag}"/>

                                                            <!-- Tag name (bottom) -->
                                                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                                       FontSize="{DynamicResource FS10}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                       FontFamily="Consolas"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Margin="0,2,0,0">
                                                                <Run Text="${"/><Run Text="{Binding Tag}"/><Run Text="}"/>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== SHEET TABS (bottom, like Excel) ===== -->
        <Border Grid.Row="3" Background="{DynamicResource SurfaceBrush}" Padding="4,2"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7C4;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}" 
                           Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center" Margin="4,0,8,0"/>
                <ItemsControl ItemsSource="{Binding SheetNames}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <RadioButton Content="{Binding}" GroupName="SheetTabs"
                                         Margin="0,0,1,0" Padding="14,4"
                                         FontSize="{DynamicResource FS11}" Cursor="Hand"
                                         Checked="SheetTab_Checked">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <Border x:Name="TabBd" Padding="{TemplateBinding Padding}"
                                                Background="White"
                                                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1,1,1,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="TabBd" Property="Background" Value="White"/>
                                                <Setter TargetName="TabBd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter TargetName="TabBd" Property="BorderThickness" Value="1,2,1,0"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="TabBd" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RadioButton.Template>
                            </RadioButton>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ===== FOOTER (Status bar) ===== -->
        <Border Grid.Row="4" Background="{DynamicResource CardBackgroundBrush}" 
                Padding="10,4" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Merge legend -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                    <Border Width="14" Height="14" CornerRadius="2" Margin="0,0,4,0"
                            Background="{DynamicResource AccentLightBrush}" BorderBrush="{DynamicResource AccentDarkBrush}" BorderThickness="1"/>
                    <TextBlock Text="{DynamicResource XlsxMergeMaster}" FontSize="{DynamicResource FS10}" Foreground="{DynamicResource SecondaryForegroundBrush}" 
                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <Border Width="14" Height="14" CornerRadius="2" Margin="0,0,4,0"
                            Background="{DynamicResource CardHoverBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"/>
                    <TextBlock Text="{DynamicResource XlsxMergePart}" FontSize="{DynamicResource FS10}" Foreground="{DynamicResource SecondaryForegroundBrush}" 
                               VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <Border Width="14" Height="14" CornerRadius="2" Margin="0,0,4,0"
                            Background="White" BorderBrush="{DynamicResource AccentDarkBrush}" BorderThickness="1"/>
                    <TextBlock Text="{DynamicResource XlsxTag}" FontSize="{DynamicResource FS10}" Foreground="{DynamicResource AccentDarkBrush}" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Status message -->
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" 
                           FontSize="{DynamicResource FS11}" Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
