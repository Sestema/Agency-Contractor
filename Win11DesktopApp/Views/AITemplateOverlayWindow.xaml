<Window x:Class="Win11DesktopApp.Views.AITemplateOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Template Assistant" 
        Width="420" Height="500"
        MinWidth="300" MinHeight="300"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" CornerRadius="12"
                      GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border Style="{StaticResource DialogSectionCard}"
            Background="{DynamicResource ContentBackgroundBrush}"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1.5"
            CornerRadius="12"
            Margin="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar (draggable) -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="12,10" 
                    Background="{DynamicResource BrandAiGradientBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Cursor="SizeAll">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="28"
                            Height="28"
                            CornerRadius="8"
                            Background="{DynamicResource AccentLightBrush}"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" 
                                   FontSize="14" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="AI Template Assistant" FontSize="13" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="AI helper for current template"
                                   FontSize="11"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Click="CloseButton_Click"
                            Style="{StaticResource ToolbarInlineIconButton}"
                            Background="{DynamicResource AccentLightBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            Foreground="White">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Quick actions -->
            <Border Grid.Row="1" Style="{StaticResource DialogPreviewSurface}" Padding="10" Margin="10,8,10,4">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnAnalyze"
                            Click="AnalyzeTemplate_Click"
                            Style="{StaticResource FilledActionButton}"
                            Padding="10,6"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource AIAnalyzeTemplate}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnSuggestTags"
                            Click="SuggestTags_Click"
                            Style="{StaticResource DialogAccentSoftButton}"
                            Background="{DynamicResource WarningChipBackgroundBrush}"
                            Foreground="{DynamicResource WarningChipForegroundBrush}"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource AISuggestTags}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Messages -->
            <Border Grid.Row="2"
                    Margin="10,4,10,4"
                    Style="{StaticResource DialogPreviewSurface}"
                    Background="{DynamicResource WindowBackgroundBrush}">
                <ScrollViewer x:Name="MessagesScroll" VerticalScrollBarVisibility="Auto" Padding="8,6">
                    <ItemsControl x:Name="MessagesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,3" Padding="10,7" CornerRadius="8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Input -->
            <Grid Grid.Row="3" Margin="10,4,10,10">
                <Border Style="{StaticResource DialogPreviewSurface}"
                        Background="{DynamicResource WindowBackgroundBrush}"
                        Padding="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="InputBox" Grid.Column="0" 
                                 FontSize="12" Background="Transparent" BorderThickness="0" Padding="8,6"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 AcceptsReturn="False" TextWrapping="Wrap" MaxLines="3"
                                 KeyDown="InputBox_KeyDown"/>
                        <Button Grid.Column="1"
                                Click="SendMessage_Click"
                                Width="36"
                                Height="36"
                                Style="{StaticResource FilledActionButton}"
                                Background="{DynamicResource BrandAiGradientBrush}"
                                Padding="0">
                            <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
