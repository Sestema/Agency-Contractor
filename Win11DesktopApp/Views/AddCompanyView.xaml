<UserControl x:Class="Win11DesktopApp.Views.AddCompanyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="600">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="CompanyFieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryForegroundBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="{DynamicResource FS13}"/>
        </Style>

        <Style x:Key="CompanySectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="{DynamicResource FS16}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CompanyInputTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogSecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Background="Transparent">
        <Border x:Name="MainBorder" 
                Style="{StaticResource DialogSectionCard}"
                Background="{DynamicResource CardBackgroundBrush}" 
                CornerRadius="18" 
                MinWidth="500" MinHeight="400"
                MaxWidth="1200" MaxHeight="900"
                Width="700" Height="760"
                Padding="0">
            
            <Grid>
                <Grid Margin="26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource PageHeaderIconBadge}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#C77C36" Offset="0"/>
                                        <GradientStop Color="#E0A157" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="&#xE8D2;" Style="{StaticResource PageHeaderIconText}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding DialogTitle}"
                                           Style="{StaticResource PageHeaderTitleText}"
                                           FontSize="{DynamicResource FS26}"/>
                                <TextBlock Text="{DynamicResource CompanyDialogSubtitle}"
                                           FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource ToolbarIconButton}"
                                Width="40"
                                Height="40">
                            <TextBlock Text="&#xE711;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{DynamicResource FS13}"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        </Button>
                    </Grid>
                    
                    <!-- Tabs -->
                    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="FontSize" Value="{DynamicResource FS13}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border Name="Border"
                                                    Background="Transparent"
                                                    BorderThickness="1"
                                                    BorderBrush="Transparent"
                                                    CornerRadius="10"
                                                    Margin="0,0,12,0"
                                                    Padding="14,8">
                                                <ContentPresenter x:Name="ContentSite"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    ContentSource="Header"
                                                    Margin="6,0"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentDarkBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- Employer Tab -->
                        <TabItem Header="{DynamicResource TabEmployer}">
                            <ScrollViewer Margin="0,18,0,0" Style="{StaticResource ThinScroll}">
                                <StackPanel>
                                    <Border Style="{StaticResource DialogSectionCard}"
                                            Padding="18,16"
                                            Margin="0,0,0,16">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource AccentLightBrush}">
                                                    <TextBlock Text="&#xE8D2;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="{DynamicResource FS13}"
                                                               Foreground="{DynamicResource AccentDarkBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{DynamicResource TabEmployer}" Style="{StaticResource CompanySectionTitle}"/>
                                            </StackPanel>

                                            <TextBlock Text="{DynamicResource LabelCompanyName}" Style="{StaticResource CompanyFieldLabel}"/>
                                            <TextBox Text="{Binding Employer.Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CompanyInputTextBox}"/>
                                            
                                            <TextBlock Text="{DynamicResource LabelICO}" Style="{StaticResource CompanyFieldLabel}"/>
                                            <TextBox Text="{Binding Employer.ICO, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CompanyInputTextBox}"/>

                                            <TextBlock Text="{DynamicResource LabelLegalAddress}" Style="{StaticResource CompanyFieldLabel}"/>
                                            <TextBox Text="{Binding Employer.LegalAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CompanyInputTextBox}" Margin="0"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Addresses -->
                                    <Border Style="{StaticResource DialogSectionCard}"
                                            Padding="18,16"
                                            Margin="0,0,0,16">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource SuccessLightBrush}">
                                                    <TextBlock Text="&#xE707;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="{DynamicResource FS13}"
                                                               Foreground="{DynamicResource SuccessBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{DynamicResource LabelWorkAddresses}" Style="{StaticResource CompanySectionTitle}"/>
                                            </StackPanel>

                                    <ItemsControl ItemsSource="{Binding Employer.Addresses}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource DialogPreviewSurface}" Padding="12" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="3*"/>
                                                                    <ColumnDefinition Width="1*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                    <TextBlock Text="{DynamicResource LabelStreet}" Style="{StaticResource CompanyFieldLabel}"/>
                                                                    <TextBox Text="{Binding Street}" Style="{StaticResource CompanyInputTextBox}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{DynamicResource LabelNumber}" Style="{StaticResource CompanyFieldLabel}"/>
                                                                    <TextBox Text="{Binding Number}" Style="{StaticResource CompanyInputTextBox}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="2*"/>
                                                                    <ColumnDefinition Width="1*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                    <TextBlock Text="{DynamicResource LabelCity}" Style="{StaticResource CompanyFieldLabel}"/>
                                                                    <TextBox Text="{Binding City}" Style="{StaticResource CompanyInputTextBox}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{DynamicResource LabelZip}" Style="{StaticResource CompanyFieldLabel}"/>
                                                                    <TextBox Text="{Binding ZipCode}" Style="{StaticResource CompanyInputTextBox}" Margin="0"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                        <!-- Delete address button -->
                                                        <Button Grid.Column="1" 
                                                                Command="{Binding DataContext.RemoveAddressCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                VerticalAlignment="Top" Margin="8,0,0,0"
                                                                Width="30" Height="30"
                                                                Style="{StaticResource ToolbarInlineIconButton}"
                                                                Background="{DynamicResource ErrorLightBrush}"
                                                                BorderBrush="{DynamicResource ErrorLightBrush}"
                                                                ToolTip="{DynamicResource CompanyTooltipDeleteAddr}">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" Foreground="{DynamicResource ErrorBrush}"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                            <Button Command="{Binding AddAddressCommand}"
                                                    HorizontalAlignment="Left"
                                                    Style="{StaticResource DialogAccentSoftButton}">
                                                <TextBlock Text="{DynamicResource BtnAddAddress}"
                                                           FontSize="{DynamicResource FS13}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentDarkBrush}"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Positions -->
                                    <Border Style="{StaticResource DialogSectionCard}"
                                            Padding="18,16"
                                            Margin="0,0,0,16">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource InfoLightBrush}">
                                                    <TextBlock Text="&#xE8EF;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="{DynamicResource FS13}"
                                                               Foreground="{DynamicResource InfoBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{DynamicResource LabelPositions}" Style="{StaticResource CompanySectionTitle}"/>
                                            </StackPanel>
                                    <ItemsControl ItemsSource="{Binding Employer.Positions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource DialogPreviewSurface}" Padding="12" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="2*"/>
                                                                    <ColumnDefinition Width="1*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                    <TextBlock Text="{DynamicResource LabelPosTitle}" Style="{StaticResource CompanyFieldLabel}"/>
                                                                    <TextBox Text="{Binding Title}" Style="{StaticResource CompanyInputTextBox}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{DynamicResource LabelPosNumber}" Style="{StaticResource CompanyFieldLabel}"/>
                                                                    <TextBox Text="{Binding PositionNumber}" Style="{StaticResource CompanyInputTextBox}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="1*"/>
                                                                    <ColumnDefinition Width="1*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                    <TextBlock Text="{DynamicResource LabelSalary}" Style="{StaticResource CompanyFieldLabel}"/>
                                                                    <TextBox Text="{Binding MonthlySalaryBrutto}" Style="{StaticResource CompanyInputTextBox}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock Text="{DynamicResource LabelHourly}" Style="{StaticResource CompanyFieldLabel}"/>
                                                                    <TextBox Text="{Binding HourlySalary}" Style="{StaticResource CompanyInputTextBox}" Margin="0"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                        <!-- Delete position button -->
                                                        <Button Grid.Column="1" 
                                                                Command="{Binding DataContext.RemovePositionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                VerticalAlignment="Top" Margin="8,0,0,0"
                                                                Width="30" Height="30"
                                                                Style="{StaticResource ToolbarInlineIconButton}"
                                                                Background="{DynamicResource ErrorLightBrush}"
                                                                BorderBrush="{DynamicResource ErrorLightBrush}"
                                                                ToolTip="{DynamicResource CompanyTooltipDeletePos}">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" Foreground="{DynamicResource ErrorBrush}"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                            <Button Command="{Binding AddPositionCommand}"
                                                    HorizontalAlignment="Left"
                                                    Style="{StaticResource DialogAccentSoftButton}">
                                                <TextBlock Text="{DynamicResource BtnAddPosition}"
                                                           FontSize="{DynamicResource FS13}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentDarkBrush}"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <!-- Work Hours & Shifts -->
                                    <Border Style="{StaticResource DialogSectionCard}"
                                            Padding="18,16"
                                            Margin="0,0,0,4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource PurpleLightBrush}">
                                                    <TextBlock Text="&#xE823;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="{DynamicResource FS13}"
                                                               Foreground="{DynamicResource PurpleBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{DynamicResource LabelWorkHoursAndShifts}" Style="{StaticResource CompanySectionTitle}"/>
                                            </StackPanel>
                                    <Border Style="{StaticResource DialogPreviewSurface}" Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <TextBlock Text="{DynamicResource LabelWeeklyHours}" Style="{StaticResource CompanyFieldLabel}"/>
                                                <TextBox Text="{Binding Employer.WeeklyWorkHours}" Style="{StaticResource CompanyInputTextBox}" Margin="0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                                <TextBlock Text="{DynamicResource LabelDailyHours}" Style="{StaticResource CompanyFieldLabel}"/>
                                                <TextBox Text="{Binding Employer.DailyWorkHours}" Style="{StaticResource CompanyInputTextBox}" Margin="0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{DynamicResource LabelShiftCount}" Style="{StaticResource CompanyFieldLabel}"/>
                                                <ComboBox SelectedItem="{Binding Employer.ShiftCount, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource ThemedComboBox}">
                                                    <sys:Int32>1</sys:Int32>
                                                    <sys:Int32>2</sys:Int32>
                                                    <sys:Int32>3</sys:Int32>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        
                        <!-- Agency Tab -->
                        <TabItem Header="{DynamicResource TabAgency}">
                            <ScrollViewer Margin="0,18,0,0" Style="{StaticResource ThinScroll}">
                                <Border Style="{StaticResource DialogSectionCard}" Padding="18,16">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource WarningLightBrush}">
                                                <TextBlock Text="&#xE8D4;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="{DynamicResource FS13}"
                                                           Foreground="{DynamicResource WarningBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{DynamicResource TabAgency}" Style="{StaticResource CompanySectionTitle}"/>
                                        </StackPanel>

                                        <TextBlock Text="{DynamicResource LabelCompanyName}" Style="{StaticResource CompanyFieldLabel}"/>
                                        <TextBox Text="{Binding Agency.Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CompanyInputTextBox}"/>
                                        
                                        <TextBlock Text="{DynamicResource LabelICO}" Style="{StaticResource CompanyFieldLabel}"/>
                                        <TextBox Text="{Binding Agency.ICO, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CompanyInputTextBox}"/>
                                        
                                        <TextBlock Text="{DynamicResource LabelFullAddress}" Style="{StaticResource CompanyFieldLabel}"/>
                                        <TextBox Text="{Binding Agency.FullAddress, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource CompanyInputTextBox}"
                                                 Height="88"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Margin="0"/>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                    
                    <!-- Footer -->
                    <Grid Grid.Row="2" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Delete button (only in edit mode) -->
                        <Button Grid.Column="0" Command="{Binding DeleteCompanyCommand}" 
                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                Style="{StaticResource ToolbarIconButton}"
                                Width="42" Height="42"
                                Background="{DynamicResource ErrorLightBrush}"
                                BorderBrush="{DynamicResource ErrorLightBrush}"
                                ToolTip="{DynamicResource CompanyTooltipDeleteCompany}">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}" Foreground="{DynamicResource ErrorBrush}"/>
                        </Button>

                        <!-- Cancel -->
                        <Button Grid.Column="2"
                                Command="{Binding CancelCommand}"
                                Margin="0,0,10,0"
                                Style="{StaticResource DialogSecondaryButton}">
                            <TextBlock Text="{DynamicResource BtnCancel}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"/>
                        </Button>
                        
                        <!-- Save -->
                        <Button Grid.Column="3"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource FilledActionButton}"
                                Padding="26,10">
                            <TextBlock Text="{DynamicResource BtnSave}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold" Foreground="White"/>
                        </Button>
                    </Grid>
                </Grid>
                
                <!-- Resize Grip -->
                <Thumb HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" Width="20" Height="20" Margin="0,0,0,0" DragDelta="Thumb_DragDelta">
                    <Thumb.Template>
                        <ControlTemplate>
                            <Grid Background="Transparent">
                                <Path Data="M16,16 L16,4 L4,16 Z" Fill="{DynamicResource ForegroundBrush}" Opacity="0.5" Stretch="Uniform" Width="10" Height="10" Margin="5"/>
                            </Grid>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
            </Grid>
        </Border>
    </Grid>
</UserControl>
