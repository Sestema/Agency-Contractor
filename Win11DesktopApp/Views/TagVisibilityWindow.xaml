<Window x:Class="Win11DesktopApp.Views.TagVisibilityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource TagVisTitle}"
        Width="560" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{DynamicResource TagVisHeader}"
                   FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                   Foreground="{DynamicResource ForegroundBrush}"
                   Margin="0,0,0,12"/>

        <!-- Select All / Deselect All -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="{DynamicResource TagVisSelectAll}" Click="SelectAll_Click"
                    Padding="14,6" Margin="0,0,10,0" Cursor="Hand"
                    FontSize="{DynamicResource FS13}" FontWeight="Medium">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Foreground>
                    <SolidColorBrush Color="White"/>
                </Button.Foreground>
            </Button>
            <Button Content="{DynamicResource TagVisDeselectAll}" Click="DeselectAll_Click"
                    Padding="14,6" Margin="0,0,10,0" Cursor="Hand"
                    FontSize="{DynamicResource FS13}" FontWeight="Medium">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource CardBackgroundBrush}" 
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- Tag list grouped by category -->
        <ScrollViewer Grid.Row="2" Style="{StaticResource ThinScroll}">
            <ItemsControl x:Name="TagGroupsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="{Binding GroupName}"
                                       FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                                  Margin="12,3,0,3" Cursor="Hand">
                                            <CheckBox.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Description}" 
                                                               FontSize="{DynamicResource FS13}"
                                                               Foreground="{DynamicResource ForegroundBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Tag, StringFormat=' ({0})'}" 
                                                               FontSize="{DynamicResource FS11}" Opacity="0.5"
                                                               Foreground="{DynamicResource ForegroundBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{DynamicResource TagVisSave}" Click="Save_Click"
                    Padding="20,8" Margin="0,0,10,0" Cursor="Hand"
                    FontSize="{DynamicResource FS14}" FontWeight="SemiBold">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Foreground>
                    <SolidColorBrush Color="White"/>
                </Button.Foreground>
            </Button>
            <Button Content="{DynamicResource TagVisCancel}" Click="Cancel_Click"
                    Padding="20,8" Cursor="Hand"
                    FontSize="{DynamicResource FS14}" FontWeight="Medium">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource CardBackgroundBrush}" 
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
