<UserControl x:Class="Win11DesktopApp.Views.ProblemsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels"
             xmlns:views="clr-namespace:Win11DesktopApp.Views"
             xmlns:h="clr-namespace:Win11DesktopApp.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:ExpirySeverityColorConverter x:Key="SeverityColor"/>
        <conv:ExpirySeverityBackgroundConverter x:Key="SeverityBg"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}" Margin="32,20,32,32" ClipToBounds="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding GoBackCommand}" Height="36" Padding="12,0" Margin="0,0,10,0"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                        Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource BtnBack}" FontSize="{DynamicResource FS14}"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS22}" 
                           Foreground="{DynamicResource ErrorBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Title}" FontSize="{DynamicResource FS24}" FontWeight="SemiBold" 
                           VerticalAlignment="Center" Foreground="{DynamicResource ForegroundBrush}"/>
            </StackPanel>

            <!-- Export PDF button -->
            <Button Grid.Column="1" Command="{Binding ExportToPdfCommand}" Cursor="Hand"
                    VerticalAlignment="Center">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="8" Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{DynamicResource ProbExportPdf}" FontSize="{DynamicResource FS13}" FontWeight="Medium"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- STATS -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <!-- Expired / Critical -->
            <Button Command="{Binding FilterExpiredCommand}" Cursor="Hand" Margin="0,0,10,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource ErrorLightBrush}" CornerRadius="8" Padding="16,10" MinWidth="140"
                                BorderBrush="{DynamicResource ErrorLightBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding ExpiredDisplay}" FontSize="{DynamicResource FS28}" FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}"/>
                                <TextBlock Text="{DynamicResource ProbStatExpired}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource ErrorBrush}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ErrorLightBrush}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsFilterExpired}" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ErrorLightBrush}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Warning / Expiring soon -->
            <Button Command="{Binding FilterWarningCommand}" Cursor="Hand" Margin="0,0,10,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource WarningLightBrush}" CornerRadius="8" Padding="16,10" MinWidth="140"
                                BorderBrush="{DynamicResource WarningLightBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding WarningDisplay}" FontSize="{DynamicResource FS28}" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}"/>
                                <TextBlock Text="{DynamicResource ProbStatWarning}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource WarningBrush}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource WarningLightBrush}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsFilterWarning}" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource WarningLightBrush}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Total -->
            <Button Command="{Binding FilterAllCommand}" Cursor="Hand" Margin="0,0,10,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="16,10" MinWidth="140"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalDisplay}" FontSize="{DynamicResource FS28}" FontWeight="Bold" 
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{DynamicResource ProbStatTotal}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsFilterAll}" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Ignored -->
            <Button Command="{Binding ToggleIgnoredListCommand}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{DynamicResource AccentLightBrush}" CornerRadius="8" Padding="16,10" MinWidth="140"
                                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding IgnoredCount}" FontSize="{DynamicResource FS28}" FontWeight="Bold" Foreground="{DynamicResource AccentDarkBrush}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource ProbIgnored}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource AccentDarkBrush}"/>
                                    <TextBlock Text=" &#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS9}"
                                               Foreground="{DynamicResource AccentDarkBrush}" VerticalAlignment="Center" Margin="4,1,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- IGNORED LIST (collapsible) -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="10"
                Padding="16,12" Margin="0,0,0,12"
                Visibility="{Binding IsIgnoredListVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="&#xE7E7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                               Foreground="{DynamicResource AccentDarkBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{DynamicResource ProbIgnoredTitle}" FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentDarkBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding IgnoredProblems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="12,8" Margin="0,0,0,5"
                                    BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}">
                                            <Run Text="{Binding EmployeeName, Mode=OneWay}"/>
                                            <Run Text=" — " Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                            <Run Text="{Binding DocumentTypeDisplay, Mode=OneWay}"/>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}"
                                                       Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding FirmName}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,12,0"/>
                                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}"
                                                       Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding ExpiryDateStr}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,12,0"/>
                                            <Border Background="{DynamicResource AccentLightBrush}" CornerRadius="6" Padding="6,2">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{DynamicResource ProbUntil}" FontSize="{DynamicResource FS10}" Foreground="{DynamicResource AccentDarkBrush}"/>
                                                    <TextBlock Text="{Binding IgnoredUntil}" FontSize="{DynamicResource FS10}" Foreground="{DynamicResource AccentDarkBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="1" VerticalAlignment="Center" Cursor="Hand"
                                            Command="{Binding DataContext.RestoreProblemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{DynamicResource ProbRestoreTooltip}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{DynamicResource AccentLightBrush}" CornerRadius="6" Padding="10,6"
                                                        BorderBrush="{DynamicResource AccentDarkBrush}" BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}"
                                                                   Foreground="{DynamicResource AccentDarkBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{DynamicResource ProbRestore}" FontSize="{DynamicResource FS11}" FontWeight="Medium"
                                                                   Foreground="{DynamicResource AccentDarkBrush}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentLightBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- PROBLEMS LIST (grouped by employee) -->
        <Grid Grid.Row="3">
            <ItemsControl ItemsSource="{Binding ProblemGroups}" Margin="16,4,16,4"
                          Visibility="{Binding HasProblems, Converter={StaticResource BoolToVis}}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True">
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <ScrollViewer Style="{StaticResource ThinScroll}" Padding="10" CanContentScroll="True" Focusable="False" ClipToBounds="False">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </ItemsControl.Template>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10"
                                    Padding="0" Margin="16,6,16,10"
                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                    RenderTransformOrigin="0.5,0.5" Cursor="Hand"
                                    MouseLeftButtonDown="EmployeeCard_MouseLeftButtonDown"
                                    h:StaggerAnimation.Enable="True">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        <TranslateTransform Y="0"/>
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.06"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Severity color strip (worst severity) -->
                                    <Border Grid.Column="0" CornerRadius="10,0,0,10"
                                            Background="{Binding WorstSeverity, Converter={StaticResource SeverityColor}}"/>

                                    <Grid Grid.Column="1" Margin="16,14,16,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Employee header -->
                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon -->
                                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" 
                                                    Margin="0,0,14,0" VerticalAlignment="Center"
                                                    Background="{Binding WorstSeverity, Converter={StaticResource SeverityBg}}">
                                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS18}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{Binding WorstSeverity, Converter={StaticResource SeverityColor}}"/>
                                            </Border>

                                            <!-- Name + firm -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding EmployeeName}" FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}"
                                                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding FirmName}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                    <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                                                        <TextBlock Text="{DynamicResource ProbIssueCount}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                        <TextBlock Text="{Binding IssueCount}" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Open employee button -->
                                            <Button Grid.Column="2" VerticalAlignment="Center" Cursor="Hand"
                                                    Command="{Binding DataContext.OpenEmployeeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{DynamicResource ProbOpenTooltip}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="{DynamicResource CardBackgroundBrush}"
                                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                                                CornerRadius="6" Padding="10,6">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}"
                                                                           Foreground="{DynamicResource AccentBrush}"
                                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                <TextBlock Text="{DynamicResource ProbOpen}" FontSize="{DynamicResource FS12}"
                                                                           Foreground="{DynamicResource AccentBrush}"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>

                                        <!-- Issues list -->
                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Issues}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,5" Padding="12,8" CornerRadius="6"
                                                            Background="{Binding Severity, Converter={StaticResource SeverityBg}}"
                                                            BorderBrush="{Binding Severity, Converter={StaticResource SeverityColor}}"
                                                            BorderThickness="0,0,0,0">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Document type icon -->
                                                            <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                                                       Foreground="{Binding Severity, Converter={StaticResource SeverityColor}}"
                                                                       VerticalAlignment="Center" Margin="0,0,10,0"
                                                                       Text="&#xE7BA;"/>

                                                            <!-- Doc type + date + badge -->
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource ForegroundBrush}">
                                                                    <Run Text="{Binding DocumentTypeDisplay, Mode=OneWay}"/>
                                                                </TextBlock>
                                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}"
                                                                               Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding ExpiryDateStr}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,10,0"/>
                                                                    <Border CornerRadius="8" Padding="8,2"
                                                                            Background="{Binding Severity, Converter={StaticResource SeverityBg}}">
                                                                        <TextBlock FontSize="{DynamicResource FS10}" FontWeight="SemiBold"
                                                                                   Text="{Binding DaysRemaining, Converter={x:Static conv:DaysRemainingTextConverter.Instance}}"
                                                                                   Foreground="{Binding Severity, Converter={StaticResource SeverityColor}}"/>
                                                                    </Border>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <!-- Ignore button -->
                                                            <Button Grid.Column="3" VerticalAlignment="Center" Cursor="Hand"
                                                                    Command="{Binding DataContext.IgnoreProblemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip="{DynamicResource ProbIgnoreTooltip}">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="6,4">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="&#xE7E7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}"
                                                                                           Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                                <TextBlock Text="{DynamicResource ProbIgnore}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                                           VerticalAlignment="Center"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Grid>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1.015" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1.015" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            <!-- Empty state -->
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="8" Padding="30"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    Visibility="{Binding HasProblems, Converter={StaticResource InverseBoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS42}" 
                               HorizontalAlignment="Center" Foreground="{DynamicResource SuccessBrush}"/>
                    <TextBlock Text="{DynamicResource ProbAllOk}" FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                               Margin="0,12,0,4" TextAlignment="Center" Foreground="{DynamicResource SuccessBrush}"/>
                    <TextBlock Text="{DynamicResource ProbAllOkDesc}" 
                               FontSize="{DynamicResource FS13}" TextAlignment="Center" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
        <!-- Employee Details Overlay -->
        <Grid Grid.RowSpan="4" Visibility="{Binding IsEmployeeDetailsOpen, Converter={StaticResource BoolToVis}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsEmployeeDetailsOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding EmployeeDetailsVm.CloseCommand}"/>
                </Border.InputBindings>
            </Border>
            <ContentControl Content="{Binding EmployeeDetailsVm}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:EmployeeDetailsViewModel}">
                        <views:EmployeeDetailsView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>
    </Grid>
</UserControl>
