<Window x:Class="Win11DesktopApp.Invoices.Views.InvoicePdfPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="{DynamicResource InvoicesPreviewWindowTitle}"
        Width="1100"
        Height="820"
        MinWidth="860"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Style="{StaticResource PageHeaderIconBadge}" Background="{DynamicResource AccentBrush}">
                    <TextBlock Text="&#xE8A5;" Style="{StaticResource PageHeaderIconText}"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource InvoicesPreviewWindowTitle}" Style="{StaticResource PageHeaderTitleText}"/>
                    <TextBlock x:Name="TxtSubtitle"
                               Margin="0,2,0,0"
                               FontSize="{DynamicResource FS11}"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               Text="{DynamicResource InvoicesPreviewLoading}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="BtnOpenExternal"
                        Click="BtnOpenExternal_Click"
                        Margin="0,0,8,0"
                        Padding="14,9"
                        Style="{StaticResource FilledActionButton}">
                    <TextBlock Text="{DynamicResource InvoicesPreviewOpenExternal}"
                               FontSize="{DynamicResource FS12}"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                </Button>
                <Button x:Name="BtnSaveAs"
                        Click="BtnSaveAs_Click"
                        Margin="0,0,8,0"
                        Padding="14,9"
                        Style="{StaticResource FilledActionButton}">
                    <TextBlock Text="{DynamicResource InvoicesPreviewSaveAs}"
                               FontSize="{DynamicResource FS12}"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                </Button>
                <Button x:Name="BtnClose"
                        Click="BtnClose_Click"
                        Padding="14,9"
                        Style="{StaticResource FilledActionButton}">
                    <TextBlock Text="{DynamicResource InvoicesPreviewClose}"
                               FontSize="{DynamicResource FS12}"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="{DynamicResource ContentBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <wv2:WebView2 x:Name="PdfWebView"/>

                <Border x:Name="PreviewMessageOverlay"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        Opacity="0.92"
                        CornerRadius="12">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500">
                        <TextBlock x:Name="TxtOverlayTitle"
                                   Text="{DynamicResource InvoicesPreviewLoading}"
                                   FontSize="{DynamicResource FS18}"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                        <TextBlock x:Name="TxtOverlayMessage"
                                   Margin="0,8,0,0"
                                   FontSize="{DynamicResource FS12}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="4,10,4,0"
                   FontSize="{DynamicResource FS11}"
                   Foreground="{DynamicResource MutedForegroundBrush}"
                   Text="{DynamicResource InvoicesPreviewHint}"/>
    </Grid>
</Window>
