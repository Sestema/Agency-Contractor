<UserControl x:Class="Win11DesktopApp.Views.DocumentPreviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="10" Background="{DynamicResource ContentBackgroundBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <ItemsControl Grid.Row="0" Panel.ZIndex="1" ItemsSource="{Binding CarouselItems}" Margin="4,6,4,2"
                          Visibility="{Binding HasCarouselItems, Converter={StaticResource BoolToVis}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Label}" Style="{StaticResource CarouselTabBtn}"
                                Command="{Binding DataContext.SelectCarouselTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Border Grid.Row="1" ClipToBounds="True">
                <Grid>
                    <Image x:Name="DocImage" Source="{Binding CarouselPreviewPath, Converter={StaticResource ImagePathConverter}}" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           MouseWheel="DocImage_MouseWheel"
                           MouseRightButtonDown="DocImage_MouseRightButtonDown"
                           MouseRightButtonUp="DocImage_MouseRightButtonUp"
                           MouseMove="DocImage_MouseMove"
                           MouseLeftButtonDown="DocImage_ResetZoom">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CarouselPreviewPath, Converter={StaticResource StringToVis}}" Value="{x:Static Visibility.Collapsed}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                <TranslateTransform X="0" Y="0"/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>

                    <Border Margin="12"
                            Padding="24,20"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource CompactEmptyStateCard}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CarouselPreviewPath, Converter={StaticResource StringToVis}}" Value="{x:Static Visibility.Collapsed}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE8A7;" Style="{StaticResource CompactEmptyStateIconText}" FontSize="{DynamicResource FS24}"/>
                            <TextBlock Text="Попередній перегляд з'явиться тут"
                                       Style="{StaticResource CompactEmptyStateTitleText}"/>
                            <TextBlock Text="Завантаж документ або перейди до кроку з прикріпленим файлом."
                                       Style="{StaticResource CompactEmptyStateDescriptionText}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
