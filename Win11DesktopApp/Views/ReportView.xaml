<UserControl x:Class="Win11DesktopApp.Views.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels"
             xmlns:views="clr-namespace:Win11DesktopApp.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

        <Style x:Key="ToggleBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleBtnActive" TargetType="Button" BasedOn="{StaticResource ToggleBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Padding="{TemplateBinding Padding}"
                                Background="{DynamicResource AccentBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="ExpanderHeaderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ReportSurfaceCard" TargetType="Border" BasedOn="{StaticResource SettingsSectionCard}">
            <Setter Property="Padding" Value="24,20"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="ReportInnerCard" TargetType="Border" BasedOn="{StaticResource DialogPreviewSurface}">
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="ReportMetricCard" TargetType="Border" BasedOn="{StaticResource SurfaceMetricCard}">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="MinWidth" Value="170"/>
        </Style>

        <Style x:Key="ReportDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0,0,1,2"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="SortDirection" Value="Ascending">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
                <Trigger Property="SortDirection" Value="Descending">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReportDataGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}"/>

        <Style x:Key="ReportDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExpiryText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding PassportExpiryStatus}" Value="expired">
                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding PassportExpiryStatus}" Value="warning">
                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding PassportExpiryStatus}" Value="ok">
                    <Setter Property="Foreground" Value="{DynamicResource SuccessChipForegroundBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== FIXED HEADER ===== -->
        <Grid Grid.Row="0" Margin="20,16,20,12" MaxWidth="1100" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                    Style="{StaticResource HeaderBackButton}"
                    VerticalAlignment="Center">
                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
            </Button>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Style="{StaticResource PageHeaderIconBadge}" Background="{DynamicResource AccentBrush}">
                        <TextBlock Text="&#xE9D2;" Style="{StaticResource PageHeaderIconText}"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource ReportTitle}" Style="{StaticResource PageHeaderTitleText}"/>
                    </StackPanel>
                </StackPanel>
                <Border Style="{StaticResource DialogPreviewSurface}" Padding="12,7" Margin="0,10,0,0" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource MutedForegroundBrush}" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Click="ColumnsButton_Click"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Style="{StaticResource DialogAccentSoftButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource ReportColumnsButton}" FontSize="{DynamicResource FS13}" FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Click="ResetColumnsButton_Click"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Style="{StaticResource DialogAccentSoftButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource ReportColumnsResetButton}" FontSize="{DynamicResource FS13}" FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ShowExportDialogCommand}"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Style="{StaticResource FilledActionButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource ReportConfigExport}" FontSize="{DynamicResource FS13}" FontWeight="Medium"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===== SCROLLABLE CONTENT ===== -->
        <ScrollViewer Grid.Row="1" x:Name="MainScrollViewer" Style="{StaticResource ThinScroll}"
                      PreviewMouseWheel="MainScrollViewer_PreviewMouseWheel">
            <StackPanel Margin="20,0,20,20" MaxWidth="1100" HorizontalAlignment="Center">

                <!-- ===== FILTERS CARD ===== -->
                <Border Style="{StaticResource ReportSurfaceCard}">
                    <Expander IsExpanded="True" Foreground="{DynamicResource ForegroundBrush}">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource SoftIconBadge}" Background="{DynamicResource InfoChipBackgroundBrush}">
                                    <TextBlock Text="&#xE71C;" Style="{StaticResource SoftIconBadgeText}"
                                               Foreground="{DynamicResource InfoChipForegroundBrush}"/>
                                </Border>
                                <TextBlock Text="{DynamicResource ReportFilters}" FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Expander.Header>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource ReportInnerCard}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Style="{StaticResource SectionHeaderIconBadge}" Width="22" Height="22" CornerRadius="6" Margin="0,0,6,0"
                                                Background="{DynamicResource SuccessChipBackgroundBrush}">
                                            <TextBlock Text="&#xE80F;" Style="{StaticResource SoftIconBadgeText}" FontSize="{DynamicResource FS10}"
                                                       Foreground="{DynamicResource SuccessChipForegroundBrush}"/>
                                        </Border>
                                        <TextBlock Text="{DynamicResource ReportEmployers}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <CheckBox Content="{DynamicResource ReportAllEmployers}"
                                              IsChecked="{Binding AllCompaniesSelected}"
                                              Foreground="{DynamicResource ForegroundBrush}"
                                              FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <ItemsControl ItemsSource="{Binding CompanyFilters}" Margin="16,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding CompanyName}"
                                                          IsChecked="{Binding IsChecked}"
                                                          Foreground="{DynamicResource ForegroundBrush}"
                                                          Margin="0,2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource ReportInnerCard}" Margin="16,0,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Style="{StaticResource SectionHeaderIconBadge}" Width="22" Height="22" CornerRadius="6" Margin="0,0,6,0"
                                                Background="{DynamicResource PurpleLightBrush}">
                                            <TextBlock Text="&#xE77B;" Style="{StaticResource SoftIconBadgeText}" FontSize="{DynamicResource FS10}"
                                                       Foreground="{DynamicResource PurpleBrush}"/>
                                        </Border>
                                        <TextBlock Text="{DynamicResource ReportAgencies}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <CheckBox Content="{DynamicResource ReportAllAgencies}"
                                              IsChecked="{Binding AllAgenciesSelected}"
                                              Foreground="{DynamicResource ForegroundBrush}"
                                              FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <ItemsControl ItemsSource="{Binding AgencyFilters}" Margin="16,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding CompanyName}"
                                                          IsChecked="{Binding IsChecked}"
                                                          Foreground="{DynamicResource ForegroundBrush}"
                                                          Margin="0,2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource ReportInnerCard}" Margin="24,0,0,0" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ReportDateFrom}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}" Opacity="0.7" Margin="0,0,0,6"/>
                                    <DatePicker x:Name="DateFromPicker"
                                                SelectedDate="{Binding DateFrom}" Width="150"
                                                Style="{StaticResource ThemedDatePicker}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Style="{StaticResource ReportInnerCard}" Margin="12,0,0,0" VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ReportDateTo}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}" Opacity="0.7" Margin="0,0,0,6"/>
                                    <DatePicker x:Name="DateToPicker"
                                                SelectedDate="{Binding DateTo}" Width="150"
                                                Style="{StaticResource ThemedDatePicker}"/>
                                </StackPanel>
                            </Border>

                            <Button Grid.Column="4" Command="{Binding GenerateReportCommand}" 
                                    Cursor="Hand" VerticalAlignment="Bottom" Margin="16,0,0,0" Height="40"
                                    MinWidth="96" Padding="10,6"
                                    Style="{StaticResource FilledActionButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                               Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{DynamicResource ReportGenerate}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Expander>
                </Border>

                <!-- ===== VIEW TOGGLE ===== -->
                <Border Style="{StaticResource ToolbarSurfaceBorder}"
                        Padding="8"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SwitchToSummaryCommand}" Margin="0,0,6,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToggleBtn}">
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSummaryView}" Value="True">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="8" Padding="20,8"
                                                            Background="{DynamicResource AccentBrush}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource ReportViewSummary}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SwitchToEmployeesCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ToggleBtn}">
                                <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEmployeesView}" Value="True">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="8" Padding="20,8"
                                                            Background="{DynamicResource AccentBrush}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource ReportViewEmployees}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                </Border>

                <Border Style="{StaticResource CompactEmptyStateCard}"
                        Margin="0,0,0,20"
                        Padding="28,24"
                        Visibility="{Binding HasData, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS28}"
                                   Foreground="{DynamicResource TertiaryForegroundBrush}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{DynamicResource ReportTitle}" FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" HorizontalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ╔══════════════════════════════════════════╗ -->
                <!-- ║           SUMMARY VIEW                   ║ -->
                <!-- ╚══════════════════════════════════════════╝ -->
                <StackPanel Visibility="{Binding IsSummaryView, Converter={StaticResource BoolToVis}}">

                    <!-- ===== STATISTICS CARDS ===== -->
                    <WrapPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <!-- Total employees -->
                        <Border Style="{StaticResource ReportMetricCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Style="{StaticResource SectionHeaderIconBadge}" Width="28" Height="28" CornerRadius="6"
                                            Background="{DynamicResource InfoChipBackgroundBrush}">
                                        <TextBlock Text="&#xE77B;" Style="{StaticResource SoftIconBadgeText}" FontSize="{DynamicResource FS13}"
                                                   Foreground="{DynamicResource InfoChipForegroundBrush}"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource ReportTotalEmployees}" FontSize="{DynamicResource FS12}"
                                               Foreground="{DynamicResource ForegroundBrush}" Opacity="0.6"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding TotalEmployees}" FontSize="{DynamicResource FS28}" FontWeight="Bold"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Active -->
                        <Border Style="{StaticResource ReportMetricCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Style="{StaticResource SectionHeaderIconBadge}" Width="28" Height="28" CornerRadius="6"
                                            Background="{DynamicResource SuccessChipBackgroundBrush}">
                                        <TextBlock Text="&#xE73E;" Style="{StaticResource SoftIconBadgeText}" FontSize="{DynamicResource FS13}"
                                                   Foreground="{DynamicResource SuccessChipForegroundBrush}"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource ReportActiveEmployees}" FontSize="{DynamicResource FS12}"
                                               Foreground="{DynamicResource ForegroundBrush}" Opacity="0.6"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ActiveEmployees}" FontSize="{DynamicResource FS28}" FontWeight="Bold"
                                           Foreground="{DynamicResource SuccessChipForegroundBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- New in period -->
                        <Border Style="{StaticResource ReportMetricCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Style="{StaticResource SectionHeaderIconBadge}" Width="28" Height="28" CornerRadius="6"
                                            Background="{DynamicResource InfoChipBackgroundBrush}">
                                        <TextBlock Text="&#xE8FA;" Style="{StaticResource SoftIconBadgeText}" FontSize="{DynamicResource FS13}"
                                                   Foreground="{DynamicResource InfoChipForegroundBrush}"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource ReportNewInPeriod}" FontSize="{DynamicResource FS12}"
                                               Foreground="{DynamicResource ForegroundBrush}" Opacity="0.6"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding NewInPeriod}" FontSize="{DynamicResource FS28}" FontWeight="Bold"
                                           Foreground="{DynamicResource InfoChipForegroundBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Dismissed (archived in period) -->
                        <Border Style="{StaticResource ReportMetricCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Style="{StaticResource SectionHeaderIconBadge}" Width="28" Height="28" CornerRadius="6"
                                            Background="{DynamicResource ErrorChipBackgroundBrush}">
                                        <TextBlock Text="&#xE74D;" Style="{StaticResource SoftIconBadgeText}" FontSize="{DynamicResource FS13}"
                                                   Foreground="{DynamicResource ErrorChipForegroundBrush}"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource ReportDismissedInPeriod}" FontSize="{DynamicResource FS12}"
                                               Foreground="{DynamicResource ForegroundBrush}" Opacity="0.6"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding EndedInPeriod}" FontSize="{DynamicResource FS28}" FontWeight="Bold"
                                           Foreground="{DynamicResource ErrorChipForegroundBrush}"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- ===== FIRM DETAILS TABLE ===== -->
                    <Border Style="{StaticResource ReportSurfaceCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Style="{StaticResource SoftIconBadge}" Background="{DynamicResource SuccessChipBackgroundBrush}">
                                    <TextBlock Text="&#xE80F;" Style="{StaticResource SoftIconBadgeText}"
                                               Foreground="{DynamicResource SuccessChipForegroundBrush}"/>
                                </Border>
                                <TextBlock Text="{DynamicResource ReportByFirm}" FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding FirmDetails}" AutoGenerateColumns="False"
                                      IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      BorderThickness="0" Background="Transparent"
                                      RowBackground="{DynamicResource CardBackgroundBrush}"
                                      AlternatingRowBackground="{DynamicResource WindowBackgroundBrush}"
                                      HorizontalGridLinesBrush="{DynamicResource CardBorderBrush}"
                                      Foreground="{DynamicResource ForegroundBrush}">
                                <DataGrid.RowStyle>
                                    <StaticResource ResourceKey="ReportDataGridRowStyle"/>
                                </DataGrid.RowStyle>
                                <DataGrid.ColumnHeaderStyle>
                                    <StaticResource ResourceKey="ReportDataGridColumnHeaderStyle"/>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <StaticResource ResourceKey="ReportDataGridCellStyle"/>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource ReportColFirm}" Binding="{Binding FirmName}" Width="*"/>
                                    <DataGridTextColumn Header="{DynamicResource ReportColTotal}" Binding="{Binding TotalEmployees}" Width="100"/>
                                    <DataGridTextColumn Header="{DynamicResource ReportColActive}" Binding="{Binding ActiveEmployees}" Width="100"/>
                                    <DataGridTextColumn Header="{DynamicResource ReportColNoPermit}" Binding="{Binding PassportOnlyCount}" Width="120"/>
                                    <DataGridTextColumn Header="{DynamicResource ReportColArchived}" Binding="{Binding ArchivedEmployees}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- ВСЬОГО summary row -->
                            <Border Background="{DynamicResource AccentBrush}" CornerRadius="0,0,8,8" Padding="0" Margin="0,0,0,0"
                                    Opacity="0.9">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource ReportTotal}" FontSize="{DynamicResource FS12}" FontWeight="Bold"
                                               Foreground="White" Padding="12,8" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SummaryTotal}" FontSize="{DynamicResource FS12}" FontWeight="Bold"
                                               Foreground="White" Padding="12,8" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding SummaryActive}" FontSize="{DynamicResource FS12}" FontWeight="Bold"
                                               Foreground="White" Padding="12,8" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding SummaryPassportOnly}" FontSize="{DynamicResource FS12}" FontWeight="Bold"
                                               Foreground="White" Padding="12,8" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{Binding SummaryArchived}" FontSize="{DynamicResource FS12}" FontWeight="Bold"
                                               Foreground="White" Padding="12,8" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ===== AGENCY STATISTICS TABLE ===== -->
                    <Border Style="{StaticResource ReportSurfaceCard}"
                            Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Style="{StaticResource SoftIconBadge}" Background="{DynamicResource PurpleLightBrush}">
                                    <TextBlock Text="&#xE77B;" Style="{StaticResource SoftIconBadgeText}"
                                               Foreground="{DynamicResource PurpleBrush}"/>
                                </Border>
                                <TextBlock Text="{DynamicResource ReportAgencyStats}" FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                <Border Style="{StaticResource CounterChipBorder}" Margin="12,0,0,0"
                                        Background="{DynamicResource PurpleLightBrush}">
                                    <TextBlock Text="{Binding AgencyDetails.Count}" Style="{StaticResource CounterChipText}"
                                               Foreground="{DynamicResource PurpleBrush}"/>
                                </Border>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding AgencyDetails}" AutoGenerateColumns="False"
                                      IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      BorderThickness="0" Background="Transparent"
                                      RowBackground="{DynamicResource CardBackgroundBrush}"
                                      AlternatingRowBackground="{DynamicResource WindowBackgroundBrush}"
                                      HorizontalGridLinesBrush="{DynamicResource CardBorderBrush}"
                                      Foreground="{DynamicResource ForegroundBrush}">
                                <DataGrid.RowStyle>
                                    <StaticResource ResourceKey="ReportDataGridRowStyle"/>
                                </DataGrid.RowStyle>
                                <DataGrid.ColumnHeaderStyle>
                                    <StaticResource ResourceKey="ReportDataGridColumnHeaderStyle"/>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <StaticResource ResourceKey="ReportDataGridCellStyle"/>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource ReportColAgency}" Binding="{Binding AgencyName}" Width="*"/>
                                    <DataGridTextColumn Header="{DynamicResource ReportColFirmCount}" Binding="{Binding FirmCount}" Width="120"/>
                                    <DataGridTextColumn Header="{DynamicResource ReportColTotal}" Binding="{Binding TotalEmployees}" Width="140"/>
                                    <DataGridTextColumn Header="{DynamicResource ReportColActive}" Binding="{Binding ActiveEmployees}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- ===== ARCHIVE CHART (Expander, collapsed) ===== -->
                    <Border Style="{StaticResource ReportSurfaceCard}"
                            Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">
                        <Expander IsExpanded="False" Style="{StaticResource ExpanderHeaderStyle}">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Border Style="{StaticResource SoftIconBadge}" Background="{DynamicResource WarningChipBackgroundBrush}">
                                        <TextBlock Text="&#xE9D2;" Style="{StaticResource SoftIconBadgeText}"
                                                   Foreground="{DynamicResource WarningChipForegroundBrush}"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource ReportArchiveChart}" FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                            </Expander.Header>
                            <oxy:PlotView Model="{Binding ArchiveChartModel}" Height="280"
                                          Background="Transparent" Margin="0,12,0,0"/>
                        </Expander>
                    </Border>

                    <!-- ===== ARCHIVE HISTORY (Expander, collapsed) ===== -->
                    <Border Style="{StaticResource ReportSurfaceCard}"
                            Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">
                        <Expander IsExpanded="False" Style="{StaticResource ExpanderHeaderStyle}">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <Border Style="{StaticResource SoftIconBadge}" Background="{DynamicResource PurpleLightBrush}">
                                        <TextBlock Text="&#xE81C;" Style="{StaticResource SoftIconBadgeText}"
                                                   Foreground="{DynamicResource PurpleBrush}"/>
                                    </Border>
                                    <TextBlock Text="{DynamicResource ReportArchiveLog}" FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <Border Style="{StaticResource CounterChipBorder}" Margin="12,0,0,0"
                                            Background="{DynamicResource PurpleLightBrush}">
                                        <TextBlock Text="{Binding ArchiveHistory.Count}" Style="{StaticResource CounterChipText}"
                                                   Foreground="{DynamicResource PurpleBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Expander.Header>

                            <DataGrid ItemsSource="{Binding ArchiveHistory}" AutoGenerateColumns="False"
                                      IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      BorderThickness="0" Background="Transparent" MaxHeight="300"
                                      RowBackground="{DynamicResource CardBackgroundBrush}"
                                      AlternatingRowBackground="{DynamicResource WindowBackgroundBrush}"
                                      HorizontalGridLinesBrush="{DynamicResource CardBorderBrush}"
                                      Foreground="{DynamicResource ForegroundBrush}" Margin="0,12,0,0">
                                <DataGrid.RowStyle>
                                    <StaticResource ResourceKey="ReportDataGridRowStyle"/>
                                </DataGrid.RowStyle>
                                <DataGrid.ColumnHeaderStyle>
                                    <StaticResource ResourceKey="ReportDataGridColumnHeaderStyle"/>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.CellStyle>
                                    <StaticResource ResourceKey="ReportDataGridCellStyle"/>
                                </DataGrid.CellStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource ReportColEmployee}" Binding="{Binding EmployeeName}" Width="*"/>
                                    <DataGridTextColumn Header="{DynamicResource ReportColFirm}" Binding="{Binding FirmName}" Width="180"/>
                                    <DataGridTextColumn Header="{DynamicResource ReportColAction}" Binding="{Binding Action}" Width="100"/>
                                    <DataGridTextColumn Header="{DynamicResource ReportColDate}" Binding="{Binding Date}" Width="110"/>
                                    <DataGridTextColumn Header="{DynamicResource ReportColTimestamp}" Binding="{Binding Timestamp}" Width="160"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>
                    </Border>

                </StackPanel>

                <!-- ╔══════════════════════════════════════════╗ -->
                <!-- ║          EMPLOYEES VIEW                  ║ -->
                <!-- ╚══════════════════════════════════════════╝ -->
                <StackPanel Visibility="{Binding IsEmployeesView, Converter={StaticResource BoolToVis}}">

                    <!-- Search bar -->
                    <Border Style="{StaticResource ToolbarSurfaceBorder}"
                            Padding="{StaticResource ToolbarPadding}" Margin="{StaticResource SectionGapLargeMargin}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource ForegroundBrush}" Opacity="0.4"
                                       VerticalAlignment="Center" Margin="8,0,12,0"/>
                            <TextBox Grid.Column="1" Text="{Binding EmployeeSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="{DynamicResource FS14}" BorderThickness="0" Background="Transparent"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}"
                                       Opacity="0.5" VerticalAlignment="Center" Margin="12,0,8,0">
                                <Run Text="{Binding EmployeeGroups.Count, Mode=OneWay}"/>
                                <Run Text=" "/>
                                <Run Text="{DynamicResource ReportFirmsCount}"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Employee groups by firm -->
                    <ItemsControl ItemsSource="{Binding EmployeeGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ReportSurfaceCard}" Padding="{StaticResource CardInnerPadding}" Margin="{StaticResource SectionGapMargin}">
                                    <Expander IsExpanded="True">
                                        <Expander.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Style="{StaticResource SectionHeaderIconBadge}" Width="28" Height="28"
                                                        Background="{DynamicResource SuccessChipBackgroundBrush}">
                                                    <TextBlock Text="&#xE80F;" Style="{StaticResource SoftIconBadgeText}" FontSize="{DynamicResource FS12}"
                                                               Foreground="{DynamicResource SuccessChipForegroundBrush}"/>
                                                </Border>
                                                <TextBlock FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ForegroundBrush}"
                                                           VerticalAlignment="Center" Margin="10,0,0,0">
                                                    <Run Text="{Binding FirmName, Mode=OneWay}"/>
                                                </TextBlock>
                                                <Border Style="{StaticResource CounterChipBorder}" Margin="10,0,0,0"
                                                        Background="{DynamicResource InfoChipBackgroundBrush}">
                                                    <TextBlock Style="{StaticResource CounterChipText}" Foreground="{DynamicResource InfoChipForegroundBrush}">
                                                        <Run Text="{Binding EmployeeCount, Mode=OneWay}"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{DynamicResource ReportEmpCount}"/>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </Expander.Header>

                                        <DataGrid ItemsSource="{Binding Employees}" AutoGenerateColumns="False"
                                                  IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                                                  CanUserReorderColumns="True" CanUserResizeColumns="True"
                                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                  BorderThickness="0" Background="Transparent"
                                                  RowBackground="{DynamicResource CardBackgroundBrush}"
                                                  AlternatingRowBackground="{DynamicResource WindowBackgroundBrush}"
                                                  HorizontalGridLinesBrush="{DynamicResource CardBorderBrush}"
                                                  Foreground="{DynamicResource ForegroundBrush}" Margin="0,12,0,0"

                                                  Loaded="EmployeeGrid_Loaded"
                                                  Unloaded="EmployeeGrid_Unloaded"
                                                  ColumnReordered="EmployeeGrid_ColumnReordered"
                                                  Tag="EmployeeReportGrid">
                                            <DataGrid.ColumnHeaderStyle>
                                                <StaticResource ResourceKey="ReportDataGridColumnHeaderStyle"/>
                                            </DataGrid.ColumnHeaderStyle>
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow" BasedOn="{StaticResource ModernDataGridRow}">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <EventSetter Event="MouseDoubleClick" Handler="EmployeeRow_DoubleClick"/>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.CellStyle>
                                                <Style TargetType="DataGridCell">
                                                    <Setter Property="Padding" Value="12,8"/>
                                                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="DataGridCell">
                                                                <Border Padding="{TemplateBinding Padding}"
                                                                        Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsArchived}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource ErrorChipBackgroundBrush}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource ErrorChipForegroundBrush}"/>
                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.CellStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="{DynamicResource ReportColName}" Binding="{Binding FullName}" Width="200" SortMemberPath="FullName"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColType}" Binding="{Binding EmployeeType}" Width="180" SortMemberPath="EmployeeType"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColDocumentType}" Binding="{Binding DocumentType}" Width="130" SortMemberPath="DocumentType"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColPassportNumber}" Binding="{Binding PassportNumber}" Width="170" SortMemberPath="PassportNumber"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColVisaNumber}" Binding="{Binding VisaNumber}" Width="170" SortMemberPath="VisaNumber"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColWorkAddress}" Binding="{Binding WorkAddress}" Width="220" SortMemberPath="WorkAddress"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColHighestEducation}" Binding="{Binding HighestEducation}" Width="220" SortMemberPath="HighestEducation"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColBirthDate}" Binding="{Binding BirthDate}" Width="100" SortMemberPath="BirthDate"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColGender}" Binding="{Binding Gender}" Width="90" SortMemberPath="Gender"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColAddressCz}" Binding="{Binding AddressCz}" Width="220" SortMemberPath="AddressCz"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColAddressAbroad}" Binding="{Binding AddressAbroad}" Width="220" SortMemberPath="AddressAbroad"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColPassportIssuedBy}" Binding="{Binding PassportIssuedBy}" Width="180" SortMemberPath="PassportIssuedBy"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColPositionCode}" Binding="{Binding PositionCode}" Width="110" SortMemberPath="PositionCode"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColAgency}" Binding="{Binding Agency}" Width="150" SortMemberPath="Agency"/>
                                                <DataGridTemplateColumn Header="{DynamicResource ReportColPassportExp}" Width="100" SortMemberPath="PassportExpiry">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding PassportExpiry}" Padding="2,0" VerticalAlignment="Center" FontSize="{DynamicResource FS12}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding PassportExpiryStatus}" Value="expired">
                                                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding PassportExpiryStatus}" Value="warning">
                                                                                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding PassportExpiryStatus}" Value="ok">
                                                                                <Setter Property="Foreground" Value="{DynamicResource SuccessChipForegroundBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="{DynamicResource ReportColVisaExp}" Width="100" SortMemberPath="VisaExpiry">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding VisaExpiry}" Padding="2,0" VerticalAlignment="Center" FontSize="{DynamicResource FS12}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding VisaExpiryStatus}" Value="expired">
                                                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding VisaExpiryStatus}" Value="warning">
                                                                                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding VisaExpiryStatus}" Value="ok">
                                                                                <Setter Property="Foreground" Value="{DynamicResource SuccessChipForegroundBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="{DynamicResource ReportColInsExp}" Width="100" SortMemberPath="InsuranceExpiry">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding InsuranceExpiry}" Padding="2,0" VerticalAlignment="Center" FontSize="{DynamicResource FS12}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding InsuranceExpiryStatus}" Value="expired">
                                                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding InsuranceExpiryStatus}" Value="warning">
                                                                                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding InsuranceExpiryStatus}" Value="ok">
                                                                                <Setter Property="Foreground" Value="{DynamicResource SuccessChipForegroundBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="{DynamicResource ReportColStartDate}" Binding="{Binding StartDate}" Width="90" SortMemberPath="StartDate"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColEndDate}" Binding="{Binding EndDate}" Width="90" SortMemberPath="EndDate"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColPhone}" Binding="{Binding Phone}" Width="110" SortMemberPath="Phone"/>
                                                <DataGridTextColumn Header="{DynamicResource EmployeeBankAccountNumber}" Binding="{Binding BankAccountNumber}" Width="150" SortMemberPath="BankAccountNumber"/>
                                                <DataGridTextColumn Header="{DynamicResource EmployeeBankName}" Binding="{Binding BankName}" Width="150" SortMemberPath="BankName"/>
                                                <DataGridTextColumn Header="{DynamicResource ReportColPosition}" Binding="{Binding Position}" Width="110" SortMemberPath="Position"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Expander>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>

                <!-- Status bar -->
                <TextBlock Text="{Binding StatusMessage}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource ForegroundBrush}"
                           Opacity="0.4" HorizontalAlignment="Right" Margin="0,0,0,8"/>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="0" Grid.RowSpan="2" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}"/>
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="22,18"
                    CornerRadius="14"
                    Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <ProgressBar Width="84" Height="6" IsIndeterminate="True"
                                 Foreground="{DynamicResource AccentBrush}"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="{DynamicResource FS13}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="320"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== EMPLOYEE DETAILS OVERLAY ===== -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Visibility="{Binding IsEmployeeDetailsOpen, Converter={StaticResource BoolToVis}}"
              Style="{StaticResource OverlayFadeInGrid}">
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding EmployeeDetailsVm.CloseCommand}"/>
                </Border.InputBindings>
            </Border>
            <ContentControl Content="{Binding EmployeeDetailsVm}" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Style="{StaticResource DialogEntranceContentControl}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:EmployeeDetailsViewModel}">
                        <views:EmployeeDetailsView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>

        <!-- ===== EXPORT CONFIGURATION DIALOG OVERLAY ===== -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Visibility="{Binding IsExportDialogOpen, Converter={StaticResource BoolToVis}}"
              Style="{StaticResource OverlayFadeInGrid}">
            <Border Background="{DynamicResource OverlayBrush}" />
            <Border Style="{StaticResource AnimatedDialogSectionCard}"
                    Padding="32,28" Width="420"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="{StaticResource SectionGapLargeMargin}">
                        <Border Background="{DynamicResource InfoChipBackgroundBrush}" CornerRadius="8" Width="36" Height="36">
                            <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource InfoChipForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource ReportExportTitle}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <TextBlock Text="{DynamicResource ReportExportDesc}" FontSize="{DynamicResource FS13}"
                               Foreground="{DynamicResource ForegroundBrush}" Opacity="0.7"
                               TextWrapping="Wrap" Margin="{StaticResource SectionGapMargin}"/>

                    <!-- Format selector -->
                    <Border Style="{StaticResource DialogPreviewSurface}" Padding="16,14" Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource ReportExportFormat}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <RadioButton Content="Excel (.xlsx)" IsChecked="{Binding ExportAsXlsx}"
                                         Foreground="{DynamicResource ForegroundBrush}" FontSize="{DynamicResource FS13}"
                                         VerticalAlignment="Center" Margin="0,0,20,0" GroupName="ExportFormat"/>
                            <RadioButton Content="PDF (.pdf)" IsChecked="{Binding ExportAsPdf}"
                                         Foreground="{DynamicResource ForegroundBrush}" FontSize="{DynamicResource FS13}"
                                         VerticalAlignment="Center" GroupName="ExportFormat"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DialogPreviewSurface}" Padding="16,14" Margin="0,0,0,24">
                        <ItemsControl ItemsSource="{Binding ExportSheets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" Margin="0,6"
                                              Foreground="{DynamicResource ForegroundBrush}" FontSize="{DynamicResource FS14}">
                                        <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap"/>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelExportCommand}" Cursor="Hand" Margin="0,0,10,0"
                                Style="{StaticResource DialogAccentSoftButton}"
                                Content="{DynamicResource BtnCancel}"/>

                        <Button Command="{Binding ConfirmExportCommand}" Cursor="Hand"
                                Style="{StaticResource FilledActionButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource ReportExportBtn}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                           Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
