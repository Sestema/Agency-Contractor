<UserControl x:Class="Win11DesktopApp.Invoices.Views.InvoicesTrashSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1100">
    <UserControl.Resources>
        <Style x:Key="InvoicesTrashSurfaceCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect" Value="{DynamicResource CardShadow}"/>
        </Style>

        <Style x:Key="InvoicesTrashGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F8F7"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
        </Style>

        <Style x:Key="InvoicesTrashGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InvoicesTrashGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinHeight" Value="42"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0D26A69A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InvoicesTrashActionButton" TargetType="Button" BasedOn="{StaticResource HeaderGhostButton}">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="MinWidth" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,14"
                CornerRadius="20"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFF7FBFA" Offset="0"/>
                    <GradientStop Color="#FFF1F8F6" Offset="0.6"/>
                    <GradientStop Color="#FFEAF4F1" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Background="#1426A69A"
                            BorderBrush="#1F26A69A"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="10,5"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Foreground="{DynamicResource AccentBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource InvoicesSectionTrash}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{DynamicResource InvoicesSectionTrash}" FontSize="{DynamicResource FS28}" Style="{StaticResource PageHeaderTitleText}" Margin="0,12,0,0"/>
                    <TextBlock Text="{DynamicResource InvoicesTrashSubtitle}" FontSize="{DynamicResource FS13}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource FilledActionButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" Margin="0,0,6,0"/>
                            <TextBlock Text="{DynamicResource NewsRefresh}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Border Visibility="{Binding HasItems, Converter={StaticResource BoolToVis}}"
                    Style="{StaticResource InvoicesTrashSurfaceCard}"
                    Padding="0">
                <DataGrid ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          Background="Transparent"
                          RowHeaderWidth="0"
                          RowStyle="{StaticResource InvoicesTrashGridRowStyle}"
                          AlternatingRowBackground="{DynamicResource WindowBackgroundBrush}">
                    <DataGrid.ColumnHeaderStyle>
                        <StaticResource ResourceKey="InvoicesTrashGridHeaderStyle"/>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <StaticResource ResourceKey="InvoicesTrashGridCellStyle"/>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource InvoicesColumnNumber}" Binding="{Binding Number}" Width="150"/>
                        <DataGridTextColumn Header="{DynamicResource InvoicesColumnSupplier}" Binding="{Binding SupplierName}" Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource InvoicesColumnCustomer}" Binding="{Binding CustomerName}" Width="*"/>
                        <DataGridTextColumn Header="{DynamicResource InvoicesColumnAmount}" Binding="{Binding TotalLabel}" Width="130"/>
                        <DataGridTextColumn Header="{DynamicResource InvoicesTrashDeletedAt}" Binding="{Binding DeletedAtUtc, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="160"/>
                        <DataGridTemplateColumn Header="{DynamicResource InvoicesColumnActions}" Width="220">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <WrapPanel>
                                        <Button Command="{Binding DataContext.RestoreCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource InvoicesTrashActionButton}">
                                            <TextBlock Text="{DynamicResource InvoicesTrashRestore}" FontSize="{DynamicResource FS11}" FontWeight="SemiBold"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.DeleteForeverCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource InvoicesTrashActionButton}">
                                            <TextBlock Text="{DynamicResource InvoicesActionDeleteForever}" FontSize="{DynamicResource FS11}" FontWeight="SemiBold"/>
                                        </Button>
                                    </WrapPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Visibility="{Binding HasItems, Converter={StaticResource InverseBoolToVis}}"
                    Style="{StaticResource InvoicesTrashSurfaceCard}"
                    Padding="32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="460">
                <StackPanel>
                    <TextBlock Text="{DynamicResource InvoicesTrashEmptyTitle}" FontSize="{DynamicResource FS20}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource InvoicesTrashEmptyDescription}"
                               FontSize="{DynamicResource FS13}"
                               TextAlignment="Center"
                               Foreground="{DynamicResource SecondaryForegroundBrush}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
