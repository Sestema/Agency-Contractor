<Window x:Class="Win11DesktopApp.Views.ConfirmPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ConfirmPasswordTitle}"
        Width="460"
        MinWidth="420"
        MaxWidth="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Border Style="{StaticResource PageHeaderIconBadge}">
                <TextBlock Text="&#xE72E;" Style="{StaticResource PageHeaderIconText}"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource ConfirmPasswordTitle}"
                           FontSize="{DynamicResource FS18}"
                           Style="{StaticResource PageHeaderTitleText}"/>
                <TextBlock Text="{DynamicResource ConfirmPasswordMessage}"
                           FontSize="{DynamicResource FS11}"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource DialogSectionCard}">
            <StackPanel>
                <TextBlock Text="{DynamicResource ProfilePasswordLabel}"
                           FontSize="{DynamicResource FS12}"
                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                           Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             Padding="10,7"
                             FontSize="{DynamicResource FS13}"
                             VerticalContentAlignment="Center"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{DynamicResource BtnCancel}"
                    Click="Cancel_Click"
                    Margin="0,0,8,0"
                    Padding="16,8"
                    FontSize="{DynamicResource FS12}"
                    Style="{StaticResource HeaderGhostButton}"/>
            <Button Content="{DynamicResource ConfirmPasswordButton}"
                    Click="Confirm_Click"
                    Padding="20,8"
                    FontSize="{DynamicResource FS12}"
                    FontWeight="SemiBold"
                    Style="{StaticResource FilledActionButton}"/>
        </StackPanel>
    </Grid>
</Window>
