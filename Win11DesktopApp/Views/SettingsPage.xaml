                                                                        Command="{Binding DataContext.RemoveTelegramAuthorizedUserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding TelegramUserId}"
                                                                        Padding="10,5"
                                                                        Style="{StaticResource HeaderGhostButton}">
                                                                    <TextBlock Text="{DynamicResource SettingsTelegramUnlink}"
                                                                               FontSize="{DynamicResource FS11}"
                                                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Web Panel Section -->
            <Border Grid.Row="12" Style="{StaticResource SettingsSectionCard}" Padding="24,22"
                    Visibility="{Binding IsServerSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource InfoLightBrush}">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                           Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource SettingsWebPanelTitle}" FontSize="{DynamicResource FS17}"
                                           FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{DynamicResource SettingsWebPanelSubtitle}"
                                           FontSize="{DynamicResource FS11}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.55"/>
                            </StackPanel>
                        </StackPanel>

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding WebPanelEnabled}"
                                  VerticalAlignment="Center"
                                  Content="{DynamicResource SettingsEnable}"/>
                    </Grid>

                    <Border Style="{StaticResource DialogPreviewSurface}" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="{Binding WebPanelStatus}"
                                       FontSize="{DynamicResource FS12}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Command="{Binding OpenWebPanelUrlCommand}"
                                        HorizontalAlignment="Left"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        ToolTip="{DynamicResource SettingsOpenInBrowser}">
                                    <TextBlock Text="{Binding WebPanelUrl}"
                                               FontSize="{DynamicResource FS12}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               TextDecorations="Underline"/>
                                </Button>

                                <Button Grid.Column="1"
                                        Command="{Binding CopyWebPanelUrlCommand}"
                                        Padding="10,5"
                                        Margin="12,0,0,0"
                                        Cursor="Hand"
                                        Style="{StaticResource DialogAccentSoftButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,5,0"/>
                                        <TextBlock Text="{DynamicResource SettingsCopy}" FontSize="{DynamicResource FS12}"/>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="2"
                                        Command="{Binding OpenWebPanelUrlCommand}"
                                        Padding="10,5"
                                        Margin="8,0,0,0"
                                        Cursor="Hand"
                                        Style="{StaticResource DialogAccentSoftButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,5,0"/>
                                        <TextBlock Text="{DynamicResource SettingsOpen}" FontSize="{DynamicResource FS12}"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <Border Margin="0,10,0,0"
                                    Padding="12,10"
                                    CornerRadius="12"
                                    Background="{DynamicResource AccentLightBrush}"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="1"
                                    Opacity="0.96">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource SettingsWebPanelLanTitle}"
                                                   FontSize="{DynamicResource FS12}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="{Binding WebPanelLanUrl}"
                                                   Margin="0,3,0,0"
                                                   FontSize="{DynamicResource FS12}"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock Text="{DynamicResource SettingsWebPanelLanDesc}"
                                                   Margin="0,4,0,0"
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding CopyWebPanelLanUrlCommand}"
                                            Padding="12,7"
                                            Margin="12,0,0,0"
                                            Cursor="Hand"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource DialogAccentSoftButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS11}" Margin="0,0,5,0"/>
                                            <TextBlock Text="{DynamicResource SettingsWebPanelCopyWifi}" FontSize="{DynamicResource FS12}"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding WebPanelActionStatus}"
                                       Margin="0,6,0,0"
                                       FontSize="{DynamicResource FS11}"
                                       Foreground="{DynamicResource SuccessChipForegroundBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{DynamicResource SettingsWebPanelLocalhostHint}"
                                       Margin="0,8,0,0"
                                       FontSize="{DynamicResource FS11}"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       TextWrapping="Wrap"/>

                            <Border Style="{StaticResource DialogPreviewSurface}"
                                    Margin="0,12,0,0"
                                    Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource SettingsSyncBetweenPcTitle}"
                                                   FontSize="{DynamicResource FS12}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="{Binding SyncStatusSummary}"
                                                   Margin="0,3,0,0"
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SyncEventsFolderPath}"
                                                   Margin="0,3,0,0"
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding RefreshSyncStatusCommand}"
                                            Padding="12,7"
                                            Margin="12,0,0,0"
                                            Cursor="Hand"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource DialogAccentSoftButton}">
                                        <TextBlock Text="{DynamicResource NewsRefresh}" FontSize="{DynamicResource FS12}"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <TextBlock Text="{DynamicResource SettingsPortLabel}"
                                           VerticalAlignment="Center"
                                           FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
