                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Background="{DynamicResource AccentLightBrush}" CornerRadius="8" Width="36" Height="36" VerticalAlignment="Center">
                            <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource AIProviderTitle}" FontSize="{DynamicResource FS16}"
                                       FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="Google Gemini API" FontSize="{DynamicResource FS11}"
                                       Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Gemini status indicator -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#9E9E9E"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGeminiConfigured}" Value="True">
                                            <Setter Property="Fill" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="{DynamicResource FS12}" FontWeight="SemiBold" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{DynamicResource AIStatusNotLoaded}"/>
                                    <Setter Property="Foreground" Value="#9E9E9E"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGeminiConfigured}" Value="True">
                                            <Setter Property="Text" Value="{DynamicResource AIStatusReady}"/>
                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Gemini API Key -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="{DynamicResource AIGeminiApiKey}" FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MaxWidth="300"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding GeminiApiKey, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="{DynamicResource FS12}" Padding="8,6"
                                     Background="{DynamicResource ContentBackgroundBrush}"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"/>
                            <Button Grid.Column="1" Command="{Binding TestGeminiCommand}" Margin="8,0,0,0"
                                    Padding="12,6" Cursor="Hand" BorderThickness="0"
                                    Background="#4CAF50" Foreground="White" FontSize="{DynamicResource FS11}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="{DynamicResource AIGeminiTest}" Foreground="White" FontSize="{DynamicResource FS11}"/>
                            </Button>
                            <Button Grid.Column="2" Command="{Binding OpenGeminiSiteCommand}" Margin="8,0,0,0"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <TextBlock Text="{DynamicResource AIGeminiGetKey}" FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource AccentBrush}" TextDecorations="Underline"/>
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding GeminiTestResult}" FontSize="{DynamicResource FS11}"
                                   Foreground="{DynamicResource SuccessBrush}" Margin="0,4,0,0"
                                   Visibility="{Binding GeminiTestResult, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- Gemini Model Selection -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="{DynamicResource AIGeminiModel}" FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox Style="{StaticResource ThemedComboBox}" Width="200"
                                  ItemsSource="{Binding GeminiModels}" SelectedItem="{Binding GeminiModel}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- App Version Card -->
            <Border Grid.Row="11" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="24,20" Margin="0,0,0,16"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <Border Background="{DynamicResource PurpleLightBrush}" CornerRadius="8" Width="36" Height="36"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                   Foreground="{DynamicResource PurpleBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource SettingsAppVersion}" 
                                   FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Border Background="{DynamicResource AccentBrush}" CornerRadius="10" Padding="10,3">
                                <TextBlock Text="{Binding AppVersion}" 
                                           FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                            <TextBlock Text="Agency Contractor" 
                                       FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.4"
                                       VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Copyright Card -->
            <Border Grid.Row="12" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="24,20" Margin="0,0,0,16"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="36" Height="36" CornerRadius="8" Background="#E8EAF6"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="#3949AB" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource SettingsCopyrightTitle}" Margin="14,0,0,0"
                                   FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource SettingsCopyrightText}"
                               FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,4,0,2"/>
                    <TextBlock Text="{DynamicResource SettingsCopyrightDesc}"
                               FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- License Status Card -->
            <Border Grid.Row="13" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="24,20" Margin="0,0,0,16"
                    Effect="{DynamicResource CardShadow}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="36" Height="36" CornerRadius="8" Background="#E8F5E9"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="#388E3C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource SettingsLicenseTitle}" Margin="14,0,0,0"
                                   FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding LicenseStatus}"
                               FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                               Foreground="{DynamicResource ForegroundBrush}" Margin="0,4,0,2"/>
                    <TextBlock FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,2,0,0">
                        <Run Text="ID:"/>
                        <Run Text="{Binding MachineId, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>

    <!-- ===== COMPANY VISIBILITY OVERLAY ===== -->
    <Grid Grid.RowSpan="2" Visibility="{Binding IsCompanyVisibilityOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border Background="#80000000">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding CloseCompanyVisibilityCommand}"/>
            </Border.InputBindings>
        </Border>
        <Border Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                CornerRadius="16" Padding="28,24" Width="480" MaxHeight="600"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Effect="{DynamicResource CardShadow}">
            <StackPanel>
                <!-- Header -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#E3F2FD" CornerRadius="8" Width="36" Height="36" VerticalAlignment="Center">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="#1565C0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{DynamicResource SettingsFirmsVisibilityTitle}"
                                   FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding CloseCompanyVisibilityCommand}" Cursor="Hand"
                            Background="Transparent" BorderThickness="0" VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="6">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                               Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBorderBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Hint -->
                <TextBlock Text="{DynamicResource SettingsFirmsVisibilityHint}"
                           FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}"
                           Opacity="0.6" TextWrapping="Wrap" Margin="0,0,0,16"/>

                <!-- Company list -->
                <ScrollViewer MaxHeight="360" Style="{StaticResource ThinScroll}">
                    <ItemsControl ItemsSource="{Binding CompanyVisibilityItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Checkbox -->
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsVisible}"
                                                  IsEnabled="{Binding HasActiveEmployees, Converter={StaticResource InverseBoolConverter}}"
                                                  VerticalAlignment="Center" Margin="0,0,12,0"/>

                                        <!-- Company name -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{DynamicResource FS14}" FontWeight="Medium"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                            <!-- Warning if has active employees -->
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding HasActiveEmployees, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                           Foreground="#F57F17" VerticalAlignment="Center" Margin="0,2,4,0"/>
                                                <TextBlock FontSize="{DynamicResource FS11}" Foreground="#F57F17" Margin="0,2,0,0">
                                                    <Run Text="{DynamicResource SettingsFirmsHasEmployees}"/>
                                                    <Run Text="{Binding ActiveEmployeeCount, Mode=OneWay}"/>
                                                    <Run Text="{DynamicResource SettingsFirmsEmployeesCount}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Active count badge -->
                                        <Border Grid.Column="2" Background="#E3F2FD" CornerRadius="10"
                                                Padding="10,3" VerticalAlignment="Center"
                                                Visibility="{Binding HasActiveEmployees, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding ActiveEmployeeCount, Mode=OneWay}"
                                                       FontSize="{DynamicResource FS12}" FontWeight="Bold"
                                                       Foreground="#1565C0"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- OK button -->
                <Button Command="{Binding CloseCompanyVisibilityCommand}" Cursor="Hand"
                        HorizontalAlignment="Center" Margin="0,16,0,0" MinWidth="120">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="8" Padding="32,12">
                                <TextBlock Text="OK"
                                           FontSize="{DynamicResource FS14}" FontWeight="SemiBold" Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>

    </Grid>
</UserControl>
