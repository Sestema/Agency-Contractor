<UserControl x:Class="Win11DesktopApp.Views.EmployeeDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:InverseBooleanConverter x:Key="InverseBool"/>
        <conv:StepEqualsToVisibilityConverter x:Key="StepVis"/>
        <conv:StatusColorConverter x:Key="StatusColor"/>
        <conv:StatusBackgroundConverter x:Key="StatusBg"/>

        <!-- Base text style -->
        <Style x:Key="BaseText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Field input -->
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Document card button -->
        <Style x:Key="DocCardBtn" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        </Style>

        <!-- Tab button base -->
        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main Card -->
        <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" Width="1020" Height="720">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.2"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="*"/>     <!-- Content -->
                </Grid.RowDefinitions>

                <!-- ===== HEADER ===== -->
                <Border Grid.Row="0" Padding="20,16,20,12" 
                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="18" 
                                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FullName}" FontSize="20" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Command="{Binding CloseCommand}"
                                Width="32" Height="32" Background="Transparent" BorderThickness="0"
                                Foreground="#999" Cursor="Hand" ToolTip="{DynamicResource DetTooltipClose}">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ===== BODY ===== -->
                <Grid Grid.Row="1" Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ===== LEFT SIDEBAR ===== -->
                    <Border Grid.Column="0" Padding="20,16" Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,1,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Photo -->
                                <Border Height="220" CornerRadius="8" Background="#F0F4F8" Margin="0,0,0,14"
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Image Source="{Binding PhotoFilePath}" Stretch="Uniform" 
                                               Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"/>
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    Visibility="{Binding HasPhoto, Converter={StaticResource InverseBoolToVis}}">
                                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="28" 
                                                       Foreground="#CCC" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource DetNoPhoto}" FontSize="11" Foreground="#AAA" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Name -->
                                <TextBlock Text="{Binding FullName}" FontSize="16" FontWeight="Bold" 
                                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,4"/>

                                <!-- Position -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="&#xE821;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                               Foreground="#999" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Data.PositionTag}" FontSize="12" Foreground="#666"/>
                                </StackPanel>

                                <!-- Contract type -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                               Foreground="#999" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Data.ContractType}" FontSize="12" Foreground="#666"/>
                                </StackPanel>

                                <!-- Separator -->
                                <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,10"/>

                                <!-- Contact info -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Data.Phone}" FontSize="12" Foreground="{DynamicResource ForegroundBrush}"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Data.StartDate}" FontSize="12" Foreground="{DynamicResource ForegroundBrush}"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Data.ContractSignDate}" FontSize="12" Foreground="{DynamicResource ForegroundBrush}"/>
                                </StackPanel>

                                <!-- Separator -->
                                <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,10"/>

                                <!-- Generate button -->
                                <Button Command="{Binding OpenGenerateDialogCommand}" Padding="12,8" Cursor="Hand"
                                        Background="{DynamicResource AccentBrush}" Foreground="White" 
                                        BorderThickness="0" FontWeight="SemiBold" HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource DetBtnGenerate}" FontSize="12"/>
                                    </StackPanel>
                                </Button>

                                <!-- Open folder button -->
                                <Button Command="{Binding OpenFolderCommand}" Padding="12,8" Cursor="Hand" Margin="0,8,0,0"
                                        Background="{DynamicResource ContentBackgroundBrush}" 
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                        Foreground="{DynamicResource ForegroundBrush}" HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource DetBtnOpenFolder}" FontSize="12"/>
                                    </StackPanel>
                                </Button>

                                <!-- Archive button -->
                                <Button Command="{Binding ArchiveEmployeeCommand}" Padding="12,8" Cursor="Hand" Margin="0,8,0,0"
                                        Background="#FFEBEE" 
                                        BorderBrush="#E57373" BorderThickness="1"
                                        Foreground="#C62828" HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource DetBtnArchive}" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>

                                <!-- Status -->
                                <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,10"/>
                                <TextBlock Text="{DynamicResource DetLabelStatus}" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                                <Border CornerRadius="6" Padding="8,4" 
                                        Background="{Binding Data.Status, Converter={StaticResource StatusBg}}">
                                    <TextBlock Text="{Binding Data.Status, FallbackValue='—'}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{Binding Data.Status, Converter={StaticResource StatusColor}}"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- ===== RIGHT CONTENT ===== -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Tabs -->
                            <RowDefinition Height="*"/>     <!-- Tab content -->
                        </Grid.RowDefinitions>

                        <!-- Tab Buttons -->
                        <Border Grid.Row="0" Padding="20,0,20,0"
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding ShowDocumentsCommand}" Margin="0,0,4,0">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource DetTabDocs}" FontSize="13"/>
                                        </StackPanel>
                                    </Button.Content>
                                    <!-- Active state: accent color underline -->
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TabBtn}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TabIndex}" Value="0">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Command="{Binding ShowProfileCommand}" Margin="0,0,4,0">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE779;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource DetTabProfile}" FontSize="13"/>
                                        </StackPanel>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TabBtn}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TabIndex}" Value="1">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button Command="{Binding ShowHistoryCommand}" Margin="0,0,4,0">
                                    <Button.Content>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource DetTabHistory}" FontSize="13"/>
                                        </StackPanel>
                                    </Button.Content>
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TabBtn}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TabIndex}" Value="2">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Tab Content -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
                            <Grid>
                                <!-- ========== TAB 0: DOCUMENTS ========== -->
                                <StackPanel Visibility="{Binding TabIndex, Converter={StaticResource StepVis}, ConverterParameter=0}">
                                    <TextBlock Text="{DynamicResource DetDocsTitle}" Style="{StaticResource SectionHeader}" FontSize="16" Margin="0,0,0,14"/>
                                    <WrapPanel>
                                        <!-- Passport -->
                                        <Border Width="300" Margin="0,0,12,12" Padding="14" 
                                                Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource DetDocPassport}" FontWeight="SemiBold" FontSize="14" 
                                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                                </StackPanel>
                                                <Border Height="120" CornerRadius="4" Background="#F5F5F5" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Image Source="{Binding PassportFilePath}" Stretch="Uniform"
                                                               Visibility="{Binding PassportIsPdf, Converter={StaticResource InverseBoolToVis}}"/>
                                                        <TextBlock Text="PDF" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                   FontSize="16" FontWeight="Bold" Foreground="#999"
                                                                   Visibility="{Binding PassportIsPdf, Converter={StaticResource BoolToVis}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding ReplacePassportCommand}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnReplace}" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding OpenPassportCommand}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnOpenFile}" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Visa -->
                                        <Border Width="300" Margin="0,0,12,12" Padding="14" 
                                                Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource DetDocVisa}" FontWeight="SemiBold" FontSize="14" 
                                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                                </StackPanel>
                                                <Border Height="120" CornerRadius="4" Background="#F5F5F5" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Image Source="{Binding VisaFilePath}" Stretch="Uniform"
                                                               Visibility="{Binding VisaIsPdf, Converter={StaticResource InverseBoolToVis}}"/>
                                                        <TextBlock Text="PDF" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                   FontSize="16" FontWeight="Bold" Foreground="#999"
                                                                   Visibility="{Binding VisaIsPdf, Converter={StaticResource BoolToVis}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding ReplaceVisaCommand}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnReplace}" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding OpenVisaCommand}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnOpenFile}" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding ExtendVisaCommand}"
                                                            ToolTip="{DynamicResource DetTooltipExtendVisa}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnExtend}" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Insurance -->
                                        <Border Width="300" Margin="0,0,12,12" Padding="14" 
                                                Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="&#xE8C9;" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource DetDocInsurance}" FontWeight="SemiBold" FontSize="14" 
                                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                                </StackPanel>
                                                <Border Height="120" CornerRadius="4" Background="#F5F5F5" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Image Source="{Binding InsuranceFilePath}" Stretch="Uniform"
                                                               Visibility="{Binding InsuranceIsPdf, Converter={StaticResource InverseBoolToVis}}"/>
                                                        <TextBlock Text="PDF" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                   FontSize="16" FontWeight="Bold" Foreground="#999"
                                                                   Visibility="{Binding InsuranceIsPdf, Converter={StaticResource BoolToVis}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding ReplaceInsuranceCommand}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnReplace}" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding OpenInsuranceCommand}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnOpenFile}" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding ExtendInsuranceCommand}"
                                                            ToolTip="{DynamicResource DetTooltipExtendIns}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnExtend}" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Photo -->
                                        <Border Width="300" Margin="0,0,12,12" Padding="14" 
                                                Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource DetDocPhoto}" FontWeight="SemiBold" FontSize="14" 
                                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                                </StackPanel>
                                                <Border Height="120" CornerRadius="4" Background="#F5F5F5" Margin="0,0,0,10">
                                                    <Grid>
                                                        <Image Source="{Binding PhotoFilePath}" Stretch="Uniform"
                                                               Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"/>
                                                        <TextBlock Text="{DynamicResource DetNoPhoto}" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                   FontSize="12" Foreground="#AAA"
                                                                   Visibility="{Binding HasPhoto, Converter={StaticResource InverseBoolToVis}}"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding ReplacePhotoCommand}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnReplace}" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource DocCardBtn}" Command="{Binding OpenPhotoCommand}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{DynamicResource DetBtnOpenFile}" FontSize="11"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>

                                <!-- ========== TAB 1: PROFILE (ANKETA) ========== -->
                                <StackPanel Visibility="{Binding TabIndex, Converter={StaticResource StepVis}, ConverterParameter=1}">

                                    <!-- Action buttons -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <Button Command="{Binding EditProfileCommand}" Padding="12,7" Margin="0,0,8,0" Cursor="Hand"
                                                Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVis}}"
                                                Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource DetBtnEditProfile}" FontSize="12"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding SaveProfileCommand}" Padding="12,7" Margin="0,0,8,0" Cursor="Hand"
                                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                                Background="#2E7D32" Foreground="White" BorderThickness="0" FontWeight="SemiBold">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource DetBtnSave}" FontSize="12"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding CancelEditCommand}" Padding="12,7" Cursor="Hand"
                                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                                                Background="{DynamicResource ContentBackgroundBrush}" 
                                                Foreground="{DynamicResource ForegroundBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <TextBlock Text="{DynamicResource DetBtnCancel}" FontSize="12"/>
                                        </Button>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- ===== LEFT COLUMN ===== -->
                                        <StackPanel Grid.Column="0">
                                            <!-- Personal -->
                                            <TextBlock Text="{DynamicResource DetSecPersonal}" Style="{StaticResource SectionHeader}"/>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldFirstName}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.FirstName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldLastName}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.LastName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldBirthDate}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.BirthDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Passport -->
                                            <TextBlock Text="{DynamicResource DetSecPassport}" Style="{StaticResource SectionHeader}"/>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldPassportNum}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.PassportNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldBirthCity}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.PassportCity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldBirthCountry}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.PassportCountry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldExpiry}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.PassportExpiry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Visa -->
                                            <TextBlock Text="{DynamicResource DetDocVisa}" Style="{StaticResource SectionHeader}"/>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldVisaNum}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.VisaNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldVisaType}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.VisaType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldExpiry}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.VisaExpiry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Insurance -->
                                            <TextBlock Text="{DynamicResource DetDocInsurance}" Style="{StaticResource SectionHeader}"/>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldInsCompany}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.InsuranceCompanyShort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldInsNum}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.InsuranceNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldExpiry}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.InsuranceExpiry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- ===== RIGHT COLUMN ===== -->
                                        <StackPanel Grid.Column="2">
                                            <!-- Address local -->
                                            <TextBlock Text="{DynamicResource DetSecAddrLocal}" Style="{StaticResource SectionHeader}"/>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldStreet}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.AddressLocal.Street, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldHouseNum}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.AddressLocal.Number, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="10"/>
                                                            <ColumnDefinition Width="100"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{DynamicResource DetFieldCity}" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox Text="{Binding Data.AddressLocal.City, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="{DynamicResource DetFieldZip}" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox Text="{Binding Data.AddressLocal.Zip, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <!-- Address abroad -->
                                            <TextBlock Text="{DynamicResource DetSecAddrAbroad}" Style="{StaticResource SectionHeader}"/>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldStreet}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.AddressAbroad.Street, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldHouseNum}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.AddressAbroad.Number, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="10"/>
                                                            <ColumnDefinition Width="100"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{DynamicResource DetFieldCity}" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox Text="{Binding Data.AddressAbroad.City, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="{DynamicResource DetFieldZip}" Style="{StaticResource FieldLabel}"/>
                                                            <TextBox Text="{Binding Data.AddressAbroad.Zip, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <!-- Work info -->
                                            <TextBlock Text="{DynamicResource DetSecWork}" Style="{StaticResource SectionHeader}"/>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldPosition}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.PositionTag, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldSalary}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.MonthlySalaryBrutto, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldHourly}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.HourlySalary, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldWorkAddr}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.WorkAddressTag, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Contact & Dates -->
                                            <TextBlock Text="{DynamicResource DetSecContacts}" Style="{StaticResource SectionHeader}"/>
                                            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                    Padding="14" Margin="0,0,0,16"
                                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource DetFieldPhone}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldStartDate}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.StartDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>
                                                    <TextBlock Text="{DynamicResource DetFieldSignDate}" Style="{StaticResource FieldLabel}"/>
                                                    <TextBox Text="{Binding Data.ContractSignDate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldInput}" IsReadOnly="{Binding IsEditMode, Converter={StaticResource InverseBool}}"/>

                                                    <TextBlock Text="{DynamicResource DetLabelStatus}" Style="{StaticResource FieldLabel}"/>
                                                    <ComboBox ItemsSource="{Binding AvailableStatuses}" 
                                                              SelectedItem="{Binding Data.Status, UpdateSourceTrigger=PropertyChanged}" 
                                                              IsEnabled="{Binding IsEditMode}"
                                                              Padding="8,6" Margin="0,0,0,10" FontSize="13">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                                                                             Fill="{Binding Converter={StaticResource StatusColor}}"/>
                                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Status message -->
                                    <TextBlock Text="{Binding StatusMessage}" Foreground="#c00" Margin="0,4,0,0" FontSize="12"/>
                                </StackPanel>

                                <!-- ========== TAB 2: HISTORY ========== -->
                                <StackPanel Visibility="{Binding TabIndex, Converter={StaticResource StepVis}, ConverterParameter=2}">
                                    <TextBlock Text="{DynamicResource DetHistoryTitle}" Style="{StaticResource SectionHeader}" FontSize="16" Margin="0,0,0,14"/>

                                    <!-- History list -->
                                    <ItemsControl ItemsSource="{Binding HistoryEntries}"
                                                  Visibility="{Binding HasHistory, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                                                        Padding="0" Margin="0,0,0,8"
                                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="5"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Color strip -->
                                                        <Border Grid.Column="0" CornerRadius="8,0,0,8"
                                                                Background="{DynamicResource AccentBrush}"/>

                                                        <StackPanel Grid.Column="1" Margin="14,10">
                                                            <!-- Timestamp + Action -->
                                                            <Grid Margin="0,0,0,4">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="11" 
                                                                               Foreground="#999" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                    <TextBlock FontSize="11" Foreground="#888"
                                                                               Text="{Binding Timestamp, StringFormat='{}{0:dd.MM.yyyy  HH:mm}'}"/>
                                                                </StackPanel>
                                                                <Border HorizontalAlignment="Right" CornerRadius="4" Padding="8,2"
                                                                        Background="#E8F5E9">
                                                                    <TextBlock Text="{Binding Action}" FontSize="10" FontWeight="SemiBold" Foreground="#2E7D32"/>
                                                                </Border>
                                                            </Grid>
                                                            <!-- Description -->
                                                            <TextBlock Text="{Binding Description}" FontSize="13" 
                                                                       Foreground="{DynamicResource ForegroundBrush}" 
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Empty state -->
                                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" Padding="24"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                            Visibility="{Binding HasHistory, Converter={StaticResource InverseBoolToVis}}">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="32" 
                                                       HorizontalAlignment="Center" Foreground="#CCC"/>
                                            <TextBlock Text="{DynamicResource DetHistoryEmpty}" FontSize="14" FontWeight="SemiBold" 
                                                       Margin="0,8,0,4" TextAlignment="Center" Foreground="#888"/>
                                            <TextBlock Text="{DynamicResource DetHistoryEmptyMsg}"
                                                       FontSize="12" TextAlignment="Center" Foreground="#AAA"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- ===== Generate Document Dialog Overlay ===== -->
        <Grid Visibility="{Binding IsGenerateDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#66000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseGenerateDialogCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" 
                    Width="500" MaxHeight="500"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="18" 
                                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource DetGenTitle}" FontSize="18" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Command="{Binding CloseGenerateDialogCommand}"
                                Width="30" Height="30" Background="Transparent" BorderThickness="0" 
                                Foreground="#999" Cursor="Hand">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                        </Button>
                    </Grid>

                    <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="#888" Margin="0,0,0,10" FontSize="12"
                               Text="{DynamicResource DetGenDesc}"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="300">
                        <ItemsControl ItemsSource="{Binding AvailableTemplates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="6" 
                                            Padding="12,8" Margin="0,0,0,6" Cursor="Hand"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6" 
                                                    Background="#E3F2FD" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Format}" VerticalAlignment="Center" 
                                                           HorizontalAlignment="Center" FontWeight="Bold" FontSize="11"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#888" 
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" 
                                                    Command="{Binding DataContext.GenerateFromTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,5" FontWeight="SemiBold"
                                                    Background="{DynamicResource AccentBrush}" Foreground="White" 
                                                    BorderThickness="0" VerticalAlignment="Center" Cursor="Hand">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource EmpGenerate}" FontSize="12"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Grid.Row="3" Text="{Binding GenerateStatusMessage}" 
                               TextWrapping="Wrap" Margin="0,10,0,0" 
                               FontSize="12" Foreground="{DynamicResource AccentBrush}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ===== Archive Dialog Overlay ===== -->
        <Grid Visibility="{Binding IsArchiveDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#66000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CancelArchiveCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" 
                    Width="420" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="32" 
                               HorizontalAlignment="Center" Foreground="#C62828" Margin="0,0,0,10"/>
                    <TextBlock Text="{DynamicResource DetArchiveTitle}" FontSize="18" FontWeight="SemiBold" 
                               TextAlignment="Center" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,6"/>
                    <TextBlock TextAlignment="Center" Foreground="#888" FontSize="12" Margin="0,0,0,16" TextWrapping="Wrap"
                               Text="{DynamicResource DetArchiveDesc}"/>
                    <TextBlock Text="{DynamicResource DetArchiveDateLabel}" FontSize="12" Foreground="#888" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ArchiveEndDate, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="10,8" FontSize="14" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding ArchiveStatus}" Foreground="#D32F2F" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Command="{Binding CancelArchiveCommand}" Padding="16,8" Margin="0,0,8,0"
                                Background="{DynamicResource ContentBackgroundBrush}" 
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                            <TextBlock Text="{DynamicResource DetBtnCancel}" FontSize="13"/>
                        </Button>
                        <Button Command="{Binding ConfirmArchiveCommand}" Padding="16,8"
                                Background="#C62828" Foreground="White" 
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource DetBtnArchive}" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Extend Date Dialog Overlay ===== -->
        <Grid Visibility="{Binding IsExtendDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="#66000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CancelExtendCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="12" 
                    Width="380" Padding="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="28" 
                               HorizontalAlignment="Center" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding ExtendDialogTitle}" FontSize="18" FontWeight="SemiBold" 
                               TextAlignment="Center" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="{DynamicResource DetExtendDateLabel}" FontSize="12" Foreground="#888" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NewExpiryDate, UpdateSourceTrigger=PropertyChanged}" 
                             Padding="10,8" FontSize="14" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Command="{Binding CancelExtendCommand}" Padding="16,8" Margin="0,0,8,0"
                                Background="{DynamicResource ContentBackgroundBrush}" 
                                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                Foreground="{DynamicResource ForegroundBrush}" Cursor="Hand">
                            <TextBlock Text="{DynamicResource DetBtnCancel}" FontSize="13"/>
                        </Button>
                        <Button Command="{Binding ConfirmExtendCommand}" Padding="16,8"
                                Background="{DynamicResource AccentBrush}" Foreground="White" 
                                BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource DetBtnSave}" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
