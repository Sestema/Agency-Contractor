{\rtf1\ansi\ansicpg1252\uc1\htmautsp\deff2{\fonttbl{\f0\fcharset0 Times New Roman;}{\f2\fcharset0 Segoe UI;}}{\colortbl\red0\green0\blue0;\red255\green255\blue255;}\loch\hich\dbch\pard\plain\ltrpar\itap0{\lang1033\fs18\f2\cf0 \cf0\ql{\fs32\f2\b {\ltrch Pracovni smlouva}\li0\ri0\sa180\sb0\fi0\qc\par}
{\fs15\f2 {\ltrch uzavrena dle zakona c. 262/2006 Sb., zakoniku prace v platnem zneni}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs15\f2 {\ltrch mezi nasledujicimi smluvnimi stranami}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 \li0\ri0\sa120\sb0\fi0\ql\par}
{\fs30\f2\b {\ltrch Smluvni strany}\li0\ri0\sa120\sb0\fi0\qc\par}
{\fs22\f2 {\b\ltrch Zamestnavatel: $\{AGENCY_Name\}}{\ltrch , }{\b\ltrch IC: $\{AGENCY_ICO\}}{\ltrch ,}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\b\ltrch se sidlem: $\{AGENCY_FullAddress\},}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\b\ltrch zastoupeny/a: }{\ltrch doplnte jmeno jednatele], jednatel,}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\b\ltrch OR vedeny }{\ltrch [doplnte soud, oddil a vlozku],}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch (dale jen jako "Zamestnavatel")}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 \li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\b\ltrch zamestnanec: $\{EMPLOYEE_FullName\},}{\ltrch \tab }{\b\ltrch c. dokladu: $\{EMPLOYEE_PassportNumber\},}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\b\ltrch narozen/a: $\{EMPLOYEE_BirthDate\},\tab misto narozeni: $\{EMPLOYEE_PassportCity\},}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\b\ltrch statni obcanstvi: $\{EMPLOYEE_PassportCountry\},}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\b\ltrch bydliste v CR: $\{EMPLOYEE_AbroadAddress_Full\}}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\b\ltrch trvale bydliste: $\{EMPLOYEE_LocalAddress_Full\}.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch (dale jen jako "Zamestnanec")}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 \li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch uzaviraji tuto pracovni smlouvu (dale jen jako "Smlouva"), kterou je sjednan pracovni pomer s timto obsahem:}\li0\ri0\sa120\sb0\fi0\qc\par}
{\fs22\f2 \li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2\b {\ltrch Clanek I}\li0\ri0\sa120\sb0\fi0\qc\par}
{\fs22\f2 {\ltrch Zakladni ujednani}\li0\ri0\sa120\sb0\fi0\qc\par}
{\fs22\f2 {\ltrch 1.}{\lang1058\ltrch  }{\ltrch Druh prace (funkce): }{\b\ltrch $\{EMPLOYEE_Position\},}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 2.}{\lang1058\ltrch  }{\ltrch Misto vykonu prace: }{\b\ltrch $\{EMPLOYEE_WorkAddress\},}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 3. Den nastupu do prace: }{\b\ltrch $\{EMPLOYEE_StartDate\},}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 4. Pracovni pomer se sjednava na dobu neurcitou.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 \li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2\b {\ltrch Clanek II}\li0\ri0\sa120\sb0\fi0\qc\par}
{\fs22\f2 {\ltrch Zvlastni ujednani}\li0\ri0\sa120\sb0\fi0\qc\par}
{\fs22\f2 {\ltrch 5. Zkusebni doba: 3 mesice.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 6. Zkusebni doba pocina dnem vzniku pracovniho pomeru. Podminky zkusebni doby jsou uvedeny v par. 35 ZP. Zruseni pracovniho pomeru ve zkusebni dobe se ridi par. 66 ZP.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 7. Delka a rozvrh pracovni doby: 5 dni v tydnu }{\b\ltrch $\{COMPANY_WeeklyWorkHours\}}{\ltrch  hod.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 8. Narok na dovolenou se ridi ustanovenimi par. 211 a nasl. ZP.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 9. Vymera dovolene cini 4 tydny v kalendarnim roce a ridi se par. 212 a par. 213 ZP. Zpusob urcovani delky dovolene se ridi par. 217 a par. 218 ZP. V pripade naroku na dovolenou nad ramec uvedeny v ZP je narok na dovolenou uveden v pokynech k docasnemu prideleni zamestnance agentury prace k uzivateli (dale jen jako "Pokyn").}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 \li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2\b {\ltrch }\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2\b {\ltrch Clanek III}\li0\ri0\sa120\sb0\fi0\qc\par}
{\fs22\f2 {\ltrch Mzdove ujednani}\li0\ri0\sa120\sb0\fi0\qc\par}
{\fs22\f2 {\ltrch 10. Mzdove podminky jsou stanoveny zakladni hodinovou hrubou mzdou ve vysi }{\b\ltrch $\{EMPLOYEE_HourlySalary\}}{\ltrch ,- Kc/hod v souladu s prislusnymi pravnimi predpisy.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 11. Nahrada mzdy za svatek se ridi par. 115 ZP.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 12. Priplatky ke mzde se ridi par. 114, par. 116, par. 117 a par. 118 ZP.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 13. V pripade naroku na dalsi pohyblive slozky mzdy jsou tyto uvedeny v Pokynu.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 14. Splatnost mzdy se ridi par. 141 ZP. Termin vyplaty mzdy se sjednava k 20. dni v nasledujicim mesici po mesici, ve kterem vzniklo Zamestnanci pravo na mzdu. Mzda bude Zamestnanci vyplacena po dohode v hotovosti v miste vykonu prace nebo na bankovni ucet.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 \li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2\b {\ltrch Clanek IV}\li0\ri0\sa120\sb0\fi0\qc\par}
{\fs22\f2 {\ltrch Ostatni ujednani}\li0\ri0\sa120\sb0\fi0\qc\par}
{\fs22\f2 {\ltrch 15. Zamestnanec je povinen sverenou praci vykonavat v pracovni dobe svedomite a odborne podle svych nejlepsich schopnosti a vedomosti, ridit se prikazy a pokyny vedoucich manazeru Zamestnavatele a plnit povinnosti vyplyvajici z par. 106 ZP.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 16. Zamestnanec se zavazuje dodrzovat pracovni kazen a zachovavat mlcenlivost zejmena o obchodnich, vyrobnich a organizacnich skutecnostech, ktere maji byt utajeny. Tato povinnost mlcenlivosti trva i po pripadnem rozvazani pracovniho pomeru.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 17. Zamestnanec je povinen pri vykonu prace dodrzovat predpisy o bezpecnosti a ochrane zdravi pri praci, predpisy na useku pozarni ochrany a ochrany zivotniho prostredi, pripadne jine predpisy vztahujici se k jim vykonavanemu druhu prace.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 18. Zamestnanec potvrzuje, ze pred uzavrenim Smlouvy byl radne seznamen s pravy a povinnostmi, ktere pro nej vyplyvaji z teto Smlouvy, zejmena s pracovnimi a mzdovymi podminkami, za nichz ma praci vykonavat, dale ze byl radne seznamen s predpisy k zajisteni BOZP, pozarni ochrany a ochrany zivotniho prostredi.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 19. Zamestnavatel se zavazuje pridelovat Zamestnanci praci v ramci sjednaneho druhu prace, platit mu za vykonanou praci mzdu a vytvaret podminky pro plneni pracovnich ukolu.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 20. Rozvrzeni pracovni doby se ridi par. 81 az 84 ZP.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 21. Rozsah minimalniho nepretrziteho denniho odpocinku a nepretrziteho odpocinku v tydnu se ridi par. 90 az 92 ZP. Zamestnavatel se zavazuje poskytnout zamestnanci prestavku v praci na jidlo a oddech podle par. 88 ZP.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 22. Zamestnanec je povinen podrobit se vstupni lekarske prohlidce pred vznikem pracovniho pomeru, jakoz i dalsim preventivnim prohlidkam a vystupni prohlidce u profesi urcenych Zamestnavatelem.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 23. Zamestnavatel je povinen prihlasit Zamestnance ke zdravotnimu a socialnimu pojisteni podle prislusnych pravnich predpisu.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 24. Zpusob rozvazani pracovniho pomeru se ridi par. 48 ZP. Postup, ktery jsou Zamestnanec a Zamestnavatel povinni dodrzet pri rozvazani pracovniho pomeru, se ridi par. 50 ZP. Vypoved z pracovniho pomeru musi byt vzdy pisemna.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 25. Zamestnavatel muze dat Zamestnanci vypoved jen z duvodu uvedenych v par. 52 ZP. Pripadny narok na odstupne Zamestnance se ridi par. 67 ZP.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 26. Zamestnavatel muze okamzite zrusit pracovni pomer z duvodu uvedenych v par. 55 ZP.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 27. Zamestnanec muze pracovni pomer okamzite zrusit z duvodu stanovenych v par. 56 ZP.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 28. Pokud je opravneni k zamestnavani Zamestnance zalozeno platnym pracovnim opravnenim a/nebo platnym povolenim k pobytu, konci pracovni vztah zalozeny touto smlouvou dnem zaniku platnosti pracovniho opravneni a/nebo dnem zaniku platnosti povoleni k pobytu, podle toho, jaky den nastane drive.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 29. Vypovedni doba se ridi par. 51 a 51a ZP. Je-li pracovni pomer sjednan na dobu urcitou, pouzije se par. 65 ZP.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 30. Prace prescas je blize definovana v par. 78 ZP. Rozsah prace prescas se ridi par. 93 ZP.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 31. Zamestnanec je povinen hlasit Zamestnavateli veskere zmeny v osobnich udajich, k nimz dojde za trvani pracovniho pomeru, jakoz i veskere okolnosti, ktere mohou mit vliv na vykon prace a na naroky a povinnosti z pracovniho pomeru vyplyvajici.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 32. Zamestnanec souhlasi, aby Zamestnavatel zpracovaval jeho osobni udaje v rozsahu nezbytne nutnem pro ucely tohoto pracovniho pomeru, vcetne fotografie pro ucely vystaveni opravneni ke vstupu a pro spolecenske ucely u Zamestnavatele obvykle.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 \li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2\b {\ltrch Clanek V}\li0\ri0\sa120\sb0\fi0\qc\par}
{\fs22\f2 {\ltrch Zaverecna ujednani}\li0\ri0\sa120\sb0\fi0\qc\par}
{\fs22\f2 {\ltrch 33. Ostatni prava a povinnosti vyplyvajici z pracovniho pomeru vznikleho na zaklade teto Smlouvy se ridi zejmena ZP a souvisejicimi pravnimi predpisy, pripadne vnitrnimi predpisy Zamestnavatele.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 34. Nedilnou soucasti teto Smlouvy je Pokyn.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 35. Tato Smlouva je sepsana ve dvou pisemnych vyhotovenich, z nichz jedno obdrzi Zamestnanec a druhe Zamestnavatel.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 36. Sjednany obsah teto Smlouvy lze zmenit, dohodnou-li se Zamestnanec a Zamestnavatel na jeho zmene. Zmena musi byt provedena pisemne.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 37. Zamestnanec a Zamestnavatel podepisuji tuto Smlouvu na dukaz souhlasu s jejim obsahem.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 {\ltrch 38. Zamestnanec a Zamestnavatel timto vyslovne prohlasuji, ze tato Smlouva vyjadruje jejich pravou a svobodnou vuli, cemuz na dukaz pripojuji nize sve podpisy.}\li0\ri0\sa120\sb0\fi0\ql\par}
{\fs22\f2 \li0\ri0\sa120\sb0\fi0\ql\par}
