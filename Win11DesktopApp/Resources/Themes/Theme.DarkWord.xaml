<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="CardHoverBrush" Color="#3F3F3F"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#555555"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#4A90E2"/>
    
    <DropShadowEffect x:Key="CardShadow" BlurRadius="10" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.5"/>
</ResourceDictionary>
