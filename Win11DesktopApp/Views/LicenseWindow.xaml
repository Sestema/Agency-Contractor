<Window x:Class="Win11DesktopApp.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource LicenseWindowTitle}"
        Width="620" Height="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        MinWidth="460" MinHeight="500"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Style="{StaticResource ThinScroll}" VerticalScrollBarVisibility="Auto" Padding="28,24,28,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
                    <Border Style="{StaticResource PageHeaderIconBadge}">
                        <TextBlock Text="&#xE8D7;" Style="{StaticResource PageHeaderIconText}"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Agency Contractor" FontSize="{DynamicResource FS24}" Style="{StaticResource PageHeaderTitleText}"/>
                        <TextBlock Text="{DynamicResource LicenseHeaderSubtitle}"
                                   FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Style="{StaticResource DialogSectionCard}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource DialogPreviewSurface}" Padding="14,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource AccentLightBrush}">
                                        <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                                   Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LicenseAccessStatusTitle}"
                                                   FontSize="{DynamicResource FS14}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="{DynamicResource LicenseAccessStatusDescription}"
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock x:Name="TxtStatus"
                                           Text="{DynamicResource LicenseChecking}"
                                           FontSize="{DynamicResource FS16}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ErrorBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtStatusDetail"
                                           Text=""
                                           Margin="0,8,0,0"
                                           FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="TxtAdminMessage"
                                           Text=""
                                           Margin="0,8,0,0"
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource DialogPreviewSurface}" Padding="14,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource InfoLightBrush}">
                                        <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                                   Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource LicenseMachineIdTitle}"
                                                   FontSize="{DynamicResource FS14}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <TextBlock Text="{DynamicResource LicenseMachineIdDescription}"
                                                   FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock x:Name="TxtMachineId"
                                           Text="..."
                                           FontSize="{DynamicResource FS12}"
                                           FontFamily="Consolas"
                                           Foreground="{DynamicResource ForegroundBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource DialogSectionCard}" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource InfoLightBrush}">
                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                           Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource LicenseMainAccessTitle}"
                                           FontSize="{DynamicResource FS15}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{DynamicResource LicenseMainAccessDescription}"
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <Button x:Name="BtnRefreshStatus" Click="BtnRefreshStatus_Click"
                                Padding="16,11"
                                Style="{StaticResource FilledActionButton}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS15}"
                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource LicenseRefreshAccess}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Expander Header="{DynamicResource LicenseLegacyActivationHeader}"
                          Margin="0,0,0,12"
                          Background="{DynamicResource CardBackgroundBrush}"
                          Foreground="{DynamicResource ForegroundBrush}">
                    <Border Style="{StaticResource DialogSectionCard}" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource LicenseLegacyActivationDescription}"
                                       FontSize="{DynamicResource FS11}"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="{DynamicResource LicenseTermLabel}"
                                       FontSize="{DynamicResource FS12}"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                                       Margin="0,0,0,6"/>
                            <ComboBox x:Name="CbPlan"
                                      FontSize="{DynamicResource FS13}"
                                      Style="{StaticResource ThemedComboBox}"
                                      Margin="0,0,0,14">
                                <ComboBoxItem Content="{DynamicResource LicenseTerm30Days}" Tag="30"/>
                                <ComboBoxItem Content="{DynamicResource LicenseTerm90Days}" Tag="90"/>
                                <ComboBoxItem Content="{DynamicResource LicenseTerm180Days}" Tag="180"/>
                                <ComboBoxItem Content="{DynamicResource LicenseTerm362Days}" Tag="362"/>
                                <ComboBoxItem Content="{DynamicResource LicenseTermUnlimited}" Tag="0" IsSelected="True"/>
                            </ComboBox>

                            <Button x:Name="BtnActivate" Click="BtnActivate_Click"
                                    Padding="16,11"
                                    Style="{StaticResource HeaderGhostButton}"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS15}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{DynamicResource LicenseSelectLegacyKey}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Expander>

                <Border Style="{StaticResource DialogPreviewSurface}" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource LicenseResultTitle}"
                                   FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtResult" Text="" FontSize="{DynamicResource FS12}" TextWrapping="Wrap"
                                   Foreground="{DynamicResource SuccessBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="{DynamicResource WindowBackgroundBrush}" Padding="32,8,32,16"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtVersion"
                               Text="Agency Contractor"
                               FontSize="{DynamicResource FS11}"
                               Foreground="{DynamicResource TertiaryForegroundBrush}"/>
                    <TextBlock Text="{DynamicResource LicenseContinueHint}"
                               FontSize="{DynamicResource FS10}"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="BtnContinue" Content="{DynamicResource LicenseContinueButton}" Click="BtnContinue_Click"
                        FontSize="{DynamicResource FS13}" Padding="20,8" IsEnabled="False"
                        Background="{DynamicResource SuccessBrush}" Foreground="White" BorderThickness="0"
                        Style="{StaticResource FilledActionButton}">
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
