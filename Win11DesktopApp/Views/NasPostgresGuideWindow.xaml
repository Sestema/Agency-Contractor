<Window x:Class="Win11DesktopApp.Views.NasPostgresGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource SettingsNasPostgresGuideTitle}"
        Width="820"
        Height="720"
        MinWidth="680"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="{DynamicResource SettingsNasPostgresGuideTitle}"
                       FontSize="{DynamicResource FS20}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundBrush}"/>
            <TextBlock Text="{DynamicResource SettingsNasPostgresGuideSubtitle}"
                       Margin="0,4,0,0"
                       FontSize="{DynamicResource FS12}"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Padding="16"
                CornerRadius="14"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1">
            <ScrollViewer Style="{StaticResource ThinScroll}"
                          VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="GuideTextBlock"
                           FontSize="{DynamicResource FS13}"
                           Foreground="{DynamicResource ForegroundBrush}"
                           TextWrapping="Wrap"
                           LineHeight="21"/>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2"
                Margin="0,14,0,0"
                Padding="18,9"
                HorizontalAlignment="Right"
                Style="{StaticResource FilledActionButton}"
                Click="CloseButton_Click">
            <TextBlock Text="{DynamicResource DetBtnClose}"
                       FontSize="{DynamicResource FS12}"
                       FontWeight="SemiBold"
                       Foreground="White"/>
        </Button>
    </Grid>
</Window>
