<UserControl x:Class="Win11DesktopApp.Views.StepVisaDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Win11DesktopApp.Views">
    <Border Style="{StaticResource StepFade}" Visibility="{Binding StepIndex, Converter={StaticResource StepVis}, ConverterParameter=4}"
            Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="22"
            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>
            <ScrollViewer Grid.Column="0" Style="{StaticResource ThinScroll}" Margin="0,0,12,0"
                          VerticalScrollBarVisibility="Hidden"
                          PreviewMouseWheel="InnerScrollViewer_PreviewMouseWheel">
                <StackPanel>
                    <StackPanel Margin="0,0,0,18">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource PageHeaderIconBadge}" Background="{DynamicResource AccentBrush}">
                                <TextBlock Text="&#xE8A7;" Style="{StaticResource PageHeaderIconText}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource StepVisaData}"
                                           FontSize="{DynamicResource FS18}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                <TextBlock Text="{DynamicResource AIScanBtn}"
                                           FontSize="{DynamicResource FS11}"
                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Style="{StaticResource DialogPreviewSurface}" Padding="12,10" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Command="{Binding AIScanDocumentCommand}"
                                        Style="{StaticResource FilledActionButton}"
                                        Padding="12,6"
                                        Margin="0,0,10,0"
                                        Visibility="{Binding IsAIScanning, Converter={StaticResource InverseBoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="White"/>
                                        <TextBlock Text="{DynamicResource AIScanBtn}" FontSize="{DynamicResource FS12}" Foreground="White"/>
                                    </StackPanel>
                                </Button>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding AIScanStatus}"
                                           FontSize="{DynamicResource FS12}"
                                           Foreground="{DynamicResource SecondaryForegroundBrush}"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding AIScanStatus, Converter={StaticResource StringToVis}}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource WizVisaNum}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.VisaNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizVisaAuthority}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.VisaAuthority, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizVisaType}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.VisaType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                    <TextBlock Text="{DynamicResource WizVisaExpiry}" Style="{StaticResource WizLabel}"/>
                    <TextBox Text="{Binding Data.VisaExpiry, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>

                    <TextBlock Text="{DynamicResource WizWorkPermitName}" Style="{StaticResource WizLabel}" Margin="0,14,0,0"/>
                    <TextBox Text="{Binding Data.WorkPermitName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WizInput}"/>
                </StackPanel>
            </ScrollViewer>
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"
                          Margin="0"/>
            <views:DocumentPreviewPanel Grid.Column="2" Margin="12,0,0,0"/>
        </Grid>
    </Border>
</UserControl>
