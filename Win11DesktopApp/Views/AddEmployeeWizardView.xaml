<UserControl x:Class="Win11DesktopApp.Views.AddEmployeeWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             xmlns:views="clr-namespace:Win11DesktopApp.Views"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="920">

    <Viewbox StretchDirection="DownOnly" Stretch="Uniform">
    <Border Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="16" Width="920" Height="720"
            Effect="{DynamicResource CardShadow}">
        <Grid Margin="28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header + Step indicator -->
                <RowDefinition Height="*"/>     <!-- Content -->
                <RowDefinition Height="Auto"/>  <!-- Navigation -->
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border CornerRadius="10" Width="40" Height="40">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#667EEA" Offset="0"/>
                                <GradientStop Color="#764BA2" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS18}"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{DynamicResource HeaderAddEmployee}" FontSize="{DynamicResource FS22}" FontWeight="SemiBold" 
                               Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="14,0,0,0"/>
                </StackPanel>

                <!-- Step indicator (dynamic) -->
                <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="10" Padding="12,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontSize="{DynamicResource FS13}" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} / {1}">
                                    <Binding Path="CurrentStepDisplay"/>
                                    <Binding Path="TotalSteps"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ===== CONTENT ===== -->
            <Grid Grid.Row="1">
                    <!-- STEP 0: Documents Upload -->
                    <views:StepDocumentsUploadView/>


                    <!-- STEP 1: Crop Photo -->
                    <views:StepCropPhotoView/>

                    <!-- STEP 2: Passport Data -->
                    <views:StepPassportDataView/>

                    <!-- STEP 3: Insurance Data -->
                    <views:StepInsuranceDataView/>

                    <!-- STEP 4: Visa Data -->
                    <views:StepVisaDataView/>

                    <!-- STEP 7: Work Permit Data -->
                    <views:StepWorkPermitDataView/>

                    <!-- STEP 8: EU Passport Page 2 — Work Permit Info -->
                    <views:StepPassportPage2View/>

                    <!-- STEP 5: Addresses + Work -->
                    <views:StepAddressesView/>

                    <!-- STEP 6: Additional + Save -->
                    <views:StepAdditionalView/>

            <!-- AI Scan overlay -->
            <Border Panel.ZIndex="1000" Background="#80000000" CornerRadius="12"
                    Visibility="{Binding IsAIScanning, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="48" Height="48" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding AIScanStatus}" FontSize="{DynamicResource FS14}"
                               Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            </Grid>

            <!-- ===== NAVIGATION BUTTONS ===== -->
            <Grid Grid.Row="2" Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Command="{Binding CancelCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="16,10"
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1.5">
                                    <TextBlock Text="{DynamicResource BtnCancel}" FontSize="{DynamicResource FS13}" FontWeight="Medium"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding BackCommand}" Cursor="Hand" Margin="0,0,10,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="16,10"
                                        BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1.5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}"
                                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{DynamicResource BtnBack}" FontSize="{DynamicResource FS13}" FontWeight="Medium"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding NextCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="8" Padding="20,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{DynamicResource BtnNext}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                                   Foreground="White" VerticalAlignment="Center"/>
                                        <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}"
                                                   Foreground="White" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
    </Viewbox>
</UserControl>
