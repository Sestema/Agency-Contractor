<UserControl x:Class="Win11DesktopApp.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:Win11DesktopApp.Views"
             xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             xmlns:h="clr-namespace:Win11DesktopApp.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
        <CubicEase x:Key="SmoothEase" EasingMode="EaseOut"/>
    </UserControl.Resources>
    
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid Margin="32,20,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding GoBackCommand}"
                        Style="{StaticResource HeaderBackButton}">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Style="{StaticResource PageHeaderIconBadge}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#11998E" Offset="0"/>
                                <GradientStop Color="#38EF7D" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="&#xE8A5;" Style="{StaticResource PageHeaderIconText}"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontSize="{DynamicResource FS26}"
                                   Style="{StaticResource PageHeaderTitleText}"/>
                        <TextBlock FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Margin="0,3,0,0">
                            <Run Text="{Binding Templates.Count, Mode=OneWay, FallbackValue=0}"/>
                            <Run Text=" "/>
                            <Run Text="{DynamicResource TplTemplateCount}"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Add template button -->
                <Button Grid.Column="2"
                        Command="{Binding AddTemplateCommand}"
                        Style="{StaticResource FilledActionButton}"
                        Padding="18,10"
                        VerticalAlignment="Center">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#11998E" Offset="0"/>
                            <GradientStop Color="#38EF7D" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource BtnAddTemplate}" FontSize="{DynamicResource FS14}" FontWeight="SemiBold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ===== TEMPLATE LIST ===== -->
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Templates}" Margin="0,4,0,8"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True">
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <ScrollViewer Style="{StaticResource ThinScroll}" CanContentScroll="True" Focusable="False">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </ItemsControl.Template>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TemplateCard" 
                                    Background="{DynamicResource CardBackgroundBrush}" 
                                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                    CornerRadius="14" Padding="15,12" Margin="12,4,12,14"
                                    RenderTransformOrigin="0.5,0.5"
                                    Effect="{DynamicResource CardShadow}"
                                    h:StaggerAnimation.Enable="True">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
                                        <TranslateTransform x:Name="CardTranslate" Y="0"/>
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Format badge with gradient -->
                                    <Border Grid.Column="0" Width="52" Height="52" CornerRadius="14" Margin="0,0,16,0"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#667EEA" Offset="0"/>
                                                            <GradientStop Color="#764BA2" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Format}" Value="XLSX">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#11998E" Offset="0"/>
                                                                    <GradientStop Color="#38EF7D" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Format}" Value="PDF">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#FF512F" Offset="0"/>
                                                                    <GradientStop Color="#F09819" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock x:Name="FormatIcon" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS18}"
                                                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,2">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#xE8A5;"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Format}" Value="XLSX">
                                                                <Setter Property="Text" Value="&#xE80A;"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Format}" Value="PDF">
                                                                <Setter Property="Text" Value="&#xEA00;"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Format}" HorizontalAlignment="Center"
                                                       FontWeight="Bold" FontSize="{DynamicResource FS9}" Foreground="White" Opacity="0.9"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Template info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="{DynamicResource FS15}" 
                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="8,3"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Format}"
                                                           FontSize="{DynamicResource FS10}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                            </Border>
                                            <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS10}"
                                                       Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock FontSize="{DynamicResource FS12}" Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                       VerticalAlignment="Center">
                                                <Run Text="{DynamicResource TplUpdated}"/>
                                                <Run Text="{Binding UpdatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Action buttons -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Edit button -->
                                        <Button Command="{Binding DataContext.EditTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource FilledActionButton}"
                                                Padding="14,8"
                                                Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}"
                                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock Text="{DynamicResource TplBtnEdit}" FontSize="{DynamicResource FS12}" FontWeight="Medium"
                                                           Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Rename button -->
                                        <Button Command="{Binding DataContext.RenameTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ToolbarIconButton}"
                                                Width="38"
                                                Height="38"
                                                Margin="0,0,8,0"
                                                Background="{DynamicResource WarningLightBrush}"
                                                BorderBrush="{DynamicResource WarningLightBrush}"
                                                Foreground="{DynamicResource WarningBrush}">
                                            <TextBlock Text="&#xE8AC;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="{DynamicResource FS14}"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                        </Button>

                                        <!-- Copy to company button -->
                                        <Button Command="{Binding DataContext.CopyTemplateToCompanyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ToolbarIconButton}"
                                                Width="38"
                                                Height="38"
                                                Margin="0,0,8,0"
                                                ToolTip="{DynamicResource TplCopyToCompanyTooltip}"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                Foreground="{DynamicResource AccentBrush}">
                                            <TextBlock Text="&#xE8FA;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="{DynamicResource FS14}"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                        </Button>

                                        <!-- Delete button -->
                                        <Button Command="{Binding DataContext.DeleteTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ToolbarIconButton}"
                                                Width="38"
                                                Height="38"
                                                Background="{DynamicResource ErrorLightBrush}"
                                                BorderBrush="{DynamicResource ErrorLightBrush}"
                                                Foreground="{DynamicResource ErrorBrush}">
                                            <TextBlock Text="&#xE74D;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="{DynamicResource FS14}"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardTranslate" Storyboard.TargetProperty="Y"
                                                             To="-3" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                                                             To="1.01" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                                                             To="1.01" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardTranslate" Storyboard.TargetProperty="Y"
                                                             To="0" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.25"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            <!-- Empty state -->
            <Border Grid.Row="1" Style="{StaticResource EmptyStateCard}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding HasTemplates, Converter={StaticResource InverseBoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8A5;" Style="{StaticResource EmptyStateIconText}" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{DynamicResource TplEmptyState}" Style="{StaticResource EmptyStateTitleText}" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Modal Dialog Overlay — Add Template ===== -->
        <Grid Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}">
                 <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAddDialogCommand}"/>
                </Border.InputBindings>
            </Border>
            <ContentControl Content="{Binding AddTemplateVm}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:AddTemplateViewModel}" xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels">
                        <views:AddTemplateView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>

        <!-- ===== Copy Template Dialog Overlay ===== -->
        <Grid Visibility="{Binding IsCopyDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CancelCopyTemplateCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Style="{StaticResource DialogSectionCard}"
                    Width="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="28"
                    Background="{DynamicResource ContentBackgroundBrush}">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{DynamicResource AccentLightBrush}" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0">
                                <TextBlock Text="&#xE8FA;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{DynamicResource TplCopyDialogTitle}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding CancelCopyTemplateCommand}"
                                Style="{StaticResource ToolbarInlineIconButton}">
                            <TextBlock Text="&#xE711;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{DynamicResource FS12}"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        </Button>
                    </Grid>

                    <Border Style="{StaticResource DialogPreviewSurface}" Padding="16,14" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TplCopyDialogCompany}" FontSize="{DynamicResource FS13}"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding CopyTargetCompanies}"
                                      SelectedItem="{Binding SelectedCopyTargetCompany}"
                                      TextSearch.TextPath="Name"
                                      Style="{StaticResource ThemedComboBox}"
                                      FontSize="{DynamicResource FS13}"
                                      Margin="0,0,0,14">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="{DynamicResource TplCopyDialogName}" FontSize="{DynamicResource FS13}"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding CopyTemplateName, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="{DynamicResource FS14}" Padding="10,8"
                                     Background="{DynamicResource CardBackgroundBrush}"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelCopyTemplateCommand}" Cursor="Hand" Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="16,9"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                        <TextBlock Text="{DynamicResource BtnCancel}" FontSize="{DynamicResource FS13}" FontWeight="Medium"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding ConfirmCopyTemplateCommand}"
                                Style="{StaticResource FilledActionButton}"
                                Padding="18,9">
                            <TextBlock Text="{DynamicResource TplCopyDialogBtn}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Rename Dialog Overlay ===== -->
        <Grid Visibility="{Binding IsRenameDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CancelRenameCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Style="{StaticResource DialogSectionCard}"
                    Width="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="28"
                    Background="{DynamicResource ContentBackgroundBrush}">
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{DynamicResource WarningLightBrush}" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0">
                                <TextBlock Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                           Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{DynamicResource TplRenameTitle}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding CancelRenameCommand}"
                                Style="{StaticResource ToolbarInlineIconButton}">
                            <TextBlock Text="&#xE711;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="{DynamicResource FS12}"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                        </Button>
                    </Grid>

                    <Border Style="{StaticResource DialogPreviewSurface}" Padding="16,14" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TplRenamePrompt}" FontSize="{DynamicResource FS13}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,8"/>

                            <TextBox Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="{DynamicResource FS14}" Padding="10,8" 
                                     Background="{DynamicResource CardBackgroundBrush}"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelRenameCommand}" Cursor="Hand" Margin="0,0,10,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="16,9"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                        <TextBlock Text="{DynamicResource BtnCancel}" FontSize="{DynamicResource FS13}" FontWeight="Medium"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding ConfirmRenameCommand}"
                                Style="{StaticResource FilledActionButton}"
                                Padding="18,9">
                            <TextBlock Text="{DynamicResource TplRenameBtn}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Tags Panel Overlay ===== -->
        <Grid Visibility="{Binding IsTagsPanelOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource OverlayBrush}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseTagsPanelCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border Style="{StaticResource DialogSectionCard}"
                    Width="650"
                    MaxHeight="600"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="28"
                    Background="{DynamicResource ContentBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{DynamicResource AccentLightBrush}" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0">
                                <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                           Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{DynamicResource TplTagsTitle}" FontSize="{DynamicResource FS18}" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Command="{Binding CloseTagsPanelCommand}"
                                Style="{StaticResource ToolbarInlineIconButton}">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS12}" 
                                       Foreground="{DynamicResource SecondaryForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource DialogPreviewSurface}" Padding="14,12" Margin="0,0,0,16">
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryForegroundBrush}" FontSize="{DynamicResource FS12}"
                                   Text="{DynamicResource TplTagsDesc}"/>
                    </Border>

                    <!-- Tags list -->
                    <Border Grid.Row="2" Style="{StaticResource DialogPreviewSurface}" Padding="10">
                        <ScrollViewer Style="{StaticResource ThinScroll}" MaxHeight="400">
                        <ItemsControl ItemsSource="{Binding AvailableTags}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DialogPreviewSurface}"
                                            Background="{DynamicResource CardBackgroundBrush}" CornerRadius="10" 
                                            Padding="12,8" Margin="0,0,0,6"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <Border Grid.Column="0" CornerRadius="6" Padding="8,3" Margin="0,0,12,0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E3F2FD"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Category}" Value="Employee">
                                                                <Setter Property="Background" Value="{DynamicResource SuccessLightBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Category}" Value="Agency">
                                                                <Setter Property="Background" Value="{DynamicResource WarningLightBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Category}" FontSize="{DynamicResource FS10}" FontWeight="Medium" Foreground="{DynamicResource SecondaryForegroundBrush}"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock FontWeight="SemiBold" FontSize="{DynamicResource FS13}" FontFamily="Consolas"
                                                           Foreground="{DynamicResource AccentBrush}">
                                                    <Run Text="${"/><Run Text="{Binding Tag}"/><Run Text="}"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Description}" FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <Button Grid.Column="2" 
                                                    Command="{Binding DataContext.CopyTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Cursor="Hand" VerticalAlignment="Center">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" Background="{DynamicResource AccentBrush}" CornerRadius="6" Padding="10,5">
                                                            <TextBlock Text="{DynamicResource TplCopyTag}" FontSize="{DynamicResource FS11}" FontWeight="Medium"
                                                                       Foreground="White"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Command="{Binding OpenTemplateFileCommand}"
                                Style="{StaticResource FilledActionButton}"
                                Padding="18,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                           Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{DynamicResource TplOpenEditor}" FontSize="{DynamicResource FS13}" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
