<UserControl x:Class="Win11DesktopApp.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:Win11DesktopApp.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>
        <conv:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,4,14,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{Binding GoBackCommand}"
                        Style="{StaticResource HeaderBackButton}"
                        Width="40" Height="40"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="0,0,12,0">
                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                </Button>

                <Border Grid.Column="1"
                        MaxWidth="660"
                        HorizontalAlignment="Center"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource PageHeaderIconBadge}"
                                Margin="0"
                                Width="30"
                                Height="30"
                                CornerRadius="9">
                            <TextBlock Text="&#xE713;"
                                       Style="{StaticResource PageHeaderIconText}"
                                       FontSize="{DynamicResource FS13}"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource SettingsTitle}"
                                       FontSize="{DynamicResource FS22}"
                                       Style="{StaticResource PageHeaderTitleText}"/>
                            <TextBlock FontSize="{DynamicResource FS11}"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Opacity="0.82"
                                       Margin="0,1,0,0">
                                <Run Text="Agency Contractor - "/>
                                <Run Text="{Binding AppVersion, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Width="46" Opacity="0"/>
            </Grid>
        </Border>

    <ScrollViewer Grid.Row="1" Style="{StaticResource ThinScroll}">
        <Grid MaxWidth="1100" HorizontalAlignment="Center" Margin="48,10,48,48">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Settings Section Switcher -->
            <Border Grid.Row="0" Style="{StaticResource SettingsSectionCard}" Padding="14,12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource SettingsSectionSwitcherTitle}"
                                   FontSize="{DynamicResource FS15}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundBrush}"/>
                        <TextBlock Text="{DynamicResource SettingsSectionSwitcherSubtitle}"
                                   Margin="0,2,0,0"
                                   FontSize="{DynamicResource FS11}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <Button Content="{DynamicResource SettingsSectionProgram}"
                                Command="{Binding ChangeSettingsSectionCommand}"
                                CommandParameter="Program">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentSettingsSection}" Value="Program">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource SettingsSectionServers}"
                                Command="{Binding ChangeSettingsSectionCommand}"
                                CommandParameter="Servers"
                                Margin="8,0,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentSettingsSection}" Value="Servers">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Language & Localization Section -->
            <Border Grid.Row="2" Style="{StaticResource SettingsSectionCard}"
                    Visibility="{Binding IsProgramSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource AccentLightBrush}">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="{DynamicResource FS17}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}">
                                <Run Text="{DynamicResource LangLabel}"/>
                                <Run Text=" + "/>
                                <Run Text="{DynamicResource SettingsDocLangTitle}"/>
                            </TextBlock>
                            <TextBlock FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.55"
                                       Margin="0,2,0,0">
                                <Run Text="{DynamicResource SettingsLangHint}"/>
                                <Run Text=" "/>
                                <Run Text="{DynamicResource SettingsDocLangHint}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <Border Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="16,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource AccentLightBrush}"
                                        Width="32" Height="32" CornerRadius="8">
                                    <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                               Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource LangLabel}" 
                                               FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{DynamicResource SettingsLangHint}" 
                                               FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <WrapPanel Orientation="Horizontal">
                                <Button Content="🇺🇦 Українська" 
                                        Command="{Binding ChangeLanguageCommand}" CommandParameter="uk">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentLanguage}" Value="uk">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇨🇿 Čeština" 
                                        Command="{Binding ChangeLanguageCommand}" CommandParameter="cs">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentLanguage}" Value="cs">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇷🇺 Русский" 
                                        Command="{Binding ChangeLanguageCommand}" CommandParameter="ru">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentLanguage}" Value="ru">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇬🇧 English" 
                                        Command="{Binding ChangeLanguageCommand}" CommandParameter="en">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentLanguage}" Value="en">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>

                            <Border Height="1" Margin="0,16,0,16" Background="{DynamicResource CardBorderBrush}" Opacity="0.7"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource InfoLightBrush}"
                                        Width="32" Height="32" CornerRadius="8">
                                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"
                                               Foreground="{DynamicResource InfoBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource SettingsDocLangTitle}" 
                                               FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"/>
                                    <TextBlock Text="{DynamicResource SettingsDocLangHint}" 
                                               FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <WrapPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource DocLangSameAsUI}" 
                                        Command="{Binding ChangeDocLanguageCommand}" CommandParameter="">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇺🇦 Українська" 
                                        Command="{Binding ChangeDocLanguageCommand}" CommandParameter="uk">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="uk">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇨🇿 Čeština" 
                                        Command="{Binding ChangeDocLanguageCommand}" CommandParameter="cs">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="cs">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇷🇺 Русский" 
                                        Command="{Binding ChangeDocLanguageCommand}" CommandParameter="ru">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="ru">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="🇬🇧 English" 
                                        Command="{Binding ChangeDocLanguageCommand}" CommandParameter="en">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SelectorButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CurrentDocLanguage}" Value="en">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Theme Card -->
            <Border Grid.Row="4" Style="{StaticResource SettingsSectionCard}"
                    Visibility="{Binding IsProgramSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource WarningLightBrush}">
                            <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource ThemeLabel}" 
                                       FontSize="{DynamicResource FS16}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"/>
                            <TextBlock Text="{DynamicResource SettingsThemeHint}" 
                                       FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <UniformGrid Columns="3" HorizontalAlignment="Left" MaxWidth="700">
                        <!-- Light theme preview -->
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="Light"
                                Margin="0,0,10,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="OuterBd" CornerRadius="10" BorderThickness="2.5"
                                            BorderBrush="Transparent" Padding="3"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border x:Name="InnerBd" CornerRadius="8" Width="136" Height="90"
                                                Background="#F3F3F3" ClipToBounds="True">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="28"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="22"/>
                                                </Grid.RowDefinitions>
                                                <!-- Title bar -->
                                                <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E5E5E5" BorderThickness="0,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                                                        <Ellipse Width="6" Height="6" Fill="#FF605C" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#FFBD44" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#00CA4E"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Content area -->
                                                <StackPanel Grid.Row="1" Margin="8,5,8,0">
                                                    <Border Background="#E5E5E5" CornerRadius="2" Height="4" Width="60" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <Border Background="#E5E5E5" CornerRadius="2" Height="4" Width="44" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <Border Background="#FFFFFF" CornerRadius="3" Width="36" Height="18" BorderBrush="#E5E5E5" BorderThickness="1" Margin="0,0,4,0"/>
                                                        <Border Background="#FFFFFF" CornerRadius="3" Width="36" Height="18" BorderBrush="#E5E5E5" BorderThickness="1"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <!-- Accent bar -->
                                                <Border Grid.Row="2" Background="#0078D4" CornerRadius="0,0,8,8">
                                                    <TextBlock Text="{DynamicResource ThemeLight}" FontSize="{DynamicResource FS10}" FontWeight="SemiBold"
                                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding CurrentTheme}" Value="Light">
                                            <Setter TargetName="OuterBd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- DarkWord theme preview -->
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="DarkWord"
                                Margin="0,0,10,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="OuterBd" CornerRadius="10" BorderThickness="2.5"
                                            BorderBrush="Transparent" Padding="3"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border x:Name="InnerBd" CornerRadius="8" Width="136" Height="90"
                                                Background="#191C20" ClipToBounds="True">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="28"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="22"/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0" Background="#1E2228" BorderBrush="#373E47" BorderThickness="0,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                                                        <Ellipse Width="6" Height="6" Fill="#FF605C" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#FFBD44" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#00CA4E"/>
                                                    </StackPanel>
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="8,5,8,0">
                                                    <Border Background="#373E47" CornerRadius="2" Height="4" Width="60" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <Border Background="#373E47" CornerRadius="2" Height="4" Width="44" HorizontalAlignment="Left" Margin="0,0,0,3"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <Border Background="#252A31" CornerRadius="3" Width="36" Height="18" BorderBrush="#373E47" BorderThickness="1" Margin="0,0,4,0"/>
                                                        <Border Background="#252A31" CornerRadius="3" Width="36" Height="18" BorderBrush="#373E47" BorderThickness="1"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <Border Grid.Row="2" Background="#3B8EEA" CornerRadius="0,0,8,8">
                                                    <TextBlock Text="{DynamicResource ThemeDarkWord}" FontSize="{DynamicResource FS10}" FontWeight="SemiBold"
                                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding CurrentTheme}" Value="DarkWord">
                                            <Setter TargetName="OuterBd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetName="OuterBd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Dark2 (Night) theme preview -->
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="Dark2"
                                Margin="0,0,10,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="OuterBd" CornerRadius="10" BorderThickness="2.5"
                                            BorderBrush="Transparent" Padding="3"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border x:Name="InnerBd" CornerRadius="8" Width="136" Height="90"
                                                Background="#0D1117" ClipToBounds="True">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="28"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="22"/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0" Background="#131920" BorderBrush="#30363D" BorderThickness="0,0,0,1">
                                                    <StackPanel Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                                                        <Ellipse Width="6" Height="6" Fill="#FF605C" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#FFBD44" Margin="0,0,3,0"/>
                                                        <Ellipse Width="6" Height="6" Fill="#00CA4E"/>
                                                    </StackPanel>
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="8,5,8,0">
                                                    <Border Background="#30363D" CornerRadius="2" Height="4" Width="60" HorizontalAlignment="Left" Margin="0,0,0,3"/>
