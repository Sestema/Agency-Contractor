<UserControl x:Class="Win11DesktopApp.Views.AIChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Win11DesktopApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding GoBackCommand}" Style="{StaticResource HeaderBackButton}" Margin="0,0,10,0">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS14}"/>
                    </Button>
                    <Border Style="{StaticResource PageHeaderIconBadge}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0"/>
                                <GradientStop Color="#448AFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path Data="{StaticResource IconAIAssistant}"
                              Fill="White" Stretch="Uniform" Width="18" Height="18"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{DynamicResource AIChatTitle}"
                               FontSize="{DynamicResource FS24}"
                               Style="{StaticResource PageHeaderTitleText}"/>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding NewChatCommand}" Style="{StaticResource FilledActionButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                   Foreground="White" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource AIChatNewChat}" FontSize="{DynamicResource FS12}"
                                   FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- LEFT SIDEBAR: Chat Sessions -->
            <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="12" Margin="0,0,12,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Chat list -->
                    <ScrollViewer Grid.Row="0" Style="{StaticResource ThinScroll}" 
                                  VerticalScrollBarVisibility="Auto" Padding="6,8">
                        <ItemsControl ItemsSource="{Binding ChatSessions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="ChatItemBd" CornerRadius="8" Padding="10,8" Margin="0,1"
                                            Cursor="Hand" Background="Transparent">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SelectChatCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Title}" FontSize="{DynamicResource FS11}"
                                                           Foreground="{DynamicResource ForegroundBrush}"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="140"/>
                                                <TextBlock Text="{Binding DateDisplay}" FontSize="9"
                                                           Foreground="{DynamicResource ForegroundBrush}" Opacity="0.4"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" VerticalAlignment="Center"
                                                    Command="{Binding DataContext.DeleteChatCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    Width="22" Height="22" Opacity="0.4">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                           Foreground="{DynamicResource ForegroundBrush}" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="ChatItemBd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                        </DataTrigger>
                                        <Trigger SourceName="ChatItemBd" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ChatItemBd" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT SIDE: Chat area -->
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Messages List -->
                <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" 
                        CornerRadius="12" BorderBrush="{DynamicResource CardBorderBrush}" 
                        BorderThickness="1">
                    <ScrollViewer x:Name="MessagesScroll" Style="{StaticResource ThinScroll}"
                                  VerticalScrollBarVisibility="Auto" Padding="16,12">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding Messages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <!-- User message (right aligned) -->
                                            <StackPanel HorizontalAlignment="Right" MaxWidth="520"
                                                        Visibility="{Binding IsUser, Converter={StaticResource BoolToVis}}">
                                                <Border CornerRadius="10" Margin="0,0,0,4"
                                                        HorizontalAlignment="Right"
                                                        Visibility="{Binding HasImage, Converter={StaticResource BoolToVis}}">
                                                    <Border.Clip>
                                                        <RectangleGeometry RadiusX="10" RadiusY="10" Rect="0,0,200,150"/>
                                                    </Border.Clip>
                                                    <Image Source="{Binding FilePath}" MaxWidth="200" MaxHeight="150" Stretch="UniformToFill"/>
                                                </Border>
                                                <Border CornerRadius="8" Margin="0,0,0,4" Padding="10,6"
                                                        HorizontalAlignment="Right" Background="#E3F2FD">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding HasFile}" Value="True"/>
                                                                        <Condition Binding="{Binding HasImage}" Value="False"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                   Foreground="#1565C0" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding FileName}" FontSize="{DynamicResource FS11}"
                                                                   Foreground="#1565C0" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="#7C4DFF" CornerRadius="16,16,4,16" Padding="14,10"
                                                        HorizontalAlignment="Right">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Text}" Foreground="White" 
                                                                   FontSize="{DynamicResource FS13}" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding TimeDisplay}" Foreground="#AAFFFFFF" 
                                                                   FontSize="10" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <!-- AI / System message (left aligned) -->
                                            <StackPanel HorizontalAlignment="Left" MaxWidth="520">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Border CornerRadius="16,16,16,4" Padding="14,10">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSystem}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Direction="270" Opacity="0.08"/>
                                                    </Border.Effect>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Text}" 
                                                                   Foreground="{DynamicResource ForegroundBrush}" 
                                                                   FontSize="{DynamicResource FS13}" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding TimeDisplay}" Opacity="0.4"
                                                                   Foreground="{DynamicResource ForegroundBrush}" 
                                                                   FontSize="10" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Typing indicator -->
                            <Border Visibility="{Binding IsTyping, Converter={StaticResource BoolToVis}}"
                                    HorizontalAlignment="Left" Margin="0,4,0,8"
                                    Background="{DynamicResource ContentBackgroundBrush}" CornerRadius="16,16,16,4" Padding="14,10">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Direction="270" Opacity="0.08"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource ForegroundBrush}" Opacity="0.4">
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0.3" To="1" Duration="0:0:0.4"
                                                                         AutoReverse="True" BeginTime="0:0:0"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource ForegroundBrush}" Opacity="0.4" Margin="4,0,0,0">
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0.3" To="1" Duration="0:0:0.4"
                                                                         AutoReverse="True" BeginTime="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource ForegroundBrush}" Opacity="0.4" Margin="4,0,0,0">
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0.3" To="1" Duration="0:0:0.4"
                                                                         AutoReverse="True" BeginTime="0:0:0.3"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Attached file indicator -->
                <Border Grid.Row="1" Margin="0,8,0,0"
                        Visibility="{Binding HasAttachedFile, Converter={StaticResource BoolToVis}}">
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" 
                            Padding="10,6" HorizontalAlignment="Left"
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="#7C4DFF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding AttachedFileName}" FontSize="{DynamicResource FS11}"
                                       Foreground="{DynamicResource ForegroundBrush}" MaxWidth="300" 
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            <Button Command="{Binding RemoveFileCommand}" Background="Transparent" 
                                    BorderThickness="0" Cursor="Hand" Margin="8,0,0,0" Width="20" Height="20">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="#FF5252"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Input area -->
                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" 
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            Padding="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Command="{Binding AttachFileCommand}" 
                                    Width="38" Height="38" Background="Transparent" 
                                    BorderThickness="0" Cursor="Hand"
                                    ToolTip="{DynamicResource AIChatAttachImage}">
                                <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" 
                                           FontSize="{DynamicResource FS16}" 
                                           Foreground="{DynamicResource ForegroundBrush}" Opacity="0.5"/>
                            </Button>

                            <TextBox Grid.Column="1" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="{DynamicResource FS13}" VerticalAlignment="Center"
                                     Background="Transparent" BorderThickness="0" Padding="8,8"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     AcceptsReturn="False" MaxLines="3" TextWrapping="Wrap"
                                     x:Name="InputBox" KeyDown="InputBox_KeyDown"/>

                            <Button Grid.Column="2" Command="{Binding SendMessageCommand}" 
                                    Width="38" Height="38" Cursor="Hand" BorderThickness="0"
                                    ToolTip="{DynamicResource AIChatSend}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="SendBorder" CornerRadius="8" Padding="6">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#7C4DFF" Offset="0"/>
                                                    <GradientStop Color="#448AFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" 
                                                       FontSize="16" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SendBorder" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
