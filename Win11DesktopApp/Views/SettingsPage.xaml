                                          IsChecked="{Binding WebPanelPreventSleep}"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Profile Section -->
            <Border Grid.Row="13" Style="{StaticResource SettingsSectionCard}"
                    Visibility="{Binding IsProgramSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Style="{StaticResource SettingsSectionIconBadge}" Background="{DynamicResource AccentLightBrush}">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS16}"
                                       Foreground="{DynamicResource AccentDarkBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="{DynamicResource FS17}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}">
                                <Run Text="{DynamicResource SettingsProfileTitle}"/>
                                <Run Text=" + "/>
                                <Run Text="{DynamicResource SettingsLicenseTitle}"/>
                                <Run Text=" + "/>
                                <Run Text="{DynamicResource SettingsUpdateTitle}"/>
                            </TextBlock>
                            <TextBlock Text="{DynamicResource SettingsAccessMainSubtitle}"
                                       FontSize="{DynamicResource FS12}" Foreground="{DynamicResource ForegroundBrush}"
                                       Opacity="0.55" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Style="{StaticResource DialogPreviewSurface}" Padding="16,14"
                            Visibility="{Binding HasProfile, Converter={StaticResource InverseBoolToVis}}">
                        <TextBlock Text="{DynamicResource SettingsProfileNotLoaded}"
                                   FontSize="{DynamicResource FS12}"
                                   Foreground="{DynamicResource MutedForegroundBrush}"/>
                    </Border>

                    <StackPanel Visibility="{Binding HasProfile, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Style="{StaticResource DialogPreviewSurface}" Padding="16,14" Margin="0,0,0,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="{DynamicResource SettingsProfileFullNameLabel}"
                                               FontSize="{DynamicResource FS10}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedForegroundBrush}"/>
                                    <TextBlock FontSize="{DynamicResource FS17}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"
                                               Margin="0,3,0,0">
                                        <Run Text="{Binding ProfileFirstName, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding ProfileLastName, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <Grid Grid.Row="0"
                                      Grid.Column="2"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="106"/>
                                        <ColumnDefinition Width="106"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                                Visibility="{Binding HasAccessPlan, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                HorizontalAlignment="Stretch">
                                        <TextBlock Text="{DynamicResource SettingsPlanLabel}"
                                                   FontSize="{DynamicResource FS9}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <Border Margin="0,3,0,0"
                                                Padding="0,7"
                                                CornerRadius="999"
                                                BorderThickness="1"
                                                MinWidth="100"
                                                HorizontalAlignment="Stretch">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FFF6E5"/>
                                                    <Setter Property="BorderBrush" Value="#F2E0B5"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AccessPlanCode}" Value="standard">
                                                            <Setter Property="Background" Value="#EAF2FF"/>
                                                            <Setter Property="BorderBrush" Value="#D3E3FF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding AccessPlanCode}" Value="pro">
                                                            <Setter Property="Background" Value="#EAF8ED"/>
                                                            <Setter Property="BorderBrush" Value="#D4EFD9"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding AccessPlanDisplay}"
                                                       FontSize="{DynamicResource FS12}"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#A46A00"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AccessPlanCode}" Value="standard">
                                                                <Setter Property="Foreground" Value="#355C8C"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding AccessPlanCode}" Value="pro">
                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Margin="6,0,0,0"
                                                HorizontalAlignment="Stretch">
                                        <TextBlock Text="{DynamicResource SettingsAppVersion}"
                                                   FontSize="{DynamicResource FS9}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <Border Margin="0,3,0,0"
                                                Padding="0,7"
                                                CornerRadius="999"
                                                BorderThickness="1"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                HorizontalAlignment="Stretch">
                                            <TextBlock FontSize="{DynamicResource FS11}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                       HorizontalAlignment="Center">
                                                <Run Text="v"/>
                                                <Run Text="{Binding AppVersion, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="0,10,0,0">
                                    <TextBlock Text="{Binding AccessStatusTitle}"
                                               FontSize="{DynamicResource FS15}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding AccessStatusDetail}"
                                               FontSize="{DynamicResource FS12}"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               Margin="0,2,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1"
                                            Grid.Column="2"
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Right">
                                    <Button Command="{Binding EditProfileCommand}"
                                            Padding="12,6"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource FilledActionButton}"
                                            Visibility="{Binding IsProfileEditMode, Converter={StaticResource InverseBoolToVis}}">
                                        <TextBlock Text="{DynamicResource EmpBtnEdit}"
                                                   FontSize="{DynamicResource FS12}"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Button>

                                    <Button Command="{Binding CancelProfileEditCommand}"
                                            Padding="12,6"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource SelectorButton}"
                                            Visibility="{Binding IsProfileEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{DynamicResource BtnCancel}"
                                                   FontSize="{DynamicResource FS12}"
                                                   FontWeight="SemiBold"/>
                                    </Button>
                                </StackPanel>

                                <CheckBox Grid.Row="2"
                                          Grid.ColumnSpan="3"
                                          Content="{DynamicResource ProfileRememberMe}"
                                          IsChecked="{Binding ProfileRememberMeEnabled}"
                                          Margin="0,10,0,0"
                                          HorizontalAlignment="Left"/>
                            </Grid>
                        </Border>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource DialogPreviewSurface}" Padding="14,12" MinHeight="160">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource SuccessChipBackgroundBrush}">
                                            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                                       Foreground="{DynamicResource SuccessChipForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource SettingsAccessTitle}"
                                                       FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                            <TextBlock Text="{DynamicResource SettingsAccessStatusHint}"
                                                       FontSize="{DynamicResource FS11}"
                                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                                       Margin="0,2,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Background="{DynamicResource WindowBackgroundBrush}"
                                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="10,8">
                                        <StackPanel>
                                            <TextBlock FontSize="{DynamicResource FS11}" Foreground="{DynamicResource SecondaryForegroundBrush}">
                                                <Run Text="ID: "/>
                                                <Run Text="{Binding MachineId, Mode=OneWay}"/>
                                            </TextBlock>
                                            <Border Margin="0,8,0,0"
                                                    Padding="8,6"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource CardBackgroundBrush}"
                                                    Visibility="{Binding HasAccessStatusAdminMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel>
                                                    <TextBlock Text="{DynamicResource AccessStatusAdminMessageLabel}"
                                                               FontSize="{DynamicResource FS10}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"/>
                                                    <TextBlock Text="{Binding AccessStatusAdminMessage}"
                                                               Margin="0,2,0,0"
                                                               FontSize="{DynamicResource FS11}"
                                                               Foreground="{DynamicResource ForegroundBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource DialogPreviewSurface}" Padding="14,12" MinHeight="160">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Style="{StaticResource SectionHeaderIconBadge}" Background="{DynamicResource InfoChipBackgroundBrush}">
                                            <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="{DynamicResource FS13}"
                                                       Foreground="{DynamicResource InfoChipForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource SettingsUpdateTitle}"
                                                       FontSize="{DynamicResource FS15}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ForegroundBrush}"/>
                                            <TextBlock Text="{DynamicResource SettingsUpdateDesc}"
                                                       FontSize="{DynamicResource FS11}" Foreground="{DynamicResource MutedForegroundBrush}"
                                                       Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Background="{DynamicResource WindowBackgroundBrush}"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="10,8"
                                            Margin="0,0,0,10">
                                        <TextBlock FontSize="{DynamicResource FS11}"
                                                   Foreground="{DynamicResource SecondaryForegroundBrush}">
                                            <Run Text="{DynamicResource SettingsAppVersion}"/>
                                            <Run Text=": "/>
                                            <Run Text="{Binding AppVersion, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Border>

                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding CheckForUpdatesCommand}"
                                                Padding="14,8"
                                                Foreground="White"
                                                Style="{StaticResource FilledActionButton}">
                                            <TextBlock Text="{DynamicResource SettingsUpdateBtn}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold" Foreground="White"/>
                                        </Button>
                                        <Button Command="{Binding InstallUpdateCommand}"
                                                Padding="14,8"
                                                Background="{DynamicResource SuccessBrush}"
                                                Foreground="White"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource FilledActionButton}"
                                                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{DynamicResource SettingsInstallBtn}" FontSize="{DynamicResource FS12}" FontWeight="SemiBold" Foreground="White"/>
